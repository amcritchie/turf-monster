<%# Animated gradient splash background — adapted from a CodePen by design.kayac.com.
    A dark background: pairs with dark-theme, light text. %>
<style>
  @keyframes lp-grad {
    0%, 100% { background-position: 50% 0%; }
    50%      { background-position: 50% 100%; }
  }
  .lp-bg {
    position: fixed; inset: 0; z-index: 0;
    background: linear-gradient(to bottom,
      #655bef 0%, #fa28bf 20%, #ff4665 40%,
      #fbde4e 60%, #00fbea 80%, #555def 100%);
    background-size: 100% 400%;
    animation: lp-grad 17.5s ease-in-out infinite;
  }
  .lp-scrim { position: fixed; inset: 0; z-index: 0; background: rgba(13, 11, 30, 0.62); }
  /* .lp-splash text overrides live in app/assets/tailwind/application.css @layer utilities. */
  @media (prefers-reduced-motion: reduce) {
    .lp-bg { animation: none; background-position: 50% 40%; }
  }
</style>

<div class="lp-bg" aria-hidden="true"></div>
<div class="lp-scrim" aria-hidden="true"></div>

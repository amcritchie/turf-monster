<%= render "tokens/pack_button_styles" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-2">Entry Tokens</h1>
  <p class="text-secondary mb-8">1 token = 1 contest entry (any tier).</p>

  <%# Coinflow rail (additive, flag-gated on AppFlags.coinflow?). Stacks
      alongside the Coinbase / PayPal / Stripe rails — one click buys exactly
      1 entry token via Coinflow's hosted checkout, then /webhooks/coinflow
      mints it on-chain. %>
  <% if AppFlags.coinflow? %>
    <div class="card shadow p-5 mb-8" data-coinflow-buy>
      <h2 class="text-lg font-bold text-heading mb-1">Buy 1 entry with Coinflow</h2>
      <p class="text-xs text-secondary mb-4">Pay with a card via Coinflow's secure checkout. One entry token &mdash; <span class="font-semibold">$19</span> &mdash; lands in your wallet automatically.</p>
      <button type="button" onclick="tmCoinflowBuyOne('single'); return false;" class="btn btn-primary">
        Buy 1 entry &mdash; Coinflow
      </button>
      <% unless Rails.env.production? %>
        <div class="mt-3 pt-3 border-t border-white/10">
          <button type="button" onclick="tmCoinflowSimulateSettle(); return false;" class="btn btn-outline text-xs">
            Simulate settlement (dev)
          </button>
          <p class="text-[10px] text-muted mt-1">Local only &mdash; stands in for Coinflow's <span class="font-mono">Settled</span> webhook, which can't reach localhost. Click after a checkout to mint the token.</p>
        </div>
      <% end %>
    </div>
    <%= render "tokens/coinflow_script" %>
  <% end %>

  <% if Payments.paypal_checkout? %>
    <%# PayPal/Venmo onramp — select a pack, pay with the standalone buttons,
        then the same confirming/minted/errored status cards the Stripe-return
        page shows, all in-page (no /tokens/processing leg). %>
    <%= render "tokens/paypal_sdk" %>
    <div class="mb-8">
      <%= render "tokens/paypal_buttons",
          flow: "page",
          next_target: @next_contest ? contest_path(@next_contest) : contests_path %>
    </div>
  <% else %>
    <% stripe_on = Payments.stripe? %>

    <% if !stripe_on && current_user&.admin? %>
      <div class="mb-4 p-3 rounded-lg bg-yellow-500/10 border border-yellow-600/30 text-yellow-300 text-xs">
        <% if Payments.paypal? %>
          Checkout is disabled — <span class="font-mono">PAYMENT_PROVIDER=paypal</span> but <span class="font-mono">PAYPAL_CLIENT_ID</span> / <span class="font-mono">PAYPAL_CLIENT_SECRET</span> aren't set. Use the dev-mint buttons below or add the keys to <span class="font-mono">.env</span> and restart.
        <% elsif Payments.provider == "stripe" %>
          Card checkout is disabled — <span class="font-mono">PAYMENT_PROVIDER=stripe</span> but <span class="font-mono">STRIPE_SECRET_KEY</span> is not set (or <span class="font-mono">STRIPE_CHECKOUT_DISABLED</span> is true). Use the dev-mint buttons below or fix <span class="font-mono">.env</span> and restart.
        <% else %>
          Fiat checkout is disabled — set <span class="font-mono">PAYMENT_PROVIDER=paypal</span>, <span class="font-mono">PAYMENT_PROVIDER=stripe</span>, or <span class="font-mono">ENABLE_CDP_RAMP=true</span> only when intentionally testing a provider.
        <% end %>
      </div>
    <% end %>

    <% if !stripe_on && AppFlags.cdp_ramp? %>
      <div class="card shadow p-5 mb-8">
        <h2 class="text-lg font-bold text-heading mb-1">Buy USDC with Coinbase</h2>
        <p class="text-xs text-secondary mb-4">Pay with debit, Apple Pay, or your Coinbase balance. USDC lands in your wallet and covers the entry fee shown on each contest.</p>
        <button type="button" @click="$store.modals.open('cdp-ramp', { flow: 'buy', step: 'preflight' })"
                class="btn btn-primary">Buy USDC</button>
      </div>
    <% else %>
      <div class="space-y-3 mb-8">
        <% @packs.each do |pack_id, pack| %>
          <%= render "tokens/pack_button", pack_id: pack_id, pack: pack, disabled: !stripe_on %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# Lazarus audit #21: dev/test-only. The free-mint route is not drawn in
      production, so this affordance (and its tokens_dev_mint_path helper) must
      be production-gated too — otherwise the page NameErrors in prod, where
      Solana::Config.devnet? is currently true. %>
  <% if !Rails.env.production? && current_user&.admin? && Solana::Config.devnet? %>
    <div class="space-y-2 mb-6">
      <p class="text-[10px] uppercase tracking-widest text-muted">Dev (admin · devnet)</p>
      <% @packs.each do |pack_id, pack| %>
        <%= button_to "Mint #{pack[:quantity]} free (dev)", tokens_dev_mint_path(pack: pack_id), method: :post,
          form: { data: { turbo: false } },
          class: "btn btn-outline w-full text-xs" %>
      <% end %>
    </div>
  <% end %>

  <div class="text-center">
    <%= link_to "Look around first →", root_path, class: "text-sm text-secondary hover:text-primary underline underline-offset-2" %>
  </div>
</div>

<style>
  /* === Glow Pair: N orb clusters (1 cluster per pack quantity), orbital hover === */
  .glow-pair-btn { position: relative; overflow: hidden; transition: all 500ms ease; }
  .glow-pair-btn .orb {
    position: absolute; border-radius: 9999px;
    pointer-events: none; z-index: 10;
    transition: all 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .glow-pair-btn .orb-small { width: 48px; height: 48px; background: var(--orb1); filter: blur(14px); }
  .glow-pair-btn .orb-big   { width: 76px; height: 76px; background: var(--orb2); filter: blur(22px); }

  /* Rest positions — orbs spread to opposite halves of the card.
     Smalls peek from the top edge (slight overhang), bigs anchored low.
     This makes the hover motion (smalls ↓ past bottom, bigs ↑ past top)
     feel like a single sweeping direction rather than orbs leaving a cluster. */
  .glow-pair-btn .orb-l.orb-small { left: -10px;            top: 6%; }
  .glow-pair-btn .orb-l.orb-big   { left: 40px;             top: 68%; }
  .glow-pair-btn .orb-c.orb-small { left: calc(50% - 24px); top: 6%; }
  .glow-pair-btn .orb-c.orb-big   { left: calc(50% - 38px); top: 72%; }
  .glow-pair-btn .orb-r.orb-small { right: -10px;           top: 6%; }
  .glow-pair-btn .orb-r.orb-big   { right: 40px;            top: 68%; }

  /* Hover: small orbs dive past the bottom + giant halos; big orbs rocket up and out */
  .glow-pair-btn:hover { border-color: var(--orb-accent); }
  .glow-pair-btn:hover .orb-l.orb-small { left: 96px;             top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-l.orb-big   { left: -80px;            top: -64px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn:hover .orb-c.orb-small { left: calc(50% - 12px); top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-c.orb-big   { left: calc(50% - 50px); top: -80px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn:hover .orb-r.orb-small { right: 96px;            top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-r.orb-big   { right: -80px;           top: -64px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn > .glow-content { position: relative; z-index: 20; }

  .glow-brand { --orb1: #4BAF50; --orb2: #f97316; --orb-accent: #f97316; }
</style>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-2">Entry Tokens</h1>
  <p class="text-secondary mb-8">1 token = 1 contest entry (any tier).</p>

  <% format_price = ->(cents) { cents % 100 == 0 ? "$#{cents / 100}" : dollars(cents / 100.0) } %>
  <% per_token = ->(q) { StripePurchase.per_token_cents(q) } %>
  <% subtitle = ->(q) { q > 1 ? "#{format_price.call(per_token.call(q))} each" : "Single contest entry" } %>
  <% savings_pct = ->(q) { (100 - (per_token.call(q) * 100 / 1900)).round } %>
  <% stripe_on = Rails.application.config.x.stripe_enabled %>

  <% if !stripe_on && current_user&.admin? %>
    <div class="mb-4 p-3 rounded-lg bg-yellow-500/10 border border-yellow-600/30 text-yellow-300 text-xs">
      Card checkout is disabled — <span class="font-mono">STRIPE_SECRET_KEY</span> not set. Use the dev-mint buttons below or add the key to <span class="font-mono">.env</span> and restart.
    </div>
  <% end %>

  <div class="space-y-3 mb-8">
    <% @packs.each do |quantity, price_cents| %>
      <% clusters = quantity == 1 ? [:r] : [:l, :c, :r] %>
      <%= button_to tokens_stripe_checkout_path(quantity: quantity), method: :post,
          form: { class: "w-full", data: { turbo: false } }, disabled: !stripe_on,
          class: "glow-pair-btn glow-brand group block w-full text-left p-6 rounded-xl border-2 border-primary/40 hover:border-primary bg-primary/5 transition" do %>
        <% clusters.each do |pos| %>
          <span class="orb orb-<%= pos %> orb-small"></span>
          <span class="orb orb-<%= pos %> orb-big"></span>
        <% end %>
        <div class="glow-content flex items-center gap-6">
          <div class="w-16 text-center">
            <div class="text-5xl font-extrabold text-white leading-none font-mono"><%= quantity %></div>
            <div class="text-[10px] uppercase tracking-widest text-white/70 mt-1"><%= quantity == 1 ? 'Entry' : 'Entries' %></div>
          </div>
          <div class="flex-1 border-l border-strong pl-6 text-right">
            <div class="text-3xl font-bold text-heading font-mono"><%= format_price.call(price_cents) %></div>
            <div class="text-xs text-secondary mt-1">
              <%= subtitle.call(quantity) %>
              <% if quantity > 1 %><span class="ml-1 inline-block px-1.5 py-0.5 rounded bg-primary text-white text-[10px] font-extrabold tracking-wider uppercase">Save <%= savings_pct.call(quantity) %>%</span><% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if current_user&.admin? && Solana::Config.devnet? %>
    <div class="space-y-2 mb-6">
      <p class="text-[10px] uppercase tracking-widest text-muted">Dev (admin · devnet)</p>
      <% @packs.each do |quantity, _| %>
        <%= button_to "Mint #{quantity} free (dev)", tokens_dev_mint_path(quantity: quantity), method: :post,
          form: { data: { turbo: false } },
          class: "btn btn-outline w-full text-xs" %>
      <% end %>
    </div>
  <% end %>

  <div class="text-center">
    <%= link_to "Look around first →", root_path, class: "text-sm text-secondary hover:text-primary underline underline-offset-2" %>
  </div>
</div>

<% if @contest %>
  <%# When the buyer came from a specific contest, render it behind the
      success card so this new tab feels like a continuation of the contest
      tab — the same darkened-backdrop pattern as the "Get Entry Tokens"
      modal. The iframe is non-interactive (pointer-events: none); the app
      navbar (z-30, sticky) overlaps the iframe's identical navbar at top:0,
      so only one navbar is visible. %>
  <iframe src="<%= contest_path(@contest) %>"
          class="fixed inset-0 w-screen h-screen border-0 pointer-events-none z-0"
          aria-hidden="true"
          tabindex="-1"
          loading="eager"></iframe>
  <div class="fixed inset-0 bg-black/70 backdrop-blur-sm pointer-events-none z-10"></div>
<% end %>

<div class="<%= @contest ? 'fixed inset-0 flex items-center justify-center p-4 z-20' : 'max-w-md mx-auto mt-12' %>"
     x-data="tokenProcessing('<%= j @session_id %>', '<%= @contest ? j(contest_path(@contest)) : '' %>')"
     x-init="start()">
  <div class="card shadow<%= '-2xl' if @contest %> p-8 text-center<%= ' max-w-md w-full pointer-events-auto' if @contest %>">
    <%# Loading state %>
    <template x-if="!ready && !errored">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full border-4 border-primary/30 border-t-primary animate-spin mb-6"></div>
        <h1 class="text-xl font-bold text-heading mb-2">Confirming your purchase…</h1>
        <p class="text-sm text-secondary">Crediting your entry tokens and topping up your wallet.</p>
        <p class="text-xs text-muted mt-4" x-show="elapsed >= 8">
          Still working… this can take up to 30 seconds.
        </p>
      </div>
    </template>

    <%# Success state %>
    <template x-if="ready">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-heading mb-2">
          <span x-text="minted"></span> entry token<span x-show="minted !== 1">s</span> added
        </h1>
        <p class="text-sm text-secondary mb-6">
          You now have <span class="font-bold text-primary font-mono" x-text="balance"></span> available.
        </p>
        <p x-show="contestUrl" class="text-sm text-secondary">Returning to your contest…</p>
        <div x-show="!contestUrl" class="flex gap-3 justify-center">
          <%= link_to "Enter a contest", root_path, class: "btn btn-primary" %>
          <%= link_to "Buy more", tokens_buy_path, class: "btn btn-outline" %>
        </div>
      </div>
    </template>

    <%# Timeout / error state %>
    <template x-if="errored">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full bg-yellow-500/15 flex items-center justify-center mb-6">
          <span class="text-2xl">⏳</span>
        </div>
        <h1 class="text-xl font-bold text-heading mb-2">Still processing</h1>
        <p class="text-sm text-secondary mb-6">
          Your payment went through but we haven't seen the confirmation yet. It usually arrives within a minute — refresh this page in a bit, or check <%= link_to "your wallet", wallet_path, class: "text-primary underline" %>.
        </p>
        <%= link_to "Refresh now", "#", onclick: "window.location.reload(); return false;", class: "btn btn-outline" %>
      </div>
    </template>
  </div>
</div>

<script>
  function tokenProcessing(sessionId, contestUrl) {
    return {
      ready: false,
      contestUrl: contestUrl,
      minted: 0,
      balance: 0,
      elapsed: 0,
      errored: false,
      _timer: null,
      _ticker: null,

      start() {
        if (!sessionId) { this.errored = true; return; }
        this._ticker = setInterval(() => { this.elapsed += 1 }, 1000);
        this.poll();
        this._timer = setInterval(() => this.poll(), 1500);
        setTimeout(() => {
          if (!this.ready) { this.stop(); this.errored = true; }
        }, 45000);
      },

      stop() {
        if (this._timer) { clearInterval(this._timer); this._timer = null; }
        if (this._ticker) { clearInterval(this._ticker); this._ticker = null; }
      },

      async poll() {
        try {
          const r = await fetch('<%= tokens_status_path %>?session_id=' + encodeURIComponent(sessionId), {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin'
          });
          if (!r.ok) return;
          const d = await r.json();
          if (d.ready) {
            this.minted = d.minted;
            this.balance = d.balance;
            this.ready = true;
            this.stop();
            if (window.opener && !window.opener.closed) {
              // Opened in a new tab from the contest — hand control back
              // there (it finishes the entry) and close this tab.
              try {
                window.opener.postMessage(
                  { source: 'tt-tokens', status: 'minted', contestUrl: contestUrl },
                  window.location.origin
                );
              } catch (e) {}
              setTimeout(function () { window.close(); }, 1500);
            } else if (contestUrl) {
              // Same-tab checkout — return to the contest to finish.
              setTimeout(function () { window.location.href = contestUrl; }, 1800);
            }
          }
        } catch (e) { /* keep polling */ }
      }
    };
  }
</script>

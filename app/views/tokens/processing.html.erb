<%# Stripe-checkout return page. The canonical flow is:
    contest tab opens checkout in a new tab → Stripe → /tokens/processing
    posts the session_id back here and closes; the contest tab's modal
    shows the "Confirming your purchase…" + success states inline so the
    buyer never visually leaves the contest.

    Fallback — if there's no opener (user navigated directly, or the
    opener tab was closed mid-flow), poll /tokens/status here and show
    the standalone success card. %>
<div class="max-w-md mx-auto mt-12" x-data="tokenProcessing('<%= j @session_id %>', '<%= @contest ? j(contest_path(@contest)) : '' %>')" x-init="start()">
  <div class="card shadow p-8 text-center">
    <%# Loading state — also covers the moment after hand-off, before window.close() %>
    <template x-if="!ready && !errored">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full border-4 border-primary/30 border-t-primary animate-spin mb-6"></div>
        <h1 class="text-xl font-bold text-heading mb-2">Confirming your purchase…</h1>
        <p class="text-sm text-secondary">Crediting your entry tokens and topping up your wallet.</p>
        <p class="text-xs text-muted mt-4" x-show="elapsed >= 8">
          Still working… this can take up to 30 seconds.
        </p>
      </div>
    </template>

    <%# Success state (fallback path) %>
    <template x-if="ready">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-heading mb-2">
          <span x-text="minted"></span> entry token<span x-show="minted !== 1">s</span> added
        </h1>
        <p class="text-sm text-secondary mb-6">
          You now have <span class="font-bold text-primary font-mono" x-text="balance"></span> available.
        </p>
        <p x-show="contestUrl" class="text-sm text-secondary">Returning to your contest…</p>
        <%# Standalone success path (no opener contest tab) — single CTA
            to the current main contest (Contest.target). Falls through
            to /contests if no live contest exists at all. %>
        <% next_target = @next_contest ? contest_path(@next_contest) : contests_path %>
        <%= link_to "Enter contest", next_target,
            class: "btn btn-primary w-full",
            "x-show": "!contestUrl" %>
      </div>
    </template>

    <%# Timeout / error state %>
    <template x-if="errored">
      <div>
        <div class="mx-auto w-12 h-12 rounded-full bg-yellow-500/15 flex items-center justify-center mb-6">
          <span class="text-2xl">⏳</span>
        </div>
        <h1 class="text-xl font-bold text-heading mb-2">Still processing</h1>
        <p class="text-sm text-secondary mb-6">
          Your payment went through but we haven't seen the confirmation yet. It usually arrives within a minute — refresh this page in a bit, or check <%= link_to "your wallet", wallet_path, class: "text-primary underline" %>.
        </p>
        <%= link_to "Refresh now", "#", onclick: "window.location.reload(); return false;", class: "btn btn-outline" %>
      </div>
    </template>
  </div>
</div>

<script>
  function tokenProcessing(sessionId, contestUrl) {
    return {
      ready: false,
      contestUrl: contestUrl,
      minted: 0,
      balance: 0,
      elapsed: 0,
      errored: false,
      _timer: null,
      _ticker: null,

      start() {
        if (!sessionId) { this.errored = true; return; }

        // Notify any listening contest tab (the modal there mirrors the
        // confirming → minted → submitted flow). Two channels because
        // browsers may have dropped window.opener (implicit noopener on
        // target=_blank forms is common):
        //   1. BroadcastChannel — same-origin, opener-independent
        //   2. window.opener.postMessage — legacy fallback
        try {
          if ('BroadcastChannel' in window) {
            var ch = new BroadcastChannel('tt-tokens');
            ch.postMessage({ source: 'tt-tokens', status: 'returned', sessionId: sessionId });
            ch.close();
          }
        } catch (e) {}

        try {
          if (window.opener && !window.opener.closed) {
            window.opener.postMessage(
              { source: 'tt-tokens', status: 'returned', sessionId: sessionId },
              window.location.origin
            );
          }
        } catch (e) {}

        // Contest-context flow: the buyer came from a contest tab
        // (success_url carried ?contest=slug → controller set @contest →
        // contestUrl is non-empty). The contest tab's modal owns the
        // confirming → minted UI; this tab just hands off and gets out
        // of the way. window.close() works for script-opened popups;
        // the location-href fallback covers form-opened tabs that can't
        // be closed. Either way the buyer never visually leaves the
        // contest. We use contestUrl as a reliable proxy for "there's
        // a listener" because postMessage/BroadcastChannel give no
        // delivery confirmation — see commit 4890000 for the standalone
        // case where contestUrl is empty and polling is the only path.
        if (contestUrl) {
          setTimeout(function () { window.close(); }, 80);
          setTimeout(function () { window.location.href = contestUrl; }, 400);
          return;
        }

        // Standalone flow: no contest context (e.g. /tokens/buy direct
        // purchase, or webhook arrived during a server-down window).
        // Poll /tokens/status until the mint completes, then show the
        // standalone success card.
        this._ticker = setInterval(() => { this.elapsed += 1 }, 1000);
        this.poll();
        this._timer = setInterval(() => this.poll(), 1500);
        setTimeout(() => {
          if (!this.ready) { this.stop(); this.errored = true; }
        }, 45000);
      },

      stop() {
        if (this._timer) { clearInterval(this._timer); this._timer = null; }
        if (this._ticker) { clearInterval(this._ticker); this._ticker = null; }
      },

      async poll() {
        try {
          const r = await fetch('<%= tokens_status_path %>?session_id=' + encodeURIComponent(sessionId), {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin'
          });
          if (!r.ok) return;
          const d = await r.json();
          if (d.ready) {
            this.minted = d.minted;
            this.balance = d.balance;
            this.ready = true;
            this.stop();
            if (contestUrl) {
              setTimeout(function () { window.location.href = contestUrl; }, 1800);
            }
          }
        } catch (e) { /* keep polling */ }
      }
    };
  }
</script>

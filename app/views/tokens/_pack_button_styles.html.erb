<%# Orb-glow CSS + JS helper for tokens/_pack_button. Render once per
    page that uses the partial, outside any x-if/x-show wrapper so the
    rules + helper are in the DOM before the button mounts. %>
<script>
  // Synchronous-user-gesture popup helper for the modal pack-purchase
  // flow. Chrome (esp. in incognito) was silently dropping the new tab
  // when we relied on the form's target attribute, even with a same-
  // domain named target. Instead we open a blank tab FROM THE SUBMIT
  // EVENT (still a user gesture → allowed), POST via fetch, then
  // navigate the already-open tab to whatever the server redirects to
  // (Stripe checkout URL).
  if (!window.tokenCheckoutSubmit) {
    window.tokenCheckoutSubmit = function(form) {
      var newTab = window.open('', '_blank');
      if (!newTab) {
        alert('Please allow popups for this site to complete checkout.');
        return;
      }
      // Ask the controller for the Stripe URL as JSON. If we let fetch
      // follow the 302 to Stripe instead, the background request
      // consumes the checkout session and Stripe shows "page not
      // found" when the actual tab tries to load the same URL.
      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' }
      }).then(function(r) {
        return r.json().then(function(d) { return { ok: r.ok, data: d }; });
      }).then(function(res) {
        if (res.ok && res.data && res.data.url) {
          newTab.location.href = res.data.url;
        } else {
          newTab.close();
          if (res.data && res.data.error) alert('Checkout failed: ' + res.data.error);
        }
      }).catch(function() {
        try { newTab.close(); } catch (_) {}
      });
    };
  }
</script>
<style>
  /* === Glow Pair: N orb clusters (1 cluster per pack quantity), orbital hover === */
  .glow-pair-btn { position: relative; overflow: hidden; transition: all 500ms ease; }
  .glow-pair-btn .orb {
    position: absolute; border-radius: 9999px;
    pointer-events: none; z-index: 10;
    transition: all 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .glow-pair-btn .orb-small { width: 48px; height: 48px; background: var(--orb1); filter: blur(14px); }
  .glow-pair-btn .orb-big   { width: 76px; height: 76px; background: var(--orb2); filter: blur(22px); }

  /* Rest positions — orbs spread to opposite halves of the card.
     Smalls peek from the top edge (slight overhang), bigs anchored low.
     This makes the hover motion (smalls ↓ past bottom, bigs ↑ past top)
     feel like a single sweeping direction rather than orbs leaving a cluster. */
  .glow-pair-btn .orb-l.orb-small { left: -10px;            top: 6%; }
  .glow-pair-btn .orb-l.orb-big   { left: 40px;             top: 68%; }
  .glow-pair-btn .orb-c.orb-small { left: calc(50% - 24px); top: 6%; }
  .glow-pair-btn .orb-c.orb-big   { left: calc(50% - 38px); top: 72%; }
  .glow-pair-btn .orb-r.orb-small { right: -10px;           top: 6%; }
  .glow-pair-btn .orb-r.orb-big   { right: 40px;            top: 68%; }

  /* Hover: small orbs dive past the bottom + giant halos; big orbs rocket up and out */
  .glow-pair-btn:hover { border-color: var(--orb-accent); }
  .glow-pair-btn:hover .orb-l.orb-small { left: 96px;             top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-l.orb-big   { left: -80px;            top: -64px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn:hover .orb-c.orb-small { left: calc(50% - 12px); top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-c.orb-big   { left: calc(50% - 50px); top: -80px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn:hover .orb-r.orb-small { right: 96px;            top: 110%; filter: blur(24px); box-shadow: 0 0 44px 36px var(--orb1); transform: scale(1.4); }
  .glow-pair-btn:hover .orb-r.orb-big   { right: -80px;           top: -64px; filter: blur(36px); transform: scale(1.3); }
  .glow-pair-btn > .glow-content { position: relative; z-index: 20; }

  .glow-brand { --orb1: #4BAF50; --orb2: #f97316; --orb-accent: #f97316; }
</style>

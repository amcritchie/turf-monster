<p style="margin:0 0 16px;font-size:16px;line-height:1.6;color:#3f4a3c;">Hi <%= @inviter.display_name %> 👋🏻</p>

<p style="margin:0 0 16px;font-size:16px;line-height:1.6;color:#3f4a3c;">
  🎉 <strong style="color:#1f2a1c;"><%= @invitee.display_name %></strong> just entered their first
  Turf Monster contest using your invite link.
</p>

<% if @remaining.positive? %>
  <p style="margin:0 0 28px;font-size:16px;line-height:1.6;color:#3f4a3c;">
    You're <strong style="color:#1f2a1c;"><%= @invitees_in_contest %>/<%= @target %></strong> of the way to a
    free entry token — bring <strong style="color:#1f2a1c;"><%= @remaining %> more friend<%= "s" if @remaining != 1 %></strong>
    into a contest and we'll credit you one.
  </p>
<% else %>
  <p style="margin:0 0 28px;font-size:16px;line-height:1.6;color:#3f4a3c;">
    That's <strong style="color:#1f2a1c;"><%= @invitees_in_contest %> friends</strong> in — your free entry
    token is on the way. 🪙
  </p>
<% end %>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin:0 auto;">
  <tr><td align="center" bgcolor="#4BAF50" style="border-radius:10px;">
    <a href="<%= @account_url %>" style="display:inline-block;padding:16px 40px;font-size:17px;font-weight:700;color:#ffffff;text-decoration:none;border-radius:10px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Share your invite link →</a>
  </td></tr>
</table>

<p style="margin:28px 0 0;font-size:13px;line-height:1.5;color:#6b756a;text-align:center;">
  Thanks for spreading the word.<br>— Turf Monster
</p>

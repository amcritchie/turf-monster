<%# newsletter-subscribe — the newsletter join, as a self-contained modal.
    Reached two ways:
      - swapped in from quest-success ("Subscribe for +25 more seeds")
      - opened from the /account newsletter card ("Subscribe")
    Mirrors the questNewsletter factory's consent gating + _newsletter_email's
    capture, but inlined so the partial keeps a SINGLE root (host mounts via its
    own <template x-if>). x-data is double-quoted, so EVERYTHING inside it is
    single-quoted.

    Email field is SERVER-gated on current_user.email.blank? — only web3 / no-email
    accounts see it (web2 users already have an email on file and one-click join).
    The consent checkbox disables Subscribe until ticked. On success: swap to the
    newsletter-success celebration + fire StateFanout (the +25 seeds land only on a
    first-ever join). Bottom Close link like every modal. %>
<% needs_email = current_user.email.blank? %>
<div x-data="{
       saving: false,
       error: null,
       consent: true,
       email: '',
       needsEmail: <%= needs_email %>,
       url: '<%= newsletter_subscribe_path %>',
       async subscribe() {
         if (this.saving || !this.consent) return;
         if (this.needsEmail && (this.email || '').indexOf('@') < 1) {
           this.error = 'Enter a valid email address.';
           return;
         }
         this.saving = true;
         this.error = null;
         try {
           var csrf = (document.querySelector('meta[name=csrf-token]') || {}).content || '';
           var fetcher = window.authedFetch || window.fetch;
           var resp = await fetcher(this.url, {
             method: 'POST',
             headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf, 'Accept': 'application/json' },
             body: JSON.stringify({ email: this.needsEmail ? this.email : null })
           });
           if (!resp) { this.saving = false; return; }
           var data = await resp.json();
           if (!data.success) throw new Error(data.error || 'Could not join the newsletter.');
           if (window.seedFanoutPayloadPresent && window.seedFanoutPayloadPresent(data)) {
             window.applyStateFanoutWhenReady('seeds', data, { source: 'newsletter-modal', dispatchDelay: 300 });
           }
           try { window.dispatchEvent(new CustomEvent('newsletter-state-changed', { detail: { subscribed: true } })); } catch (e) {}
           this.$store.modals.swap('newsletter-success', { seeds_earned: data.seeds_earned || 0 });
         } catch (e) {
           this.error = (e && e.message) || 'Could not join the newsletter.';
           this.saving = false;
         }
       }
     }">
  <%= render "modals/blocks/card_header",
        size: :md,
        icon_emoji: "📬",
        title: "Join the Newsletter",
        subtitle: "Sports news and contest updates — and 25 seeds for joining." %>

  <% if needs_email %>
    <input type="email" x-model="email" @keydown.enter.prevent="subscribe()"
           placeholder="you@example.com" autocomplete="email"
           class="w-full bg-inset border border-subtle rounded-lg px-3 py-2 text-sm text-heading mb-3 focus:border-primary/50 focus:outline-none">
  <% end %>

  <label class="flex items-center gap-2 text-xs text-secondary mb-3 select-none cursor-pointer">
    <input type="checkbox" x-model="consent" class="rounded border-subtle text-primary cursor-pointer">
    Subscribe to the Turf Monster newsletter
  </label>

  <p x-show="error" x-cloak x-text="error" class="text-xs mb-3" style="color:#f87171"></p>

  <button type="button" @click="subscribe()" :disabled="saving || !consent"
          class="btn btn-primary btn-lg w-full disabled:opacity-50 disabled:cursor-not-allowed">
    <span x-show="!saving">Subscribe</span>
    <span x-show="saving" x-cloak class="inline-flex items-center justify-center gap-2">
      <span class="cta-spinner" aria-hidden="true"></span>Subscribing…
    </span>
  </button>

  <button type="button" @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Close
  </button>
</div>

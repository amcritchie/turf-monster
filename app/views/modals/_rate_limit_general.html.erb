<%#
  Tier-1 "general" rate-limit wait modal (rate-limit epic, Phase 1). Opened by
  the authedFetch 429 interceptor (solana_utils.js) when a general-tier throttle
  trips — e.g. hammering "Mint USDC". Friendly "give it a sec" beat with a live
  countdown seeded from the 429's Retry-After; auto-closes at 0. Dismissible
  (it's a soft, forgiving cap).

  Opened via $store.modals.open('rate-limit-general', { secondsLeft, message }).
  Single root <div> (the host mounts this through its own <template x-if>).
  x-data inline; keep it free of double-quotes and backticks — it is a
  double-quoted HTML attribute, so an inner double-quote closes it and silently
  breaks the modal.
%>
<div x-data="{
       get props() { return ($store.modals.current() || {}).props || {} },
       get waitDisplay() {
         var s = this.props.secondsLeft || 0;
         return s > 90 ? (Math.ceil(s / 60) + ' min') : (s + 's');
       },
       _timer: null,
       init() {
         var self = this;
         if (this._timer) clearInterval(this._timer);
         this._timer = setInterval(function () {
           var p = self.props;
           if (!p) { clearInterval(self._timer); self._timer = null; return; }
           p.secondsLeft = (p.secondsLeft || 0) - 1;
           if (p.secondsLeft <= 0) {
             p.secondsLeft = 0;
             clearInterval(self._timer); self._timer = null;
             $store.modals.close();
           }
         }, 1000);
       },
       destroy() { if (this._timer) { clearInterval(this._timer); this._timer = null; } }
     }">
  <%= render 'modals/blocks/card_header', icon_emoji: '✋', title: 'Easy there' do %>
    <span x-text="props.message || 'You are going a bit fast.'"></span>
    <span class="block mt-1">Try again in <span class="text-heading font-semibold" x-text="waitDisplay"></span>.</span>
  <% end %>
  <button @click="$store.modals.close()" class="block mx-auto mt-1 text-sm text-secondary hover:text-heading transition">Dismiss</button>
</div>

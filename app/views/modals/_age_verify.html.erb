<%#
  Age-verification modal — entry-time DOB gate (ENABLE_AGE_GATE). Mounted by
  the modal host as id 'age-verify'; opened from the contest hold-to-confirm
  flow (selectionBoard#showAgeVerifyModal) BEFORE the Get Entry Tokens modal.

  Collects a real date of birth, POSTs to /age/verify where the age is
  recomputed server-side against the user's detected state (AgePolicy), and on
  success stamps date_of_birth + age_attested_at — one-time, every later entry
  passes straight through. Single root element (template-x-if mount rule).

  minAge/state are baked in at render time from the request's geo_state.
%>
<% min_age = AgePolicy.minimum_age(geo_state) %>
<div x-data="ageVerifyModal({ minAge: <%= min_age %>, state: '<%= j geo_state.to_s %>', url: '<%= age_verify_path %>' })">
  <%= render layout: "modals/blocks/shell", locals: { title: "Verify your age" } do %>
    <p class="text-sm text-muted mb-4">
      You must be <span class="text-heading font-semibold"><%= min_age %>+</span>
      to enter skill-based contests<%= geo_state.present? ? " in #{geo_state}" : "" %>.
      Enter your date of birth — we only ask once.
    </p>

    <%# Month / Day / Year selectors %>
    <div class="grid grid-cols-3 gap-2 mb-4">
      <div>
        <label class="label-upper block mb-1">Month</label>
        <select x-model="month" @change="onMonthChange()" class="input-field !px-3 !py-2.5 text-sm appearance-none cursor-pointer">
          <option value="" disabled>Month</option>
          <template x-for="m in months" :key="m.n">
            <option :value="m.n" x-text="m.label"></option>
          </template>
        </select>
      </div>
      <div>
        <label class="label-upper block mb-1">Day</label>
        <select x-model="day" @change="error = ''" class="input-field !px-3 !py-2.5 text-sm appearance-none cursor-pointer">
          <option value="" disabled>Day</option>
          <template x-for="d in dayOptions" :key="d">
            <option :value="d" x-text="d"></option>
          </template>
        </select>
      </div>
      <div>
        <label class="label-upper block mb-1">Year</label>
        <select x-model="year" @change="onMonthChange()" class="input-field !px-3 !py-2.5 text-sm appearance-none cursor-pointer">
          <option value="" disabled>Year</option>
          <template x-for="y in years" :key="y">
            <option :value="y" x-text="y"></option>
          </template>
        </select>
      </div>
    </div>

    <%# Live too-young hint — shown only once a full date is picked and it
        fails the bar, so the user sees the problem before submitting. %>
    <template x-if="complete && computedAge !== null && computedAge < minAge">
      <p class="text-red-400 text-sm mb-3" x-text="'You must be ' + minAge + '+ to enter contests' + (stateCode ? ' in ' + stateCode : '') + '.'"></p>
    </template>

    <%# Server error (e.g. invalid date, or the authoritative too-young check). %>
    <template x-if="error">
      <p class="text-red-400 text-sm mb-3" x-text="error"></p>
    </template>

    <button type="button" @click="submit()"
            class="btn btn-primary btn-lg w-full"
            :disabled="!complete || submitting || (computedAge !== null && computedAge < minAge)">
      <span x-show="!submitting">Confirm &amp; Continue</span>
      <span x-show="submitting" class="inline-flex items-center justify-center gap-2" style="display: none;">
        <span class="cta-spinner" aria-hidden="true"></span>
        Verifying…
      </span>
    </button>

    <p class="text-[11px] text-muted text-center mt-3 leading-snug">
      We use your date of birth only to confirm eligibility. Skill-based contest
      age limits: 18+ most states; 19+ AL/NE; 21+ IA/MA/VA.
    </p>
  <% end %>
</div>

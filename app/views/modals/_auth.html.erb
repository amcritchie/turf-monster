<%#
  Auth wizard — the canonical post-signup-to-entry flow, rendered inside
  shared/_modal_host through Alpine.store('modals').open('auth', { step, ... }).
  One modal id, internal step machine on $store.modals.current().props.step.

  Steps (in flow order — but the modal can be opened at any step):
    credentials       — Google + Solana wallet hub + email magic-link request
    magic-link-sent   — "check your inbox" confirmation after the email request
    tokens-picker     — Stripe pack picker (orb-glow cards)
    tokens-waiting    — Stripe checkout open in new tab; awaiting return
    tokens-confirming — Stripe returned; polling /tokens/status for the mint
    tokens-minted     — tokens credited; in-modal Hold to Confirm Entry
    tokens-error      — poll timed out / submission failed
                        (entry success has no step — board's resolveEntry()
                        swaps to the shared onchain-tx Entry Confirmed card)
    redirect          — countdown auto-redirect (entry blocked, geo, etc.)

  State split:
    - The email field + wallet-hub open/list live in this partial's own
      x-data — local to user input, no need to outlive the modal.
    - Display state (sentEmail, mintedCount, errorText, etc.) lives on the
      store entry's props, mutated by the selectionBoard methods.
    - Submitting/error flags for each auth attempt live on props too.

  Cross-scope actions: every button dispatches a window event the
  selectionBoard listens for (auth-google-click, auth-wallet-hub-open,
  auth-magic-link-submit). We don't reach into board scope from here; the
  wizard partial is rendered at layout level, outside the board's x-data.
%>
<%# CRITICAL: this partial is rendered inside <template x-if="...id==='auth'">
    in shared/_modal_host.html.erb. Alpine requires the template's content to
    have a SINGLE root element — anything else mounts as a silent no-op. Keep
    all rendered output inside the wizard's outer <div>; every inner
    <template x-if>/<template x-for> also has exactly one root child. %>
<div x-data="{
       email: '',
       // Hardened against a transient null current() during modal open/close
       // transitions — Alpine catches exceptions in x-if expressions and
       // treats them as falsy. Returning {} keeps every binding evaluating
       // cleanly until current() is real again.
       get props() {
         var c = $store.modals.current();
         return (c && c.props) || {};
       },
       get isCredentialsStep() {
         var s = this.props.step;
         if (!s) return true;
         if (s === 'redirect' || s === 'magic-link-sent' || s === 'magic-link-resent') return false;
         if (s.indexOf && s.indexOf('tokens-') === 0) return false;
         return true;
       },
       // Self-contained resend for the magic-link-sent step (login page or
       // in-contest). postMagicLink resolves rather than throwing on a non-2xx,
       // so this reads the result and surfaces visible feedback either way.
       // After a successful resend, a 60s cooldown disables the button and
       // counts down so the user cannot hammer it. NOTE: keep this x-data free
       // of double-quotes and backticks -- it is a double-quoted HTML
       // attribute, so an inner double-quote closes it and silently breaks the
       // whole modal (regressed PR #30).
       _resendTimer: null,
       startResendCooldown(seconds) {
         var self = this;
         var p = this.props;
         if (!p) return;
         p.resendCooldown = seconds || 60;
         if (this._resendTimer) clearInterval(this._resendTimer);
         this._resendTimer = setInterval(function () {
           var pp = self.props;
           if (!pp) { clearInterval(self._resendTimer); self._resendTimer = null; return; }
           pp.resendCooldown = (pp.resendCooldown || 0) - 1;
           if (pp.resendCooldown <= 0) {
             pp.resendCooldown = 0;
             clearInterval(self._resendTimer);
             self._resendTimer = null;
           }
         }, 1000);
       },
       destroy() {
         if (this._resendTimer) { clearInterval(this._resendTimer); this._resendTimer = null; }
       },
       async resendMagicLink() {
         var p = this.props;
         if (!p || p.submitting || (p.resendCooldown || 0) > 0) return;
         p.resendError = '';
         p.resent = false;
         p.submitting = 'magic-link';
         try {
           var data = await window.postMagicLink(p.sentEmail, { contest: p.sentContest, picks: p.sentPicks });
           if (data && data.success) {
             // Swap to the dedicated success step — the directional slide IS
             // the visual confirmation. Re-advancing on each resend re-runs the
             // slide, so every resend gets its own little confirmation beat.
             Alpine.store('modals').advance({ step: 'magic-link-resent' });
             this.startResendCooldown(60);
           } else {
             p.resendError = (data && data.error) || 'Could not resend — wait a moment and try again.';
           }
         } catch (e) {
           p.resendError = 'Could not resend — check your connection and try again.';
         }
         p.submitting = null;
       }
     }"
     class="relative">

  <%# === CREDENTIALS STEP =================================================== %>
  <%# x-show (not x-if) so the content is ALWAYS in the DOM — only hidden via
      display:none when another step is active. Layout follows the Wizard
      template: centered title with absolute-positioned close ×, segmented
      3-of-3 progress pill below. CTA order: Google → Solana wallet hub →
      (or) → email magic link. %>
  <div x-show="isCredentialsStep" x-cloak>
      <div class="relative mb-3 -mt-2">
        <h3 class="text-heading font-bold text-lg leading-tight text-center pt-1">Sign in</h3>
        <button @click="$store.modals.close()"
                class="absolute top-0 right-0 -mr-2 text-secondary hover:text-heading text-xl leading-none"
                aria-label="Close">&times;</button>
      </div>
      <%= render "modals/blocks/progress_pill", current: 1, total: 3 %>
      <p class="text-xs text-secondary mb-4 text-center">Your 6 picks are saved — sign in to submit your lineup.</p>

      <!-- 1. Google OAuth — opens a popup; the closer page postMessages the result -->
      <button @click="$dispatch('auth-google-click')"
              :disabled="props.submitting"
              class="btn btn-neutral btn-lg w-full gap-3 mb-3 disabled:cursor-wait">
        <span x-show="props.submitting !== 'google'" class="inline-flex"><%= render "components/google_logo" %></span>
        <span x-show="props.submitting === 'google'" class="cta-spinner" aria-hidden="true"></span>
        <span x-text="props.submitting === 'google' ? 'Waiting for Google…' : 'Google'"></span>
      </button>
      <template x-if="props.googleError">
        <p class="text-red-400 text-xs -mt-2 mb-3" x-text="props.googleError"></p>
      </template>

      <!-- 2. Solana — progresses to the Connect Wallet picker modal. The board
           saves the cart + passes returnUrl so the lineup survives (see
           selectionBoard#openWalletConnect). -->
      <button @click="$dispatch('auth-wallet-hub-open')" :disabled="props.submitting"
              class="btn btn-neutral btn-lg w-full gap-3 mb-3 disabled:cursor-wait">
        <img src="/solana-mark.svg" alt="" class="w-5 h-5" x-show="props.submitting !== 'wallet'">
        <span x-show="props.submitting === 'wallet'" class="cta-spinner" aria-hidden="true"></span>
        <span x-text="props.submitting === 'wallet' ? 'Connecting…' : 'Solana'"></span>
      </button>
      <template x-if="props.phantomError">
        <p class="text-red-400 text-xs -mt-2 mb-3" x-text="props.phantomError"></p>
      </template>

      <div class="relative my-4">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
        <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
      </div>

      <!-- 3. Email magic link — no password. Dispatches the request; the board
           emails a one-tap link and advances to the 'magic-link-sent' step. -->
      <form @submit.prevent="$dispatch('auth-magic-link-submit', { email: email })" novalidate>
        <div class="mb-3">
          <label class="block text-xs text-secondary mb-1 font-medium">Email</label>
          <%# Live client-side validity decorator (UX only — never blocks
              submit). name omitted so this still feeds the parent modal scope's
              "email" via x-model (the form dispatches that value rather than
              natively posting); the emailValidator child scope does not define
              "email" or "props", so both bind upward to the modal's x-data. %>
          <%= render "shared/email_field",
                name: nil, x_model: "email",
                placeholder: "you@example.com", required: true,
                disabled_expr: "props.submitting" %>
        </div>
        <template x-if="props.formError">
          <p class="text-red-400 text-xs mb-3" x-text="props.formError"></p>
        </template>
        <button type="submit" :disabled="props.submitting"
                class="btn btn-neutral btn-lg w-full gap-2 disabled:cursor-wait">
          <span x-show="props.submitting === 'magic-link'" class="cta-spinner" aria-hidden="true"></span>
          <span x-text="props.submitting === 'magic-link' ? 'Sending link…' : 'Email Link'"></span>
        </button>
        <p class="text-xs text-muted text-center mt-2">No password needed — we'll email you a one-tap link.</p>
      </form>
  </div>

  <%# === MAGIC-LINK-SENT STEP =============================================== %>
  <%# Status-card pattern: icon-on-top via the shared card_header block, email
      inline in the subtext. Resend is a centered LINK (not a button) + a Close
      link (resend stays a link, per the design call). %>
  <template x-if="props.step === 'magic-link-sent'">
    <div>
      <%= render 'modals/blocks/card_header', icon_emoji: '📬', title: 'Check your inbox' do %>
        We emailed <span class="text-heading font-medium break-all" x-text="props.sentEmail"></span>
        a one-tap sign-in link. Check your email and
        <span class="text-heading font-semibold">Click the Magic Link</span> to continue.
      <% end %>
      <%# Resend (link) + error + Close — shared with the resent step. A failed
          resend stays here and shows the error; a success swaps to the resent
          step (the slide is the confirmation). %>
      <%= render 'modals/auth/resend_footer' %>
    </div>
  </template>

  <%# === MAGIC-LINK-RESENT STEP ============================================ %>
  <%# Success confirmation after a resend — resendMagicLink advances here so the
      directional slide is the visual "it sent!" beat. Check-pill icon via
      card_header. Single root <div>. Keeps its own resend link so the user can
      resend again once the cooldown clears (re-advancing re-runs the slide). %>
  <template x-if="props.step === 'magic-link-resent'">
    <div>
      <%= render 'modals/blocks/card_header', icon_color: 'primary', title: 'Link Resent!' do %>
        We just resent <span class="text-heading font-medium break-all" x-text="props.sentEmail"></span>
        a one-tap sign-in link. Check your email and
        <span class="text-heading font-semibold">Click the Magic Link</span> to continue.
      <% end %>
      <%= render 'modals/auth/resend_footer' %>
    </div>
  </template>

  <%# === TOKENS SUB-FLOW ====================================================
      tokens-picker / -waiting / -confirming / -minted / -submitted / -error
      live in modals/auth/_tokens.html.erb so this partial stays focused on
      auth credentials + the redirect step. Same x-data scope. %>
  <%= render 'modals/auth/tokens' %>

  <%# === REDIRECT STEP ======================================================
      Status-template spine: card_header with caller-provided emoji
      (icon_emoji_key reads props.icon) + cta_redirect for the drain-
      and-go button. The board's setInterval + props.countdown loop
      is retired — cta_redirect owns the timer end-to-end and reads
      props.url at fire time so the CTA respects late-bound URLs +
      the null-bypass (gallery preview). %>
  <template x-if="props.step === 'redirect'">
    <div>
      <%= render 'modals/blocks/card_header',
            icon_emoji_key: "props.icon",
            title_key:      "props.title",
            subtitle_key:   "props.message" %>
      <%= render 'modals/blocks/cta_redirect',
            href_key:         "props.url",
            label_key:        "props.cta || 'Go now'",
            duration_seconds: 5 %>
    </div>
  </template>
</div>

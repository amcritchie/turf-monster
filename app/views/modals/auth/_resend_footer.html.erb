<%#
  Resend-link + error + Close footer, shared by the auth modal's
  magic-link-sent and magic-link-resent steps (identical in both). Rendered
  INSIDE each step's root <div> (so the parent <template x-if>'s single-root
  rule is unaffected) and within the auth modal's x-data scope, so props.* and
  resendMagicLink() resolve from the host component. Resend is a LINK (not a
  button); disabled during an in-flight resend and the 60s cooldown, which it
  counts down inline. Keep this free of double-quotes/backticks inside the
  Alpine expressions for the same reason the host x-data is (see _auth.html.erb).
%>
<button @click="resendMagicLink()" :disabled="props.submitting === 'magic-link' || (props.resendCooldown || 0) > 0"
        class="block mx-auto text-sm text-primary hover:text-primary-300 underline underline-offset-2 disabled:opacity-50 disabled:no-underline">
  <span class="inline-flex items-center justify-center gap-1.5">
    <span x-show="props.submitting === 'magic-link'" class="cta-spinner" aria-hidden="true"></span>
    <span x-text="props.submitting === 'magic-link' ? 'Resending…' : ((props.resendCooldown || 0) > 0 ? ('Resend available in ' + props.resendCooldown + 's') : 'Resend link')"></span>
  </span>
</button>
<p x-show="props.resendError" x-cloak class="text-xs text-red-400 mt-3 text-center" x-text="props.resendError"></p>
<button @click="$store.modals.close()" class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">Close</button>

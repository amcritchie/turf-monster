<%#
  USDC funding sub-flow of the auth modal — the CDP-era replacement for the
  Stripe token picker. The original (modals/auth/_tokens.html.erb) is kept
  dormant and byte-identical: _auth.html.erb picks which one renders via
  entry_funding_mode, so setting PAYMENT_PROVIDER=stripe and enabling Stripe
  checkout restores the token packs wholesale.

  Mounts on the same step machine the board already drives: the entry gate
  still opens 'tokens-picker'; this partial renders USDC funding instead of
  packs. The Buy CTA hands off to the cdp-ramp modal (cross-modal swap with
  the entry fee prefilled). After the buy settles, the board's hold button
  passes the USDC eligibility gate — no entry token involved, so the
  tokens-waiting/confirming/minted steps never occur on this path.
%>
<template x-if="props.step && props.step.indexOf('tokens-') === 0">
  <div>
    <%# Shared close × — top-right, matches the tokens sub-flow. %>
    <button @click="$store.modals.close()"
            class="absolute top-0 right-0 -mt-2 -mr-2 text-secondary hover:text-heading text-xl leading-none z-10"
            aria-label="Close">&times;</button>

    <template x-if="props.step === 'tokens-picker'">
      <div>
        <%# Wizard-template header — same shell as the token picker so the
            3-step onboarding journey reads identically to reviewers. %>
        <div class="text-center pt-1 mb-3">
          <h3 class="text-heading font-bold text-lg leading-tight">Add USDC to Play</h3>
        </div>
        <%= render "modals/blocks/progress_pill", current: 2, total: 3 %>
        <% if AppFlags.cdp_ramp? %>
          <% entry_fee_dollars = ((@contest&.entry_fee_cents || 1900) / 100) %>
          <p class="text-xs text-secondary mb-4 text-center">Entry fee is $<%= entry_fee_dollars %> in USDC. Your lineup is saved &mdash; add USDC to finish.</p>
          <p class="text-xs text-muted mb-4 text-center"
             x-show="$store.session && ($store.session.usdcCents || 0) > 0">
            Wallet balance:
            <span class="font-mono text-primary"
                  x-text="'$' + (($store.session.usdcCents || 0) / 100).toFixed(2)"></span>
          </p>
          <div class="space-y-3">
            <button @click="$store.modals.swap('cdp-ramp', { flow: 'buy', step: 'preflight', presetFiat: <%= entry_fee_dollars %> })"
                    class="btn btn-primary btn-lg w-full">Buy USDC with Coinbase</button>
          </div>
          <p class="text-center text-xs text-muted mt-4">Pay with debit, Apple Pay, or your Coinbase balance. USDC lands in your wallet &mdash; then hold to confirm your entry.</p>
        <% else %>
          <%= render "modals/blocks/card_header",
                icon: :error,
                title: "Purchases temporarily offline",
                subtitle: "Entry purchases are paused while we upgrade checkout. Your picks are saved." %>
        <% end %>
      </div>
    </template>
  </div>
</template>

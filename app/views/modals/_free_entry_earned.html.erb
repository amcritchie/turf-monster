<%# free-entry-earned — pops when a user crosses a seed level (every 100 seeds
    earns one free entry). Opened from app/javascript/state_fanout.js's seeds
    handler on a level-up (swap over any open modal, else open). Title is the
    level reached; body explains the Free Entry Token arrives within 48h + a
    keep-leveling nudge. SINGLE root. %>
<div x-data="{ get props() { return ($store.modals.current() || {}).props || {} } }"
     x-init="setTimeout(function () { try { if (window.fireFreeEntryConfetti) window.fireFreeEntryConfetti(); } catch (e) {} }, 120)">
  <%# title is the level reached, passed in props by the layout's
      navbar-seeds-update listener; generic fallback when absent. Top emoji is the
      celebration popper; the ticket sits inline beside "Free Entry Token". %>
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_emoji: "🎉",
        title_key: "props.level ? ('Level ' + props.level) : 'Free Entry Earned'",
        subtitle: "Well done! You earned a <strong class='text-heading font-semibold'>Free Entry Token &#127915;</strong> that will arrive in 48 hours. Keep earning more free entries with each level.".html_safe %>

  <button type="button" @click="$store.modals.close()"
          class="block mx-auto mt-4 text-sm text-secondary hover:text-heading transition">
    Close
  </button>
</div>

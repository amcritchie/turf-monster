<%#
  Generic on-chain transaction success card — the DEFAULT-FALLBACK
  success state for any Solana transaction that isn't a contest entry
  (devnet faucet mint, contest creation, on-chain username change,
  etc.). Decoupled from modals/blocks/_entry_confirmed so a faucet
  claim no longer shows the contest-entry "Good Luck / Contest Lobby"
  celebration.

  Same visual spine as _entry_confirmed (card_header at :lg with the
  primary check pill + branded Solana tx link) MINUS the entry-only
  enrichments: no seeds bar, no level-up celebration, no 5s lobby
  auto-redirect drain. The CTA here is a plain link (no drain) and is
  optional — when no cta label/href is supplied the card degrades to
  just the Dismiss link.

  All copy + CTA are caller-supplied via Alpine expression strings so
  the same card serves every generic on-chain flow; the calling code
  sets them through $store.solanaModal.success(tx, msg, opts).

  Single root: content lives in one <div> so Alpine's <template x-if>
  clones it whole (see [[feedback_alpine_template_single_root]]).

  Locals (all Alpine expressions):
    tx_signature_key — expression returning the Solana tx hash (link
                       mounts only when truthy)
    title_key        — expression returning the headline
    subtitle_key     — expression returning the sub-headline
    cta_label_key    — expression returning the CTA button label
                       (button mounts only when truthy)
    cta_href_key     — expression returning the CTA href
%>
<%
  tx_signature_key = local_assigns.fetch(:tx_signature_key)
  title_key        = local_assigns.fetch(:title_key)
  subtitle_key     = local_assigns.fetch(:subtitle_key)
  cta_label_key    = local_assigns.fetch(:cta_label_key)
  cta_href_key     = local_assigns.fetch(:cta_href_key)
  cluster_param    = Solana::Config.devnet? ? "?cluster=devnet" : ""
%>
<div>

  <%# Card header — same Success-template spine as _entry_confirmed
      (size :lg, primary check pill). Title + subtitle are caller-
      supplied via Alpine expressions. %>
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_color: 'primary',
        title_key:    title_key,
        subtitle_key: subtitle_key %>

  <%# Solana tx attestation — boxed branded link with the Solana gradient
      mark + truncated signature. Mounts only when the signature is set.
      Mirrors the link in _entry_confirmed (gradient ids namespaced to
      this card so both can co-exist on a page without collision). %>
  <template x-if="(<%= tx_signature_key %>)">
    <div class="text-center mb-3 -mt-1">
      <a :href="'https://explorer.solana.com/tx/' + (<%= tx_signature_key %>) + '<%= cluster_param %>'"
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-subtle hover:border-primary/50 transition group no-underline"
         style="background: rgba(var(--color-primary-500-rgb), 0.06);">
        <svg width="14" height="11" viewBox="0 0 397 311" fill="none">
          <defs><linearGradient id="os-solana-grad" x1="361" y1="-9" x2="153" y2="389" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#00FFA3"/><stop offset="1" stop-color="#DC1FFF"/>
          </linearGradient></defs>
          <path d="M65 234c2-2 6-4 9-4h317c6 0 9 7 5 11l-63 63c-2 2-6 4-9 4H6c-6 0-9-7-5-11l64-63z" fill="url(#os-solana-grad)"/>
          <path d="M65 4c2-2 6-4 9-4h317c6 0 9 7 5 11l-63 63c-2 2-6 4-9 4H6c-6 0-9-7-5-11L65 4z" fill="url(#os-solana-grad)"/>
          <path d="M333 119c-2-2-6-4-9-4H7c-6 0-9 7-5 11l63 63c2 2 6 4 9 4h317c6 0 9-7 5-11l-63-63z" fill="url(#os-solana-grad)"/>
        </svg>
        <span class="font-mono text-[11px] text-secondary group-hover:text-primary transition"
              x-text="(<%= tx_signature_key %>) ? ((<%= tx_signature_key %>).substring(0, 16) + '…') : ''"></span>
        <svg class="w-3 h-3 text-muted group-hover:text-primary transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </template>

  <%# Optional primary CTA — plain link (no drain, no auto-redirect:
      generic on-chain successes shouldn't bounce the user). Mounts
      only when a label is supplied; href falls back to '#'. %>
  <template x-if="(<%= cta_label_key %>)">
    <a :href="(<%= cta_href_key %>) || '#'"
       class="btn btn-primary btn-lg w-full no-underline"
       x-text="<%= cta_label_key %>"></a>
  </template>

  <%# Dismiss link — always present (Success template's secondary
      pattern). The only action when no CTA was supplied. %>
  <button @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Dismiss
  </button>
</div>

<%# Shared modal shell — opt-in convenience wrapper. See the docblock %>
<%# below this partial in any caller for usage; gist:                  %>
<%#   render layout "modals/blocks/shell", locals title body              %>
<%# Locals all optional: title (string, top-row), dismissible (default %>
<%# true; suppress the close button). Host gates @click.outside +      %>
<%# escape on props.dismissible at open() time, not this flag.         %>
<%
  shell_title       = local_assigns[:title]
  shell_dismissible = local_assigns.fetch(:dismissible, true)
%>

<div>
  <% if shell_title || shell_dismissible %>
    <div class="flex items-start justify-between gap-3 -mt-2 -mr-2 mb-3">
      <% if shell_title %>
        <h3 class="text-heading font-bold text-lg leading-tight pt-1"><%= shell_title %></h3>
      <% else %>
        <%# Spacer to keep the × pushed right when there's no title. %>
        <span></span>
      <% end %>
      <% if shell_dismissible %>
        <button type="button" @click="$store.modals.close()"
                class="text-secondary hover:text-heading text-xl leading-none flex-shrink-0"
                aria-label="Close">&times;</button>
      <% end %>
    </div>
  <% end %>

  <%= yield %>
</div>

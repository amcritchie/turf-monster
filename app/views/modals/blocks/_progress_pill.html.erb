<%#
  Segmented progress pill — N rounded bars in a row, the first `current`
  filled in primary, the rest as muted outlines. Drops into any wizard-
  style modal step to show position in a multi-step flow.

  Locals:
    current — 1-indexed step number that should be filled up to (e.g.
              current: 2 with total: 3 fills 2/3 bars). Required.
    total   — total segment count. Default 3.

  Sizing matches the wizard template (h-1.5 bars, gap-1.5, max-w-[200px]
  centered) so credentials / tokens-picker / wizard-template share one
  visual rhythm. Change the values here once and every caller updates.
%>
<%
  current = local_assigns.fetch(:current)
  total   = local_assigns.fetch(:total, 3)
%>
<div class="flex items-center justify-center gap-1.5 mx-auto max-w-[200px] mb-4">
  <% total.times do |i| %>
    <% if (i + 1) <= current %>
      <div class="h-1.5 flex-1 rounded-full bg-primary"></div>
    <% else %>
      <div class="h-1.5 flex-1 rounded-full bg-inset border border-subtle"></div>
    <% end %>
  <% end %>
</div>

<%#
  Shared modal card header — icon pill + title + subtext.
  Owns the visual top of every success / confirmation modal so the
  header style and subtext font stay aligned across the app. Each
  callsite slots its own action area (button, link, hold button)
  BELOW this header.

  Mirrors studio-engine's _success_card large_title mode (text-3xl
  title, w-14 icon pill, w-7 svg, text-sm subtext) — keep the values
  in sync until this partial is promoted into the engine and the
  success_card is refactored to render through it.

  Locals (all optional except title/title_key):
    title:        static title string
    title_key:    Alpine expression for the title (rendered via x-text).
                  Takes priority over title.
    subtitle:     static subtext string
    subtitle_key: Alpine expression for the subtext (rendered via
                  x-text). Takes priority over subtitle.
    icon_color:   color token for the default check — 'primary'
                  (default), 'mint', 'success', 'warning'.
    icon_emoji:   large emoji (text-5xl, no pill) to use instead of
                  the default check icon. Use for warnings (⚠️), the
                  "still processing" hourglass (⏳), etc.
    icon:         :error — X mark in a red pill (hard error states).
                  :external_tab — arrow-exiting-box pill (signals the
                  action is happening in another tab/window).
    spinner:      truthy — renders an animated spinner instead of the
                  check pill. Use for processing/loading states so
                  they share the same header style as success states.
    size:         :md (default, in-flow confirmation — text-lg title,
                  w-12 pill, w-6 svg, text-xs subtext) OR :lg
                  (celebration end-state — text-3xl title, w-14 pill,
                  w-7 svg, text-sm subtext, matches studio-engine's
                  _success_card large_title mode).

  Block: if given, the block's content replaces the subtitle area.
  Use this when the subtext mixes static copy with Alpine-driven
  inline values (e.g. an x-text span embedded mid-sentence).
%>
<%
  icon_color = local_assigns[:icon_color] || 'primary'
  size       = local_assigns[:size] || :md
  pill_class = size == :lg ? 'w-14 h-14' : 'w-12 h-12'
  svg_class  = size == :lg ? 'w-7 h-7'   : 'w-6 h-6'
  title_cls  = size == :lg ? 'text-3xl font-bold text-heading mb-2' : 'text-lg font-bold text-heading mb-2'
  sub_cls    = size == :lg ? 'text-sm text-secondary mb-4'          : 'text-xs text-secondary mb-5'
%>
<div class="text-center">
  <% if local_assigns[:spinner] %>
    <%# Three bouncing dots — replaces the border-spinner. Vertical
        translateY animation reads as motion at a glance regardless of
        contrast/perception thresholds. Container keeps the same square
        footprint as the icon pills so the card_header layout stays
        consistent across spinner / icon / emoji modes. %>
    <div class="mx-auto <%= pill_class %> flex items-center justify-center mb-4">
      <div class="loading-dots">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  <% elsif local_assigns[:icon] == :error %>
    <div class="mx-auto <%= pill_class %> rounded-full bg-red-500/15 flex items-center justify-center mb-4">
      <svg class="<%= svg_class %> text-red-400" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
  <% elsif local_assigns[:icon] == :external_tab %>
    <div class="mx-auto <%= pill_class %> rounded-full bg-<%= icon_color %>/15 flex items-center justify-center mb-4">
      <%# Plain diagonal arrow (no link/box framing) — heroicons
          arrow-up-right at stroke-width 2.5 for visual weight. %>
      <svg class="<%= svg_class %> text-<%= icon_color %>" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
      </svg>
    </div>
  <% elsif local_assigns[:icon_emoji] %>
    <div class="text-5xl mb-4 leading-none"><%= icon_emoji %></div>
  <% else %>
    <div class="mx-auto <%= pill_class %> rounded-full bg-<%= icon_color %>/15 flex items-center justify-center mb-4">
      <svg class="<%= svg_class %> text-<%= icon_color %>" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
  <% end %>

  <% if local_assigns[:title_key] %>
    <h3 class="<%= title_cls %>" x-text="<%= title_key %>"></h3>
  <% elsif local_assigns[:title] %>
    <h3 class="<%= title_cls %>"><%= title %></h3>
  <% end %>

  <%# Subtitle priority: explicit locals BEFORE block_given?. Why:
      block_given? inside a partial can return TRUE even when the
      caller did not pass an explicit block (it inherits the layout's
      yield context) — and `yield` then returns the entire enclosing
      view's HTML. We saw this manifest as the whole contests show
      content rendering inside the subtitle paragraph in the modal
      card whenever a caller used subtitle without a block. Check
      the explicit subtitle locals first; only fall back to the
      implicit block if neither was passed.
      See memory feedback_rails_partial_block_given for full story. %>
  <% if local_assigns[:subtitle_key] %>
    <p class="<%= sub_cls %>" x-text="<%= subtitle_key %>"></p>
  <% elsif local_assigns[:subtitle] %>
    <p class="<%= sub_cls %>"><%= subtitle %></p>
  <% elsif block_given? %>
    <p class="<%= sub_cls %>"><%= yield %></p>
  <% end %>
</div>

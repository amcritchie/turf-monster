<%#
  Entry-confirmed celebration. The canonical "you're in" modal for
  BOTH web3 (on-chain Solana entry) and web2 (entry-token-funded)
  flows so the user sees the same UX regardless of payment method.

  Componentized from modals/templates/_success.html.erb — same visual
  spine (card_header at :lg + primary btn-lg CTA + subtle dismiss
  link) plus three on-chain enrichments that make this distinct from
  a generic success modal:

    - Branded Solana tx link (gradient mark + truncated signature)
    - Seeds bar with level-up celebration animation
    - 5-second drain countdown on the primary CTA + auto-redirect
      (delegated to modals/blocks/_cta_redirect — that partial owns
      the timer + drain styling; this card only fires confetti)

  Owns the confetti setTimeout; destroy() clears it so a mid-modal
  close doesn't fire confetti past unmount.

  All data is passed in as Alpine expression strings so the partial
  works against any backing store/scope. Callers wire:
    web3: $store.solanaModal.{txSignature,lobbyUrl,seedsEarned,seedsTotal}
    web2: props.{txSignature,lobbyUrl,seedsEarned,seedsTotal}

  Locals (all Alpine expressions, all required):
    tx_signature_key — expression returning the Solana tx hash
    lobby_url_key    — expression returning the lobby URL (CTA href
                       + auto-redirect destination)
    seeds_earned_key — expression returning seeds awarded this entry
    seeds_total_key  — expression returning user's total seeds

  Optional local:
    kickoff_at       — Time when the contest locks / kicks off (Contest
                       #starts_at). When present, a live "Kicks off in"
                       countdown renders below the seeds bar so the user
                       knows when their contest begins. Server value (the
                       contest is known at render time on the contest page);
                       omitted in the /admin/modals gallery preview.
%>
<%
  tx_signature_key = local_assigns.fetch(:tx_signature_key)
  lobby_url_key    = local_assigns.fetch(:lobby_url_key)
  seeds_earned_key = local_assigns.fetch(:seeds_earned_key)
  seeds_total_key  = local_assigns.fetch(:seeds_total_key)
  kickoff_at       = local_assigns[:kickoff_at]
%>
<div x-data="{
       _confettiTimer: null,
       init() {
         var self = this;
         self._confettiTimer = setTimeout(function () {
           self._confettiTimer = null;
           try { if (window.fireSuccessConfetti) window.fireSuccessConfetti(); } catch (_) {}
         }, 100);
       },
       destroy() {
         if (this._confettiTimer) { clearTimeout(this._confettiTimer); this._confettiTimer = null; }
       }
     }">

  <%# Card header — Success-template spine (size :lg, primary icon
      circle to match every other success/celebration card across the
      app; bg-mint/15 isn't in the Tailwind safelist so the previous
      mint accent rendered the check without its containing pill).
      "Good Luck" headline + "Entry Confirmed" subtitle. %>
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_color: 'primary',
        title: "Good Luck",
        subtitle: "Entry Confirmed" %>

  <%# Solana tx attestation — branded explorer link (shared with
      _onchain_success). Mounts only when the signature is set. %>
  <%= render "modals/blocks/solana_tx_link", tx_signature_key: tx_signature_key %>

  <%# Seeds bar + level-up celebration. Mounts only when this entry
      awarded seeds; otherwise the card falls back to header + tx + CTA.
      Animation walks the bar from the user's previous toward-next value
      up to the new one (or through 100→0 with a level-up flourish if
      they crossed a threshold). Own _timers array so destroy() can
      clear every scheduled setTimeout on modal close / auto-redirect —
      we previously leaked a setInterval that ran for 9 minutes per
      entry session. %>
  <template x-if="(<%= seeds_earned_key %>) > 0">
    <div x-data="{
           displaySeeds: 0,
           displayLevel: 1,
           levelingUp: false,
           showFreeEntryBadge: false,
           _timers: [],
           init() {
             var self = this;
             var total = (<%= seeds_total_key %>) || 0;
             var earned = (<%= seeds_earned_key %>) || 0;
             var seedsPerLevel = 100;
             var oldSeeds = Math.max(0, total - earned);
             var oldLevel = Math.floor(oldSeeds / seedsPerLevel) + 1;
             var newLevel = Math.floor(total / seedsPerLevel) + 1;
             var oldToward = oldSeeds % seedsPerLevel;
             var newToward = total % seedsPerLevel;
             self.displaySeeds = oldToward;
             self.displayLevel = oldLevel;
             var schedule = function (fn, ms) { self._timers.push(setTimeout(fn, ms)); };
             schedule(function () {
               if (newLevel > oldLevel) {
                 self.levelingUp = true;
                 self.displaySeeds = 100;
                 schedule(function () {
                   self.displayLevel = newLevel;
                   self.showFreeEntryBadge = true;
                 }, 1900);
                 schedule(function () { self.displaySeeds = 0; }, 3400);
                 schedule(function () {
                   self.displaySeeds = newToward;
                   self.levelingUp = false;
                 }, 3600);
               } else {
                 self.displaySeeds = newToward;
               }
             }, 2000);
           },
           destroy() {
             this._timers.forEach(clearTimeout);
             this._timers = [];
           }
         }"
         class="mx-auto mb-4" style="max-width: 100%;">
      <template x-if="!showFreeEntryBadge">
        <div class="relative">
          <div class="seeds-bar-continuous flex gap-1.5"
               style="height: 22px; transition: --bar-progress 1.9s cubic-bezier(0.16, 1, 0.3, 1);"
               :style="{ '--bar-progress': displaySeeds }">
            <template x-for="i in 5" :key="i">
              <div class="flex-1 relative overflow-hidden rounded-md"
                   style="background: rgb(var(--color-primary-500-rgb) / 0.06); border: 1.5px solid rgb(var(--color-primary-500-rgb) / 0.2);">
                <div class="absolute inset-0 pointer-events-none"
                     :style="{
                       backgroundPosition: ((i - 1) * 25) + '% 0',
                       clipPath: 'inset(0 calc(100% - clamp(0%, calc((var(--bar-progress) - ' + ((i - 1) * 20) + ') * 5%), 100%)) 0 0)'
                     }"
                     style="background-image: linear-gradient(90deg, color-mix(in srgb, var(--color-cta) 30%, transparent), color-mix(in srgb, var(--color-cta) 60%, transparent)); background-size: 500% 100%; background-repeat: no-repeat;"></div>
                <div class="modal-shimmer absolute top-0 bottom-0 pointer-events-none"
                     :style="{ left: -(i - 1) * 100 + '%', width: '500%' }"
                     style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.55) 50%, transparent 100%); transform: translateX(200%);"></div>
              </div>
            </template>
          </div>
          <div class="absolute inset-y-0 right-2 flex items-center pointer-events-none">
            <span class="inline-flex items-baseline gap-1 font-mono font-bold text-sm" style="color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.7);">
              <span class="relative overflow-hidden inline-block text-right" style="height: 1.25em; width: 3.2ch; line-height: 1.25em;">
                <span class="block"
                      :style="{ transform: 'translateY(-' + (displaySeeds * 1.25) + 'em)', transition: 'transform 1.9s cubic-bezier(0.16, 1, 0.3, 1)' }">
                  <template x-for="n in 101" :key="n">
                    <span class="block" style="height: 1.25em; line-height: 1.25em;" x-text="n - 1">0</span>
                  </template>
                </span>
              </span>
              <span class="text-[10px] font-normal opacity-90">seeds</span>
            </span>
          </div>
        </div>
      </template>
      <template x-if="showFreeEntryBadge">
        <div class="level-up-pop inline-flex items-center justify-center w-full px-4 py-2.5 rounded-lg font-bold text-sm"
             style="background: transparent; color: var(--color-cta); border: 2px solid var(--color-cta);">
          <span>Free Entry Earned 🎟️</span>
        </div>
      </template>
    </div>
  </template>

  <%# Kickoff countdown — live "Kicks off in" timer to the contest's lock
      time (Contest#starts_at, the moment entries close and play begins).
      Only renders when kickoff_at is passed (a real entry on a contest
      page); skipped in the gallery preview where no contest is in scope.
      Reuses contests/_timestamp_countdown (no on_done_modal here — the
      contest page's own countdown owns the "It Begins" hand-off). %>
  <% if kickoff_at.present? %>
    <div class="flex justify-center mb-4">
      <%= render "contests/timestamp_countdown",
            target:        kickoff_at,
            label:         "Kicks off in",
            done_label:    "🟢 Contest underway",
            tone:          "yellow",
            wrapper_class: "" %>
    </div>
  <% end %>

  <%# Primary CTA — drain-overlay button + 5s auto-redirect, all
      managed by modals/blocks/_cta_redirect. When lobby_url_key
      resolves to null (gallery preview), the drain still plays but
      the timer-end redirect is a no-op so the iframe stays put. %>
  <%= render "modals/blocks/cta_redirect",
        href_key:   lobby_url_key,
        label_html: "Contest Lobby &#x2694;&#xFE0F;" %>

  <%# Subtle dismiss link — Success template's secondary pattern. %>
  <button @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Dismiss
  </button>
</div>

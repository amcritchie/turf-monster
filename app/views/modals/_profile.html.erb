<%#
  Profile modal — edit username + avatar after a new signup.
  Mounted by studio-engine's modal host as id 'profile'; the host
  owns the backdrop / scroll lock / escape / click-outside / ARIA /
  transitions. Trigger: $store.modals.open('profile').

  Auto-opens once after a new Phantom signup — see the
  localStorage 'show_profile_modal' flag set during the wallet
  verify path; the layout's alpine:init handler consumes the flag
  and opens this modal.

  Form state (saving / error) lives in this partial's own x-data
  because it doesn't need to outlive the modal. The form posts to
  save_profile_account_path; on success we close the modal and
  reload the page so the navbar avatar/name refresh.
%>
<div x-data="{
       saving: false,
       error: null,
       submit() {
         var self = this;
         self.saving = true;
         self.error = null;
         var form = document.getElementById('profile-modal-form');
         var formData = new FormData(form);
         var csrf = document.querySelector('meta[name=\'csrf-token\']')?.content || '';
         fetch('<%= save_profile_account_path %>', {
           method: 'POST',
           headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' },
           body: formData
         })
         .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
         .then(function(result) {
           if (result.ok && result.data.success) {
             $store.modals.close();
             window.location.reload();
           } else {
             self.error = result.data.error || 'Failed to save profile';
             self.saving = false;
           }
         })
         .catch(function(e) {
           self.error = e.message || 'Network error';
           self.saving = false;
         });
       }
     }">

  <div class="flex justify-end -mt-2 -mr-2 mb-2">
    <button @click="$store.modals.close()"
            class="text-secondary hover:text-heading text-xl leading-none">&times;</button>
  </div>

  <h3 class="text-heading font-bold text-lg mb-6">Edit Profile</h3>

  <template x-if="error">
    <p class="text-red-400 text-sm mb-4" x-text="error"></p>
  </template>

  <form id="profile-modal-form" @submit.prevent="submit()" class="space-y-5">
    <%= render "components/avatar_cropper", form_field_name: "user[avatar]" %>

    <button type="submit" class="btn btn-primary btn-lg w-full"
            :disabled="saving">
      <span x-show="!saving">Save Profile</span>
      <span x-show="saving" class="inline-flex items-center gap-2">
        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        Saving...
      </span>
    </button>
  </form>
</div>

<%#
  Update Banner modal — content partial for the shared modal host.
  Opened (admin only) from the contest hero's "Edit banner" button or the
  contest actions dropdown: Alpine.store('modals').open('contest-banner').
  Registered in layouts/application.html.erb's host block (admins on contest
  pages only — the partial references @contest).

  Flow: pick/drop an image -> frame it to the hero's wide aspect ratio with
  cropper.js (drag to move, scroll to zoom) -> Save crops to a Blob, drops it
  into the form's file input, and submits a multipart PATCH to
  banner_contest_path via Turbo. On success the server replaces #contest-hero
  (Turbo Stream) and the layout's turbo:submit-end listener closes this modal;
  a bad file returns 422 into #contest-banner-error and the modal stays open.
  cropper.js (the global Cropper bannerCropper relies on) is loaded by the
  layout for admin contest pages.

  Single root: mounts inside the host's <template x-if>, so the outer x-data
  div is the only top-level element here.
%>
<% has_banner = @contest.contest_image.attached? %>
<div x-data="bannerCropper({ aspectRatio: 3, outputWidth: 1500, outputHeight: 500 })">
  <h3 class="text-heading font-bold text-lg text-center mb-1">Update banner</h3>
  <p class="text-xs text-muted text-center mb-4">Frame your image to fit the hero for <%= @contest.name %>.</p>

  <%# Error slot — the update_banner stream targets this on a 422. %>
  <div id="contest-banner-error"></div>
  <template x-if="error">
    <p class="text-red-400 text-sm text-center mb-3" x-text="error"></p>
  </template>

  <%# Raw picker — feeds the cropper; not part of the submitted form. %>
  <input id="banner-image-picker" type="file" x-ref="picker" @change="pick($event)"
         accept="image/png,image/jpeg,image/webp" class="hidden">

  <%# State 1: dropzone (no image chosen yet). %>
  <template x-if="!imageUrl">
    <div @click="$refs.picker.click()"
         @dragover.prevent="dragging = true"
         @dragleave.prevent="dragging = false"
         @drop.prevent="drop($event)"
         :class="dragging ? 'border-primary bg-primary/10' : 'border-subtle hover:border-primary'"
         class="cursor-pointer border-2 border-dashed rounded-lg flex flex-col items-center justify-center text-center p-4 mb-4 transition"
         style="aspect-ratio: 3 / 1;">
      <svg class="w-8 h-8 text-muted mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.9 5 5 0 019.9-1A5.5 5.5 0 0118 16h-1m-6-4l3-3m0 0l3 3m-3-3v12"/>
      </svg>
      <p class="text-sm font-medium text-body">Drop an image or click to upload</p>
      <p class="text-xs text-muted mt-1"><%= has_banner ? "Replaces the current banner" : "PNG, JPG or WebP, up to 8 MB" %></p>
    </div>
  </template>

  <%# State 2: cropper (image chosen — drag to reposition within the frame). %>
  <template x-if="imageUrl">
    <div class="mb-3">
      <div class="rounded-lg overflow-hidden bg-black/30" style="max-height: 240px;">
        <img x-ref="cropImage" :src="imageUrl" alt="" class="block max-w-full" style="max-height: 240px;">
      </div>
      <div class="flex items-center justify-between mt-2">
        <p class="text-xs text-muted">Drag to reposition &middot; scroll to zoom</p>
        <button type="button" @click="$refs.picker.click()"
                class="text-xs text-secondary hover:text-heading underline underline-offset-2">Choose a different image</button>
      </div>
    </div>
  </template>

  <%= form_with model: @contest, url: banner_contest_path(@contest), method: :patch,
        html: { multipart: true, id: "contest-banner-form", "x-ref": "form" } do |f| %>
    <%= f.file_field :contest_image, class: "hidden", "x-ref": "fileInput" %>
    <div class="flex gap-3">
      <button type="button" @click="$store.modals.close()" class="btn btn-outline flex-1">Cancel</button>
      <button type="button" @click="save()"
              :disabled="!imageUrl || cropping"
              :class="(!imageUrl || cropping) ? 'opacity-60 cursor-not-allowed' : ''"
              class="btn btn-primary flex-1">
        <span x-show="!cropping">Save banner</span>
        <span x-show="cropping">Saving&hellip;</span>
      </button>
    </div>
  <% end %>

  <a href="<%= edit_contest_path(@contest) %>" data-turbo="false"
     class="block text-center mt-4 text-xs text-secondary hover:text-heading underline underline-offset-2">
    Edit name, tagline &amp; lock time&hellip;
  </a>
</div>

<%#
  Username modal — on-chain rename. Mounted by studio-engine's modal
  host as id 'username'; host owns backdrop / escape / ARIA.
  Trigger: $store.modals.open('username').

  Gating: renames are blocked until the user has confirmed at least
  one contest entry on-chain — User#can_change_username?. We branch
  at ERB render time (not Alpine-side) so the partial keeps a single
  root element, as required by template-x-if mounting.

  Flow lifted from the old inline Username card on accounts/show:
    1. POST update_username_account_path
       - custodial wallet → server co-signs, success: true → reload
       - phantom wallet   → needs_signature + serialized_tx + token
    2. Phantom signs the partial TX, broadcasts, then we
       POST confirm_username_account_path with the tx_signature
%>
<% if current_user.can_change_username? %>
  <%# usernameRenameForm() factory lives in app/javascript/username_rename_form.js.
      The shell partial (modals/blocks/_shell) provides the title row + close ×
      so we don't repeat that boilerplate. %>
  <div x-data="usernameRenameForm({
         initialUsername: '<%= j current_user.username %>',
         updateUrl: '<%= update_username_account_path %>',
         confirmUrl: '<%= confirm_username_account_path %>',
         initialSaving: (($store.modals.current() || {}).props || {}).previewLoading || false
       })">
    <%= render layout: "modals/blocks/shell", locals: { title: "Change Username" } do %>
      <p class="text-sm text-muted mb-4">
        Your username is stored on-chain.
        <%= current_user.phantom_wallet? ? "Saving opens your Phantom wallet to sign." : "Changes are saved via your managed wallet." %>
      </p>

      <template x-if="error">
        <p class="text-red-400 text-sm mb-3" x-text="error"></p>
      </template>

      <form @submit.prevent="save()" class="space-y-4">
        <input type="text" x-model="username" class="input-field w-full"
               placeholder="username" minlength="3" maxlength="30" pattern="[a-zA-Z0-9_-]+"
               title="3-30 characters — letters, numbers, hyphens, and underscores"
               autofocus>
        <button type="submit" class="btn btn-primary btn-lg w-full" :disabled="saving || !changed">
          <span x-show="!saving" x-text="changed ? 'Save' : 'Saved'">Save</span>
          <span x-show="saving" class="inline-flex items-center justify-center gap-2">
            <span class="cta-spinner" aria-hidden="true"></span>
            <span x-text="savingLabel">Saving…</span>
          </span>
        </button>
      </form>
    <% end %>
  </div>
<% else %>
  <%# Locked state — Success-template spine via card_header :lg + :error
      icon. CTA targets the admin-set main contest (via SeasonConfig.main_contest,
      which falls back to most-recent open) so the click lands somewhere
      actionable; root_path would work too but adds a redirect hop.
      block_given? trap is dodged by passing subtitle explicitly. %>
  <% locked_target = SeasonConfig.main_contest %>
  <div x-data="{}">
    <%= render 'modals/blocks/card_header',
          size: :lg,
          icon: :error,
          title: "Enter Contest First",
          subtitle: "Your username is locked until you've played at least one contest. Submit an entry and the rename is unlocked for good." %>

    <%= link_to (locked_target ? "Enter #{locked_target.name}" : "Browse Contests"),
                (locked_target ? contest_path(locked_target) : contests_path),
                class: "btn btn-primary btn-lg w-full",
                "@click": "$store.modals.close()" %>
    <button @click="$store.modals.close()"
            class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
      Dismiss
    </button>
  </div>
<% end %>

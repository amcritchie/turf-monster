<%# unsubscribe-goodbye — the final beat after a confirmed unsubscribe.
    Trigger: $store.modals.swap('unsubscribe-goodbye'). Just an acknowledgement +
    a Close link. SINGLE root. %>
<div x-data="{}">
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_emoji: "✌️",
        title: "See you later",
        subtitle: "You're off the list. Change your mind anytime from your account." %>

  <button type="button" @click="$store.modals.close()" class="btn btn-primary btn-lg w-full">
    Close
  </button>
</div>

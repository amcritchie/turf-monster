<%#
  On-chain transaction modal — replaces shared/_solana_modal.html.erb.
  Rendered inside studio-engine's modal host as modal id 'onchain-tx';
  the host owns the backdrop / scroll lock / escape / aria / transitions.

  Reads display state from $store.solanaModal (kept as the source of
  truth so the existing 59 caller sites' API — show/success/error/close,
  direct field reads like .visible / .txSignature / .seedsEarned, the
  .onClose callback, .setRecovery() — all keep working unchanged).
  The store's methods ALSO push/pop the modal stack so the host shell
  renders this partial when the store opens.

  Visual idiom stays Solana-canonical (large title, branded tx-link,
  Contest Lobby drain CTA, seeds bar + level-up celebration). The
  generic _processing_card and _error_card engine blocks cover the
  non-Solana-specific states; the rich success state stays inline
  here because the Solana mark + lobby drain + seeds animation are
  turf-specific. Promoting them to the engine is step F.

  Single root: this partial's content lives inside one <div> so
  Alpine's <template x-if> clones it whole (see
  [[feedback_alpine_template_single_root]]).
%>
<div x-data="{
       init() {
         var self = this;
         // Confetti when the state flips to success — same trigger as
         // before, just rewired to watch the store from inside the
         // host-mounted content.
         this.$watch('$store.solanaModal.state', function(val) {
           // Confetti is gated on the .confetti flag: the entry variant
           // defaults it on (unchanged), the generic variant defaults it
           // off and opts.confetti:true turns it back on. (The entry card
           // also fires its own confetti in init; this watcher is the
           // ONLY confetti source for the generic card.)
           if (val === 'success' && $store.solanaModal.confetti) {
             setTimeout(function() {
               try { if (window.fireSuccessConfetti) window.fireSuccessConfetti(); } catch (_) {}
             }, 100);
           }
         });
       }
     }">

  <%# === PROCESSING ========================================================
      Pending Phantom signature, pending RPC confirmation, etc. Status-
      template shape via card_header (spinner + small title) — same
      structural family as the auth-modal tokens-confirming step so
      both on-chain wait states read identically. %>
  <template x-if="$store.solanaModal.state === 'processing'">
    <%= render 'modals/blocks/card_header',
          spinner: true,
          title_key:    "$store.solanaModal.title",
          subtitle_key: "$store.solanaModal.message" %>
  </template>

  <%# === SUCCESS (entry) ===================================================
      Contest-entry celebration — the default success variant. Both web2
      (entry-token-funded) and web3 (on-chain) entry success render this
      same semantic 'entry confirmed' card. Seeds bar + level-up
      celebration mount automatically when seeds were awarded.

      Gated to variant !== 'generic' so the ~59 existing success()
      callers (which never set a variant) keep the entry card unchanged. %>
  <template x-if="$store.solanaModal.state === 'success' && $store.solanaModal.successVariant !== 'generic'">
    <%# lobby_url_key passed straight (no || fallback) — cta_redirect
        treats null as "skip the auto-redirect, keep the drain visual"
        so a missing lobbyUrl stays visible in the gallery and degrades
        gracefully in prod instead of bouncing to '#'. %>
    <%= render 'modals/blocks/entry_confirmed',
        tx_signature_key: "$store.solanaModal.txSignature",
        lobby_url_key:    "$store.solanaModal.lobbyUrl",
        seeds_earned_key: "$store.solanaModal.seedsEarned",
        seeds_total_key:  "$store.solanaModal.seedsTotal" %>
  </template>

  <%# === SUCCESS (generic) =================================================
      Fallback success state for any on-chain TX that isn't a contest
      entry (faucet mint, contest creation, username change, …). Copy +
      CTA are caller-supplied via success(tx, msg, { variant: 'generic',
      title, subtitle, ctaLabel, ctaHref }). No seeds bar, no lobby
      auto-redirect drain. %>
  <template x-if="$store.solanaModal.state === 'success' && $store.solanaModal.successVariant === 'generic'">
    <%= render 'modals/blocks/onchain_success',
        tx_signature_key: "$store.solanaModal.txSignature",
        title_key:        "$store.solanaModal.successTitle",
        subtitle_key:     "$store.solanaModal.successSubtitle",
        cta_label_key:    "$store.solanaModal.ctaLabel",
        cta_href_key:     "$store.solanaModal.ctaHref" %>
  </template>

  <%# === ERROR =============================================================
      Status-template shape via card_header :error + primary CTA. The
      Phantom-branded recovery button stays inline because "Phantom-
      branded recovery" is Solana-specific — same gap-3 / image-pair
      pattern as the auth modal's Phantom Connect button. Subtitle uses
      subtitle_key so the live errorMessage surfaces unchanged. %>
  <template x-if="$store.solanaModal.state === 'error'">
    <div>
      <%= render 'modals/blocks/card_header',
            icon: :error,
            title_key:    "$store.solanaModal.title",
            subtitle_key: "$store.solanaModal.errorMessage" %>
      <template x-if="$store.solanaModal.recoveryLabel && $store.solanaModal.recoveryPhantom">
        <button @click="$store.solanaModal._triggerRecovery()"
                class="btn btn-secondary btn-lg w-full gap-3">
          <img src="/phantom-white.png" alt="Phantom" class="w-5 h-5">
          <span x-text="$store.solanaModal.recoveryLabel"></span>
        </button>
      </template>
      <template x-if="$store.solanaModal.recoveryLabel && !$store.solanaModal.recoveryPhantom">
        <button @click="$store.solanaModal._triggerRecovery()"
                x-text="$store.solanaModal.recoveryLabel"
                class="btn btn-primary btn-lg w-full"></button>
      </template>
      <button @click="$store.solanaModal.close()"
              class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
        Close
      </button>
    </div>
  </template>
</div>

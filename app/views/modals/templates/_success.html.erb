<%# === Template: SUCCESS modal ====================================== %>
<%# Large-title celebration for end states — entry confirmed, tokens %>
<%# minted, action completed. Card_header at :lg size gives a text-3xl %>
<%# title that dominates the modal; the primary CTA pulls the user    %>
<%# forward to whatever's next (lobby, contest, account).             %>
<%#                                                                   %>
<%# When the success warrants a SOLANA tx link, auto-redirect          %>
<%# countdown, or seeds-bar level-up celebration, drop this template  %>
<%# and use modals/blocks/_entry_confirmed.html.erb instead — that    %>
<%# composes studio-engine's _success_card with all the celebratory   %>
<%# extras. This template is the bare-bones celebration card.         %>
<%#                                                                   %>
<%# For in-flight / waiting states, use modals/templates/_status.html.erb %>
<%# — small title, spinner, no celebration.                            %>
<%#                                                                   %>
<%# Trigger: $store.modals.open('template-success').                  %>

<div x-data>
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_color: 'primary',
        title: "Done!",
        subtitle: "Operation completed. Swap in the real success copy + CTA destination." %>

  <%# Single primary CTA pulling the user forward + a subtle dismiss
      link so the success isn't a forced redirect. %>
  <button @click="$store.modals.close()" class="btn btn-primary btn-lg w-full">
    Continue
  </button>
  <button @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Dismiss
  </button>
</div>

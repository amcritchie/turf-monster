<%# === Template: WIZARD modal ====================================== %>
<%# Multi-step flow with a segmented progress pill + centered header. %>
<%# Use for onboarding flows, checkout journeys, anything that       %>
<%# breaks into 2-4 discrete screens.                                %>
<%#                                                                  %>
<%# Visual identity (intentionally distinct from form/action/status): %>
<%#   - Title is CENTERED above the progress pill — reads as "you're %>
<%#     on a journey" not "here's a form".                            %>
<%#   - Progress pill is N segments (one per step). Filled segments  %>
<%#     are primary; upcoming are inset+subtle. Animated transition  %>
<%#     fills the next segment when step advances.                   %>
<%#   - Single primary CTA (Next / Finish) — wizards should always   %>
<%#     pull the user forward. Back is a subtle text link so it      %>
<%#     never competes with the forward motion. Hidden on step 1.    %>
<%#                                                                  %>
<%# Skips the shell partial because the centered title + manual      %>
<%# close × layout doesn't fit shell's left-aligned title row.       %>
<%#                                                                  %>
<%# For complex wizards that resume from external callbacks (auth +  %>
<%# Stripe), promote `step` and `total` onto                          %>
<%# $store.modals.current().props so the modal can be re-opened at   %>
<%# a specific step without losing position.                         %>
<%#                                                                  %>
<%# Trigger: $store.modals.open('template-wizard').                  %>

<div x-data="{ step: 1, total: 3 }">
  <%# Header row — title centered on the same baseline as the close ×.
      Absolute-positioned × lets the title sit dead-center even though
      the × is fixed top-right. Pulled negative-margin up so the title
      aligns with the × visually. %>
  <div class="relative mb-3 -mt-2">
    <h3 class="text-heading font-bold text-lg leading-tight text-center pt-1">Wizard Template</h3>
    <button type="button" @click="$store.modals.close()"
            class="absolute top-0 right-0 -mr-2 text-secondary hover:text-heading text-xl leading-none"
            aria-label="Close">&times;</button>
  </div>

  <%# Segmented progress pill — one segment per step, fills primary
      as you advance. The shared block partial is static-ERB so it
      doesn't fit Alpine's reactive `step` here; use the inline
      x-for version while the demo's step counter lives in local
      x-data. Real wizards driven by props can use the shared
      modals/blocks/progress_pill partial directly. %>
  <div class="flex items-center justify-center gap-1.5 mx-auto max-w-[200px] mb-6">
    <template x-for="i in total" :key="i">
      <div class="h-1.5 flex-1 rounded-full transition-colors duration-300"
           :class="step >= i ? 'bg-primary' : 'bg-inset border border-subtle'"></div>
    </template>
  </div>

  <%# Step bodies — one x-if block per step. min-h keeps the modal
      height stable as you advance so the layout doesn't jump. %>
  <template x-if="step === 1">
    <div class="text-center space-y-3 min-h-[120px]">
      <h4 class="text-heading font-semibold text-base">Welcome</h4>
      <p class="text-sm text-secondary">
        First step — collect any prerequisites or intro context here. Replace this
        block with whatever your wizard's opening screen needs.
      </p>
    </div>
  </template>

  <template x-if="step === 2">
    <div class="text-center space-y-3 min-h-[120px]">
      <h4 class="text-heading font-semibold text-base">Configure</h4>
      <p class="text-sm text-secondary">
        Middle step(s) — forms, selections, anything that needs user input. Each step
        gets its own <code class="text-xs bg-inset px-1 rounded">&lt;template x-if&gt;</code> block.
      </p>
    </div>
  </template>

  <template x-if="step === 3">
    <div class="text-center space-y-3 min-h-[120px]">
      <h4 class="text-heading font-semibold text-base">Confirm</h4>
      <p class="text-sm text-secondary">
        Final step — show the summary + primary commit action. The Finish button
        below typically calls your real submit handler then $store.modals.close().
      </p>
    </div>
  </template>

  <%# Nav — single primary CTA pulling forward; Back and Close as
      subtle links below. Back is hidden on step 1 so the only action
      is forward. Close is always visible — gives a redundant escape
      hatch within thumb reach (the top-right × is the primary close
      but easy to miss on a multi-step modal). %>
  <button type="button"
          @click="step < total ? step++ : $store.modals.close()"
          class="btn btn-primary btn-lg w-full mt-2"
          x-text="step === total ? 'Finish' : 'Next'"></button>
  <button type="button"
          x-show="step > 1"
          @click="step--"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    &larr; Back
  </button>
  <button type="button"
          @click="$store.modals.close()"
          class="block mx-auto mt-2 text-xs text-muted hover:text-heading transition">
    Close
  </button>
</div>

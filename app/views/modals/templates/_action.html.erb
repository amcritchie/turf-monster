<%# === Template: ACTION modal ====================================== %>
<%# One-question dialog: centered icon pill + title + subtitle +     %>
<%# primary/secondary CTAs. Use for confirmations, alerts, "are you  %>
<%# sure?" prompts. Composes the shared card_header for the top      %>
<%# chunk so icon/title/subtitle stay aligned with success +         %>
<%# celebration modals across the app.                               %>
<%#                                                                  %>
<%# Variants: pass icon :error / :external_tab / icon_emoji / spinner %>
<%# OR icon_color :primary / :mint / :success / :warning to          %>
<%# card_header — see the partial's docblock for the full menu.      %>
<%#                                                                  %>
<%# Trigger: $store.modals.open('template-action').                  %>

<div x-data>
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon: :error,
        title: "Action Template",
        subtitle: "A centered confirmation card with a primary + secondary CTA. Best for one-question dialogs and destructive prompts." %>

  <%# Single primary CTA + secondary action as a subtle text link so
      there's never any ambiguity about which button is the main one. %>
  <button @click="$store.modals.close()" class="btn btn-danger btn-lg w-full">
    Confirm Action
  </button>
  <button @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Cancel
  </button>
</div>

<%# === Template: STATUS modal ====================================== %>
<%# Small-title in-flight card for short async work — server save,    %>
<%# poll, side-effect that finishes in a second or two. Card_header  %>
<%# uses its default :md size so the title stays subordinate to the  %>
<%# spinner; the modal doesn't try to celebrate, it just stands       %>
<%# guard until the operation resolves. Pair with a Cancel link if   %>
<%# the user should be able to bail out mid-flight.                  %>
<%#                                                                  %>
<%# For end-state celebrations (entry confirmed, tokens minted)      %>
<%# use modals/templates/_success.html.erb — that one's text-3xl,    %>
<%# primary CTA, designed to dominate the screen on completion.     %>
<%#                                                                  %>
<%# Demo cycles loading → error at 1.6s so a viewer can step through %>
<%# both states; click Try Again to reset to loading.               %>
<%#                                                                  %>
<%# Trigger: $store.modals.open('template-status').                  %>

<div x-data="{
       state: 'loading',
       start() {
         this.state = 'loading';
         var self = this;
         setTimeout(function() { self.state = 'error'; }, 1600);
       }
     }"
     x-init="start()">
  <%# Loading state — small spinner + small title. The default size :md
      keeps the card compact; this is a holding screen, not a celebration. %>
  <template x-if="state === 'loading'">
    <div>
      <%= render "modals/blocks/card_header",
            spinner: true,
            title: "Working on it…",
            subtitle: "Status template — small-title in-flight card for short async work." %>
      <button @click="$store.modals.close()"
              class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
        Cancel
      </button>
    </div>
  </template>

  <%# Error state — same compact footprint, red X pill. Real callers
      surface the actual error message in the subtitle and wire Try Again
      to re-run the failed op. %>
  <template x-if="state === 'error'">
    <div>
      <%= render "modals/blocks/card_header",
            icon: :error,
            title: "Something went wrong",
            subtitle: "Surface the real error message here. Try Again should re-run the failed op." %>
      <button @click="start()" class="btn btn-primary btn-lg w-full">Try Again</button>
      <button @click="$store.modals.close()"
              class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
        Cancel
      </button>
    </div>
  </template>
</div>

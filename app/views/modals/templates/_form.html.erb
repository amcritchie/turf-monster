<%# === Template: FORM modal ====================================== %>
<%# Use as the starting point for any modal that captures input —    %>
<%# settings, edit forms, rename dialogs. Wraps content in the       %>
<%# shared shell so you get a consistent title row + close × for     %>
<%# free; the body slot is whatever your form needs.                 %>
<%#                                                                  %>
<%# Trigger: $store.modals.open('template-form').                    %>
<%# Single root: the outer x-data div is the host's required root.   %>

<div x-data="{ value: '' }">
  <%= render layout: "modals/blocks/shell", locals: { title: "Form Template" } do %>
    <p class="text-sm text-muted mb-4">
      Title row + close × come from <code class="text-xs bg-inset px-1 rounded">modals/blocks/shell</code>.
      Slot in whatever inputs + primary CTA your form needs.
    </p>

    <form @submit.prevent="$store.modals.close()" class="space-y-4">
      <textarea x-model="value"
                rows="3"
                placeholder="Type something…"
                class="input-field w-full resize-none"></textarea>
      <button type="submit" class="btn btn-primary btn-lg w-full" :disabled="!value.trim()">
        Save
      </button>
    </form>
  <% end %>
</div>

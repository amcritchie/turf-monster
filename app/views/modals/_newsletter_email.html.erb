<%# Web3 email-capture modal — opened by the questNewsletter factory via
    $store.modals.open('newsletter-email', { onSubmit: fn }). Captures the email
    (web3 users have none on file), closes itself, then hands the address back to
    onSubmit, which POSTs the subscribe. Single root (the host mounts this through
    its own template x-if); props reader + submit defined inline, no factory. %>
<div x-data="{
       email: '',
       get props() { return ($store.modals.current() || {}).props || {} },
       submit() {
         var em = (this.email || '').trim();
         if (em.indexOf('@') < 1) return;
         var cb = this.props.onSubmit;
         $store.modals.close();
         if (cb) cb(em);
       }
     }">
  <%= render 'modals/blocks/card_header', size: :md, icon_emoji: '📬', title: 'One more thing' do %>
    Drop your email to join the list and claim your 40 seeds. We only use it for the newsletter.
  <% end %>
  <div class="px-5 pb-5">
    <input type="email" x-model="email" @keydown.enter.prevent="submit()"
           placeholder="you@example.com" autocomplete="email"
           class="w-full bg-inset border border-subtle rounded-lg px-3 py-2 text-sm text-heading mb-3 focus:border-primary/50 focus:outline-none">
    <button type="button" @click="submit()" class="btn btn-primary w-full">Join &amp; Claim 40 Seeds</button>
  </div>
</div>

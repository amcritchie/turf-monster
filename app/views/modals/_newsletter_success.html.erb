<%# newsletter-success — celebration after a newsletter join (via the subscribe
    modal swap, or the /account newsletter card). Title is fixed "Subscribed!";
    the seeds progress bar shows the freshly-earned +25 on a first-ever join (a
    re-subscribe earns nothing, so the bar just reflects the current total). CTA
    sends the user to browse contests. Bottom Close link. SINGLE root. %>
<div x-data="{ get props() { return ($store.modals.current() || {}).props || {} } }">
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon_emoji: "🌱",
        title: "Subscribed!",
        subtitle: "You're on the list. We'll keep the sports news and contest updates coming." %>

  <%# Seeds progress bar — ONLY on a first-ever join (seeds_earned > 0 in props).
      A re-subscribe earns nothing, so the bar is hidden rather than showing a
      flat "0 seeds". SINGLE root inside the template; self-heals from the
      seedsNavbar localStorage StateFanout just bumped. %>
  <template x-if="(props.seeds_earned || 0) > 0">
    <div class="mb-5">
      <%= render "components/seeds_bar", seeds_data: display_seeds_data, compact: false %>
    </div>
  </template>

  <%# Smart CTA: if the username quest is still available (entered a contest +
      username not yet changed → next_quest is :username), nudge straight into
      it; otherwise send the user off to browse contests. %>
  <% if current_user.next_quest == :username %>
    <button type="button" @click="$store.modals.swap('username')"
            class="btn btn-primary btn-lg w-full">
      Next Quest
    </button>
  <% else %>
    <%= link_to "Check Out Contests", contests_path,
                class: "btn btn-primary btn-lg w-full", "@click": "$store.modals.close()" %>
  <% end %>

  <button type="button" @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Close
  </button>
</div>

<%# Newsletter welcome modal — opened by questNewsletterSuccess after a join
    lands. Celebrates the 40 seeds (props.seeds), then the cta_redirect drains
    and closes; questNewsletterSuccess reloads the page a beat later, advancing
    the quest to mission 3 (invite). Single root; props reader inline. %>
<div x-data="{ get props() { return ($store.modals.current() || {}).props || {} } }">
  <%= render 'modals/blocks/card_header', size: :lg, icon_emoji: '🌱', title: "You're on the list!" do %>
    <span class="block mt-1">Welcome to the Turf Monster newsletter.</span>
    <span class="block mt-2 text-secondary text-sm" x-show="props.seeds" x-cloak>
      +<span x-text="props.seeds"></span> seeds just landed in your wallet.
    </span>
  <% end %>
  <%= render 'modals/blocks/cta_redirect',
        href_key:         "props.next",
        label_html:       "Nice &rarr;",
        duration_seconds: 4 %>
</div>

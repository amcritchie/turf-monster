<%# unsubscribe-confirm — confirm leaving the newsletter. Opened from the
    /account newsletter card ("Unsubscribe"). POSTs newsletter_unsubscribe_path;
    on success swaps to the unsubscribe-goodbye beat. The bottom Close link is the
    "never mind, keep me subscribed" out. SINGLE root; x-data double-quoted so
    everything inside is single-quoted. %>
<div x-data="{
       saving: false,
       error: null,
       url: '<%= newsletter_unsubscribe_path %>',
       async unsubscribe() {
         if (this.saving) return;
         this.saving = true;
         this.error = null;
         try {
           var csrf = (document.querySelector('meta[name=csrf-token]') || {}).content || '';
           var fetcher = window.authedFetch || window.fetch;
           var resp = await fetcher(this.url, {
             method: 'POST',
             headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf, 'Accept': 'application/json' }
           });
           if (!resp) { this.saving = false; return; }
           var data = await resp.json();
           if (!data.success) throw new Error(data.error || 'Could not unsubscribe.');
           try { window.dispatchEvent(new CustomEvent('newsletter-state-changed', { detail: { subscribed: false } })); } catch (e) {}
           this.$store.modals.swap('unsubscribe-goodbye');
         } catch (e) {
           this.error = (e && e.message) || 'Could not unsubscribe.';
           this.saving = false;
         }
       }
     }">
  <%= render "modals/blocks/card_header",
        size: :lg,
        icon: :error,
        title: "Unsubscribe?",
        subtitle: "Are you sure? You'll stop getting sports news and contest updates." %>

  <p x-show="error" x-cloak x-text="error" class="text-xs mb-3 text-center" style="color:#f87171"></p>

  <button type="button" @click="unsubscribe()" :disabled="saving"
          class="btn btn-danger btn-lg w-full disabled:opacity-50 disabled:cursor-not-allowed">
    <span x-show="!saving">Unsubscribe</span>
    <span x-show="saving" x-cloak>Unsubscribing…</span>
  </button>

  <button type="button" @click="$store.modals.close()"
          class="block mx-auto mt-3 text-sm text-secondary hover:text-heading transition">
    Close
  </button>
</div>

<% content_for :title, "Slate — #{@slate.name}" %>

<style>
  :root {
    --fc-mult: #8E82FE;
    --fc-goals: #B8B0FF;
    --fc-dk-score: #15803D;
    --fc-dk-total: #4BAF50;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
  // Formula curve line colors — single source of truth
  var FC = {
    mult:    '#8E82FE',            // Turf Score (violet)
    goals:   '#B8B0FF',            // Goals Distribution (light violet)
    dkTotal: '#4BAF50'             // DK Expectation (green)
  };

  <%# Charted per TEAM, not per matchup row — a three-week slate would otherwise
      plot 96 points for 32 teams and rank each team three times. team_total is
      the SUM across the team's games, which is what the curve is fitted on. %>
  var _fcMatchups = <%== @team_rows.map { |row|
    {
      rank: row.rank,
      emoji: row.team.emoji,
      team: row.team.name,
      short: row.team.short_name,
      opponent: row.matchups.filter_map { |m| m.opponent_team&.short_name }.join(" / "),
      turf_score: row.turf_score&.to_f,
      team_total: row.expected_points
    }
  }.to_json %>;

  var _fcChart = null;

  // Sport-aware multiplier curve, base PINNED at 1.0 (rank 1 always x1.0).
  // fifa: log decay; nfl: linear (points run nearly linear by rank).
  // Ruby mirror: SlateMatchup.turf_score_for.
  var FC_SPORT = '<%= @slate.sport %>';
  function _fcMult(rank, N, multScale) {
    if (N <= 1) return 1.0;
    var curve = FC_SPORT === 'nfl' ? (rank - 1) / (N - 1) : Math.log(rank) / Math.log(N);
    return 1.0 + multScale * curve;
  }

  function _fcCompute(A, lineExp, probExp, multBase, multScale, goalBase, goalScale) {
    var N = _fcMatchups.length;
    var lnN = Math.log(N);
    return _fcMatchups.map(function(m, i) {
      var rank = i + 1;
      return {
        emoji: m.emoji, team: m.team, opponent: m.opponent, rank: rank,
        mult: Math.round(_fcMult(rank, N, multScale) * 100) / 100,
        goals: Math.round((goalBase + goalScale * Math.log(N / rank) / lnN) * 100) / 100,
        teamTotal: m.team_total
      };
    });
  }

  // NFL axis windows: shrink the DK axis to the data (visual fidelity), then
  // derive the reversed Turf window LINEARLY from it so turf 1.0 maps to the
  // same pixel as the DK maximum — both lines leave the same point, and the
  // x2 top lands on the DK minimum's pixel. Returns null when the mapping is
  // undefined (no DK data, or a flat DK line) — callers fall back to static
  // windows.
  function _fcNflAxisWindows(data, multScale) {
    if (FC_SPORT !== 'nfl') return null;
    var dkVals = data.map(function(d) { return d.teamTotal; }).filter(function(v) { return v !== null && v !== undefined; });
    if (dkVals.length < 2) return null;
    var dkMax = Math.max.apply(null, dkVals);
    var dkMin = Math.min.apply(null, dkVals);
    if (dkMax === dkMin) return null;
    // ~one extra deviation of margin: the lines float inside the window
    // (e.g. 50-85 / 0.8-2.2 on a 54-81 spread) instead of touching its edges.
    var pad = Math.max(2, (dkMax - dkMin) * 0.13);
    var y2Min = Math.floor(dkMin - pad);
    var y2Max = Math.ceil(dkMax + pad);
    var tMin = 1 - multScale * (y2Max - dkMax) / (dkMax - dkMin);
    var tMax = tMin + multScale * (y2Max - y2Min) / (dkMax - dkMin);
    return { y2Min: y2Min, y2Max: y2Max, tMin: tMin, tMax: tMax };
  }

  function _fcBuildChart(data) {
    var canvas = document.getElementById('formulaCurvesChart');
    if (!canvas) return;
    var existing = Chart.getChart(canvas);
    if (existing) existing.destroy();
    var windows = _fcNflAxisWindows(data, _fcSliders.multScale);

    var isDark = document.documentElement.classList.contains('dark');
    var gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
    var textColor = isDark ? 'rgba(255,255,255,0.5)' : 'rgba(0,0,0,0.5)';

    var datasets = [
      {
        label: 'Turf Score',
        data: data.map(function(d) { return d.mult; }),
        borderColor: FC.mult,
        backgroundColor: FC.mult + '14',
        borderWidth: 2.5, pointRadius: 2, pointHoverRadius: 6, tension: 0.3, fill: false, yAxisID: 'y', order: 1
      }
    ];
    // Goals are a soccer concept — on NFL slates the series is noise.
    if (FC_SPORT !== 'nfl') {
      datasets.push({
        label: 'Goals Distribution',
        data: data.map(function(d) { return d.goals; }),
        borderColor: FC.goals,
        backgroundColor: FC.goals + '14',
        borderWidth: 2, borderDash: [6, 3], pointRadius: 2, pointHoverRadius: 6, tension: 0.3, fill: false, yAxisID: 'y', order: 2
      });
    }
    datasets.push({
      label: 'DK Expectation',
      data: data.map(function(d) { return d.teamTotal; }),
      borderColor: FC.dkTotal,
      backgroundColor: FC.dkTotal + '14',
      borderWidth: 1.5, borderDash: [6, 3], pointRadius: 2, pointHoverRadius: 6, tension: 0.3, fill: false, yAxisID: 'y2', spanGaps: true, order: 3
    });

    _fcChart = new Chart(canvas, {
      type: 'line',
      data: {
        labels: data.map(function(d) { return d.emoji; }),
        datasets: datasets
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: textColor, font: { size: 11 }, usePointStyle: true, pointStyle: 'line' } },
          tooltip: {
            backgroundColor: isDark ? 'rgba(20,18,40,0.95)' : 'rgba(255,255,255,0.95)',
            titleColor: isDark ? '#fff' : '#111',
            bodyColor: isDark ? 'rgba(255,255,255,0.8)' : 'rgba(0,0,0,0.7)',
            borderColor: isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)',
            borderWidth: 1, padding: 12, displayColors: true,
            callbacks: {
              title: function(items) {
                var d = _fcLastData[items[0].dataIndex];
                return d.emoji + ' ' + d.team + ' vs ' + (d.opponent || '—');
              },
              afterTitle: function(items) {
                var d = _fcLastData[items[0].dataIndex];
                return 'Rank #' + d.rank + '  ·  Turf Score x' + d.mult.toFixed(1);
              },
              label: function(ctx) {
                var val = ctx.parsed.y;
                if (val === null || val === undefined) return null;
                return '  ' + ctx.dataset.label + ': ' + val.toFixed(2);
              }
            }
          }
        },
        scales: {
          x: { ticks: { color: textColor, font: { size: 14 }, maxRotation: 0, minRotation: 0, autoSkip: true, maxTicksLimit: 48 }, grid: { color: gridColor } },
          // DK Total owns the LEFT axis and auto-scales to the data — an NFL
          // span slate reads ~0-85 while a World Cup goals slate reads ~0-5.
          // The old config bound DK Expectation to the 0-5 Turf axis, drawing
          // an 81-point total off-chart while a hardcoded 0-5 "DK Total" axis
          // mirrored uselessly on the right. Axis text wears the series green
          // so the accurate scale reads as the green line's.
          y2: windows
            ? { position: 'left', title: { display: true, text: 'DK Total', color: FC.dkTotal, font: { size: 11 } }, ticks: { color: FC.dkTotal }, grid: { drawOnChartArea: false }, min: windows.y2Min, max: windows.y2Max }
            : { position: 'left', title: { display: true, text: 'DK Total', color: FC.dkTotal, font: { size: 11 } }, ticks: { color: FC.dkTotal }, grid: { drawOnChartArea: false }, beginAtZero: true },
          // NFL: reversed so x1.0 sits at the TOP — the Turf line then falls
          // with rank alongside the DK Expectation line instead of crossing it,
          // and the window derived by _fcNflAxisWindows anchors turf 1.0 to the
          // DK maximum's pixel so both lines leave the same point.
          y: windows
            ? { position: 'right', reverse: true, title: { display: true, text: 'Turf Score', color: textColor, font: { size: 11 } }, ticks: { color: textColor }, grid: { color: gridColor }, min: windows.tMin, max: windows.tMax }
            : { position: 'right', reverse: FC_SPORT === 'nfl', title: { display: true, text: 'Turf Score', color: textColor, font: { size: 11 } }, ticks: { color: textColor }, grid: { color: gridColor }, min: 0, max: 5 }
        }
      }
    });
  }

  var _fcLastData = [];

  // Store current slider values for rankManager to use after drag
  // Initialize from DB-resolved formula (slate → default slate → hardcoded)
  var _fcDefaults = <%== @slate.resolved_formula.to_json %>;
  var _fcSliders = {
    A: _fcDefaults.formula_a,
    lineExp: _fcDefaults.formula_line_exp,
    probExp: _fcDefaults.formula_prob_exp,
    multBase: _fcDefaults.formula_mult_base,
    multScale: _fcDefaults.formula_mult_scale,
    goalBase: _fcDefaults.formula_goal_base,
    goalScale: _fcDefaults.formula_goal_scale
  };

  function _fcUpdate(A, lineExp, probExp, multBase, multScale, goalBase, goalScale) {
    _fcSliders = { A: A, lineExp: lineExp, probExp: probExp, multBase: multBase, multScale: multScale, goalBase: goalBase, goalScale: goalScale };
    var data = _fcCompute(A, lineExp, probExp, multBase, multScale, goalBase, goalScale);
    _fcLastData = data;
    if (!_fcChart) { _fcBuildChart(data); return; }
    // Label-keyed: NFL charts carry no Goals Distribution dataset, so index
    // positions are not stable across sports.
    _fcChart.data.datasets.forEach(function(ds) {
      if (ds.label === 'Turf Score') ds.data = data.map(function(d) { return d.mult; });
      else if (ds.label === 'Goals Distribution') ds.data = data.map(function(d) { return d.goals; });
      else if (ds.label === 'DK Expectation') ds.data = data.map(function(d) { return d.teamTotal; });
    });
    // A scale change moves the turf window's bottom anchor (top stays pinned
    // to the DK maximum), so the NFL axis windows recompute on every update.
    var windows = _fcNflAxisWindows(data, multScale);
    if (windows) {
      _fcChart.options.scales.y.min = windows.tMin;
      _fcChart.options.scales.y.max = windows.tMax;
      _fcChart.options.scales.y2.min = windows.y2Min;
      _fcChart.options.scales.y2.max = windows.y2Max;
    }
    _fcChart.update('none');
    _fcUpdateRankList(A, lineExp, probExp, multBase, multScale);
  }

  // Reorder _fcMatchups to match current DOM order, then refresh chart
  function _fcSyncOrder() {
    var items = document.querySelectorAll('.sortable-item');
    var byId = {};
    _fcMatchups.forEach(function(m) { byId[m.emoji + m.team] = m; });
    var reordered = [];
    items.forEach(function(item) {
      var emoji = item.querySelector('.text-lg').textContent.trim();
      var name = item.querySelector('.text-heading').textContent.trim();
      var match = byId[emoji + name];
      if (match) reordered.push(match);
    });
    if (reordered.length === _fcMatchups.length) _fcMatchups = reordered;
    // Trigger chart refresh using current slider values
    _fcUpdate(_fcSliders.A, _fcSliders.lineExp, _fcSliders.probExp, _fcSliders.multBase, _fcSliders.multScale, _fcSliders.goalBase, _fcSliders.goalScale);
  }

  function _fcUpdateRankList(A, lineExp, probExp, multBase, multScale) {
    var items = document.querySelectorAll('.sortable-item');
    var N = items.length;
    var lnN = Math.log(N);
    items.forEach(function(item, i) {
      var rank = i + 1;
      var line = parseFloat(item.dataset.teamTotal);
      var mult = _fcMult(rank, N, multScale);
      item.querySelector('.turf-score-display').textContent = mult.toFixed(1) + 'x';
    });
  }

  // Alpine component — register on alpine:init (deferred Alpine hasn't loaded yet)
  function _fcRegisterAlpine() {
    Alpine.data('formulaCurves', function() {
      return {
        A: _fcSliders.A, lineExp: _fcSliders.lineExp, probExp: _fcSliders.probExp,
        multBase: _fcSliders.multBase, multScale: _fcSliders.multScale,
        goalBase: _fcSliders.goalBase, goalScale: _fcSliders.goalScale,
        refresh() {
          _fcUpdate(this.A, this.lineExp, this.probExp, this.multBase, this.multScale, this.goalBase, this.goalScale);
        },
        init() {
          _fcChart = null;
          _fcLastData = _fcCompute(this.A, this.lineExp, this.probExp, this.multBase, this.multScale, this.goalBase, this.goalScale);
          _fcBuildChart(_fcLastData);
        }
      };
    });
  }

  // Initial load: Alpine hasn't loaded yet (defer), register via alpine:init
  document.addEventListener('alpine:init', _fcRegisterAlpine);

  // Turbo navigation: Alpine is already loaded, register immediately + build chart
  if (typeof Alpine !== 'undefined') {
    _fcRegisterAlpine();
    _fcChart = null;
    _fcLastData = _fcCompute(_fcSliders.A, _fcSliders.lineExp, _fcSliders.probExp, _fcSliders.multBase, _fcSliders.multScale, _fcSliders.goalBase, _fcSliders.goalScale);
    // Build after DOM settles
    setTimeout(function() { _fcBuildChart(_fcLastData); }, 50);
  }

  // Rebuild chart on theme toggle so colors update
  new MutationObserver(function() {
    if (_fcLastData && _fcLastData.length) { _fcBuildChart(_fcLastData); }
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<div class="max-w-3xl mx-auto py-8 px-2">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-heading">Slate Rankings</h1>
      <p class="text-sm text-secondary mt-1"><%= @slate.name %></p>
    </div>
    <%= link_to "Back to Contest", root_path,
      class: "text-primary hover:text-primary-300 text-sm font-medium underline underline-offset-2" %>
  </div>

  <!-- Slate tab selector -->
  <% if @slates.size > 1 %>
    <%# flex-wrap + whitespace-nowrap: a plain `flex` row squeezed ~30 pills until
        each one wrapped onto three lines. Let the ROW wrap instead and keep every
        pill on one line. %>
    <div class="flex flex-wrap gap-2 mb-6">
      <% @slates.each do |slate| %>
        <% active = slate.id == @slate.id %>
        <%= link_to "#{slate.sport_emoji} #{slate.selector_label}", slate_path(slate),
          class: "px-3 py-1.5 rounded-full text-sm font-semibold whitespace-nowrap transition-all #{active ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
      <% end %>
    </div>
  <% end %>

  <!-- Formula Curves Chart + Controls -->
  <div x-data="formulaCurves()" x-cloak class="mb-10">
    <h2 class="text-lg font-bold text-heading mb-4">Turf Score Formula</h2>
    <div class="bg-surface border border-subtle rounded-lg p-4" style="position: relative; height: 360px;">
      <canvas id="formulaCurvesChart"></canvas>
    </div>

    <!-- Formula Variables -->
    <h2 class="text-lg font-bold text-heading mb-4 mt-8">Formula Variables</h2>
    <div class="space-y-4">
      <!-- Multiplier -->
      <div class="bg-surface border border-subtle rounded-lg p-4" style="border-left: 3px solid var(--fc-mult);">
        <div class="mb-3">
          <span class="text-sm font-bold text-heading">Turf Score</span>
          <span class="text-muted text-sm"> = </span>
          <span class="font-mono text-sm" style="color: var(--fc-mult)">1.0</span>
          <span class="text-muted text-sm"> + </span>
          <span class="font-mono text-sm" style="color: var(--fc-mult)" x-text="multScale.toFixed(1)"></span>
          <span class="text-muted text-sm"> &times; <%= @slate.sport == "nfl" ? "(rank − 1) / (N − 1)" : "ln(rank) / ln(N)" %></span>
        </div>
        <%# Base is pinned — rank 1 always prices x1.0; only the top end flexes. %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-muted block mb-1">Base <span class="font-mono" style="color: var(--fc-mult)">1.0</span> <span class="text-muted">(pinned — rank 1 is always x1.0)</span></label>
          </div>
          <div>
            <label class="text-xs text-muted block mb-1">Scale <span class="font-mono" style="color: var(--fc-mult)" x-text="multScale.toFixed(1)"></span></label>
            <input type="range" min="0" max="10" step="0.5" x-model.number="multScale" @input="refresh()" class="w-full" style="accent-color: var(--fc-mult);">
          </div>
        </div>
      </div>

      <%# Goals are a soccer concept — the card hides on NFL slates. %>
      <% unless @slate.sport == "nfl" %>
        <!-- Goals Distribution -->
        <div class="bg-surface border border-subtle rounded-lg p-4" style="border-left: 3px solid var(--fc-goals);">
          <div class="mb-3">
            <span class="text-sm font-bold text-heading">Goals Distribution</span>
            <span class="text-muted text-sm"> = </span>
            <span class="font-mono text-sm" style="color: var(--fc-goals)" x-text="goalBase.toFixed(1)"></span>
            <span class="text-muted text-sm"> + </span>
            <span class="font-mono text-sm" style="color: var(--fc-goals)" x-text="goalScale.toFixed(1)"></span>
            <span class="text-muted text-sm"> &times; ln(N/rank) / ln(N)</span>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs text-muted block mb-1">Base <span class="font-mono" style="color: var(--fc-goals)" x-text="goalBase.toFixed(1)"></span></label>
              <input type="range" min="0" max="3" step="0.1" x-model.number="goalBase" @input="refresh()" class="w-full" style="accent-color: var(--fc-goals);">
            </div>
            <div>
              <label class="text-xs text-muted block mb-1">Scale <span class="font-mono" style="color: var(--fc-goals)" x-text="goalScale.toFixed(1)"></span></label>
              <input type="range" min="0" max="10" step="0.5" x-model.number="goalScale" @input="refresh()" class="w-full" style="accent-color: var(--fc-goals);">
            </div>
          </div>
        </div>
      <% end %>

      <!-- DK Score -->
      <div class="bg-surface border border-subtle rounded-lg p-4" style="border-left: 3px solid var(--fc-dk-score);">
        <div class="mb-3">
          <span class="text-sm font-bold text-heading">DK Score</span>
          <span class="text-muted text-sm"> = </span>
          <span class="font-mono text-sm" style="color: var(--fc-dk-score)"><span x-text="A.toFixed(2)"></span></span>
          <span class="text-muted text-sm"> &times; line</span><sup class="font-mono text-sm" style="color: var(--fc-dk-score)" x-text="lineExp.toFixed(2)"></sup>
          <span class="text-muted text-sm"> &times; prob</span><sup class="font-mono text-sm" style="color: var(--fc-dk-score)" x-text="probExp.toFixed(2)"></sup>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="text-xs text-muted block mb-1">A <span class="font-mono" style="color: var(--fc-dk-score)" x-text="A.toFixed(2)"></span></label>
            <input type="range" min="0" max="5" step="0.05" x-model.number="A" @input="refresh()" class="w-full" style="accent-color: var(--fc-dk-score);">
          </div>
          <div>
            <label class="text-xs text-muted block mb-1">Line Exp <span class="font-mono" style="color: var(--fc-dk-score)" x-text="lineExp.toFixed(2)"></span></label>
            <input type="range" min="0" max="3" step="0.02" x-model.number="lineExp" @input="refresh()" class="w-full" style="accent-color: var(--fc-dk-score);">
          </div>
          <div>
            <label class="text-xs text-muted block mb-1">Prob Exp <span class="font-mono" style="color: var(--fc-dk-score)" x-text="probExp.toFixed(2)"></span></label>
            <input type="range" min="0" max="3" step="0.02" x-model.number="probExp" @input="refresh()" class="w-full" style="accent-color: var(--fc-dk-score);">
          </div>
        </div>
      </div>
    </div>
  </div>

  <p class="text-secondary text-sm mb-6">
    Drag teams to set offensive rankings. Rank 1 = best offense (lowest Turf Score x1). Rank 48 = weakest (highest Turf Score x3).
    Higher Turf Score = more points when that team scores. Formula: 1.0 + 2.0 &times; ln(rank) / ln(N)
  </p>

  <div x-data="rankManager()" x-cloak>
    <form @submit.prevent="saveRankings()">
      <div class="mb-4 flex gap-3">
        <button type="button" @click="sortByDkScore()" class="btn btn-outline btn-lg flex-1">
          Sort by DK Score
        </button>
        <button type="submit" class="btn btn-secondary btn-lg flex-1">
          Save Rankings
        </button>
        <button type="button" @click="saveMultipliers()" class="btn btn-primary btn-lg flex-1">
          Save Multipliers
        </button>
        <button type="button" @click="saveFormula()" class="btn btn-outline btn-lg flex-1" style="border-color: var(--fc-dk-score); color: var(--fc-dk-score);">
          Save Formula
        </button>
      </div>

      <!-- Column headers -->
      <div class="flex items-center gap-3 px-4 py-2 text-xs text-muted uppercase tracking-wider font-semibold">
        <span class="w-8 text-right">Rank</span>
        <span class="text-lg invisible">🏳️</span>
        <span class="flex-1">Team</span>
        <span class="w-12 text-right">Turf</span>
      </div>

      <div class="space-y-1" x-ref="sortableList">
        <%# One row per TEAM. A team's DK total is the SUM across every game it
            plays in this slate, and that sum is what its rank and multiplier are
            derived from. A one-week slate has one game per team, so this renders
            exactly as it always did. The drag handle carries the team's FIRST
            matchup id; update_rankings resolves it to the team and writes the
            rank to all of that team's games. %>
        <% @team_rows.each_with_index do |row, i| %>
          <div class="flex items-center gap-3 bg-surface rounded-lg px-4 py-3 border border-subtle cursor-grab active:cursor-grabbing sortable-item"
               data-matchup-id="<%= row.matchups.first.id %>"
               data-team-total="<%= row.expected_points %>">
            <span class="font-mono text-muted text-sm w-8 text-right rank-number"><%= row.rank || i + 1 %></span>
            <span class="text-lg"><%= row.team.emoji %></span>
            <div class="flex-1 flex items-center gap-2 flex-wrap">
              <span class="text-heading font-semibold text-sm"><%= row.team.name %></span>
              <% opponents = row.matchups.filter_map { |m| m.opponent_team&.short_name } %>
              <% if opponents.any? %>
                <span class="text-muted text-xs">vs <%= opponents.join(" / ") %></span>
              <% end %>
              <% if row.expected_points.positive? %>
                <span class="text-muted text-xs">DK <%= sprintf('%.1f', row.expected_points) %></span>
              <% end %>
            </div>
            <span class="font-mono text-primary text-sm w-12 text-right turf-score-display"><%= row.turf_score ? sprintf('%.1f', row.turf_score) : '—' %>x</span>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex gap-3">
        <button type="button" @click="sortByDkScore()" class="btn btn-outline btn-lg flex-1">
          Sort by DK Score
        </button>
        <button type="submit" class="btn btn-secondary btn-lg flex-1">
          Save Rankings
        </button>
        <button type="button" @click="saveMultipliers()" class="btn btn-primary btn-lg flex-1">
          Save Multipliers
        </button>
        <button type="button" @click="saveFormula()" class="btn btn-outline btn-lg flex-1" style="border-color: var(--fc-dk-score); color: var(--fc-dk-score);">
          Save Formula
        </button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
<script>
  function rankManager() {
    return {
      slateSlug: '<%= @slate.slug %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,

      init() {
        const list = this.$refs.sortableList;
        Sortable.create(list, {
          animation: 150,
          ghostClass: 'opacity-30',
          onEnd: () => { this.updateNumbers(); _fcSyncOrder(); }
        });
      },

      updateNumbers() {
        const items = this.$refs.sortableList.querySelectorAll('.sortable-item');
        items.forEach((item, i) => {
          item.querySelector('.rank-number').textContent = i + 1;
        });
        _fcUpdateRankList(_fcSliders.A, _fcSliders.lineExp, _fcSliders.probExp, _fcSliders.multBase, _fcSliders.multScale);
      },

      async saveRankings() {
        const items = this.$refs.sortableList.querySelectorAll('.sortable-item');
        const ids = Array.from(items).map(item => item.dataset.matchupId);

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/slates/${this.slateSlug}/update_rankings`;

        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'patch';
        form.appendChild(methodInput);

        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = this.csrfToken;
        form.appendChild(csrfInput);

        ids.forEach(id => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'matchup_ids[]';
          input.value = id;
          form.appendChild(input);
        });

        document.body.appendChild(form);
        form.submit();
      },

      sortByDkScore() {
        const list = this.$refs.sortableList;
        const items = Array.from(list.querySelectorAll('.sortable-item'));
        function dkExpectation(el) {
          return parseFloat(el.dataset.teamTotal) || 0;
        }
        items.sort((a, b) => dkExpectation(b) - dkExpectation(a));
        items.forEach(item => list.appendChild(item));
        this.updateNumbers();
        _fcSyncOrder();
      },

      async saveFormula() {
        const s = _fcSliders;
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/slates/${this.slateSlug}/update_formula`;

        const fields = {
          '_method': 'patch',
          'authenticity_token': this.csrfToken,
          'formula_a': s.A,
          'formula_line_exp': s.lineExp,
          'formula_prob_exp': s.probExp,
          'formula_mult_base': s.multBase,
          'formula_mult_scale': s.multScale,
          'formula_goal_base': s.goalBase,
          'formula_goal_scale': s.goalScale
        };

        Object.entries(fields).forEach(([name, value]) => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = name;
          input.value = value;
          form.appendChild(input);
        });

        document.body.appendChild(form);
        form.submit();
      },

      async saveMultipliers() {
        const items = this.$refs.sortableList.querySelectorAll('.sortable-item');

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/slates/${this.slateSlug}/update_turf_scores`;

        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'patch';
        form.appendChild(methodInput);

        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = this.csrfToken;
        form.appendChild(csrfInput);

        items.forEach((item, i) => {
          const id = item.dataset.matchupId;
          const turfScore = item.querySelector('.turf-score-display').textContent.replace('x', '');

          const idInput = document.createElement('input');
          idInput.type = 'hidden';
          idInput.name = `turf_scores[][id]`;
          idInput.value = id;
          form.appendChild(idInput);

          const turfScoreInput = document.createElement('input');
          turfScoreInput.type = 'hidden';
          turfScoreInput.name = `turf_scores[][turf_score]`;
          turfScoreInput.value = turfScore;
          form.appendChild(turfScoreInput);
        });

        document.body.appendChild(form);
        form.submit();
      }
    };
  }
</script>

<%# Friendly names for the raw league codes; anything unmapped shows upcased. %>
<% league_labels = { "nfl" => "NFL", "fifa" => "World Cup" } %>
<% leagues = @teams.map(&:league).compact.uniq.sort %>
<section x-data="cardListFilter({ selector: '[data-team-card]', filters: { league: 'all' } })">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
    <h2 class="text-2xl font-bold text-heading">Teams</h2>
    <div class="flex items-center gap-3 w-full sm:w-auto">
      <input type="text"
             x-model.debounce.300ms="search"
             placeholder="Search teams..."
             class="input-field text-sm !py-2 !px-3 w-full sm:w-64">
      <span class="text-sm text-muted whitespace-nowrap" x-text="visibleCount + ' teams'"></span>
    </div>
  </div>

  <%# League filter tabs — reuse cardListFilter's exact-match `filters` map, so
      "NFL" hides the World Cup national teams. Only shown when more than one
      league is present. %>
  <% if leagues.size > 1 %>
    <div class="flex flex-wrap gap-2 mb-6">
      <button class="btn btn-sm" :class="filters.league === 'all' ? 'btn-primary' : 'btn-outline'" @click="filters.league = 'all'">All</button>
      <% leagues.each do |lg| %>
        <button class="btn btn-sm"
                :class="filters.league === '<%= lg %>' ? 'btn-primary' : 'btn-outline'"
                @click="filters.league = '<%= lg %>'">
          <%= league_labels.fetch(lg, lg.upcase) %>
        </button>
      <% end %>
    </div>
  <% end %>

  <p class="text-xs text-muted mb-4">
    Colors:
    <span class="whitespace-nowrap">🎨 background</span> ·
    <span class="whitespace-nowrap">🔤 text</span> ·
    <span class="whitespace-nowrap">☀️ alt light</span> ·
    <span class="whitespace-nowrap">🌙 alt dark</span>
  </p>

  <% if @teams.empty? %>
    <%= render "components/empty_state", message: "No teams yet." %>
  <% else %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      <% @teams.each do |team| %>
        <%= link_to team_path(team),
              class: "block card-hover p-4",
              data: {
                team_card: true,
                league: team.league,
                name: "#{team.name} #{team.short_name} #{team.location} #{team.league} #{team.division} #{team.home_arena&.name}".downcase
              } do %>
          <%# Four-color palette, each swatch labelled by its role emoji:
              🎨 primary (background) · 🔤 secondary (text) · ☀️ alt light · 🌙 alt dark.
              Alt swatches only appear when the team actually has that color. %>
          <div class="flex items-center gap-1.5 mb-2">
            <% [["🎨", team.color_primary], ["🔤", team.color_secondary], ["☀️", team.color_alt_light], ["🌙", team.color_alt_dark]].each do |emoji, hex| %>
              <% if hex.present? %>
                <div class="w-7 h-7 rounded-full flex-shrink-0 border border-white/20 flex items-center justify-center text-[8px] leading-none"
                     style="background-color: <%= hex %>" title="<%= emoji %> <%= hex %>"><span class="opacity-80"><%= emoji %></span></div>
              <% end %>
            <% end %>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-xl flex-shrink-0"><%= team.emoji %></span>
            <div class="min-w-0">
              <p class="text-heading font-semibold text-sm truncate"><%= team.name %></p>
              <% if team.short_name.present? %>
                <span class="text-xs text-secondary font-mono"><%= team.short_name %></span>
              <% end %>
            </div>
          </div>
          <% if team.league.present? || team.division.present? || team.location.present? %>
            <p class="text-xs text-muted mt-1 truncate">
              <%= [team.league&.upcase, team.division, team.location].compact.join(" · ") %>
            </p>
          <% end %>
          <% if team.home_arena.present? %>
            <p class="text-xs text-muted mt-1 truncate"><%= team.home_arena.name %></p>
          <% end %>
          <% if team.players.any? %>
            <div class="mt-2 pt-2 border-t border-subtle">
              <p class="text-xs text-muted"><%= team.players.size %> players</p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>

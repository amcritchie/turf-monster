<% content_for :title, "Transparency — Turf Totals" %>
<% content_for :meta_description, "Everything that makes Turf Totals verifiable in one place: our open-source on-chain program, proof of reserves, and policies." %>

<div class="max-w-5xl mx-auto py-8 px-2 space-y-10">
  <header class="space-y-2">
    <h1 class="text-4xl font-extrabold text-heading">Transparency</h1>
    <p class="text-secondary text-base leading-relaxed max-w-3xl">
      Everything that makes Turf Totals verifiable in one place: our open-source
      on-chain program, proof of reserves, and policies. Entry fees and prize pools
      settle on the <strong>Solana</strong> blockchain in USDC, so anyone can audit the
      numbers directly rather than trusting a custodial balance.
    </p>
  </header>

  <%# Featured: On-Chain. Tiles carry status: :reviewed for the green accent. %>
  <%= render "admin/hub_section", title: "On-Chain" do %>
    <%= render "admin/hub_tile", status: :reviewed,
          name: "Smart Contract", url: contract_path,
          note: "On-chain program, instructions & 2-of-3 multisig auth model" %>
    <%= render "admin/hub_tile", status: :reviewed,
          name: "Proof of Reserves", url: proof_of_reserves_path,
          note: "Live on-chain balances backing the prize pools" %>
    <%= render "admin/hub_tile", status: :reviewed, external: true,
          name: "Source Code", url: "https://github.com/amcritchie/turf-vault",
          note: "Open-source Anchor program (Solana)" %>
  <% end %>

  <%# Program-ID / authority callout — links to the contract page. %>
  <%= link_to contract_path, class: "card card-hover block p-5 space-y-2 group" do %>
    <div class="text-xs font-bold uppercase tracking-wider text-muted">Program & Authority</div>
    <p class="text-sm text-secondary leading-relaxed">
      Program ID
      <code class="font-mono text-xs break-all text-heading">DaFv83yokwTz8msP9CzJ13eazSGk15NuUTxjkfzJzxMM</code>.
      The upgrade authority is a <strong class="text-heading">Squads V4 2-of-3 multisig</strong> &mdash;
      no single key can alter or redeploy the program.
    </p>
    <span class="text-sm text-primary group-hover:underline">View the contract breakdown &rarr;</span>
  <% end %>

  <%= render "admin/hub_section", title: "Company & Legal" do %>
    <%= render "admin/hub_tile", name: "About", url: about_path,
          note: "Who builds Turf Totals and how it works" %>
    <%= render "admin/hub_tile", name: "Contact", url: contact_path,
          note: "Reach the team" %>
    <%= render "admin/hub_tile", name: "Terms of Service", url: terms_path,
          note: "The rules of using Turf Totals" %>
    <%= render "admin/hub_tile", name: "Privacy Policy", url: privacy_path,
          note: "What we collect and why" %>
  <% end %>

  <%= render "admin/hub_section", title: "Help" do %>
    <%= render "admin/hub_tile", name: "How to Play", url: help_how_to_play_path,
          note: "Pick 6 matchups, stack Turf Scores" %>
    <%= render "admin/hub_tile", name: "Help Center", url: help_path,
          note: "Guides, glossary, and FAQs" %>
    <%= render "admin/hub_tile", name: "Rules", url: turf_totals_v1_path,
          note: "Scoring, payouts, and contest format" %>
    <%= render "admin/hub_tile", name: "Phantom Wallet", url: help_phantom_path,
          note: "Connecting and using a Solana wallet" %>
  <% end %>
</div>

<!DOCTYPE html>
<%# Funnel splash always renders dark — it sits on an animated background. %>
<html lang="en" class="dark">
  <head>
    <%
      # Funnel pages are the URLs most likely to be shared in SMS/Slack/social,
      # so they need rich link-preview tags. This layout doesn't use the app
      # layout (no navbar/footer), so the canonical og/twitter block is mirrored
      # here — title + description come from the show view's content_for, the
      # image is the branded landscape og.png (1200x630). The show view defers
      # the unfurl metadata to exactly these tags.
      lp_title       = content_for(:title).presence || "Turf Totals"
      lp_description = content_for(:meta_description).presence ||
                       "Solana-powered World Cup pick'em contests. Pick 6 matchups, stack Turf Scores, and win prizes settled on-chain."
      lp_og_image    = "#{request.base_url}/og.png"
    %>
    <title><%= lp_title %></title>
    <meta name="description" content="<%= lp_description %>">

    <meta property="og:site_name" content="Turf Totals">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= lp_title %>">
    <meta property="og:description" content="<%= lp_description %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= lp_og_image %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= lp_title %>">
    <meta name="twitter:description" content="<%= lp_description %>">
    <meta name="twitter:image" content="<%= lp_og_image %>">

    <%= render "layouts/studio/head" %>
  </head>

  <%# Minimal funnel layout — no navbar or footer, keeps visitors on the CTA. %>
  <body class="bg-page text-body min-h-screen">
    <%= render "layouts/studio/flash" %>
    <%= yield %>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Turf Totals" %></title>
    <%= render "layouts/studio/head" %>
    <%# The splash theme follows the landing page's background style. %>
    <% splash_dark = @landing_page.nil? || @landing_page.dark_splash? %>
    <script>document.documentElement.classList.<%= splash_dark ? "add" : "remove" %>("dark");</script>
  </head>

  <%# Minimal funnel layout — no navbar or footer, keeps visitors on the CTA. %>
  <body class="bg-page text-body min-h-screen">
    <%= render "layouts/studio/flash" %>
    <%= yield %>
  </body>
</html>

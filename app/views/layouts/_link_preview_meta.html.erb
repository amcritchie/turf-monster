<%# locals: (title:, description:, image:, image_default:) — Open Graph + Twitter
    link-preview tags (Facebook / iMessage / Discord / Slack / X unfurls), shared
    by the application + landing layouts. The fixed 1200×630 dimensions are
    emitted ONLY for the static default og.png — a page-level override or an
    uploaded image may be any size. %>
<meta property="og:site_name" content="Turf Totals">
<meta property="og:type" content="website">
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= description %>">
<meta property="og:url" content="<%= request.original_url %>">
<meta property="og:image" content="<%= image %>">
<% if image_default %>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">
<% end %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= title %>">
<meta name="twitter:description" content="<%= description %>">
<meta name="twitter:image" content="<%= image %>">

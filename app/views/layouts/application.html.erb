<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <script src="https://unpkg.com/@solana/web3.js@1/lib/index.iife.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tweetnacl@1.0.3/nacl-fast.min.js"></script>
    <% if session_replay_active? %>
      <script src="https://cdn.logr-in.com/LogRocket.min.js" crossorigin="anonymous"></script>
      <script>window.LogRocket && window.LogRocket.init('jodsqq/mcritchie-studio');</script>
    <% end %>
    <% content_for :head do %>
      <script>
        <% if session_replay_active? && logged_in? && current_user %>
          <%# Identify by opaque slug only — never send email/PII to the replay
              vendor (Lazarus audit #2). Display name is already public on
              leaderboards; email is not. %>
          window.LogRocket && window.LogRocket.identify('<%= current_user.slug %>', {
            name: '<%= j(current_user.username || current_user.name || "") %>'
          });
        <% end %>
        <% if logged_in? && Solana::Config.devnet? %>
          // Devnet auto-refresh: server-side preload (ApplicationController
          // #preload_navbar_solana_data) already gives the page a fresh balance
          // on render, so this is just a "is anything newer on-chain?" sweep.
          // Holds 4s so the spinner doesn't compete with first paint or the
          // initial seeds-bar shimmer; if you need an immediate refresh after
          // a write (entry confirm / token consume) call refreshBalance()
          // directly from that success path.
          document.addEventListener('turbo:load', () => {
            setTimeout(function() { showNavSpinner(); refreshBalance().finally(function() { hideNavSpinner(); }); }, 4000);
          });
        <% end %>

        // Invite link: capture ?ref= param into localStorage
        (function() {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('inviter_slug', ref);
            params.delete('ref');
            var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            history.replaceState(null, '', clean);
          }
        })();

        // Invite link: save inviter on login. Reads loggedIn from the
        // canonical #session-context JSON block — same source the Alpine
        // session store hydrates from. Doing it this way (rather than via
        // $store.session) sidesteps a listener-ordering nuance: this
        // turbo:load handler is registered BEFORE the session-store
        // re-hydration handler below, so at this point in the tick the
        // store may still hold the previous page's state. The JSON block
        // is freshly server-rendered on every nav, so it's always current.
        document.addEventListener('turbo:load', function() {
          var loggedIn = false;
          var ctx = document.getElementById('session-context');
          if (ctx) {
            try { loggedIn = !!JSON.parse(ctx.textContent).loggedIn; } catch (e) {}
          }
          var inviterSlug = localStorage.getItem('inviter_slug');
          if (loggedIn && inviterSlug) {
            fetch('/account/set_inviter', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
              body: JSON.stringify({ inviter_slug: inviterSlug })
            }).then(function(r) {
              if (r.ok) localStorage.removeItem('inviter_slug');
            }).catch(function() {});
          }
        });
      </script>
      <script type="application/json" id="session-context"><%= client_session_payload.to_json.html_safe %></script>
      <script>
        // --- Inline Solana stores + components ---
        // Alpine's defer script fires alpine:init BEFORE importmap modules execute.
        // These must be inline so they're available when Alpine processes the DOM.
        // The full wallet_provider.js module overwrites this stub after modules load.

        // Mark a freshly-created user so the profile modal auto-opens after
        // the post-verify page reload. Called from every site that
        // successfully verifies a Solana sign-in: the inline connect()
        // below (initial connect), solana_stores.js _reauth() (silent
        // wallet-switch re-auth), and solana_sessions/phantom_callback
        // (Phantom mobile deep-link return). The localStorage round-trip
        // is intentional — it survives the window.location reload that
        // ends each of those flows; the simpler alternative (Rails flash
        // via SessionContext) would couple SessionContext to flash, which
        // it currently avoids by design.
        window.handleSolanaVerifySuccess = function(result) {
          if (result && result.new_user) {
            localStorage.setItem('show_profile_modal', 'true');
          }
        };

        // Minimal wallet provider stub — enough for Alpine x-data evaluation
        window.walletProvider = {
          isAvailable: function() {
            return !!(window.__WALLET_KEYPAIR_SECRET) || !!(window.phantom && window.phantom.solana && window.phantom.solana.isPhantom);
          },
          isMobile: function() {
            return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (navigator.maxTouchPoints > 1 && /Macintosh/.test(navigator.userAgent));
          },
          detect: function() {
            return null;
          },
          // Empty until the full wallet_provider module loads + wallets
          // register via Wallet Standard. The hub reads this at click time.
          available: function() {
            return [];
          }
        };

        // Shared SIWS connect+verify, used by the wallet-connect modal (and
        // reusable anywhere). Picks a provider by name, signs the nonce, posts
        // to verify (or link_solana when linkMode), and RESOLVES the server
        // result — the caller decides where to navigate. Inline (not a module)
        // so it's available the moment the modal mounts.
        window.solanaConnectAndVerify = async function(walletName, opts) {
          opts = opts || {};
          var provider = walletName ? window.walletProvider.get(walletName) : window.walletProvider.detect();
          if (!provider) throw new Error('Wallet not available');
          var resp = await provider.connect();
          var pubkeyB58 = resp.publicKey.toBase58();
          var data = await (await fetch('/auth/solana/nonce')).json();
          var domain = window.location.host;
          var userIdLine = (opts.linkMode && opts.currentUserId) ? ('User-ID: ' + opts.currentUserId + '\n\n') : '';
          var message = domain + ' wants you to sign in with your Solana account:\n' + pubkeyB58 + '\n\n' + userIdLine + 'Sign in to Turf Monster\n\nNonce: ' + data.nonce;
          var signed = await provider.signMessage(new TextEncoder().encode(message), 'utf8');
          var signatureB58 = encodeBase58(signed.signature);
          var verifyUrl = opts.linkMode ? '/account/link_solana' : '/auth/solana/verify';
          return await (await fetch(verifyUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
            body: JSON.stringify({ message: message, signature: signatureB58, pubkey: pubkeyB58 })
          })).json();
        };

        // Shared magic-link request. Form-encoded (so the rack-attack per-email
        // throttle, which reads req.params before JSON parsing, applies) with
        // Accept: json for the response. opts.contest / opts.picks ride along
        // for the in-contest flow so the emailed link returns to the contest.
        // Resolves the parsed JSON. Inline so every scope (standalone form,
        // board, modal) shares one request shape.
        window.postMagicLink = async function(email, opts) {
          opts = opts || {};
          var body = new URLSearchParams();
          body.set('email', email || '');
          if (opts.contest) body.set('contest', opts.contest);
          if (opts.picks)   body.set('picks', opts.picks);
          var resp = await fetch('/magic_link', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'Accept': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: body.toString()
          });
          try { return await resp.json(); } catch (e) { return { success: resp.ok }; }
        };

        // Solana modal store — registered when Alpine starts
        document.addEventListener('alpine:init', function() {
          if (Alpine.store('solanaModal')) return;

          // Canonical session store — the single source of truth for the
          // viewer's auth/wallet state (guest / web2 / web3). Seeded from the
          // server-rendered #session-context (SessionContext#to_h) on every
          // page render; the whole UI branches on $store.session.mode.
          Alpine.store('session', {
            loggedIn: false,
            mode: 'guest',
            phantomLinked: false,
            userId: null,
            address: '',
            // On-chain balance fields — populated from #session-context on
            // page render (server merges already-preloaded @wallet_balances
            // + entry_token_balance) and refreshed by refreshSession() after
            // any on-chain success. Integer cents / count; used by the
            // synchronous entry-eligibility check during the hold gesture.
            usdcCents: 0,
            usdtCents: 0,
            tokensAvailable: 0,
            get isGuest() { return this.mode === 'guest'; },
            get isWeb2() { return this.mode === 'web2'; },
            get isWeb3() { return this.mode === 'web3'; },
            hydrate: function(ctx) {
              if (!ctx) return;
              this.loggedIn = !!ctx.loggedIn;
              this.mode = ctx.mode || 'guest';
              this.phantomLinked = !!ctx.phantomLinked;
              this.userId = ctx.userId || null;
              this.address = ctx.address || '';
              // null in the payload means "server doesn't know" (preload
              // RPC flake) — preserve null on the store so eligibilityBlocker
              // can fail open rather than zero-block a funded user.
              if (ctx.usdcCents       !== undefined) this.usdcCents       = (ctx.usdcCents       == null) ? null : (ctx.usdcCents       | 0);
              if (ctx.usdtCents       !== undefined) this.usdtCents       = (ctx.usdtCents       == null) ? null : (ctx.usdtCents       | 0);
              if (ctx.tokensAvailable !== undefined) this.tokensAvailable = (ctx.tokensAvailable == null) ? 0    : (ctx.tokensAvailable | 0);
            }
          });
          (function() {
            var el = document.getElementById('session-context');
            if (!el) return;
            try { Alpine.store('session').hydrate(JSON.parse(el.textContent)); }
            catch (e) { console.warn('[session] context parse failed', e); }
          })();

          // solanaModal is a STATELESS proxy over Alpine.store('modals').
          // Every field reads/writes props on the 'onchain-tx' modal entry
          // in the shared stack — there's no duplicate state. The store
          // exists to preserve the existing call-site API (show/success/
          // error/close + field reads) while the underlying source of
          // truth is the modal stack.
          //
          // The redundant auto-close countdown timer that used to live here
          // is gone: modals/blocks/_entry_confirmed.html.erb drives the
          // post-success redirect via the success_card's cta_drain. The
          // onClose callback path is preserved for the world-cup-survivor
          // flow that still relies on it.
          var _txCluster = document.body ? (document.body.dataset.solanaCluster || 'devnet') : 'devnet';
          var _txClusterParam = _txCluster === 'devnet' ? '?cluster=devnet' : '';
          var _onCurrent = function() {
            var c = Alpine.store('modals').current();
            return (c && c.id === 'onchain-tx') ? c : null;
          };
          var _propRead = function(key, fallback) {
            var c = _onCurrent();
            return c ? (c.props[key] !== undefined ? c.props[key] : fallback) : fallback;
          };
          var _propWrite = function(key, value) {
            var c = _onCurrent();
            if (c) c.props[key] = value;
          };
          Alpine.store('solanaModal', {
            _recoveryHandler: null,
            _onCloseHandler:  null,

            show: function(title, message) {
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              // dismissible: false suppresses click-outside + escape while
              // a Phantom signature / RPC confirm is pending — success()/
              // error() flip it to true.
              Alpine.store('modals').open('onchain-tx', {
                dismissible:     false,
                state:           'processing',
                title:           title,
                message:         message,
                txSignature:     null,
                errorMessage:    null,
                seedsEarned:     0,
                seedsTotal:      0,
                seedsLevel:      0,
                lobbyUrl:        null,
                recoveryLabel:   null,
                recoveryPhantom: false,
                // success-card variant + generic-card copy/CTA. Default
                // 'entry' keeps every existing success() caller on the
                // contest-entry celebration; the faucet (and future
                // generic on-chain flows) pass variant: 'generic'.
                successVariant:  'entry',
                successTitle:    null,
                successSubtitle: null,
                ctaLabel:        null,
                ctaHref:         null,
                // confetti on success — resolved in success() per variant
                // (entry: on, generic: off unless opts.confetti:true).
                confetti:        true
              });
            },
            // opts (optional): { variant: 'entry'|'generic', title,
            // subtitle, ctaLabel, ctaHref } for the generic success card.
            // A non-object 3rd arg (legacy autoCloseSeconds — ignored,
            // entry_confirmed drives its own countdown) is safely a no-op.
            success: function(tx, message, opts) {
              var c = _onCurrent();
              if (!c) return;
              if (!opts || typeof opts !== 'object') opts = {};
              c.props.state = 'success';
              c.props.txSignature = tx;
              if (message) c.props.message = message;
              if (opts.variant)          c.props.successVariant  = opts.variant;
              if (opts.title != null)    c.props.successTitle    = opts.title;
              if (opts.subtitle != null) c.props.successSubtitle = opts.subtitle;
              if (opts.ctaLabel != null) c.props.ctaLabel        = opts.ctaLabel;
              if (opts.ctaHref != null)  c.props.ctaHref         = opts.ctaHref;
              // Confetti: explicit opts.confetti wins; otherwise on for
              // entry, off for generic.
              c.props.confetti = (opts.confetti !== undefined)
                ? !!opts.confetti
                : (c.props.successVariant !== 'generic');
              c.props.dismissible = true;
            },
            error: function(msg, title) {
              var c = _onCurrent();
              if (!c) return;
              c.props.state = 'error';
              c.props.errorMessage = msg;
              if (title) c.props.title = title;
              c.props.dismissible = true;
            },
            close: function() {
              var cb = this._onCloseHandler;
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              if (_onCurrent()) Alpine.store('modals').close();
              if (cb) cb();
            },
            setRecovery: function(label, handler, options) {
              var c = _onCurrent();
              if (!c) return;
              c.props.recoveryLabel = label;
              c.props.recoveryPhantom = !!(options && options.phantom);
              this._recoveryHandler = handler;
            },
            _triggerRecovery: function() {
              if (this._recoveryHandler) this._recoveryHandler();
            },

            // === Field accessors — read/write 'onchain-tx' props ===
            get visible()         { return !!_onCurrent(); },
            get state()           { return _propRead('state', null); },
            get title()           { return _propRead('title', ''); },
            set title(v)          { _propWrite('title', v); },
            get message()         { return _propRead('message', ''); },
            set message(v)        { _propWrite('message', v); },
            get txSignature()     { return _propRead('txSignature', null); },
            set txSignature(v)    { _propWrite('txSignature', v); },
            get errorMessage()    { return _propRead('errorMessage', null); },
            get seedsEarned()     { return _propRead('seedsEarned', 0); },
            set seedsEarned(v)    { _propWrite('seedsEarned', v); },
            get seedsTotal()      { return _propRead('seedsTotal', 0); },
            set seedsTotal(v)     { _propWrite('seedsTotal', v); },
            get seedsLevel()      { return _propRead('seedsLevel', 0); },
            set seedsLevel(v)     { _propWrite('seedsLevel', v); },
            get lobbyUrl()        { return _propRead('lobbyUrl', null); },
            set lobbyUrl(v)       { _propWrite('lobbyUrl', v); },
            get successVariant()  { return _propRead('successVariant', 'entry'); },
            set successVariant(v) { _propWrite('successVariant', v); },
            get successTitle()    { return _propRead('successTitle', null); },
            set successTitle(v)   { _propWrite('successTitle', v); },
            get successSubtitle() { return _propRead('successSubtitle', null); },
            set successSubtitle(v){ _propWrite('successSubtitle', v); },
            get ctaLabel()        { return _propRead('ctaLabel', null); },
            set ctaLabel(v)       { _propWrite('ctaLabel', v); },
            get ctaHref()         { return _propRead('ctaHref', null); },
            set ctaHref(v)        { _propWrite('ctaHref', v); },
            get confetti()        { return _propRead('confetti', true); },
            set confetti(v)       { _propWrite('confetti', v); },
            get recoveryLabel()   { return _propRead('recoveryLabel', null); },
            get recoveryPhantom() { return _propRead('recoveryPhantom', false); },

            // onClose remains a settable callback (legacy survivor-board flow).
            get onClose()         { return this._onCloseHandler; },
            set onClose(fn)       { this._onCloseHandler = fn; },

            get explorerUrl() {
              var tx = this.txSignature;
              return tx ? ('https://explorer.solana.com/tx/' + tx + _txClusterParam) : null;
            }
          });

          // Auto-open the profile modal once after a new Phantom signup.
          // The wallet verify path sets localStorage 'show_profile_modal'
          // on result.new_user; consume it here and route through the
          // shared modal stack. setTimeout defers past Alpine's own init
          // pass so the store is fully wired when we call open().
          if (localStorage.getItem('show_profile_modal') === 'true') {
            localStorage.removeItem('show_profile_modal');
            setTimeout(function() {
              var m = Alpine.store('modals');
              if (m) m.open('profile');
            }, 300);
          }
        });
        // Alpine.store('modals') + window.StudioModals.holdAtLeast both
        // live in studio-engine's studio/modals/host partial now — see
        // <%%= render "studio/modals/host" %> below.

        // Cross-tab session broadcast — same shape as the tt-tokens channel
        // used by the token-purchase return path. Tabs broadcast on every
        // rehydrate (cheap); peers compare userId + loggedIn against their
        // local store and refetch /account/session_state only on mismatch.
        // The per-tab _sessionTabId prevents a tab from reacting to its own
        // broadcast, so there's no echo loop.
        var _sessionTabId = Math.random().toString(36).slice(2);
        var _sessionChannel = ('BroadcastChannel' in window)
          ? new BroadcastChannel('tm-session') : null;

        function fetchAndHydrateSession() {
          return fetch('/account/session_state', {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            cache: 'no-store'
          })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data) return;
              var store = window.Alpine && Alpine.store && Alpine.store('session');
              if (store && store.hydrate) store.hydrate(data);
              if (data.csrf) {
                var meta = document.querySelector('meta[name="csrf-token"]');
                if (meta) meta.setAttribute('content', data.csrf);
              }
            })
            .catch(function() {});
        }

        if (_sessionChannel) {
          _sessionChannel.addEventListener('message', function(e) {
            var msg = e.data;
            if (!msg || msg.tabId === _sessionTabId) return;
            var store = window.Alpine && Alpine.store && Alpine.store('session');
            if (!store) return;
            var changed = (msg.userId || null) !== (store.userId || null) ||
                          (!!msg.loggedIn) !== (!!store.loggedIn);
            if (changed) fetchAndHydrateSession();
          });
        }

        // Re-seed the canonical session store on every Turbo navigation —
        // auth state can change between page loads. Broadcasts the post-
        // hydrate snapshot so other tabs holding stale state refetch.
        function rehydrateSession() {
          var store = (window.Alpine && Alpine.store) ? Alpine.store('session') : null;
          var el = document.getElementById('session-context');
          if (!store || !el) return;
          try { store.hydrate(JSON.parse(el.textContent)); } catch (e) {}
          if (_sessionChannel) {
            try { _sessionChannel.postMessage({ tabId: _sessionTabId, userId: store.userId, loggedIn: store.loggedIn, mode: store.mode }); } catch (e) {}
          }
        }
        document.addEventListener('turbo:load', rehydrateSession);
        // bfcache restore (back/forward) doesn't fire turbo:load — the
        // snapshot is reused without Turbo re-initializing the page. Without
        // a pageshow rehydrate, $store.session keeps its pre-bfcache value
        // and can drift from the server's truth (e.g. user logged out in
        // another tab). The snapshot's #session-context JSON is itself
        // pre-bfcache state, but re-running hydrate() at minimum re-fires
        // any reactive consumers and resets transient flags.
        window.addEventListener('pageshow', rehydrateSession);

        // visibilitychange rehydrate — when the tab returns from background
        // (>30s away), GET /account/session_state to detect server-side
        // logout / cross-tab login changes and rotate CSRF. Avoids the
        // failure mode where a stale Alpine.store('session') makes the user
        // believe they're logged in until their next POST surfaces 401.
        var _hiddenAt = null;
        document.addEventListener('visibilitychange', function() {
          if (document.hidden) { _hiddenAt = Date.now(); return; }
          if (!_hiddenAt || (Date.now() - _hiddenAt) < 30000) return;
          _hiddenAt = null;
          fetchAndHydrateSession();
        });

      </script>
    <% end %>
    <%= action_cable_meta_tag %>
    <%= render "layouts/studio/head" %>
  </head>

  <%# Body data attrs (intentional, audited 2026-05-23):
        - data-user-id:        read SYNCHRONOUSLY by the user-change-cleanup
                               script below, BEFORE Alpine inits — moving to
                               $store.session.userId would let stale per-user
                               localStorage state leak into the next user's
                               first paint
        - data-wallet-address: read by app/javascript/solana_stores.js's
                               wallet watcher (`_serverAddress()`). The
                               session store's address would be equivalent
                               (both are request-time snapshots) so the
                               migration would be purely cosmetic
        - data-solana-cluster: a build-time constant, used as a small inline
                               default by the solanaModal store init
        - data-solana-rpc-url: env-driven (SOLANA_RPC_URL via Solana::Config).
                               Read by inline TX flows that need a Connection;
                               replaces the previous solanaWeb3.clusterApiUrl('devnet')
                               hardcode that would silently broadcast to the
                               wrong cluster on mainnet flip.
        loggedIn is NO LONGER on the body — the one reader (invite-link
        handler above) now consumes #session-context JSON directly. %>
  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }" data-user-id="<%= current_user&.id %>" data-wallet-address="<%= current_user&.solana_address %>" data-solana-cluster="<%= Solana::Config.devnet? ? 'devnet' : 'mainnet-beta' %>" data-solana-rpc-url="<%= Solana::Config::RPC_URL %>">
    <%# Single source of truth for Alpine x-data factory functions.
        Inlined here (synchronous parse-time script) because importmap
        modules load AFTER Alpine processes x-data. See the partial's
        header for the full diagnostic. %>
    <%= render "shared/alpine_factories" %>
    <%# User-change cleanup. The seeds bar (and the welcome modal flag,
        and any other per-user localStorage state) used to leak across
        sessions when User A logged out and User B logged in in the
        same browser. On every page load we compare the server-rendered
        current user id with the last-seen id in localStorage; if it
        changed (including → '' on logout), purge the user-scoped keys
        and stamp the new id. Runs synchronously before Alpine inits so
        components like _seeds_bar read a clean slate. %>
    <script>
      (function() {
        var current = document.body.dataset.userId || '';
        var last    = localStorage.getItem('lastUserId') || '';
        if (current === last) return;
        // Exact user-scoped keys.
        ['seedsNavbar', 'seedsLevelUp', 'show_profile_modal'].forEach(function(k) {
          try { localStorage.removeItem(k); } catch (_) {}
        });
        // Prefix-scoped: phantom_dl_* holds the mobile-Phantom deeplink
        // handshake (nonce + secret + pubkey + user_id + step). Per-user,
        // must NOT survive across a user switch in the same browser.
        try {
          for (var i = localStorage.length - 1; i >= 0; i--) {
            var k = localStorage.key(i);
            if (k && k.indexOf('phantom_dl_') === 0) localStorage.removeItem(k);
          }
        } catch (_) {}
        try {
          if (current) localStorage.setItem('lastUserId', current);
          else         localStorage.removeItem('lastUserId');
        } catch (_) {}
      })();
    </script>
    <%= render "layouts/studio/flash" %>
    <%= render "layouts/navbar" %>

    <div class="max-w-7xl mx-auto px-4">
      <%= yield %>
    </div>

    <%= render "shared/solana_errors" %>
    <%# Generic modal host from studio-engine. Owns Alpine.store('modals'),
        the StudioModals.holdAtLeast helper, the backdrop / scroll lock /
        escape / click-outside / ARIA / transitions, and renders this app's
        content partials by id (registered in the block below). %>
    <%= render "studio/modals/host" do %>
      <template x-if="$store.modals.current().id === 'check-email'">
        <%= render "modals/check_email" %>
      </template>
      <%# Email-change-pending — opened on the /account page after a held
          email change (AccountsController#update). Informational handoff:
          "go click the confirm link in your inbox." Auto-opened from the
          server flash[:email_change_pending] via the inline script in
          accounts/show.html.erb. %>
      <template x-if="$store.modals.current().id === 'email-change-pending'">
        <%= render "modals/email_change_pending" %>
      </template>
      <template x-if="$store.modals.current().id === 'auth'">
        <%= render "modals/auth" %>
      </template>
      <%# Multi-wallet "Connect Wallet" picker (reown-style). Opened directly
          from the standalone Solana button, or swapped-into from the auth
          modal's Solana button (board#openWalletConnect saves the cart first
          and passes returnUrl). %>
      <template x-if="$store.modals.current().id === 'wallet-connect'">
        <%= render "modals/wallet_connect" %>
      </template>
      <%# On-chain TX modal (replaces shared/_solana_modal.html.erb).
          State lives in Alpine.store('solanaModal') — show/success/
          error/close on that store push/pop this id onto the stack. %>
      <template x-if="$store.modals.current().id === 'onchain-tx'">
        <%= render "modals/onchain_tx" %>
      </template>
      <%# "It Begins" — fired client-side when a contest's lock countdown hits
          zero (contests/_timestamp_countdown). Celebratory; the draining CTA
          reloads the lobby into its locked/leaderboard view. %>
      <template x-if="$store.modals.current().id === 'it-begins'">
        <%= render "modals/it_begins" %>
      </template>
      <% if logged_in? %>
        <template x-if="$store.modals.current().id === 'profile'">
          <%= render "modals/profile" %>
        </template>
        <template x-if="$store.modals.current().id === 'username'">
          <%= render "modals/username" %>
        </template>
      <% end %>
      <%# crop-photo gets pushed on top of whatever modal owns the avatar
          cropper (profile modal, complete_profile, /account). Not gated by
          logged_in? because complete_profile renders before the profile is
          finished. %>
      <template x-if="$store.modals.current().id === 'crop-photo'">
        <%= render "modals/crop_photo" %>
      </template>
      <%# wallet-deposit — opened by the entry-eligibility blocker when a
          web3 user lacks USDC/USDT for the entry fee. Symmetric to the
          tokens-picker step inside auth for the web2 path. %>
      <% if logged_in? %>
        <template x-if="$store.modals.current().id === 'wallet-deposit'">
          <%= render "modals/wallet_deposit" %>
        </template>
      <% end %>

      <%# Admin "Update banner" modal — opened from the contest hero's Edit
          button. Registered only on contest pages (where @contest is set) for
          admins, since the partial references @contest. %>
      <% if current_user&.admin? && @contest&.persisted? %>
        <template x-if="$store.modals.current().id === 'contest-banner'">
          <%= render "modals/contest_banner" %>
        </template>
      <% end %>

      <%# Template reference modals — registered in non-production only so
          they don't add JS surface area to prod. Surfaced at the top of
          /admin/modals as "Templates" so new modal work has copy-paste
          starting points. %>
      <% unless Rails.env.production? %>
        <template x-if="$store.modals.current().id === 'template-form'">
          <%= render "modals/templates/form" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-action'">
          <%= render "modals/templates/action" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-status'">
          <%= render "modals/templates/status" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-success'">
          <%= render "modals/templates/success" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-wizard'">
          <%= render "modals/templates/wizard" %>
        </template>
      <% end %>
    <% end %>

    <%# Close the "Update banner" modal once its Turbo submit succeeds (the
        server already swapped #contest-hero via Turbo Stream). Lives OUTSIDE
        the modal host template so it actually runs; scoped to the form id so it
        ignores every other Turbo form. A 422 (bad file) is not a success, so
        the modal stays open with its inline error. Bound once (window flag) so
        Turbo Drive re-rendering the layout doesn't stack duplicate listeners. %>
    <script>
      (function () {
        if (window.__contestBannerCloseBound) return;
        window.__contestBannerCloseBound = true;
        document.addEventListener("turbo:submit-end", function (e) {
          if (e.target && e.target.id === "contest-banner-form" && e.detail && e.detail.success) {
            if (window.Alpine && Alpine.store("modals")) Alpine.store("modals").close();
          }
        });
      })();
    </script>

    <% if logged_in? && current_user.solana_connected? %>
      <%= render "shared/phantom_watcher" %>
    <% end %>
  </body>
</html>

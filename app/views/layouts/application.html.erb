<!DOCTYPE html>
<html>
  <head>
    <%#
      Site identity + trust/unfurl metadata. App-level (not the studio-engine
      head partial, which renders below) so we don't have to bump the gem.
      The engine head already ships viewport, csrf/csp, importmap, --nav-h,
      overflow-anchor, and apple-mobile-web-app-capable — none of which we
      touch here. og:url/og:image are absolute (wallet scanners + link
      unfurlers require absolute URLs). Title / description / share image
      resolve through OgHelper: a page-level content_for(:title) /
      content_for(:meta_description) / content_for(:og_image) override wins,
      then the admin-set SiteSetting defaults, then the hardcoded fallbacks.
    %>
    <%# Title/description/og:image resolve through OgHelper: a page-level
        content_for override wins, then the admin-set SiteSetting defaults
        (/admin/dashboard), then the hardcoded fallbacks below. See OgHelper. %>
    <% page_title = og_title(content_for(:title)) %>
    <% meta_description = og_description(content_for(:meta_description)) %>
    <%# og:image — a page-level content_for(:og_image) override wins; otherwise
        the admin-uploaded SiteSetting default, falling back to the static
        public/og.png (1200x630 landscape, ~53KB — sized + compressed for the
        unfurl; the old 1.3MB /logo.png timed out and blanked previews). Only
        the static fallback has known fixed dimensions. %>
    <% og_override = content_for(:og_image).presence %>
    <% resolved_og_image = og_override || og_image_url %>
    <% og_image_is_default = og_override.blank? && og_image_default? %>
    <title><%= page_title %></title>
    <meta name="description" content="<%= meta_description %>">

    <%# Favicons + PWA icons (Turf Totals green monster mark) %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
    <link rel="manifest" href="/site.webmanifest">

    <%# Brand dark navy (matches --color-page / manifest theme_color). %>
    <meta name="theme-color" content="#1e1b35">
    <%# Modern companion to the engine head's apple-mobile-web-app-capable
        (clears the Chrome deprecation warning). Both are intentionally kept. %>
    <meta name="mobile-web-app-capable" content="yes">

    <%# Open Graph + Twitter unfurl tags (shared with the landing layout). %>
    <%= render "layouts/link_preview_meta", title: page_title, description: meta_description,
          image: resolved_og_image, image_default: og_image_is_default %>

    <%# SRI-pinned (audit H2): exact versions + integrity so a poisoned CDN/package
        can't swap the signing-path crypto. web3.js @1 currently resolves to 1.98.4;
        pinning freezes that (re-pin + recompute the sha384 on any intentional bump). %>
    <script src="https://unpkg.com/@solana/web3.js@1.98.4/lib/index.iife.min.js"
            integrity="sha384-I45YF+S0YGWIolUyTksLk9TNtTqaDgZg8e6T1OoBoJvvFmphqYNIPZw3Kl0TkZNN"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/tweetnacl@1.0.3/nacl-fast.min.js"
            integrity="sha384-05+sicyRJQ56XpL4U9HJ8YbtSzFDvAg7apPKOGV6A0JsAJKFM68jp5oLnUjG5mEp"
            crossorigin="anonymous"></script>
    <% if session_replay_active? %>
      <script src="https://cdn.logr-in.com/LogRocket.min.js" crossorigin="anonymous"></script>
      <script>
        // LogRocket records DOM + network in prod. Sanitize before anything leaves the
        // browser (audit LR-1): never ship the CSRF token, the api-keyed Helius RPC URL,
        // or auth/account/wallet request+response bodies (SIWS sigs, emails, tokens) to
        // the third-party recorder. Defensive (try/catch) so a field-shape change can
        // only under-record, never throw or break init.
        window.LogRocket && window.LogRocket.init('jodsqq/mcritchie-studio', {
          dom: { inputSanitizer: true },
          network: {
            requestSanitizer: function (request) {
              try {
                var u = request.url || '';
                if (u.indexOf('api-key=') !== -1) request.url = u.replace(/api-key=[^&]+/gi, 'api-key=REDACTED');
                if (/\/(auth|account|wallet|magic_link|webhooks)(\/|\?|$)/.test(u)) request.body = undefined;
                if (request.headers) { delete request.headers['X-CSRF-Token']; delete request.headers['x-csrf-token']; }
              } catch (e) {}
              return request;
            },
            responseSanitizer: function (response) {
              try {
                var u = (response && response.url) || '';
                if (/\/(auth|account|wallet|magic_link|session_state)(\/|\?|$)/.test(u)) response.body = undefined;
              } catch (e) {}
              return response;
            }
          }
        });
      </script>
    <% end %>
    <% content_for :head do %>
      <script>
        <% if session_replay_active? && logged_in? && current_user %>
          <%# Identify by opaque slug only — never send email/PII to the replay
              vendor (Lazarus audit #2). Display name is already public on
              leaderboards; email is not. %>
          window.LogRocket && window.LogRocket.identify('<%= current_user.slug %>', {
            name: '<%= j(current_user.username || current_user.name || "") %>'
          });
        <% end %>
        <% if logged_in? && current_user.solana_connected? %>
          // Navbar hydrate. The server NO LONGER blocks the HTML render on the
          // USDC/USDT/seeds RPCs (perf: ~0.3-1s/page) — display_balance /
          // display_seeds_data render cache-first, nil ("loading") when cold.
          // So this fires refreshSession() RIGHT AWAY on every load (initial +
          // every Turbo nav). It is THE one page-load hydrate: pill + token
          // badge + seeds bar + $store.session cents + any data-wallet-tile
          // spans on the page (/account's balance tiles) all converge from
          // this single call. The nav spinner spins until it lands. A write
          // success path (entry confirm / token consume) still calls
          // refreshSession() directly for its own refresh.
          (function() {
            var _navHydrating = false;
            function hydrateNavbar() {
              if (_navHydrating) return;             // de-dupe initial + turbo:load
              _navHydrating = true;
              if (window.showNavSpinner) window.showNavSpinner();
              refreshSession().finally(function() {
                if (window.hideNavSpinner) window.hideNavSpinner();
                _navHydrating = false;
              });
            }
            document.addEventListener('turbo:load', hydrateNavbar);
            // Fire on initial load too — turbo:load may already have run (or
            // be racing) before this inline script registers its listener.
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', hydrateNavbar);
            } else {
              hydrateNavbar();
            }
          })();
        <% end %>

        // Invite link: capture ?ref= param into localStorage
        (function() {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('inviter_slug', ref);
            params.delete('ref');
            var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            history.replaceState(null, '', clean);
          }
        })();

        // Invite link: save inviter on login. Reads loggedIn from the
        // canonical #session-context JSON block — same source the Alpine
        // session store hydrates from. Doing it this way (rather than via
        // $store.session) sidesteps a listener-ordering nuance: this
        // turbo:load handler is registered BEFORE the session-store
        // re-hydration handler below, so at this point in the tick the
        // store may still hold the previous page's state. The JSON block
        // is freshly server-rendered on every nav, so it's always current.
        document.addEventListener('turbo:load', function() {
          var loggedIn = false;
          var ctx = document.getElementById('session-context');
          if (ctx) {
            try { loggedIn = !!JSON.parse(ctx.textContent).loggedIn; } catch (e) {}
          }
          var inviterSlug = localStorage.getItem('inviter_slug');
          if (loggedIn && inviterSlug) {
            fetch('/account/set_inviter', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
              body: JSON.stringify({ inviter_slug: inviterSlug })
            }).then(function(r) {
              if (r.ok) localStorage.removeItem('inviter_slug');
            }).catch(function() {});
          }
        });
      </script>
      <script type="application/json" id="session-context"><%= client_session_payload.to_json.html_safe %></script>
      <script>
        // --- Inline Solana stores + components ---
        // Alpine's defer script fires alpine:init BEFORE importmap modules execute.
        // These must be inline so they're available when Alpine processes the DOM.
        // The full wallet_provider.js module overwrites this stub after modules load.

        // Mark a freshly-created user so the profile modal auto-opens after
        // the post-verify page reload. Called from every site that
        // successfully verifies a Solana sign-in: the inline connect()
        // below (initial connect), solana_stores.js _reauth() (silent
        // wallet-switch re-auth), and solana_sessions/phantom_callback
        // (Phantom mobile deep-link return). The localStorage round-trip
        // is intentional — it survives the window.location reload that
        // ends each of those flows; the simpler alternative (Rails flash
        // via SessionContext) would couple SessionContext to flash, which
        // it currently avoids by design.
        // Post-Solana-verify hook. The new-Phantom-signup avatar prompt (the
        // 'profile' modal) was retired — usernames auto-generate, nothing to
        // complete — so this is now a no-op extension point for future hooks.
        window.handleSolanaVerifySuccess = function(result) {};

        // Minimal wallet provider stub — enough for Alpine x-data evaluation
        window.walletProvider = {
          isAvailable: function() {
            return !!(window.__WALLET_KEYPAIR_SECRET) || !!(window.phantom && window.phantom.solana && window.phantom.solana.isPhantom);
          },
          isMobile: function() {
            return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (navigator.maxTouchPoints > 1 && /Macintosh/.test(navigator.userAgent));
          },
          detect: function() {
            return null;
          },
          // Empty until the full wallet_provider module loads + wallets
          // register via Wallet Standard. The hub reads this at click time.
          available: function() {
            return [];
          }
        };

        // Shared SIWS connect+verify, used by the wallet-connect modal (and
        // reusable anywhere). Picks a provider by name, signs the nonce, posts
        // to verify (or link_solana when linkMode), and RESOLVES the server
        // result — the caller decides where to navigate. Inline (not a module)
        // so it's available the moment the modal mounts.
        window.solanaConnectAndVerify = async function(walletName, opts) {
          opts = opts || {};
          var provider = walletName ? window.walletProvider.get(walletName) : window.walletProvider.detect();
          if (!provider) throw new Error('Wallet not available');
          var resp = await provider.connect();
          var pubkeyB58 = resp.publicKey.toBase58();
          var data = await (await fetch('/auth/solana/nonce')).json();
          var domain = window.location.host;
          var userIdLine = (opts.linkMode && opts.currentUserId) ? ('User-ID: ' + opts.currentUserId + '\n\n') : '';
          var message = domain + ' wants you to sign in with your Solana account:\n' + pubkeyB58 + '\n\n' + userIdLine + 'Sign in to Turf Monster\n\nNonce: ' + data.nonce;
          var signed = await provider.signMessage(new TextEncoder().encode(message), 'utf8');
          var signatureB58 = encodeBase58(signed.signature);
          var verifyUrl = opts.linkMode ? '/account/link_solana' : '/auth/solana/verify';
          // Legal-age attestation (signup compliance): undefined keys are
          // dropped by JSON.stringify, so login/link calls stay unchanged.
          var ageAttestation = (!opts.linkMode && opts.ageAttested) ? '1' : undefined;
          return await (await fetch(verifyUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
            body: JSON.stringify({ message: message, signature: signatureB58, pubkey: pubkeyB58, age_attestation: ageAttestation })
          })).json();
        };

        // Shared magic-link request. Form-encoded (so the rack-attack per-email
        // throttle, which reads req.params before JSON parsing, applies) with
        // Accept: json for the response. opts.contest / opts.picks ride along
        // for the in-contest flow so the emailed link returns to the contest.
        // Resolves the parsed JSON. Inline so every scope (standalone form,
        // board, modal) shares one request shape.
        window.postMagicLink = async function(email, opts) {
          opts = opts || {};
          var body = new URLSearchParams();
          body.set('email', email || '');
          if (opts.contest) body.set('contest', opts.contest);
          if (opts.picks)   body.set('picks', opts.picks);
          // Legal-age attestation — rides in the magic-link row so the
          // consume side can require it before creating a new account.
          if (opts.ageAttested) body.set('age_attestation', '1');
          var resp = await fetch('/magic_link', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'Accept': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: body.toString()
          });
          try { return await resp.json(); } catch (e) { return { success: resp.ok }; }
        };

        // Solana modal store — registered when Alpine starts
        document.addEventListener('alpine:init', function() {
          if (Alpine.store('solanaModal')) return;

          // Canonical session store — the single source of truth for the
          // viewer's auth/wallet state (guest / web2 / web3). Seeded from the
          // server-rendered #session-context (SessionContext#to_h) on every
          // page render; the whole UI branches on $store.session.mode.
          Alpine.store('session', {
            loggedIn: false,
            mode: 'guest',
            phantomLinked: false,
            userId: null,
            address: '',
            // On-chain balance fields — seeded from #session-context on page
            // render (null cents when the navbar cache is cold — the render no
            // longer blocks on the balance RPC) and filled by refreshBalance()
            // on load + refreshSession() after any on-chain success. Integer
            // cents / count; used by the synchronous entry-eligibility check
            // during the hold gesture (null fails open — server enforces).
            usdcCents: 0,
            usdtCents: 0,
            tokensAvailable: 0,
            // ENABLE_WEB2_USDC_ENTRY kill-switch (default on). When false the
            // web2 eligibility gate ignores USDC and blocks token-only. Static
            // per render — set once from #session-context, never refreshed.
            web2UsdcEntry: true,
            // Entry-time age gate (ENABLE_AGE_GATE). ageGateRequired = feature
            // on; ageVerified = this user already confirmed DOB. eligibilityBlocker
            // pops the DOB modal at hold-time when required && !verified.
            ageGateRequired: false,
            ageVerified: false,
            get isGuest() { return this.mode === 'guest'; },
            get isWeb2() { return this.mode === 'web2'; },
            get isWeb3() { return this.mode === 'web3'; },
            hydrate: function(ctx) {
              if (!ctx) return;
              this.loggedIn = !!ctx.loggedIn;
              this.mode = ctx.mode || 'guest';
              this.phantomLinked = !!ctx.phantomLinked;
              this.userId = ctx.userId || null;
              this.address = ctx.address || '';
              // null in the payload means "server doesn't know" (preload
              // RPC flake) — preserve null on the store so eligibilityBlocker
              // can fail open rather than zero-block a funded user.
              if (ctx.usdcCents       !== undefined) this.usdcCents       = (ctx.usdcCents       == null) ? null : (ctx.usdcCents       | 0);
              if (ctx.usdtCents       !== undefined) this.usdtCents       = (ctx.usdtCents       == null) ? null : (ctx.usdtCents       | 0);
              if (ctx.tokensAvailable !== undefined) this.tokensAvailable = (ctx.tokensAvailable == null) ? 0    : (ctx.tokensAvailable | 0);
              if (ctx.web2UsdcEntry   !== undefined) this.web2UsdcEntry   = !!ctx.web2UsdcEntry;
              if (ctx.ageGateRequired !== undefined) this.ageGateRequired = !!ctx.ageGateRequired;
              if (ctx.ageVerified     !== undefined) this.ageVerified     = !!ctx.ageVerified;
            }
          });
          (function() {
            var el = document.getElementById('session-context');
            if (!el) return;
            try { Alpine.store('session').hydrate(JSON.parse(el.textContent)); }
            catch (e) { console.warn('[session] context parse failed', e); }
          })();

          // Free-entry-earned modal — the layout owns the modal store, so the
          // seeds level-up modal is triggered HERE off the navbar-seeds-update
          // event (state_fanout.js stays UI-store-agnostic and dispatches it
          // with levelUp:true on a SEEDS_PER_LEVEL crossing). Pop it a beat
          // after the seeds bar starts climbing; swap over any open modal (e.g.
          // the newsletter-success celebration), else open fresh.
          window.addEventListener('navbar-seeds-update', function(e) {
            if (!e || !e.detail || !e.detail.levelUp) return;
            var props = { level: e.detail.newLevel };
            setTimeout(function() {
              try {
                var m = Alpine.store('modals');
                if (!m) return;
                var cur = m.current && m.current();
                // Swap over a dismissible modal (e.g. newsletter-success), but
                // never clobber an in-flight non-dismissible one (the onchain-tx
                // entry modal mid-broadcast) — open on top of that instead.
                if (cur && cur.id && !(cur.props && cur.props.dismissible === false)) {
                  m.swap('free-entry-earned', props);
                } else {
                  m.open('free-entry-earned', props);
                }
              } catch (err) {
                console.warn('[free-entry] modal open failed', err);
              }
            }, 900);
          });

          // solanaModal is a STATELESS proxy over Alpine.store('modals').
          // Every field reads/writes props on the 'onchain-tx' modal entry
          // in the shared stack — there's no duplicate state. The store
          // exists to preserve the existing call-site API (show/success/
          // error/close + field reads) while the underlying source of
          // truth is the modal stack.
          //
          // The redundant auto-close countdown timer that used to live here
          // is gone: modals/blocks/_entry_confirmed.html.erb drives the
          // post-success redirect via the success_card's cta_drain. The
          // onClose callback path is preserved for the world-cup-survivor
          // flow that still relies on it.
          var _txCluster = document.body ? (document.body.dataset.solanaCluster || 'devnet') : 'devnet';
          var _txClusterParam = _txCluster === 'devnet' ? '?cluster=devnet' : '';
          var _onCurrent = function() {
            var c = Alpine.store('modals').current();
            return (c && c.id === 'onchain-tx') ? c : null;
          };
          var _propRead = function(key, fallback) {
            var c = _onCurrent();
            return c ? (c.props[key] !== undefined ? c.props[key] : fallback) : fallback;
          };
          var _propWrite = function(key, value) {
            var c = _onCurrent();
            if (c) c.props[key] = value;
          };
          Alpine.store('solanaModal', {
            _recoveryHandler: null,
            _onCloseHandler:  null,

            show: function(title, message) {
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              // dismissible: false suppresses click-outside + escape while
              // a Phantom signature / RPC confirm is pending — success()/
              // error() flip it to true.
              Alpine.store('modals').open('onchain-tx', {
                dismissible:     false,
                state:           'processing',
                title:           title,
                message:         message,
                txSignature:     null,
                errorMessage:    null,
                seedsEarned:     0,
                seedsTotal:      0,
                seedsLevel:      0,
                lobbyUrl:        null,
                recoveryLabel:   null,
                recoveryPhantom: false,
                // success-card variant + generic-card copy/CTA. Default
                // 'entry' keeps every existing success() caller on the
                // contest-entry celebration; the faucet (and future
                // generic on-chain flows) pass variant: 'generic'.
                successVariant:  'entry',
                successTitle:    null,
                successSubtitle: null,
                ctaLabel:        null,
                ctaHref:         null,
                // confetti on success — resolved in success() per variant
                // (entry: on, generic: off unless opts.confetti:true).
                confetti:        true
              });
            },
            // opts (optional): { variant: 'entry'|'generic', title,
            // subtitle, ctaLabel, ctaHref } for the generic success card.
            // A non-object 3rd arg (legacy autoCloseSeconds — ignored,
            // entry_confirmed drives its own countdown) is safely a no-op.
            success: function(tx, message, opts) {
              var c = _onCurrent();
              if (!c) return;
              if (!opts || typeof opts !== 'object') opts = {};
              c.props.state = 'success';
              c.props.txSignature = tx;
              if (message) c.props.message = message;
              if (opts.variant)          c.props.successVariant  = opts.variant;
              if (opts.title != null)    c.props.successTitle    = opts.title;
              if (opts.subtitle != null) c.props.successSubtitle = opts.subtitle;
              if (opts.ctaLabel != null) c.props.ctaLabel        = opts.ctaLabel;
              if (opts.ctaHref != null)  c.props.ctaHref         = opts.ctaHref;
              // Confetti: explicit opts.confetti wins; otherwise on for
              // entry, off for generic.
              c.props.confetti = (opts.confetti !== undefined)
                ? !!opts.confetti
                : (c.props.successVariant !== 'generic');
              c.props.dismissible = true;
            },
            error: function(msg, title) {
              var c = _onCurrent();
              if (!c) return;
              c.props.state = 'error';
              c.props.errorMessage = msg;
              if (title) c.props.title = title;
              c.props.dismissible = true;
            },
            close: function() {
              var cb = this._onCloseHandler;
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              if (_onCurrent()) Alpine.store('modals').close();
              if (cb) cb();
            },
            setRecovery: function(label, handler, options) {
              var c = _onCurrent();
              if (!c) return;
              c.props.recoveryLabel = label;
              c.props.recoveryPhantom = !!(options && options.phantom);
              this._recoveryHandler = handler;
            },
            _triggerRecovery: function() {
              if (this._recoveryHandler) this._recoveryHandler();
            },

            // resolveEntry(opts) — land on the shared "Entry Confirmed"
            // resolution card no matter which modal is currently open. The
            // web3 path already runs show()+success() (onchain-tx is current).
            // The in-wizard token path is mid-auth-wizard, so we SWAP the auth
            // modal for the onchain-tx success modal (replace, not stack —
            // avoids two stacked modals). Both flows therefore resolve to ONE
            // card. The entry_confirmed block fires its own confetti on mount,
            // so callers don't need to.
            //   opts: { txSignature, lobbyUrl, seedsEarned, seedsTotal, seedsLevel }
            resolveEntry: function(opts) {
              opts = opts || {};
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              var successProps = {
                dismissible:     true,
                state:           'success',
                title:           'Good Luck',
                message:         null,
                txSignature:     opts.txSignature || null,
                errorMessage:    null,
                seedsEarned:     opts.seedsEarned || 0,
                seedsTotal:      opts.seedsTotal  || 0,
                seedsLevel:      opts.seedsLevel  || 0,
                lobbyUrl:        opts.lobbyUrl || null,
                recoveryLabel:   null,
                recoveryPhantom: false,
                successVariant:  'entry',
                successTitle:    null,
                successSubtitle: null,
                ctaLabel:        null,
                ctaHref:         null,
                confetti:        true
              };
              var modals = Alpine.store('modals');
              var cur = modals.current();
              if (cur && cur.id === 'onchain-tx') {
                Object.assign(cur.props, successProps);   // already on the tx modal
              } else if (cur) {
                modals.swap('onchain-tx', successProps);  // mid-wizard → replace (no stack)
              } else {
                modals.open('onchain-tx', successProps);  // nothing open → fresh
              }
            },

            // === Field accessors — read/write 'onchain-tx' props ===
            get visible()         { return !!_onCurrent(); },
            get state()           { return _propRead('state', null); },
            get title()           { return _propRead('title', ''); },
            set title(v)          { _propWrite('title', v); },
            get message()         { return _propRead('message', ''); },
            set message(v)        { _propWrite('message', v); },
            get txSignature()     { return _propRead('txSignature', null); },
            set txSignature(v)    { _propWrite('txSignature', v); },
            get errorMessage()    { return _propRead('errorMessage', null); },
            get seedsEarned()     { return _propRead('seedsEarned', 0); },
            set seedsEarned(v)    { _propWrite('seedsEarned', v); },
            get seedsTotal()      { return _propRead('seedsTotal', 0); },
            set seedsTotal(v)     { _propWrite('seedsTotal', v); },
            get seedsLevel()      { return _propRead('seedsLevel', 0); },
            set seedsLevel(v)     { _propWrite('seedsLevel', v); },
            get lobbyUrl()        { return _propRead('lobbyUrl', null); },
            set lobbyUrl(v)       { _propWrite('lobbyUrl', v); },
            get successVariant()  { return _propRead('successVariant', 'entry'); },
            set successVariant(v) { _propWrite('successVariant', v); },
            get successTitle()    { return _propRead('successTitle', null); },
            set successTitle(v)   { _propWrite('successTitle', v); },
            get successSubtitle() { return _propRead('successSubtitle', null); },
            set successSubtitle(v){ _propWrite('successSubtitle', v); },
            get ctaLabel()        { return _propRead('ctaLabel', null); },
            set ctaLabel(v)       { _propWrite('ctaLabel', v); },
            get ctaHref()         { return _propRead('ctaHref', null); },
            set ctaHref(v)        { _propWrite('ctaHref', v); },
            get confetti()        { return _propRead('confetti', true); },
            set confetti(v)       { _propWrite('confetti', v); },
            get recoveryLabel()   { return _propRead('recoveryLabel', null); },
            get recoveryPhantom() { return _propRead('recoveryPhantom', false); },

            // onClose remains a settable callback (legacy survivor-board flow).
            get onClose()         { return this._onCloseHandler; },
            set onClose(fn)       { this._onCloseHandler = fn; },

            get explorerUrl() {
              var tx = this.txSignature;
              return tx ? ('https://explorer.solana.com/tx/' + tx + _txClusterParam) : null;
            }
          });

          // (Retired) The new-Phantom-signup avatar prompt ('profile' modal)
          // used to auto-open here off a 'show_profile_modal' flag. Usernames
          // auto-generate and there's nothing to complete, so new wallet users
          // go straight to their redirect (tokens/buy, or back to the contest).
        });
        // Alpine.store('modals') + window.StudioModals.holdAtLeast both
        // live in studio-engine's studio/modals/host partial now — see
        // <%%= render "studio/modals/host" %> below.

        // Cross-tab session broadcast — same shape as the tt-tokens channel
        // used by the token-purchase return path. Tabs broadcast on every
        // rehydrate (cheap); peers compare userId + loggedIn against their
        // local store and refetch /account/session_state only on mismatch.
        // The per-tab _sessionTabId prevents a tab from reacting to its own
        // broadcast, so there's no echo loop.
        var _sessionTabId = Math.random().toString(36).slice(2);
        var _sessionChannel = ('BroadcastChannel' in window)
          ? new BroadcastChannel('tm-session') : null;

        function fetchAndHydrateSession() {
          return fetch('/account/session_state', {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            cache: 'no-store'
          })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data) return;
              var store = window.Alpine && Alpine.store && Alpine.store('session');
              if (store && store.hydrate) store.hydrate(data);
              if (data.csrf) {
                var meta = document.querySelector('meta[name="csrf-token"]');
                if (meta) meta.setAttribute('content', data.csrf);
              }
            })
            .catch(function() {});
        }

        if (_sessionChannel) {
          _sessionChannel.addEventListener('message', function(e) {
            var msg = e.data;
            if (!msg || msg.tabId === _sessionTabId) return;
            var store = window.Alpine && Alpine.store && Alpine.store('session');
            if (!store) return;
            var changed = (msg.userId || null) !== (store.userId || null) ||
                          (!!msg.loggedIn) !== (!!store.loggedIn);
            if (changed) fetchAndHydrateSession();
          });
        }

        // Re-seed the canonical session store on every Turbo navigation —
        // auth state can change between page loads. Broadcasts the post-
        // hydrate snapshot so other tabs holding stale state refetch.
        function rehydrateSession() {
          var store = (window.Alpine && Alpine.store) ? Alpine.store('session') : null;
          var el = document.getElementById('session-context');
          if (!store || !el) return;
          try { store.hydrate(JSON.parse(el.textContent)); } catch (e) {}
          if (_sessionChannel) {
            try { _sessionChannel.postMessage({ tabId: _sessionTabId, userId: store.userId, loggedIn: store.loggedIn, mode: store.mode }); } catch (e) {}
          }
        }
        document.addEventListener('turbo:load', rehydrateSession);
        // bfcache restore (back/forward) doesn't fire turbo:load — the
        // snapshot is reused without Turbo re-initializing the page. Without
        // a pageshow rehydrate, $store.session keeps its pre-bfcache value
        // and can drift from the server's truth (e.g. user logged out in
        // another tab). The snapshot's #session-context JSON is itself
        // pre-bfcache state, but re-running hydrate() at minimum re-fires
        // any reactive consumers and resets transient flags.
        window.addEventListener('pageshow', rehydrateSession);

        // visibilitychange rehydrate — when the tab returns from background
        // (>30s away), GET /account/session_state to detect server-side
        // logout / cross-tab login changes and rotate CSRF. Avoids the
        // failure mode where a stale Alpine.store('session') makes the user
        // believe they're logged in until their next POST surfaces 401.
        var _hiddenAt = null;
        document.addEventListener('visibilitychange', function() {
          if (document.hidden) { _hiddenAt = Date.now(); return; }
          if (!_hiddenAt || (Date.now() - _hiddenAt) < 30000) return;
          _hiddenAt = null;
          fetchAndHydrateSession();
        });

      </script>
    <% end %>
    <%= action_cable_meta_tag %>
    <%= render "layouts/studio/head" %>
  </head>

  <%# Body data attrs (intentional, audited 2026-05-23):
        - data-user-id:        read SYNCHRONOUSLY by the user-change-cleanup
                               script below, BEFORE Alpine inits — moving to
                               $store.session.userId would let stale per-user
                               localStorage state leak into the next user's
                               first paint
        - data-wallet-address: read by app/javascript/solana_stores.js's
                               wallet watcher (`_serverAddress()`). The
                               session store's address would be equivalent
                               (both are request-time snapshots) so the
                               migration would be purely cosmetic
        - data-app-environment: deploy environment for client-side network-intent copy.
                               QA Heroku runs Rails.env=production, so this
                               must use QA_ENV instead of Rails.env directly.
        - data-solana-cluster: a build-time constant, used as a small inline
                               default by the solanaModal store init
        - data-solana-rpc-url: env-driven (SOLANA_RPC_URL via Solana::Config).
                               Read by inline TX flows that need a Connection;
                               replaces the previous solanaWeb3.clusterApiUrl('devnet')
                               hardcode that would silently broadcast to the
                               wrong cluster on mainnet flip.
        loggedIn is NO LONGER on the body — the one reader (invite-link
        handler above) now consumes #session-context JSON directly. %>
  <% client_app_environment = AppFlags.qa_environment? ? "qa" : Rails.env.to_s %>
  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }" data-user-id="<%= current_user&.id %>" data-wallet-address="<%= current_user&.solana_address %>" data-app-environment="<%= client_app_environment %>" data-solana-cluster="<%= Solana::Config.devnet? ? 'devnet' : 'mainnet-beta' %>" data-solana-rpc-url="<%= Solana::Config::RPC_URL %>">
    <%# Single source of truth for Alpine x-data factory functions.
        Inlined here (synchronous parse-time script) because importmap
        modules load AFTER Alpine processes x-data. See the partial's
        header for the full diagnostic. %>
    <%= render "shared/alpine_factories" %>
    <%# User-change cleanup. The seeds bar (and the welcome modal flag,
        and any other per-user localStorage state) used to leak across
        sessions when User A logged out and User B logged in in the
        same browser. On every page load we compare the server-rendered
        current user id with the last-seen id in localStorage; if it
        changed (including → '' on logout), purge the user-scoped keys
        and stamp the new id. Runs synchronously before Alpine inits so
        components like _seeds_bar read a clean slate. %>
    <script>
      (function() {
        var current = document.body.dataset.userId || '';
        var last    = localStorage.getItem('lastUserId') || '';
        if (current === last) return;
        // Exact user-scoped keys.
        ['seedsNavbar', 'seedsLevelUp'].forEach(function(k) {
          try { localStorage.removeItem(k); } catch (_) {}
        });
        // Prefix-scoped: phantom_dl_* holds the mobile-Phantom deeplink
        // handshake (nonce + secret + pubkey + user_id + step). Per-user,
        // must NOT survive across a user switch in the same browser.
        try {
          for (var i = localStorage.length - 1; i >= 0; i--) {
            var k = localStorage.key(i);
            if (k && k.indexOf('phantom_dl_') === 0) localStorage.removeItem(k);
          }
        } catch (_) {}
        try {
          if (current) localStorage.setItem('lastUserId', current);
          else         localStorage.removeItem('lastUserId');
        } catch (_) {}
      })();
    </script>
    <%# Auto-open the magic-link welcome modal after a consumed magic link.
        MagicLinksController#consume redirects to the contest (return_to) with
        flash[:magic_link_welcome] = { message:, next: } (NOT a :notice — that
        renders a toast; this celebratory beat wants a modal). We render the
        signal into a JSON script tag and open the modal on load.

        Same wiring as the email-change-pending auto-open in accounts/show, but
        hoisted to the layout because the landing page varies (whichever contest
        the link returned to). turbo-stream <script> tags don't execute, but this
        is a redirect + normal page render so an inline page script runs fine.

        Timing: the redirect can land via Turbo Drive (body swap) on an in-app
        navigation OR a hard load (cold click from the email). We bind to
        turbo:load (fires on every Turbo navigation incl. the post-redirect
        render AND the initial hard load) with a one-shot guard so a back/forward
        turbo:load can't replay a stale flash, and poll briefly for the modals
        store in case turbo:load wins the race against Alpine boot on cold paint.
        Flash is single-render so the JSON tag is absent on any later visit. %>
    <% if flash[:magic_link_welcome].present? %>
      <%# Flash round-trips through the session cookie as JSON, so the hash comes
          back with STRING keys; with_indifferent_access lets us read it symbol-
          style. %>
      <% welcome = flash[:magic_link_welcome].with_indifferent_access %>
      <script type="application/json" id="magic-link-welcome-data">
        <%= raw({ message: welcome[:message], username: welcome[:username], next: welcome[:next] }.to_json) %>
      </script>
      <%# Stable flag (the JSON tag above gets consumed + removed by the
          auto-open script, so the contest board can't rely on it). The board
          reads this to defer its post-login tokens-picker (both the ?picks
          auto-enter path and the pendingAuthStep path) until AFTER the welcome
          modal has had its ~3s success beat. %>
      <script>window.__magicLinkWelcome = true;</script>
    <% end %>
    <%# Returning logins + new-user-on-a-contest get a quiet toast instead of the
        celebratory modal (MagicLinksController sets flash[:auth_toast]). Dispatched
        as a 'toast' window event so we can give it a real title (the flash→toast
        path only carries a message). %>
    <% if flash[:auth_toast].present? %>
      <% auth_toast = flash[:auth_toast].with_indifferent_access %>
      <script type="application/json" id="auth-toast-data">
        <%= raw({ title: auth_toast[:title], message: auth_toast[:message] }.to_json) %>
      </script>
    <% end %>
    <script>
      (function() {
        var fired = false;
        function openMagicLinkWelcome() {
          if (fired) return;
          var el = document.getElementById('magic-link-welcome-data');
          if (!el) return;
          var data;
          try { data = JSON.parse(el.textContent); } catch (e) { return; }
          var attempts = 0;
          (function tryOpen() {
            var m = (window.Alpine && Alpine.store) ? Alpine.store('modals') : null;
            if (m && typeof m.open === 'function') {
              fired = true;
              m.open('magic-link-welcome', { message: data.message, username: data.username, next: data.next });
              // Drop the one-shot payload so a later turbo:load (bfcache restore,
              // re-navigation) can't replay it.
              el.remove();
              return;
            }
            if (attempts++ < 50) setTimeout(tryOpen, 50); // up to ~2.5s for Alpine boot
          })();
        }
        document.addEventListener('turbo:load', openMagicLinkWelcome);
        if (document.readyState !== 'loading') openMagicLinkWelcome();
        else document.addEventListener('DOMContentLoaded', openMagicLinkWelcome);
      })();

      // Auth toast (welcome back / signed-in). The toast manager's
      // @toast.window listener is wired during Alpine's DOM walk (NOT at
      // alpine:init, when the stores register) — so we dispatch on
      // alpine:initialized, which fires AFTER that walk, to avoid racing the
      // listener and dropping the event. Drop the one-shot payload so a later
      // turbo:load can't replay it.
      (function() {
        var fired = false;
        function fireAuthToast() {
          if (fired) return;
          var el = document.getElementById('auth-toast-data');
          if (!el) return;
          var data;
          try { data = JSON.parse(el.textContent); } catch (e) { return; }
          fired = true;
          el.remove();
          window.dispatchEvent(new CustomEvent('toast', { detail: {
            type: 'notice', title: data.title, message: data.message, duration: 5000
          } }));
        }
        // Alpine already started (its components — incl. the toast manager — are
        // initialized) → fire now; otherwise wait for it to finish starting.
        if (window.Alpine && window.Alpine.version) fireAuthToast();
        else document.addEventListener('alpine:initialized', fireAuthToast, { once: true });
        document.addEventListener('turbo:load', fireAuthToast);
      })();
    </script>
    <%= render "layouts/studio/flash" %>
    <%= render "layouts/navbar" %>

    <div class="max-w-7xl mx-auto px-4">
      <%= yield %>
    </div>

    <%# Global footer — brand + site-legitimacy links (About / Contact / Terms /
        Privacy) + on-chain transparency pages. Rendered in the app layout only;
        the landing funnel layout omits it on purpose to keep the CTA focused. %>
    <%= render "shared/footer" %>

    <%= render "shared/solana_errors" %>
    <%# Generic modal host from studio-engine. Owns Alpine.store('modals'),
        the StudioModals.holdAtLeast helper, the backdrop / scroll lock /
        escape / click-outside / ARIA / transitions, and renders this app's
        content partials by id (registered in the block below). %>
    <%= render "studio/modals/host" do %>
      <%# Email-change-pending — opened on the /account page after a held
          email change (AccountsController#update). Informational handoff:
          "go click the confirm link in your inbox." Auto-opened from the
          server flash[:email_change_pending] via the inline script in
          accounts/show.html.erb. %>
      <template x-if="$store.modals.current().id === 'email-change-pending'">
        <%= render "modals/email_change_pending" %>
      </template>
      <%# Magic-link welcome — opened on the contest landing page after a
          consumed magic link (MagicLinksController#consume). Celebration +
          ~2.5s auto-redirect to the entry-tokens upsell. Auto-opened from the
          server flash[:magic_link_welcome] via the inline script below. %>
      <template x-if="$store.modals.current().id === 'magic-link-welcome'">
        <%= render "modals/magic_link_welcome" %>
      </template>
      <%# Tier-1 "general" rate-limit wait modal — opened by the authedFetch 429
          interceptor (solana_utils.js) when a general-tier throttle trips. %>
      <template x-if="$store.modals.current().id === 'rate-limit-general'">
        <%= render "modals/rate_limit_general" %>
      </template>
      <template x-if="$store.modals.current().id === 'auth'">
        <%= render "modals/auth" %>
      </template>
      <%# Entry-time age gate (ENABLE_AGE_GATE) — DOB verification, fires in the
          hold-to-confirm flow before the Get Entry Tokens modal. %>
      <template x-if="$store.modals.current().id === 'age-verify'">
        <%= render "modals/age_verify" %>
      </template>
      <%# Multi-wallet "Connect Wallet" picker (reown-style). Opened directly
          from the standalone Solana button, or swapped-into from the auth
          modal's Solana button (board#openWalletConnect saves the cart first
          and passes returnUrl). %>
      <template x-if="$store.modals.current().id === 'wallet-connect'">
        <%= render "modals/wallet_connect" %>
      </template>
      <template x-if="$store.modals.current().id === 'wallet-changed'">
        <%= render "modals/wallet_changed" %>
      </template>
      <template x-if="$store.modals.current().id === 'network-guard'">
        <%= render "modals/network_guard" %>
      </template>
      <%# On-chain TX modal (replaces shared/_solana_modal.html.erb).
          State lives in Alpine.store('solanaModal') — show/success/
          error/close on that store push/pop this id onto the stack. %>
      <template x-if="$store.modals.current().id === 'onchain-tx'">
        <%= render "modals/onchain_tx" %>
      </template>
      <%# "It Begins" — fired client-side when a contest's lock countdown hits
          zero (contests/_timestamp_countdown). Celebratory; the draining CTA
          reloads the lobby into its locked/leaderboard view. %>
      <template x-if="$store.modals.current().id === 'it-begins'">
        <%= render "modals/it_begins" %>
      </template>
      <%# Add Funds hub — rail picker (Coinbase / PayPal / Venmo / Stripe)
          reached by swap() from the Get Entry Tokens picker. Registered
          ungated (like 'auth', which opens it) so an in-session signup that
          rendered the layout while logged out can still reach it; each rail
          self-gates via onramp_rail_visible?. The Coinbase rail hands off to
          cdp-ramp (registered under logged_in? + ENABLE_CDP_RAMP below). %>
      <template x-if="$store.modals.current().id === 'onramp-hub'">
        <%= render "modals/onramp_hub" %>
      </template>
      <%# Top Up Wallet — the Coinbase-forward FIRST funds modal at the entry
          blocker (selectionBoard#showWalletTopup), replacing the pack picker at
          that trigger. Primary CTA buys USDC via cdp-ramp; the web2 kill-switch
          (ENABLE_WEB2_USDC_ENTRY off) degrades it client-side to the entry-token
          rail (tokenFallback). Registered ungated alongside onramp-hub (which it
          links into) for the same reason: it can appear right after an in-session
          signup where the server-rendered logged_in? was still false. The
          Coinbase CTA hands off to cdp-ramp (registered under logged_in? +
          ENABLE_CDP_RAMP below). %>
      <template x-if="$store.modals.current().id === 'wallet-topup'">
        <%= render "modals/wallet_topup" %>
      </template>
      <% if logged_in? %>
        <template x-if="$store.modals.current().id === 'username'">
          <%= render "modals/username" %>
        </template>
        <template x-if="$store.modals.current().id === 'newsletter-email'">
          <%= render "modals/newsletter_email" %>
        </template>
        <%# Quest / newsletter flow modals (v0.23 quest). quest-success is the
            off-contest-page celebration after a username change; the newsletter
            quartet (subscribe → success, unsubscribe-confirm → goodbye) drives the
            account-page newsletter card + the quest-success "Subscribe for +25 more"
            handoff. All gate on current_user (subscribed?/email), so they live
            inside this logged_in? block. %>
        <template x-if="$store.modals.current().id === 'quest-success'">
          <%= render "modals/quest_success" %>
        </template>
        <template x-if="$store.modals.current().id === 'newsletter-subscribe'">
          <%= render "modals/newsletter_subscribe" %>
        </template>
        <template x-if="$store.modals.current().id === 'newsletter-success'">
          <%= render "modals/newsletter_success" %>
        </template>
        <template x-if="$store.modals.current().id === 'unsubscribe-confirm'">
          <%= render "modals/unsubscribe_confirm" %>
        </template>
        <template x-if="$store.modals.current().id === 'unsubscribe-goodbye'">
          <%= render "modals/unsubscribe_goodbye" %>
        </template>
        <%# free-entry-earned — level-up (every 100 seeds) free-entry celebration,
            opened by the seeds StateFanout level-up handler. %>
        <template x-if="$store.modals.current().id === 'free-entry-earned'">
          <%= render "modals/free_entry_earned" %>
        </template>
      <% end %>
      <%# crop-photo gets pushed on top of whatever modal owns the avatar
          cropper (profile modal, complete_profile, /account). Not gated by
          logged_in? because complete_profile renders before the profile is
          finished. %>
      <template x-if="$store.modals.current().id === 'crop-photo'">
        <%= render "studio/modals/crop_photo" %>
      </template>
      <%# Generic loading card (submitFormWithProgress) — banner save, avatar upload. %>
      <template x-if="$store.modals.current().id === 'saving'">
        <%= render "studio/modals/saving" %>
      </template>
      <%# wallet-deposit — opened by the entry-eligibility blocker when a
          web3 user lacks USDC/USDT for the entry fee. Symmetric to the
          tokens-picker step inside auth for the web2 path. %>
      <% if logged_in? %>
        <template x-if="$store.modals.current().id === 'wallet-deposit'">
          <%= render "modals/wallet_deposit" %>
        </template>
        <%# cdp-ramp — Coinbase buy-USDC / cash-out flow (spec section 14).
            Flag-gated so the dark feature ships no modal markup while
            ENABLE_CDP_RAMP is unset (the kill-switch also 404s every /cdp
            endpoint via Cdp::BaseController; the inert cdpRampFlow factory
            in shared/_alpine_factories is the only remnant). Opened by the
            /wallet buttons, the wallet-deposit modal's Coinbase option, and
            the /cdp return pages' deep-link. %>
        <% if AppFlags.cdp_ramp? %>
          <template x-if="$store.modals.current().id === 'cdp-ramp'">
            <%= render "modals/cdp_ramp" %>
          </template>
        <% end %>
      <% end %>


      <%# Template reference modals — registered in non-production only so
          they don't add JS surface area to prod. Surfaced at the top of
          /admin/modals as "Templates" so new modal work has copy-paste
          starting points. %>
      <% unless Rails.env.production? %>
        <template x-if="$store.modals.current().id === 'template-form'">
          <%= render "modals/templates/form" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-action'">
          <%= render "modals/templates/action" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-status'">
          <%= render "modals/templates/status" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-success'">
          <%= render "modals/templates/success" %>
        </template>
        <template x-if="$store.modals.current().id === 'template-wizard'">
          <%= render "modals/templates/wizard" %>
        </template>
      <% end %>
    <% end %>


    <% if logged_in? && current_user.solana_connected? %>
      <%= render "shared/phantom_watcher" %>
    <% end %>
  </body>
</html>

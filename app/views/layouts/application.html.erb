<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <script src="https://unpkg.com/@solana/web3.js@1/lib/index.iife.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tweetnacl@1.0.3/nacl-fast.min.js"></script>
    <script src="https://cdn.logr-in.com/LogRocket.min.js" crossorigin="anonymous"></script>
    <script>window.LogRocket && window.LogRocket.init('jodsqq/mcritchie-studio');</script>
    <% content_for :head do %>
      <script>
        <% if logged_in? && current_user %>
          window.LogRocket && window.LogRocket.identify('<%= current_user.slug %>', {
            name: '<%= j(current_user.username || current_user.name || "") %>',
            email: '<%= j(current_user.email || "") %>'
          });
        <% end %>
        <% if logged_in? && Solana::Config.devnet? %>
          document.addEventListener('turbo:load', () => {
            setTimeout(function() { showNavSpinner(); refreshBalance().finally(function() { hideNavSpinner(); }); }, 1500);
          });
        <% end %>

        // Invite link: capture ?ref= param into localStorage
        (function() {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('inviter_slug', ref);
            params.delete('ref');
            var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            history.replaceState(null, '', clean);
          }
        })();

        // Invite link: save inviter on login
        document.addEventListener('turbo:load', function() {
          var loggedIn = document.body.getAttribute('data-logged-in') === 'true';
          var inviterSlug = localStorage.getItem('inviter_slug');
          if (loggedIn && inviterSlug) {
            fetch('/account/set_inviter', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
              body: JSON.stringify({ inviter_slug: inviterSlug })
            }).then(function(r) {
              if (r.ok) localStorage.removeItem('inviter_slug');
            }).catch(function() {});
          }
        });
      </script>
      <script type="application/json" id="session-context"><%= wallet_context.to_json.html_safe %></script>
      <script>
        // --- Inline Solana stores + components ---
        // Alpine's defer script fires alpine:init BEFORE importmap modules execute.
        // These must be inline so they're available when Alpine processes the DOM.
        // The full wallet_provider.js module overwrites this stub after modules load.

        // Minimal wallet provider stub — enough for Alpine x-data evaluation
        window.walletProvider = {
          isAvailable: function() {
            return !!(window.__WALLET_KEYPAIR_SECRET) || !!(window.phantom && window.phantom.solana && window.phantom.solana.isPhantom);
          },
          isMobile: function() {
            return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (navigator.maxTouchPoints > 1 && /Macintosh/.test(navigator.userAgent));
          },
          detect: function() {
            return null;
          }
        };

        // solanaWalletConnect — MUST stay inline because Alpine processes
        // x-data="solanaWalletConnect(...)" before importmap modules load.
        window.solanaWalletConnect = function(linkMode, currentUserId) {
          return {
            connecting: false,
            error: null,
            statusText: 'Connect Wallet',
            walletAvailable: window.walletProvider.isAvailable(),
            isMobile: window.walletProvider.isMobile(),
            async connect() {
              this.connecting = true;
              this.error = null;
              try {
                var provider = window.walletProvider.detect();
                if (!provider) throw new Error('No wallet available');
                this.statusText = 'Connecting...';
                var resp = await provider.connect();
                var pubkeyB58 = resp.publicKey.toBase58();
                this.statusText = 'Fetching nonce...';
                var data = await (await fetch('/auth/solana/nonce')).json();
                var domain = window.location.host;
                // OPSEC-005: when linking (logged-in), bind the message to the active session's user
                var userIdLine = (linkMode && currentUserId) ? ('User-ID: ' + currentUserId + '\n\n') : '';
                var message = domain + ' wants you to sign in with your Solana account:\n' + pubkeyB58 + '\n\n' + userIdLine + 'Sign in to Turf Monster\n\nNonce: ' + data.nonce;
                this.statusText = 'Sign message in wallet...';
                var signed = await provider.signMessage(new TextEncoder().encode(message), 'utf8');
                var signatureB58 = encodeBase58(signed.signature);
                this.statusText = 'Verifying...';
                var verifyUrl = linkMode ? '/account/link_solana' : '/auth/solana/verify';
                var result = await (await fetch(verifyUrl, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
                  body: JSON.stringify({ message: message, signature: signatureB58, pubkey: pubkeyB58 })
                })).json();
                if (result.success) {
                  if (result.new_user) localStorage.setItem('show_profile_modal', 'true');
                  window.location.href = result.redirect || '/';
                } else {
                  this.error = result.error || 'Verification failed';
                  this.statusText = 'Connect Wallet';
                  this.connecting = false;
                }
              } catch (e) {
                this.error = (e.code === 4001) ? 'Signature rejected' : (e.message || 'Connection failed');
                this.statusText = 'Connect Wallet';
                this.connecting = false;
              }
            }
          };
        };

        // Solana modal store — registered when Alpine starts
        document.addEventListener('alpine:init', function() {
          if (Alpine.store('solanaModal')) return;

          // Canonical session store — the single source of truth for the
          // viewer's auth/wallet state (guest / web2 / web3). Seeded from the
          // server-rendered #session-context (SessionContext#to_h) on every
          // page render; the whole UI branches on $store.session.mode.
          Alpine.store('session', {
            loggedIn: false,
            mode: 'guest',
            phantomLinked: false,
            userId: null,
            address: '',
            get isGuest() { return this.mode === 'guest'; },
            get isWeb2() { return this.mode === 'web2'; },
            get isWeb3() { return this.mode === 'web3'; },
            hydrate: function(ctx) {
              if (!ctx) return;
              this.loggedIn = !!ctx.loggedIn;
              this.mode = ctx.mode || 'guest';
              this.phantomLinked = !!ctx.phantomLinked;
              this.userId = ctx.userId || null;
              this.address = ctx.address || '';
            }
          });
          (function() {
            var el = document.getElementById('session-context');
            if (!el) return;
            try { Alpine.store('session').hydrate(JSON.parse(el.textContent)); }
            catch (e) { console.warn('[session] context parse failed', e); }
          })();

          // solanaModal is a STATELESS proxy over Alpine.store('modals').
          // Every field reads/writes props on the 'onchain-tx' modal entry
          // in the shared stack — there's no duplicate state. The store
          // exists to preserve the existing call-site API (show/success/
          // error/close + field reads) while the underlying source of
          // truth is the modal stack.
          //
          // The redundant auto-close countdown timer that used to live here
          // is gone: modals/blocks/_entry_confirmed.html.erb drives the
          // post-success redirect via the success_card's cta_drain. The
          // onClose callback path is preserved for the world-cup-survivor
          // flow that still relies on it.
          var _txCluster = document.body ? (document.body.dataset.solanaCluster || 'devnet') : 'devnet';
          var _txClusterParam = _txCluster === 'devnet' ? '?cluster=devnet' : '';
          var _onCurrent = function() {
            var c = Alpine.store('modals').current();
            return (c && c.id === 'onchain-tx') ? c : null;
          };
          var _propRead = function(key, fallback) {
            var c = _onCurrent();
            return c ? (c.props[key] !== undefined ? c.props[key] : fallback) : fallback;
          };
          var _propWrite = function(key, value) {
            var c = _onCurrent();
            if (c) c.props[key] = value;
          };
          Alpine.store('solanaModal', {
            _recoveryHandler: null,
            _onCloseHandler:  null,

            show: function(title, message) {
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              // dismissible: false suppresses click-outside + escape while
              // a Phantom signature / RPC confirm is pending — success()/
              // error() flip it to true.
              Alpine.store('modals').open('onchain-tx', {
                dismissible:     false,
                state:           'processing',
                title:           title,
                message:         message,
                txSignature:     null,
                errorMessage:    null,
                seedsEarned:     0,
                seedsTotal:      0,
                seedsLevel:      0,
                lobbyUrl:        null,
                recoveryLabel:   null,
                recoveryPhantom: false
              });
            },
            success: function(tx, message /*, autoCloseSeconds (ignored — entry_confirmed drives the countdown) */) {
              var c = _onCurrent();
              if (!c) return;
              c.props.state = 'success';
              c.props.txSignature = tx;
              if (message) c.props.message = message;
              c.props.dismissible = true;
            },
            error: function(msg, title) {
              var c = _onCurrent();
              if (!c) return;
              c.props.state = 'error';
              c.props.errorMessage = msg;
              if (title) c.props.title = title;
              c.props.dismissible = true;
            },
            close: function() {
              var cb = this._onCloseHandler;
              this._recoveryHandler = null;
              this._onCloseHandler = null;
              if (_onCurrent()) Alpine.store('modals').close();
              if (cb) cb();
            },
            setRecovery: function(label, handler, options) {
              var c = _onCurrent();
              if (!c) return;
              c.props.recoveryLabel = label;
              c.props.recoveryPhantom = !!(options && options.phantom);
              this._recoveryHandler = handler;
            },
            _triggerRecovery: function() {
              if (this._recoveryHandler) this._recoveryHandler();
            },

            // === Field accessors — read/write 'onchain-tx' props ===
            get visible()         { return !!_onCurrent(); },
            get state()           { return _propRead('state', null); },
            get title()           { return _propRead('title', ''); },
            set title(v)          { _propWrite('title', v); },
            get message()         { return _propRead('message', ''); },
            set message(v)        { _propWrite('message', v); },
            get txSignature()     { return _propRead('txSignature', null); },
            set txSignature(v)    { _propWrite('txSignature', v); },
            get errorMessage()    { return _propRead('errorMessage', null); },
            get seedsEarned()     { return _propRead('seedsEarned', 0); },
            set seedsEarned(v)    { _propWrite('seedsEarned', v); },
            get seedsTotal()      { return _propRead('seedsTotal', 0); },
            set seedsTotal(v)     { _propWrite('seedsTotal', v); },
            get seedsLevel()      { return _propRead('seedsLevel', 0); },
            set seedsLevel(v)     { _propWrite('seedsLevel', v); },
            get lobbyUrl()        { return _propRead('lobbyUrl', null); },
            set lobbyUrl(v)       { _propWrite('lobbyUrl', v); },
            get recoveryLabel()   { return _propRead('recoveryLabel', null); },
            get recoveryPhantom() { return _propRead('recoveryPhantom', false); },

            // onClose remains a settable callback (legacy survivor-board flow).
            get onClose()         { return this._onCloseHandler; },
            set onClose(fn)       { this._onCloseHandler = fn; },

            get explorerUrl() {
              var tx = this.txSignature;
              return tx ? ('https://explorer.solana.com/tx/' + tx + _txClusterParam) : null;
            }
          });

          // Auto-open the profile modal once after a new Phantom signup.
          // The wallet verify path sets localStorage 'show_profile_modal'
          // on result.new_user; consume it here and route through the
          // shared modal stack. setTimeout defers past Alpine's own init
          // pass so the store is fully wired when we call open().
          if (localStorage.getItem('show_profile_modal') === 'true') {
            localStorage.removeItem('show_profile_modal');
            setTimeout(function() {
              var m = Alpine.store('modals');
              if (m) m.open('profile');
            }, 300);
          }
        });
        // Alpine.store('modals') + window.StudioModals.holdAtLeast both
        // live in studio-engine's studio/modals/host partial now — see
        // <%%= render "studio/modals/host" %> below.

        // Re-seed the canonical session store on every Turbo navigation —
        // auth state can change between page loads.
        document.addEventListener('turbo:load', function() {
          var store = (window.Alpine && Alpine.store) ? Alpine.store('session') : null;
          var el = document.getElementById('session-context');
          if (!store || !el) return;
          try { store.hydrate(JSON.parse(el.textContent)); } catch (e) {}
        });

      </script>
    <% end %>
    <%= action_cable_meta_tag %>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }" data-logged-in="<%= logged_in? %>" data-wallet-address="<%= current_user&.solana_address %>" data-solana-cluster="<%= Solana::Config.devnet? ? 'devnet' : 'mainnet-beta' %>">
    <%= render "layouts/studio/flash" %>
    <%= render "layouts/navbar" %>

    <div class="max-w-7xl mx-auto px-4">
      <%= yield %>
    </div>

    <%= render "shared/solana_errors" %>
    <%# Generic modal host from studio-engine. Owns Alpine.store('modals'),
        the StudioModals.holdAtLeast helper, the backdrop / scroll lock /
        escape / click-outside / ARIA / transitions, and renders this app's
        content partials by id (registered in the block below). %>
    <%= render "studio/modals/host" do %>
      <template x-if="$store.modals.current().id === 'check-email'">
        <%= render "modals/check_email" %>
      </template>
      <template x-if="$store.modals.current().id === 'auth'">
        <%= render "modals/auth" %>
      </template>
      <%# On-chain TX modal (replaces shared/_solana_modal.html.erb).
          State lives in Alpine.store('solanaModal') — show/success/
          error/close on that store push/pop this id onto the stack. %>
      <template x-if="$store.modals.current().id === 'onchain-tx'">
        <%= render "modals/onchain_tx" %>
      </template>
      <% if logged_in? %>
        <template x-if="$store.modals.current().id === 'profile'">
          <%= render "modals/profile" %>
        </template>
      <% end %>
    <% end %>
    <% if logged_in? && current_user.solana_connected? %>
      <%= render "shared/phantom_watcher" %>
    <% end %>
  </body>
</html>

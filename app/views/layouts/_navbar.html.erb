<%# Navbar partial — rendered in application layout and admin navbar review.
    Locals (all optional):
      show_logged_in — override for logged_in? (default: real session)
      preview        — if true, disables scroll handler and sticky positioning
%>
<% show_user = local_assigns.fetch(:show_logged_in, logged_in?) %>
<% is_preview = local_assigns.fetch(:preview, false) %>

<%# z-[125] sits ABOVE the modal host's z-[120] backdrop so the navbar
    (and especially the 🎟️ Entry badge) stays bright during a token-
    mint celebration instead of being dimmed by the modal overlay.
    The modal's escape key + X button still close it; clicking the
    navbar no longer counts as "click outside" — acceptable trade. %>

<%# Toast z-index override now lives in application.tailwind.css as CSS
    custom properties (--studio-toast-z / --studio-toast-blur-z), read
    by studio-engine 0.4.10+. The previous inline <style> block here
    needed !important to beat the engine's old inline `style="z-index:60"`;
    the engine no longer uses inline, so the var-based override wins
    via normal cascade. %>
<header data-navbar-root x-data="{ scrolled: false }" <%= '@scroll.window="scrolled = scrolled ? (window.scrollY > 5) : (window.scrollY > 60)"'.html_safe unless is_preview %>
        class="<%= is_preview ? 'bg-page' : 'sticky top-0 z-[125] bg-page transition-shadow duration-300' %>"
        :class="scrolled && 'shadow-lg border-b border-subtle is-scrolled'">
  <% unless is_preview || Rails.env.production? %>
    <%# Env banner — rides inside the sticky header so it stays visible and
        never leaves a phantom gap for layout math (see --nav-h below). %>
    <div style="background:#eab308; color:#000; font-size:12px; font-weight:700; padding:2px 12px; position:relative;">
      <%= Rails.env.capitalize %> Environment
      <span style="position:absolute; right:8px; top:50%; transform:translateY(-50%); display:flex; align-items:center; gap:6px;">
        <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                class="rounded cursor-pointer"
                style="font-size:10px; font-weight:700; padding:1px 6px;"
                :style="$store.devMode ? 'background:rgba(0,0,0,0.4); color:#fff;' : 'background:rgba(0,0,0,0.2); color:#000;'">DEV MODE</button>
        <% if Solana::Config.devnet? %>
          <span class="rounded" style="font-size:10px; font-weight:700; padding:1px 6px; background:rgba(0,0,0,0.2);">DEVNET</span>
        <% end %>
      </span>
    </div>
  <% end %>
  <%# .user-nav-col / .nav-title / .nav-logo / .nav-logo-link responsive
      rules live in application.tailwind.css @layer utilities (migrated
      2026-05-24, dropped the 10 !important workarounds). %>
  <div class="flex items-center <%= is_preview ? 'py-6' : 'transition-all duration-300' %>"
       <%= ":class=\"scrolled ? 'py-2' : 'py-6'\"".html_safe unless is_preview %>>
    <%# Left side: logo + nav %>
    <div class="flex-1 px-4">
      <div class="flex items-center gap-6">
        <%= link_to root_path, class: "nav-logo-link inline-flex items-center gap-3 group" do %>
          <img src="/icon-192.png" alt="Turf Totals" width="48" height="48" class="nav-logo rounded-full shadow-lg <%= is_preview ? 'w-12 h-12' : 'group-hover:scale-105 transition-all duration-300' %>"
               <%= "x-bind:class=\"scrolled ? 'w-8 h-8' : 'w-12 h-12'\"".html_safe unless is_preview %>>
          <h1 class="nav-title font-extrabold text-heading tracking-tight <%= is_preview ? 'text-3xl' : 'transition-all duration-300' %>"
              <%= "x-bind:class=\"scrolled ? 'text-xl' : 'text-3xl'\"".html_safe unless is_preview %>><span class="dm-salmon">Turf</span><span class="dm-yellow text-primary">Totals</span></h1>
        <% end %>
        <nav class="dm-teal hidden md:flex items-center gap-4">
          <%= link_to "Contests", contests_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
          <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
          <%= link_to "Reserves", proof_of_reserves_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
          <%= render "components/geo_badge" %>
        </nav>
      </div>
    </div>
    <%# Right side: user nav (matches sidebar width) %>
    <% balance_html = capture do %>
      <%# Hide the $X balance link when it's $0 AND the user already has
          a free-entry token to show — the 🎟️ badge in _user_nav is
          enough; a redundant "$0" just clutters the navbar. The
          equivalent rule re-applies live via updateNavTokens /
          refreshBalance after mints + consumes. %>
      <%# display_balance is nil while the navbar cache is cold ("loading") —
          the server no longer blocks the render on the balance RPC, the
          client-side refreshBalance() fills [data-balance-display] on load.
          Render a subtle "$·" placeholder (NOT a misleading hard "$0") and
          never apply the hide-on-$0-with-token rule until we have a real
          number; refreshBalance re-applies it once the value lands. %>
      <% balance_loading = display_balance.nil? %>
      <% usdc            = display_balance.to_f %>
      <% balance_zero    = !balance_loading && usdc.zero? %>
      <% has_tokens      = (current_user.entry_token_balance rescue 0).positive? %>
      <% hide_balance    = balance_zero && has_tokens %>
      <%# USDC balance link. Free-entry tokens are surfaced by the 🎟️
          badge in _user_nav (next to the balance), not by a second
          balance-style link here. %>
      <%= link_to wallet_path, class: "dm-blue font-mono text-primary hover:text-primary-600 transition-all duration-300 font-bold leading-none mr-1 #{'hidden' if hide_balance}", "x-bind:class": "scrolled ? 'text-lg' : 'text-xl'", data: { balance_display: true } do %><% if balance_loading %><span class="opacity-40">$·</span><% else %>$<%= usdc.to_i %><% end %><% end %>
    <% end if show_user %>
    <div class="user-nav-col dm-purple flex-shrink-0 pl-0 pr-4 md:px-4">
      <% if show_user %>
        <%= render "components/user_nav", balance_html: balance_html %>
      <% else %>
        <div class="flex items-center justify-end gap-3">
          <span class="hidden md:flex"><%= render "components/theme_toggle_morph" %></span>
          <%# Single unified CTA — login + signup are one create-or-login flow
              at /signin (magic link / Google / wallet all find-or-create). %>
          <%= link_to "Sign in", signin_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
  <%# Mobile sub-navbar: compact row of links hidden on desktop %>
  <div class="dm-coral flex md:hidden items-center gap-3 px-4 py-1.5 border-t border-subtle bg-surface-alt">
    <%= link_to "Contests", contests_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
    <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
    <%= link_to "Reserves", proof_of_reserves_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
    <%= render "components/geo_badge" %>
    <span class="ml-auto flex items-center gap-3">
      <%= render "components/admin_dropdown" %>
      <%= render "components/theme_toggle_morph" %>
    </span>
  </div>
</header>
<%# --nav-h + overflow-anchor are shipped by studio-engine (>=0.4.4) from
    layouts/studio/_head.html.erb — no per-app navbar script needed. %>


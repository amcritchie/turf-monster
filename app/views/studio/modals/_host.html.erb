<%#
  Local override of studio-engine's modal host. The ONLY divergence
  from the gem partial is the card-level transition classes — we
  swap the engine's plain `transition ease-out duration-200` for the
  thematic `modal-card-enter` / `modal-card-leave` classes (defined
  in application.tailwind.css). Backdrop fade + scroll lock + escape
  + click-outside + ARIA all stay identical so future engine bug
  fixes to those behaviors can be cherry-picked in.

  Promote back to studio-engine in a future release as a configurable
  set of transition class names; this local copy is the dev preview.
%>
<%# body.modal-open + @keyframes studio-modal-drain live in
    application.tailwind.css (migrated 2026-05-24). %>
<script>
  (function() {
    // === StudioModals helpers ===========================================
    window.StudioModals = window.StudioModals || {};
    window.StudioModals.holdAtLeast = function(minMs) {
      var startedAt = Date.now();
      return {
        then: function(callback) {
          var remaining = Math.max(0, minMs - (Date.now() - startedAt));
          if (remaining === 0) { callback(); return; }
          setTimeout(callback, remaining);
        }
      };
    };

    // === Alpine.store('modals') — the stack ============================
    //
    // CLOSE_ANIM_MS: keep in sync with the modal-card-unmount + modal-
    // backdrop-unmount keyframes in application.tailwind.css. When
    // close() is called, we set _closing on the entry so the host
    // can swap in the unmount classes, then actually pop the stack
    // after this many ms so the animation plays before the DOM
    // unmounts. If you change the keyframe durations there, bump
    // this to match.
    var CLOSE_ANIM_MS = 220;

    document.addEventListener('alpine:init', function() {
      if (Alpine.store('modals')) return;
      Alpine.store('modals', {
        stack: [],
        open: function(id, props, opts) {
          props = props || {};
          opts  = opts  || {};
          if (opts.replace && this.stack.length > 0) {
            this.stack[this.stack.length - 1] = { id: id, props: props };
          } else {
            this.stack.push({ id: id, props: props });
          }
          this._sync();
        },
        close: function() {
          var self = this;
          var entry = this.current();
          if (!entry || entry._closing) return;  // empty stack or already closing
          // Flip _closing → Alpine reactivity adds the modal-card-unmount
          // and modal-backdrop-unmount classes via the :class bindings on
          // the host. Wait CLOSE_ANIM_MS for the animation to play, then
          // splice THIS specific entry from the stack (not pop() — the
          // top might have changed if another open() ran during the
          // close window).
          entry._closing = true;
          setTimeout(function() {
            var idx = self.stack.indexOf(entry);
            if (idx >= 0) {
              self.stack.splice(idx, 1);
              self._sync();
            }
          }, CLOSE_ANIM_MS);
        },
        closeAll: function() {
          // No animation — used by Turbo before-cache + bfcache cleanup
          // where the user is navigating away and we just need the DOM
          // clean immediately.
          this.stack = [];
          this._sync();
        },
        // Drops every modal whose props don't explicitly opt out of dismissal
        // (i.e. dismissible: false). Mirrors studio-engine v0.4.11. Used by
        // the bfcache + Turbo snapshot cleanup below so an in-flight on-chain
        // TX modal — which sets dismissible: false to forbid losing its UI
        // mid-flight — survives a back/forward navigation; the still-running
        // JS promise's solanaModal.success() resolves against a non-empty
        // stack. Celebratory modals (default dismissible: true) still clear.
        closeAllDismissible: function() {
          this.stack = this.stack.filter(function(modal) {
            return modal.props && modal.props.dismissible === false;
          });
          this._sync();
        },
        isOpen: function(id) {
          for (var i = 0; i < this.stack.length; i++) {
            if (this.stack[i].id === id) return true;
          }
          return false;
        },
        current: function() {
          return this.stack.length ? this.stack[this.stack.length - 1] : null;
        },
        _sync: function() {
          if (this.stack.length) {
            document.body.classList.add('modal-open');
          } else {
            document.body.classList.remove('modal-open');
          }
        }
      });
    });

    // === bfcache + Turbo snapshot cleanup ==============================
    // closeAllDismissible() keeps dismissible: false modals (pending
    // on-chain TX) so the user returning via bfcache doesn't silently lose
    // the modal that a still-in-flight JS promise will resolve against.
    function clearStaleModals() {
      if (window.Alpine && Alpine.store) {
        var m = Alpine.store('modals');
        if (m && typeof m.closeAllDismissible === 'function') {
          m.closeAllDismissible();
        } else if (m && typeof m.closeAll === 'function') {
          m.closeAll();
        }
      }
    }
    window.addEventListener('pageshow', function(e) { if (e.persisted) clearStaleModals(); });
    document.addEventListener('turbo:before-cache', clearStaleModals);
  })();
</script>

<template x-if="$store.modals.current()">
  <%# Backdrop + card use CSS @keyframe animations (NOT Alpine
      x-transition). On mount, the .modal-backdrop-mount + .modal-card-mount
      classes fire fade-in + drop-recoil. On close, the store flips
      _closing → the :class bindings add .modal-*-unmount → the exit
      keyframes play → 220ms later the store splices the entry from
      the stack and the whole thing unmounts (now invisible). %>
  <div class="fixed inset-0 z-[120] flex items-center justify-center p-4 modal-backdrop-mount"
       :class="$store.modals.current()?._closing && 'modal-backdrop-unmount'"
       style="background:rgba(0,0,0,0.6)"
       role="dialog"
       aria-modal="true"
       @keydown.escape.window="$store.modals.current() && $store.modals.current().props.dismissible !== false && $store.modals.close()"
       @click.self="$store.modals.current() && $store.modals.current().props.dismissible !== false && $store.modals.close()">
    <div class="bg-surface rounded-xl border border-subtle shadow-2xl p-6 max-w-sm w-full modal-card-mount"
         :class="$store.modals.current()?._closing && 'modal-card-unmount'">
      <%= yield if block_given? %>
    </div>
  </div>
</template>

<%# Response body for an auto-load turbo-frame fetch. Wraps this batch's
    rows + (if more pages exist) the next frame in the chain. The outer
    turbo-frame must use the same id as the frame requesting this
    response so Turbo can swap in place. %>
<turbo-frame id="users_page_<%= @page %>">
  <%= render partial: "user_row", collection: @users_data, as: :row %>
  <% if @has_next %>
    <%= render "next_page_frame",
               page: @page + 1,
               total_users: @total_users,
               per_page: Admin::FreeEntriesController::PER_PAGE %>
  <% end %>
</turbo-frame>

<%# Auto-loading turbo-frame for the next batch of users. As soon as
    this is added to the DOM the browser fetches `src` (a GET against
    the same index action with ?page=N), which responds with
    _page_frame.html.erb — a fresh turbo-frame of the same id containing
    the next batch's rows and (if more pages remain) yet another
    next_page_frame. The chain unwinds itself until the last page,
    where no replacement frame is rendered and the spinner row simply
    disappears.

    Locals:
      page — the page number to load
      total_users — used for the loading-row "users X–Y of Z" hint
      per_page    — PER_PAGE, passed in so the partial doesn't reach
                    back into the controller's constant %>
<% from   = (page - 1) * per_page + 1 %>
<% to     = [page * per_page, total_users].min %>
<turbo-frame id="users_page_<%= page %>"
             src="<%= admin_free_entries_path(page: page) %>"
             target="_top">
  <tr>
    <td colspan="7" class="px-4 py-6 text-center">
      <span class="inline-flex items-center gap-2 text-muted text-xs">
        <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
        Loading users <%= from %>–<%= to %> of <%= total_users %>…
      </span>
    </td>
  </tr>
</turbo-frame>

<% content_for(:title, "Free Entries — Admin") %>

<div class="max-w-6xl mx-auto py-8 px-4 space-y-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-heading text-2xl font-bold mb-1">Free Entries Console</h1>
      <p class="text-muted text-sm">
        Mint on-chain <code class="font-mono">EntryTokenAccount</code> PDAs for users based on their on-chain seeds.
        <span class="font-mono">owed = floor(seeds / 100) − minted</span>.
      </p>
    </div>
    <%# Mint All Owed always shown — it sweeps every user, including
        ones not yet loaded into the table. The shown-batch's owed/
        minted counts aren't authoritative for the whole list. %>
    <%= button_to admin_mint_all_free_entries_path, class: "btn btn-success", data: { turbo_confirm: "Mint owed tokens across ALL users. This may take a while." } do %>
      Mint All Owed
    <% end %>
  </div>

  <%# Stats row — Minted/Owed reflect only the first batch (each row
      costs 2 Solana RPCs; computing across all #{@total_users} users
      up-front would re-introduce the N+1 that drove this page to
      paginate in the first place). %>
  <div class="grid grid-cols-3 gap-3">
    <div class="card p-4">
      <div class="text-muted text-[10px] uppercase tracking-wide">Total Users</div>
      <div class="text-heading text-2xl font-bold font-mono"><%= @total_users %></div>
    </div>
    <div class="card p-4">
      <div class="text-muted text-[10px] uppercase tracking-wide">Minted (first <%= @users_data.length %>)</div>
      <div class="text-heading text-2xl font-bold font-mono"><%= @page_minted %></div>
    </div>
    <div class="card p-4" style="<%= 'border-color: var(--color-cta);' if @page_owed > 0 %>">
      <div class="text-muted text-[10px] uppercase tracking-wide">Owed (first <%= @users_data.length %>)</div>
      <div class="text-2xl font-bold font-mono" style="<%= @page_owed > 0 ? 'color: var(--color-cta);' : '' %>"><%= @page_owed %></div>
    </div>
  </div>

  <%# Users table %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-subtle text-muted text-[10px] uppercase tracking-wide">
          <th class="text-left px-4 py-3">User</th>
          <th class="text-right px-3 py-3">Seeds</th>
          <th class="text-right px-3 py-3">Level</th>
          <th class="text-right px-3 py-3">Minted</th>
          <th class="text-right px-3 py-3">Unconsumed</th>
          <th class="text-right px-3 py-3">Owed</th>
          <th class="text-right px-4 py-3">Action</th>
        </tr>
      </thead>
      <tbody>
        <%# Initial batch (first PER_PAGE users). Each subsequent batch
            streams in via the auto-loading turbo-frame chain below —
            no Prev/Next clicks required. %>
        <%= render partial: "user_row", collection: @users_data, as: :row %>
        <% if @has_next %>
          <%= render "next_page_frame",
                     page: @page + 1,
                     total_users: @total_users,
                     per_page: Admin::FreeEntriesController::PER_PAGE %>
        <% end %>
        <% if @users_data.empty? %>
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-muted">No users with Solana wallets.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <p class="text-muted text-xs">
    Each mint is a Solana transaction signed by the admin (Alex Bot key). 60-second cache on per-user token list — buttons may take a moment to reflect on the page refresh after minting.
  </p>
</div>

<% content_for(:title, "Free Entries — Admin") %>

<div class="max-w-6xl mx-auto py-8 px-4 space-y-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-heading text-2xl font-bold mb-1">Free Entries Console</h1>
      <p class="text-muted text-sm">
        Mint on-chain <code class="font-mono">EntryTokenAccount</code> PDAs for users based on their on-chain seeds.
        <span class="font-mono">owed = floor(seeds / 100) − minted</span>.
      </p>
    </div>
    <% if @page_owed > 0 %>
      <%= button_to admin_mint_all_free_entries_path, class: "btn btn-success", data: { turbo_confirm: "Mint owed tokens across ALL users (every page). This may take a while." } do %>
        Mint All Owed
      <% end %>
    <% end %>
  </div>

  <%# Stats row — figures reflect the current page only (each row costs 2
      Solana RPCs to compute; computing across all #{@total_users} users
      would re-introduce the N+1). Mint All Owed still sweeps every user. %>
  <div class="grid grid-cols-3 gap-3">
    <div class="card p-4">
      <div class="text-muted text-[10px] uppercase tracking-wide">Users (page <%= @page %> / <%= @total_pages %>)</div>
      <div class="text-heading text-2xl font-bold font-mono"><%= @users_data.length %> <span class="text-muted text-sm font-normal">of <%= @total_users %></span></div>
    </div>
    <div class="card p-4">
      <div class="text-muted text-[10px] uppercase tracking-wide">Minted (this page)</div>
      <div class="text-heading text-2xl font-bold font-mono"><%= @page_minted %></div>
    </div>
    <div class="card p-4" style="<%= 'border-color: var(--color-cta);' if @page_owed > 0 %>">
      <div class="text-muted text-[10px] uppercase tracking-wide">Owed (this page)</div>
      <div class="text-2xl font-bold font-mono" style="<%= @page_owed > 0 ? 'color: var(--color-cta);' : '' %>"><%= @page_owed %></div>
    </div>
  </div>

  <%# Users table %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-subtle text-muted text-[10px] uppercase tracking-wide">
          <th class="text-left px-4 py-3">User</th>
          <th class="text-right px-3 py-3">Seeds</th>
          <th class="text-right px-3 py-3">Level</th>
          <th class="text-right px-3 py-3">Minted</th>
          <th class="text-right px-3 py-3">Unconsumed</th>
          <th class="text-right px-3 py-3">Owed</th>
          <th class="text-right px-4 py-3">Action</th>
        </tr>
      </thead>
      <tbody>
        <% @users_data.each do |row| %>
          <% user = row[:user] %>
          <tr class="border-b border-subtle/40 hover:bg-inset transition">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= render "components/avatar", user: user, size: "sm" %>
                <div>
                  <div class="text-heading font-semibold"><%= user.display_name %></div>
                  <div class="font-mono text-[10px] text-muted"><%= user.truncated_solana %></div>
                </div>
              </div>
            </td>
            <td class="px-3 py-3 text-right font-mono"><%= row[:seeds] %></td>
            <td class="px-3 py-3 text-right font-mono"><%= row[:level] %></td>
            <td class="px-3 py-3 text-right font-mono"><%= row[:minted] %></td>
            <td class="px-3 py-3 text-right font-mono"><%= row[:unconsumed] %></td>
            <td class="px-3 py-3 text-right font-mono font-bold" style="<%= row[:owed] > 0 ? 'color: var(--color-cta);' : 'color: var(--color-text-muted);' %>"><%= row[:owed] %></td>
            <td class="px-4 py-3 text-right">
              <% if row[:owed] > 0 %>
                <%= button_to admin_mint_free_entries_path(user_slug: user.slug),
                              class: "btn btn-success btn-sm",
                              data: { turbo_confirm: "Mint #{row[:owed]} free #{'entry'.pluralize(row[:owed])} for #{user.display_name}?" } do %>
                  Mint <%= row[:owed] %>
                <% end %>
              <% else %>
                <span class="text-muted text-xs">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @users_data.empty? %>
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-muted">No users with Solana wallets.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination — only shown when there's more than one page. Per-user
      Solana reads are parallelized in compute_user_data_for, but with
      PER_PAGE = 25 we cap the in-flight thread count to ~50 (2 per user)
      and bound wall time even on slow devnet RPC. %>
  <% if @total_pages > 1 %>
    <nav class="flex items-center justify-between text-sm">
      <span class="text-muted">Page <%= @page %> of <%= @total_pages %> &middot; <%= @total_users %> users</span>
      <div class="flex items-center gap-2">
        <% if @page > 1 %>
          <%= link_to "← Prev", admin_free_entries_path(page: @page - 1), class: "btn btn-outline btn-sm" %>
        <% end %>
        <% if @page < @total_pages %>
          <%= link_to "Next →", admin_free_entries_path(page: @page + 1), class: "btn btn-outline btn-sm" %>
        <% end %>
      </div>
    </nav>
  <% end %>

  <p class="text-muted text-xs">
    Each mint is a Solana transaction signed by the admin (Alex Bot key). 60-second cache on per-user token list — buttons may take a moment to reflect on the page refresh after minting.
  </p>
</div>

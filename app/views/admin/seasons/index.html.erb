<% content_for(:title, "Seasons — Admin") %>

<div class="max-w-5xl mx-auto py-8 px-4 space-y-6">
  <div>
    <h1 class="text-heading text-2xl font-bold mb-1">Seasons</h1>
    <p class="text-muted text-sm">
      On-chain <code class="font-mono">Season</code> PDAs hold the seed schedule used by every entry instruction.
      Schedule slots map to <span class="font-mono">entry_num.min(4)</span> — slot 4 applies to any entry beyond the 5th.
    </p>
  </div>

  <%# Existing seasons table %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-subtle text-muted text-[10px] uppercase tracking-wide">
          <th class="text-left px-4 py-3">ID</th>
          <th class="text-left px-3 py-3">Name</th>
          <th class="text-left px-3 py-3">Schedule (entry 0 → 4+)</th>
          <th class="text-left px-3 py-3">Created</th>
          <th class="text-right px-4 py-3">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @seasons.each do |s| %>
          <% is_current = s[:season_id] == @current_season_id %>
          <tr class="border-b border-subtle/40 hover:bg-inset transition">
            <td class="px-4 py-3 font-mono"><%= s[:season_id] %></td>
            <td class="px-3 py-3 text-heading font-semibold"><%= s[:name] %></td>
            <td class="px-3 py-3 font-mono text-secondary"><%= s[:seed_schedule].join(" · ") %></td>
            <td class="px-3 py-3 font-mono text-[11px] text-muted"><%= Time.at(s[:created_at]).strftime("%Y-%m-%d %H:%M") rescue "—" %></td>
            <td class="px-4 py-3 text-right">
              <% if is_current %>
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style="background: rgba(var(--color-primary-500-rgb), 0.15); color: var(--color-cta); border: 1px solid rgba(var(--color-primary-500-rgb), 0.4);">CURRENT</span>
              <% else %>
                <%= button_to admin_set_current_season_path(season_id: s[:season_id]), class: "btn btn-outline btn-sm" do %>
                  Set Current
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @seasons.empty? %>
          <tr><td colspan="5" class="px-4 py-8 text-center text-muted">No seasons on-chain yet. Create the first one below.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Create new season %>
  <div class="card p-6">
    <h2 class="text-heading text-lg font-semibold mb-4">Create New Season</h2>
    <%= form_with url: admin_seasons_path, method: :post, local: true, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="text-muted text-[10px] uppercase tracking-wide block mb-1">Season ID</label>
          <%= f.number_field :season_id, value: @next_season_id, min: 0,
              class: "w-full text-sm rounded-md border border-subtle px-2 py-1.5 font-mono",
              style: "background: var(--color-bg-surface); color: var(--color-text-primary);" %>
        </div>
        <div class="md:col-span-2">
          <label class="text-muted text-[10px] uppercase tracking-wide block mb-1">Name</label>
          <%= f.text_field :name, placeholder: "World Cup 2026",
              class: "w-full text-sm rounded-md border border-subtle px-2 py-1.5",
              style: "background: var(--color-bg-surface); color: var(--color-text-primary);" %>
        </div>
      </div>

      <div>
        <label class="text-muted text-[10px] uppercase tracking-wide block mb-2">Seed Schedule (5 slots, entry indices 0–4+)</label>
        <div class="grid grid-cols-5 gap-2">
          <% Solana::Vault::SEASON_DEFAULT_SCHEDULE.each_with_index do |default, i| %>
            <div>
              <label class="text-muted text-[10px] block mb-1 text-center">entry <%= i %><%= "+" if i == 4 %></label>
              <%= f.number_field "slot_#{i}", value: default, min: 0,
                  class: "w-full text-sm rounded-md border border-subtle px-2 py-1.5 font-mono text-center",
                  style: "background: var(--color-bg-surface); color: var(--color-cta);" %>
            </div>
          <% end %>
        </div>
        <p class="text-muted text-xs mt-2">Default: <span class="font-mono">[25, 19, 14, 10, 7]</span>. Slot 4 applies to all entries beyond the 5th.</p>
      </div>

      <div class="flex items-center justify-between gap-3">
        <label class="text-sm text-secondary flex items-center gap-2">
          <%= f.check_box :set_current, { checked: @seasons.empty? }, "1", "0" %>
          Set as Current Season after creating
        </label>
        <%= f.submit "Create Season On-Chain", class: "btn btn-success" %>
      </div>
    <% end %>
  </div>

  <p class="text-muted text-xs">
    Creating a season writes a transaction to Solana. Seasons are immutable once created — to change the schedule, create a new season and set it as current.
  </p>
</div>

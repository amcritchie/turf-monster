<%# locals: (url:, label:, subtitle:, icon:) — a neutral dashboard quick-action
    card (icon + label + subtitle). The LogRocket card stays inline in show
    because it's bespoke (brand color + emoji + external). %>
<%= link_to url, class: "card hover:bg-surface-alt transition p-4 flex flex-col items-center justify-center gap-1.5 text-center" do %>
  <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="<%= icon %>"/>
  </svg>
  <span class="text-sm font-semibold text-heading"><%= label %></span>
  <span class="text-[11px] text-muted"><%= subtitle %></span>
<% end %>

<%# Current default og:image preview. update_link_preview_image replaces this
    (#default-og-image-preview) via Turbo Stream after an immediate crop save. %>
<div id="default-og-image-preview" class="rounded-lg overflow-hidden border border-subtle" style="aspect-ratio: 1200 / 630;">
  <% if site_setting.default_og_image.attached? %>
    <%= image_tag site_setting.default_og_image, class: "w-full h-full object-cover", alt: "Default link-preview image" %>
  <% else %>
    <div class="w-full h-full flex items-center justify-center text-xs text-muted"
         style="background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-900))">
      No image — falls back to /og.png
    </div>
  <% end %>
</div>

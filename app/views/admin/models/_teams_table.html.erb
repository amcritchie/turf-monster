<%# locals: (records:) %>
<div class="overflow-x-auto">
  <table id="models-teams-table" class="w-full min-w-[920px] text-sm">
    <thead class="bg-surface-alt text-muted text-xs uppercase tracking-wide">
      <tr>
        <th class="px-4 py-3 text-left font-semibold">Team</th>
        <th class="px-4 py-3 text-left font-semibold">Sport / League</th>
        <th class="px-4 py-3 text-left font-semibold">Conference / Division</th>
        <th class="px-4 py-3 text-left font-semibold">Home Arena</th>
        <th class="px-4 py-3 text-left font-semibold">Social</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-subtle">
      <% records.each do |team| %>
        <tr class="hover:bg-surface-alt/60 transition">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <span class="text-xl flex-shrink-0"><%= team.emoji.presence || "*" %></span>
              <div class="min-w-0">
                <div class="font-semibold text-heading truncate"><%= team.name %></div>
                <div class="text-xs text-muted font-mono truncate"><%= team.short_name %> / <%= team.slug %></div>
              </div>
            </div>
          </td>
          <td class="px-4 py-3">
            <div class="flex flex-wrap gap-1.5">
              <% [team.sport, team.league].compact_blank.each do |label| %>
                <span class="inline-flex items-center px-2 py-1 rounded text-[11px] font-bold uppercase bg-surface-alt text-secondary">
                  <%= label %>
                </span>
              <% end %>
            </div>
          </td>
          <td class="px-4 py-3 text-muted">
            <%= [team.conference, team.division].compact_blank.join(" / ").presence || "-" %>
          </td>
          <td class="px-4 py-3 text-muted">
            <%= team.home_arena&.name || "-" %>
          </td>
          <td class="px-4 py-3 text-muted">
            <% social_labels = [team.hashtag, team.hashtag2, ("@#{team.x_handle}" if team.x_handle.present?)].compact_blank %>
            <%= social_labels.join(" ").presence || "-" %>
          </td>
        </tr>
      <% end %>
      <% if records.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-10 text-center text-muted">No teams found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

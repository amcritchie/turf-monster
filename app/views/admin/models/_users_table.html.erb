<%# locals: (records:) %>
<%= admin_model_table(records, key: "users", min_width: 920,
      headers: ["User", "Role", "Wallet", "Seeds", "State", "Last Seen"],
      empty: "No users found.") do |user| %>
  <td class="px-4 py-3">
    <div class="flex items-center gap-3">
      <%= render "components/avatar", user: user, size: "nav" %>
      <div class="min-w-0">
        <div class="font-semibold text-heading truncate"><%= user.display_name %></div>
        <div class="text-xs text-muted truncate">
          <%= user.email.presence || user.truncated_solana || "No email or wallet" %>
        </div>
      </div>
    </div>
  </td>
  <td class="px-4 py-3">
    <span class="inline-flex items-center px-2 py-1 rounded text-[11px] font-bold uppercase <%= user.admin? ? 'bg-primary/15 text-primary' : 'bg-surface-alt text-secondary' %>">
      <%= user.role %>
    </span>
  </td>
  <td class="px-4 py-3">
    <div class="flex flex-wrap gap-1.5">
      <% if user.managed_wallet? %>
        <span class="px-2 py-0.5 rounded bg-surface-alt text-xs text-secondary">managed</span>
      <% end %>
      <% if user.phantom_wallet? %>
        <span class="px-2 py-0.5 rounded bg-surface-alt text-xs text-secondary">phantom</span>
      <% end %>
      <% unless user.solana_connected? %>
        <span class="px-2 py-0.5 rounded bg-surface-alt text-xs text-muted">none</span>
      <% end %>
    </div>
  </td>
  <td class="px-4 py-3 text-muted font-mono"><%= user.seeds %></td>
  <td class="px-4 py-3">
    <div class="flex flex-wrap gap-1.5">
      <% if user.frozen_at.present? %>
        <span class="px-2 py-0.5 rounded bg-red-500/15 text-xs text-red-400">frozen</span>
      <% end %>
      <% if user.payment_risk_flag? %>
        <span class="px-2 py-0.5 rounded bg-warning-500/20 text-xs text-warning">risk</span>
      <% end %>
      <% if user.contest_entered? %>
        <span class="px-2 py-0.5 rounded bg-primary/15 text-xs text-primary">entered</span>
      <% end %>
    </div>
  </td>
  <td class="px-4 py-3 text-muted whitespace-nowrap">
    <%= user.last_seen_at ? "#{time_ago_in_words(user.last_seen_at)} ago" : "never" %>
  </td>
<% end %>

<% content_for(:title, "Link Hub — Turf Monster") %>

<div class="max-w-5xl mx-auto py-8 space-y-10">
  <div>
    <h1 class="text-heading text-3xl font-extrabold mb-1">Link Hub</h1>
    <p class="text-secondary text-sm">Admin tools, data browsers, and quick actions — everything that used to live in the navbar gear.</p>
  </div>

  <%= render layout: "hub_section", locals: { title: "Design" } do %>
    <%= render "hub_tile", name: "Theme",         url: admin_theme_path %>
    <%= render "hub_tile", name: "Navbar",        url: admin_navbar_path %>
    <%= render "hub_tile", name: "Modals",        url: admin_modals_path %>
    <%= render "hub_tile", name: "Level Badges",  url: admin_level_badges_path %>
    <% unless Rails.env.production? %>
      <%= render "hub_tile", name: "Toast Test", url: toast_test_path %>
    <% end %>
  <% end %>

  <%= render layout: "hub_section", locals: { title: "Sports" } do %>
    <%= render "hub_tile", name: "Teams",   url: teams_path %>
    <%= render "hub_tile", name: "Players", url: players_path %>
    <%= render "hub_tile", name: "Games",   url: games_path %>
    <%= render "hub_tile", name: "Goal Console", url: admin_scoring_path, note: "Record goals live on game day (team + minute)" %>
  <% end %>

  <%= render layout: "hub_section", locals: { title: "Admin" } do %>
    <%= render "hub_tile", name: "Dashboard", url: admin_dashboard_path %>
    <%= render "hub_tile", name: "Schema",       url: admin_schema_path %>
    <%= render "hub_tile", name: "Users",        url: admin_users_path, status: :reviewed %>
    <%= render "hub_tile", name: "Free Entries", url: admin_free_entries_path %>
    <%= render "hub_tile", name: "Currencies",   url: admin_currencies_path, note: "On-chain accepted_currencies (register / deactivate / sweep)" %>
    <% unless Rails.env.production? %>
      <%= render "hub_tile", name: "Faucet",     url: faucet_path %>
    <% end %>
    <%= render "hub_tile", name: "Geo Settings", url: admin_geo_path, status: :reviewed %>
    <%= render "hub_tile", name: "Error Logs",   url: admin_error_logs_path, status: :reviewed,
          note: "Incident triage — class facets, target filter, deep-links" %>
  <% end %>

  <%= render layout: "hub_section", locals: { title: "Hub" } do %>
    <%= render "hub_tile", name: "New Contest", url: new_contest_path, status: :flagged %>
    <%= render "hub_tile", name: "Contests",    url: contests_path, status: :reviewed %>
    <%= render "hub_tile", name: "Landing Pages", url: admin_landing_pages_path, status: :reviewed %>
    <%= render "hub_tile", name: "Seasons",     url: admin_seasons_path, status: :flagged %>
    <%= render "hub_tile", name: "Treasury",    url: admin_pending_transactions_path, status: :flagged %>
    <% if Admin::VaultInitController.vault_uninitialized? %>
      <%= render "hub_tile", name: "Vault Init", url: admin_vault_init_path, note: "Vault is uninitialized", status: :flagged %>
    <% else %>
      <%= render "hub_tile", name: "Vault State", url: admin_vault_state_path,
            note: (Admin::VaultStateController.vault_paused? ? "🚨 PAUSED" : nil), status: :flagged %>
    <% end %>
    <%= render "hub_tile", name: "The Contract", url: contract_path, note: "turf-vault on-chain reference (admin sections expand)" %>
    <%= render "hub_tile", name: "Transparency", url: transparency_path, note: "Public trust hub — source, reserves, contract, policies" %>
    <%= render "hub_tile", name: "Jobs",        url: "/admin/jobs", status: :flagged %>
  <% end %>

  <%= render layout: "hub_section", locals: { title: "Signing & Multisig" } do %>
    <%# Signing Console is a WIP page in the mcritchie-studio app; it may 404 until that app deploys. %>
    <%= render "hub_tile", name: "Signing Console", external: true,
          url: "https://app.mcritchie.studio/admin/signing_requests",
          note: "Keyless multi-party signing queue (mcritchie-studio)" %>
    <%= render "hub_tile", name: "Squads Multisig", external: true,
          url: "https://app.squads.so/squads/4H3fP3otjMtupk1DQDjKXYY1dWjT6LNM4H4ZWZ1XcKSX",
          note: "Approve the mainnet program upgrade (2-of-3)" %>
  <% end %>

  <%= render layout: "hub_section", locals: { title: "Everything Else" } do %>
    <%= render "hub_tile", name: "Slate Formula", url: slates_path, status: :flagged %>
    <% if @active_slate %>
      <%= render "hub_tile", name: "Slate Simulator", url: manage_admin_slate_path(@active_slate), status: :flagged %>
    <% end %>
    <%= render "hub_tile", name: "Formula",           url: formula_report_slates_path, status: :flagged %>
    <%= render "hub_tile", name: "Formula Defaults",  url: admin_formula_slates_path, status: :flagged %>
    <%= render "hub_tile", name: "Contest Generator", url: generator_contests_path, status: :flagged %>
    <%= render "hub_tile", name: "Transactions",      url: admin_transactions_path, status: :flagged %>
  <% end %>

  <%# Actions — buttons and POST forms; a flex row, not the hub_section tile grid. %>
  <section>
    <h2 class="label-upper font-bold mb-3">Actions</h2>
    <div class="flex flex-wrap gap-3">
      <button type="button"
              @click="showNavSpinner(); refreshBalance().finally(function() { hideNavSpinner(); })"
              class="btn btn-outline btn-sm">Refresh Balance</button>
      <button type="button"
              @click="$dispatch('navbar-replay-level')"
              class="btn btn-outline btn-sm">Replay Level</button>
      <%= button_to(geo_override_active? ? "Clear GEO Override" : "Simulate WA",
            admin_geo_toggle_path, method: :post,
            class: "btn btn-sm #{geo_override_active? ? 'btn-danger' : 'btn-outline'}") %>
      <% if @latest_contest %>
        <%= button_to "Reset Contest", reset_contest_path(@latest_contest), method: :post,
              data: { turbo_confirm: "Reset contest? This clears all entries and results." },
              class: "btn btn-danger btn-sm" %>
      <% end %>
    </div>
  </section>
</div>

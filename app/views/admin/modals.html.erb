<% content_for(:title, "Modal Gallery — Turf Monster") %>

<%# Visual gallery of every modal partial + state. Cards are grouped by
    MODAL_VARIANTS[:group]; each card iframes admin_modal_preview_path
    (or the variant's :url for standalone modal-style pages) so the
    preview has its own Alpine context isolated from the gallery page.
    The "Open ↗" button on modal_id variants pushes the modal onto the
    real $store.modals stack of this page, so you can also poke at it
    with the live host overlay.
    The Stack-behavior tests at the bottom preserve the previous
    behavior-test version of this page. %>

<div class="max-w-7xl mx-auto py-10 px-4 space-y-10">
  <div>
    <h1 class="text-heading text-2xl font-bold mb-1">Modal Gallery</h1>
    <p class="text-muted text-sm">
      Every modal partial + interesting state rendered side-by-side. Source: <code class="text-xs bg-inset px-1 rounded">AdminController::MODAL_VARIANTS</code>.
    </p>
  </div>

  <% @variants.group_by { |v| v[:group] }.each do |group, items| %>
    <section class="space-y-4">
      <h2 class="text-heading text-lg font-semibold border-b border-subtle pb-2"><%= group %></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% items.each do |variant| %>
          <% file_short = variant[:file].to_s.sub(%r{\Aapp/views/}, "") %>
          <% iframe_src = variant[:url].presence || (variant[:modal_id] && admin_modal_preview_path(modal_id: variant[:modal_id], props: variant[:props].to_json)) %>
          <div class="card overflow-hidden border border-subtle">
            <%# Header strip %>
            <div class="bg-inset px-4 py-2 flex items-center justify-between gap-3 border-b border-subtle">
              <div class="min-w-0">
                <div class="text-heading text-sm font-semibold truncate"><%= variant[:label] %></div>
                <div class="text-[11px] text-muted font-mono truncate">
                  <% if variant[:modal_id] %>
                    id: <%= variant[:modal_id] %> · <%= file_short %>
                  <% else %>
                    <%= file_short %>
                  <% end %>
                </div>
              </div>
              <% if variant[:modal_id] %>
                <button type="button" class="text-primary hover:underline text-xs font-medium flex-shrink-0"
                        onclick='Alpine.store("modals").open(<%= variant[:modal_id].to_json.html_safe %>, <%= variant[:props].to_json.html_safe %>)'>
                  Open &nearr;
                </button>
              <% else %>
                <a href="<%= variant[:url] %>" target="_blank" rel="noopener" class="text-primary hover:underline text-xs font-medium flex-shrink-0">
                  Open &nearr;
                </a>
              <% end %>
            </div>

            <% if variant[:partial] %>
              <%# Inline-component preview — render the partial directly inside
                  a faux modal-host card. No iframe, no per-card Alpine context,
                  no countdown timers firing in the background. Pure-locals
                  templates (form/action/status/wizard) work because their
                  x-data is fully self-contained and their close-button calls
                  $store.modals.close() which is a no-op when nothing's on
                  the stack. Faux card mirrors the host's outer card classes
                  (bg-surface + rounded-xl + border + shadow + p-6) so the
                  inline render visually matches a real opened modal. %>
              <div class="flex items-start justify-center p-4 min-h-[520px]" style="background: var(--color-page);">
                <div class="bg-surface rounded-xl border border-subtle shadow-2xl p-6 max-w-sm w-full">
                  <%= render variant[:partial] %>
                </div>
              </div>
            <% else %>
              <%# Iframe preview — separate Alpine context per card. Heavy but
                  necessary for variants whose x-data reads from $store.modals
                  (auth wizard state machine, on-chain TX state). Height is
                  fixed so the grid stays consistent; loading=lazy keeps the
                  gallery snappy. %>
              <iframe src="<%= iframe_src %>"
                      loading="lazy"
                      title="<%= variant[:label] %> preview"
                      class="w-full block"
                      style="height: 520px; border: 0; background: var(--color-page);"></iframe>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# ── Enter / Leave animation simulator ───────────────────────────
      Drives the per-modal entrance/exit registry (window.ModalAnimations
      in studio/modals/_host). Buttons + dropdowns are built from the live
      registry at DOMContentLoaded, so adding a new animation key surfaces
      here automatically — no edits to this page. The demo vehicle is the
      always-registered email-change-pending modal; only its enter/exit anim varies. %>
  <section class="space-y-4 pt-6 border-t border-subtle">
    <div>
      <h2 class="text-heading text-lg font-semibold">Enter / Leave Animations</h2>
      <p class="text-muted text-sm">
        The per-modal entrance/exit registry —
        <code class="text-xs bg-inset px-1 rounded">window.ModalAnimations</code> in
        <code class="text-xs bg-inset px-1 rounded">studio/modals/_host</code>. Any modal opens with
        <code class="text-xs bg-inset px-1 rounded">$store.modals.open(id, { enterAnim, exitAnim })</code>;
        omit either → <code class="text-xs bg-inset px-1 rounded">pop</code>. Controls below are generated
        from the live registry. Demo card: <code class="text-xs bg-inset px-1 rounded">email-change-pending</code>.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%# One-click per registered ENTER animation — watch the card appear. %>
      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">Enter <span class="text-muted text-xs font-normal">— watch it appear</span></h3>
        <p class="text-secondary text-xs">Opens the demo modal with that entrance. Dismiss with Esc / click-outside / Close.</p>
        <div id="modal-anim-enter-buttons" class="flex flex-wrap gap-2"></div>
      </div>

      <%# One-click per registered EXIT animation — opens with a plain
          entrance, then auto-closes after a beat so the exit plays. %>
      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">Leave <span class="text-muted text-xs font-normal">— watch it dismiss</span></h3>
        <p class="text-secondary text-xs">Opens with a plain entrance, then auto-closes so the exit keyframe is what you watch.</p>
        <div id="modal-anim-exit-buttons" class="flex flex-wrap gap-2"></div>
      </div>

      <%# Full matrix — pick any entrance x exit and round-trip it. %>
      <div class="card p-6 space-y-3 md:col-span-2">
        <h3 class="text-heading font-semibold">Combine</h3>
        <p class="text-secondary text-xs">Pick any entrance + exit and run the round-trip.</p>
        <div class="flex flex-wrap items-end gap-3">
          <label class="text-xs text-secondary">Enter
            <select id="modal-anim-enter-select" class="block mt-1 text-sm bg-inset border border-subtle rounded px-2 py-1 text-heading"></select>
          </label>
          <label class="text-xs text-secondary">Leave
            <select id="modal-anim-exit-select" class="block mt-1 text-sm bg-inset border border-subtle rounded px-2 py-1 text-heading"></select>
          </label>
          <button class="btn btn-primary btn-sm" onclick="modalAnimOpenSelected()">Open</button>
          <button class="btn btn-outline btn-sm" onclick="modalAnimRoundTripSelected()">Open &rarr; auto-close</button>
          <button class="btn btn-outline btn-sm" onclick="Alpine.store('modals').close()">Close</button>
        </div>
      </div>
    </div>
  </section>

  <%# ── Stack behavior tests (carried over from the previous version
      of this page — useful for poking at the engine modal-stack
      mechanics: hold-at-least, dismissibility, stacking). %>
  <section class="space-y-4 pt-6 border-t border-subtle">
    <div>
      <h2 class="text-heading text-lg font-semibold">Stack Behavior Tests</h2>
      <p class="text-muted text-sm">Studio-engine modal-stack mechanics — on-chain TX cards, dismissibility, hold-at-least, LIFO stacking.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">On-Chain TX states</h3>
        <p class="text-secondary text-xs">Engine <code class="text-xs bg-inset px-1 rounded">_processing_card</code> / <code class="text-xs bg-inset px-1 rounded">_success_card</code> / <code class="text-xs bg-inset px-1 rounded">_error_card</code>.</p>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-outline btn-sm" onclick="modalProcessing()">Processing</button>
          <button class="btn btn-success btn-sm" onclick="modalSuccess()">Success</button>
          <button class="btn btn-danger btn-sm" onclick="modalError()">Error</button>
          <button class="btn btn-primary btn-sm" onclick="modalProcessThenSuccess()">Process → Success (3s)</button>
          <button class="btn btn-primary btn-sm" onclick="modalProcessThenError()">Process → Error (3s)</button>
        </div>
      </div>

      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">Error with recovery</h3>
        <p class="text-secondary text-xs"><code class="text-xs bg-inset px-1 rounded">setRecovery(label, fn, { phantom })</code> renders a labeled button on the error card.</p>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-danger btn-sm" onclick="modalErrorWithRetry()">Retry</button>
          <button class="btn btn-danger btn-sm" onclick="modalErrorPhantomFaucet()">Phantom: Mint USDC</button>
        </div>
      </div>

      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">Dismissibility</h3>
        <p class="text-secondary text-xs">Processing defaults <code class="text-xs bg-inset px-1 rounded">dismissible: false</code> — Escape + click-outside suppressed until success/error.</p>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-outline btn-sm" onclick="modalProcessing()">Try Escape (locked)</button>
          <button class="btn btn-outline btn-sm" onclick="modalDismissible()">Dismissible processing</button>
        </div>
      </div>

      <div class="card p-6 space-y-3">
        <h3 class="text-heading font-semibold">Hold at least</h3>
        <p class="text-secondary text-xs"><code class="text-xs bg-inset px-1 rounded">StudioModals.holdAtLeast(ms)</code> prevents fast ops from flashing the spinner.</p>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-primary btn-sm" onclick="modalFastWithHold()">Fast op + hold 1500ms</button>
          <button class="btn btn-outline btn-sm" onclick="modalFastNoHold()">Fast op no hold (flashes)</button>
        </div>
      </div>

      <div class="card p-6 space-y-3 md:col-span-2">
        <h3 class="text-heading font-semibold">Stacking</h3>
        <p class="text-secondary text-xs">LIFO — opening a second modal pushes the first behind it; <code class="text-xs bg-inset px-1 rounded">close()</code> pops back.</p>
        <div class="flex flex-wrap gap-2">
          <button class="btn btn-primary btn-sm" onclick="modalStackTwo()">Open Two (success on top of processing)</button>
          <button class="btn btn-outline btn-sm" onclick="$store.modals.closeAll()">closeAll()</button>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  // Sample tx signature for previews (real-looking devnet hash)
  var SAMPLE_TX = '4xPHntwjpVe1JK2bcSAtJ8e6t1qhCpRzG1QyrW8RrFu5h7nXJDvqA2zKbPGvT9MdNxLh3JsKkPRtAxHvCs8VxNm';

  function modalProcessing() {
    Alpine.store('solanaModal').show('Submitting Entry', 'Awaiting Phantom signature…');
  }

  function modalSuccess() {
    Alpine.store('solanaModal').show('Submitting Entry', 'Awaiting Phantom signature…');
    Alpine.store('solanaModal').success(SAMPLE_TX, 'Entry confirmed on-chain.');
  }

  function modalError() {
    Alpine.store('solanaModal').show('Submitting Entry', 'Awaiting Phantom signature…');
    Alpine.store('solanaModal').error('Transaction simulation failed — insufficient SOL for rent.', 'Submission Failed');
  }

  function modalProcessThenSuccess() {
    Alpine.store('solanaModal').show('Submitting Entry', 'Awaiting RPC confirmation…');
    setTimeout(function() { Alpine.store('solanaModal').success(SAMPLE_TX, 'Entry confirmed on-chain.'); }, 3000);
  }

  function modalProcessThenError() {
    Alpine.store('solanaModal').show('Submitting Entry', 'Awaiting RPC confirmation…');
    setTimeout(function() { Alpine.store('solanaModal').error('Phantom rejected the transaction.', 'Submission Failed'); }, 3000);
  }

  function modalErrorWithRetry() {
    Alpine.store('solanaModal').show('Submitting Entry', '…');
    Alpine.store('solanaModal').error('Network error — RPC timed out.', 'Submission Failed');
    Alpine.store('solanaModal').setRecovery('Retry', function() {
      toast({ type: 'notice', title: 'Recovery clicked', message: 'Would retry the failed TX here.' });
    });
  }

  function modalErrorPhantomFaucet() {
    Alpine.store('solanaModal').show('Funding Wallet', '…');
    Alpine.store('solanaModal').error('Insufficient USDC for entry fee.', 'Insufficient Balance');
    Alpine.store('solanaModal').setRecovery('Mint $500 Test USDC', function() {
      toast({ type: 'notice', title: 'Phantom recovery clicked', message: 'Would call /faucet here.' });
    }, { phantom: true });
  }

  function modalDismissible() {
    Alpine.store('modals').open('onchain-tx', {
      dismissible: true,
      state: 'processing',
      title: 'Dismissible Processing',
      message: 'Escape and click-outside close this one.',
      txSignature: null, errorMessage: null,
      seedsEarned: 0, seedsTotal: 0, seedsLevel: 0,
      lobbyUrl: null, recoveryLabel: null, recoveryPhantom: false
    });
  }

  function modalFastWithHold() {
    Alpine.store('solanaModal').show('Fast Operation', 'Holding at least 1500ms…');
    window.StudioModals.holdAtLeast(1500).then(function() {
      Alpine.store('solanaModal').success(SAMPLE_TX, 'Done (with min hold).');
    });
  }

  function modalFastNoHold() {
    Alpine.store('solanaModal').show('Fast Operation', 'No hold — flashes by.');
    setTimeout(function() { Alpine.store('solanaModal').success(SAMPLE_TX, 'Done (no hold).'); }, 50);
  }

  function modalStackTwo() {
    Alpine.store('solanaModal').show('First Modal', 'This is the bottom of the stack.');
    setTimeout(function() {
      Alpine.store('modals').open('email-change-pending', { currentEmail: 'demo@turfmonster.media', newEmail: 'new@turfmonster.media' });
    }, 600);
  }

  function toast(detail) {
    window.dispatchEvent(new CustomEvent('toast', { detail: detail }));
  }

  // === Enter / Leave animation simulator ==============================
  // Opens the always-registered email-change-pending modal varying only its
  // enter/exit animation keys, so the card motion is the star.
  var ANIM_DEMO_ID    = 'email-change-pending';
  var ANIM_DEMO_PROPS = { currentEmail: 'you@example.com', newEmail: 'new@example.com' };

  function modalAnimOpen(enterAnim, exitAnim) {
    Alpine.store('modals').open(ANIM_DEMO_ID, Object.assign({}, ANIM_DEMO_PROPS, {
      enterAnim: enterAnim, exitAnim: exitAnim
    }));
  }

  // Open, let the entrance settle, then close so the chosen exit keyframe
  // is what you watch. Hold = the entrance's registry duration + a beat.
  function modalAnimRoundTrip(enterAnim, exitAnim) {
    modalAnimOpen(enterAnim, exitAnim);
    var enterMs = ((window.ModalAnimations.enter[enterAnim] || {}).ms) || 320;
    setTimeout(function() { Alpine.store('modals').close(); }, enterMs + 700);
  }

  function modalAnimOpenSelected() {
    modalAnimOpen(
      document.getElementById('modal-anim-enter-select').value,
      document.getElementById('modal-anim-exit-select').value
    );
  }
  function modalAnimRoundTripSelected() {
    modalAnimRoundTrip(
      document.getElementById('modal-anim-enter-select').value,
      document.getElementById('modal-anim-exit-select').value
    );
  }

  // Build the quick buttons + dropdown options from the live registry.
  // Deferred to DOMContentLoaded because window.ModalAnimations is defined
  // by the modal-host inline script, which may render after this one.
  document.addEventListener('DOMContentLoaded', function buildModalAnimControls() {
    var reg = window.ModalAnimations || { enter: {}, exit: {} };
    var label = function(key) {
      return key.charAt(0).toUpperCase() + key.slice(1) + (key === 'pop' ? ' (default)' : '');
    };
    var addOption = function(sel, key) {
      if (!sel) return;
      var o = document.createElement('option');
      o.value = key; o.textContent = label(key);
      if (key === 'pop') o.selected = true;
      sel.appendChild(o);
    };
    var addButton = function(container, key, onClick, suffix) {
      if (!container) return;
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'btn btn-outline btn-sm';
      b.textContent = label(key) + (suffix || '');
      b.onclick = onClick;
      container.appendChild(b);
    };

    var enterBtns = document.getElementById('modal-anim-enter-buttons');
    var exitBtns  = document.getElementById('modal-anim-exit-buttons');
    var enterSel  = document.getElementById('modal-anim-enter-select');
    var exitSel   = document.getElementById('modal-anim-exit-select');

    Object.keys(reg.enter).forEach(function(key) {
      addButton(enterBtns, key, function() { modalAnimOpen(key, 'pop'); }, ' ↗');
      addOption(enterSel, key);
    });
    Object.keys(reg.exit).forEach(function(key) {
      addButton(exitBtns, key, function() { modalAnimRoundTrip('pop', key); });
      addOption(exitSel, key);
    });
  });
</script>

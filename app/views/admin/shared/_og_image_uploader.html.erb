<%# locals: (form_url:, form_id:, file_param:, preview_dom_id:, attachment:, alt:, fallback:, label:, note: nil) %>
<%# The cropper-backed og:image upload unit: the imageUploadHost x-data host, the
    live preview, the Edit button, and the hidden multipart form the cropper
    submits on confirm. The CALLER renders studio/cropper_assets and wraps this in
    a card. `label`/`note` are html_safe (build them with tag.label / tag.p so the
    differing copy + styling stay at the call site). Shared by the dashboard
    default + the per-landing-page override. %>
<div x-data="imageUploadHost({ aspectRatio: <%= 1200.0 / 630 %>, maxWidth: 1200, filename: 'og-image.png', saving: 'Saving image…', success: 'Image updated', successMessage: 'Your new link-preview image is live.', failure: 'Couldn\'t save the image' })"
     @crop-photo-confirmed.window="applyCrop($event.detail.blob)">
  <%= label %>
  <%= render "admin/shared/og_image_preview", dom_id: preview_dom_id,
        attachment: attachment, alt: alt, fallback: fallback %>
  <button type="button" @click="open()" class="btn btn-outline btn-sm mt-2 inline-flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
    </svg>
    Edit image
  </button>
  <%= note %>
  <%= form_with url: form_url, method: :patch, html: { multipart: true, id: form_id, "x-ref": "form" } do %>
    <%= file_field_tag file_param, class: "hidden", "x-ref": "fileInput" %>
  <% end %>
</div>

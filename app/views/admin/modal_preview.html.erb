<% content_for(:title, "Modal Preview — #{@modal_id}") %>

<%# Renders inside an iframe on /admin/modals. Reuses the modal_preview
    layout (stripped of navbar/page chrome) so Alpine + the modal host
    are wired, then:
      1. Hides the navbar + page content via CSS so only the modal card
         shows in the iframe.
      2. Demotes the modal host's full-viewport overlay to a normal
         block element so the iframe sizes naturally to the card height.
      3. Opens the requested modal via Alpine.store('modals').open on
         alpine:init with the ERB-injected props. %>

<style>
  body > header,
  body > .max-w-7xl,
  body > #flash-toasts,
  body > script,
  body > noscript { display: none !important; }

  body .fixed.inset-0[role="dialog"] {
    position: static !important;
    background: transparent !important;
    padding: 0.5rem !important;
    z-index: auto !important;
  }
  body.modal-open { overflow: visible !important; }
  html, body { background: var(--color-page) !important; }
  body { min-height: 0 !important; padding: 0 !important; margin: 0 !important; }
</style>

<script type="application/json" id="modal-preview-config">
<%= { id: @modal_id, props: @modal_props }.to_json.html_safe %>
</script>

<script>
  document.addEventListener('alpine:init', function() {
    // Defer past Alpine's own first pass so all stores (modals,
    // solanaModal, session) are registered before we call open().
    setTimeout(function() {
      var cfg = JSON.parse(document.getElementById('modal-preview-config').textContent);
      var modals = Alpine.store('modals');
      if (!modals) return;
      // Force dismissible: true so the close × is interactive even on
      // states the real app would lock down (processing onchain-tx).
      var props = Object.assign({}, cfg.props, { dismissible: true });
      modals.open(cfg.id, props);
    }, 60);
  });

  // Block in-iframe navigation (×, "Contest Lobby" link, etc. would
  // navigate the iframe and we'd lose the preview).
  document.addEventListener('click', function(e) {
    var a = e.target.closest && e.target.closest('a');
    if (a && a.href && a.target !== '_blank') e.preventDefault();
  }, true);

  // Preview-only: success_card's 5s auto-redirect fires
  // `window.location.href = url`, which Turbo treats as a same-origin
  // nav and dispatches `turbo:before-cache`. The modal host's
  // bubble-phase listener (studio/modals/_host.html.erb#clearStaleModals
  // → closeAllDismissible) then splices the modal off the stack — the
  // iframe goes blank. Intercept in capture phase + stopImmediatePropagation
  // so the host's bubble-phase listener never fires inside previews. The
  // production app still gets the cleanup because that path doesn't load
  // this layout.
  document.addEventListener('turbo:before-cache', function (e) {
    e.stopImmediatePropagation();
  }, true);
</script>

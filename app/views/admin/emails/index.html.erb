<% content_for :title, "Emails" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-heading mb-1">Emails</h1>
  <p class="text-secondary text-sm mb-6">
    Every email Turf Monster sends, typed and previewable. Transactional emails are
    action-triggered (sign-in, receipts); marketing emails get composer + send tools.
  </p>

  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead class="text-secondary border-b border-subtle">
        <tr>
          <th class="text-left p-3">Email</th>
          <th class="text-left p-3">Type</th>
          <th class="p-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @emails.each do |e| %>
          <tr class="border-b border-subtle/50">
            <td class="p-3">
              <div class="font-medium text-heading"><%= e.name %></div>
              <div class="text-xs text-secondary"><%= e.description %></div>
            </td>
            <td class="p-3">
              <span class="px-2 py-0.5 rounded text-xs <%= e.type == :marketing ? "bg-primary/20 text-primary" : "bg-surface-alt text-secondary" %>">
                <%= e.type.to_s.titleize %>
              </span>
            </td>
            <td class="p-3 text-right whitespace-nowrap">
              <%= link_to "Preview", admin_email_path(e.key), class: "text-primary underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

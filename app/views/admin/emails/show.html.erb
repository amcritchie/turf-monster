<% content_for :title, @email.name %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-2">
    <h1 class="text-2xl font-bold text-heading"><%= @email.name %></h1>
    <%= link_to "← All emails", admin_emails_path, class: "text-primary underline text-sm" %>
  </div>

  <div class="flex items-center gap-3 mb-3">
    <span class="px-2 py-0.5 rounded text-xs <%= @email.type == :marketing ? "bg-primary/20 text-primary" : "bg-surface-alt text-secondary" %>">
      <%= @email.type.to_s.titleize %>
    </span>
    <% if @subject %>
      <span class="text-secondary text-sm">Subject: <strong class="text-heading"><%= @subject %></strong></span>
    <% end %>
  </div>

  <p class="text-secondary text-sm mb-4"><%= @email.description %></p>

  <div class="card overflow-hidden p-3 bg-surface-alt">
    <iframe src="<%= admin_raw_email_path(@email.key) %>"
            style="width:100%;height:780px;border:0;border-radius:8px;background:#ffffff;"
            title="Email preview"></iframe>
  </div>
</div>

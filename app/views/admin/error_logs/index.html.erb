<div class="max-w-7xl mx-auto px-4">
  <h1 class="text-2xl font-extrabold text-heading mb-2">Error Logs</h1>
  <p class="text-secondary text-sm mb-6">First-stop incident triage over <span class="font-mono">ErrorLog.capture!</span> rows. Newest first, <%= Admin::ErrorLogsController::LIMIT %> max.</p>

  <%# -- Summary -- %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <div class="card p-4">
      <p class="label-upper">Total</p>
      <p class="font-mono text-2xl text-heading"><%= @summary[:total] %></p>
    </div>
    <div class="card p-4">
      <p class="label-upper">Last 24h</p>
      <p class="font-mono text-2xl <%= @summary[:last_24h] > 0 ? 'text-red-400' : 'text-heading' %>"><%= @summary[:last_24h] %></p>
    </div>
    <div class="card p-4">
      <p class="label-upper">Top Classes (24h)</p>
      <% if @summary[:top_classes_24h].any? %>
        <p class="font-mono text-xs text-secondary"><%= @summary[:top_classes_24h].map { |k, v| "#{k}: #{v}" }.join(" · ").truncate(120) %></p>
      <% else %>
        <p class="font-mono text-xs text-muted">none</p>
      <% end %>
    </div>
    <div class="card p-4">
      <p class="label-upper">By Target Type</p>
      <% if @summary[:by_target_type].any? %>
        <p class="font-mono text-xs text-secondary"><%= @summary[:by_target_type].map { |k, v| "#{k}: #{v}" }.join(" · ").truncate(120) %></p>
      <% else %>
        <p class="font-mono text-xs text-muted">none</p>
      <% end %>
    </div>
  </div>

  <%# -- Class facet chips (top classes, last 24h) -- %>
  <% if @summary[:top_classes_24h].any? %>
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class="label-upper mr-1">Class:</span>
      <%= link_to "all", admin_error_logs_path(request.query_parameters.except("klass")),
            class: "badge", style: ("border-color: var(--color-primary); color: var(--color-primary)" if params[:klass].blank?) %>
      <% @summary[:top_classes_24h].each do |klass, count| %>
        <%= link_to "#{klass} (#{count})",
              admin_error_logs_path(request.query_parameters.merge("klass" => klass)),
              class: "badge", style: ("border-color: var(--color-primary); color: var(--color-primary)" if params[:klass] == klass) %>
      <% end %>
    </div>
  <% end %>

  <%# -- Filters -- %>
  <%= form_with url: admin_error_logs_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3 mb-6" do %>
    <div>
      <label class="label-upper block mb-1">Message contains</label>
      <%= text_field_tag :q, params[:q], placeholder: "e.g. Exactly 6 selections", class: "input-field" %>
    </div>
    <div>
      <label class="label-upper block mb-1">Target type</label>
      <%= select_tag :target_type,
            options_for_select([["all", ""], *@summary[:by_target_type].keys.map { |t| [t, t] }], params[:target_type]),
            class: "input-field" %>
    </div>
    <div>
      <label class="label-upper block mb-1">Class</label>
      <%= text_field_tag :klass, params[:klass], placeholder: "RuntimeError", class: "input-field" %>
    </div>
    <div>
      <label class="label-upper block mb-1">Since (UTC)</label>
      <%= text_field_tag :since, params[:since], placeholder: "2026-06-01 00:00", class: "input-field" %>
    </div>
    <%= submit_tag "Filter", class: "btn btn-primary" %>
    <%= link_to "Clear", admin_error_logs_path, class: "btn btn-outline" %>
  <% end %>

  <%# -- Table -- %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-subtle text-left text-muted">
          <th class="px-3 py-2">Time</th>
          <th class="px-3 py-2">Class</th>
          <th class="px-3 py-2">Message</th>
          <th class="px-3 py-2">Target</th>
          <th class="px-3 py-2">Parent</th>
          <th class="px-3 py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% @error_logs.each do |log| %>
          <tr class="border-b border-subtle bg-red-500/5">
            <td class="px-3 py-2 font-mono text-xs text-muted whitespace-nowrap"><%= log.created_at.strftime("%m/%d %H:%M:%S") %></td>
            <td class="px-3 py-2 font-mono text-xs text-red-300 whitespace-nowrap"><%= error_class_for(log) %></td>
            <td class="px-3 py-2 text-xs text-body"><%= log.message.to_s.truncate(80) %></td>
            <td class="px-3 py-2 text-xs"><%= log.target_type.present? ? "#{log.target_type}: #{log.target_name}" : "—" %></td>
            <td class="px-3 py-2 text-xs"><%= log.parent_type.present? ? "#{log.parent_type}: #{log.parent_name}" : "—" %></td>
            <td class="px-3 py-2"><%= link_to "Show", admin_error_log_path(log), class: "text-primary hover:underline text-xs" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @error_logs.empty? %>
      <p class="text-center text-muted py-8">No error logs match these filters.</p>
    <% end %>
  </div>
</div>

<%# Current per-page og:image preview. update_og_image replaces this
    (#landing-og-image-preview) via Turbo Stream after an immediate crop save. %>
<div id="landing-og-image-preview" class="rounded-lg overflow-hidden border border-subtle" style="aspect-ratio: 1200 / 630;">
  <% if landing_page.og_image.attached? %>
    <%= image_tag landing_page.og_image, class: "w-full h-full object-cover", alt: "Link-preview image" %>
  <% else %>
    <div class="w-full h-full flex items-center justify-center text-xs text-muted text-center px-4"
         style="background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-900))">
      No custom image — falls back to the site default, then /og.png
    </div>
  <% end %>
</div>

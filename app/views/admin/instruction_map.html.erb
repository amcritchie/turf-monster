<div id="ix-map" class="max-w-6xl mx-auto py-8 space-y-6">
  <%= link_to "← Link Hub", admin_hub_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>

  <header>
    <h1 class="text-heading text-3xl font-extrabold mb-1">On-chain Instruction Map</h1>
    <p class="text-secondary text-sm max-w-3xl">
      Every <span class="font-mono">turf-vault</span> Solana instruction — its <span class="font-mono">.text</span> byte cost,
      signer/auth role, and the Web3 (Phantom) and Web2 (Rails / Alex Bot) callers that invoke it.
      Click any row for the caller detail. Sort by clicking a column header; filter with the buttons.
    </p>
  </header>

  <%# ── Meta strip ─────────────────────────────────────────────── %>
  <div class="ix-stats">
    <div class="ix-stat">
      <div class="ix-stat-label">Program</div>
      <div class="ix-stat-value"><%= ix_meta[:source_version] %> <span class="ix-stat-unit">source · <%= ix_meta[:live_version] %> live</span></div>
    </div>
    <div class="ix-stat">
      <div class="ix-stat-label">Instructions</div>
      <div class="ix-stat-value"><%= ix_data.size %> <span class="ix-stat-unit">handlers</span></div>
    </div>
    <div class="ix-stat">
      <div class="ix-stat-label">Deploy binary</div>
      <div class="ix-stat-value"><%= number_with_delimiter(ix_meta[:binary_bytes]) %> <span class="ix-stat-unit">bytes · ~<%= ix_meta[:perm_sol] %> SOL rent</span></div>
    </div>
    <div class="ix-stat">
      <div class="ix-stat-label">Error codes</div>
      <div class="ix-stat-value"><%= ix_meta[:error_range] %> <span class="ix-stat-unit">39 variants</span></div>
    </div>
  </div>

  <%# ── Instruction table ──────────────────────────────────────── %>
  <section class="card p-5 sm:p-6">
    <div class="flex items-baseline justify-between flex-wrap gap-2 mb-1">
      <h2 class="text-heading text-lg font-bold">Per-instruction byte cost</h2>
      <span class="label-upper text-muted">measured · <%= number_with_delimiter(ix_meta[:handler_bytes]) %> handler bytes of <%= number_with_delimiter(ix_meta[:text_bytes]) %> .text</span>
    </div>
    <p class="text-secondary text-sm mb-4">
      Each instruction's bytes = its handler function plus the Anchor-generated <span class="font-mono">try_accounts</span> validator
      (the validators dwarf the business logic). <span class="font-mono">ICF</span> = identical-code-folding shares bytes between siblings.
    </p>

    <div class="ix-controls">
      <button class="ix-filter is-active" data-filter="all">All <%= ix_data.size %></button>
      <button class="ix-filter" data-filter="live">Live <%= status_counts["live"] %></button>
      <button class="ix-filter" data-filter="admin">Admin-only <%= status_counts["admin"] %></button>
      <button class="ix-filter" data-filter="one">One-time <%= status_counts["one"] %></button>
      <button class="ix-filter" data-filter="dead">Unused <%= status_counts["dead"] %></button>
      <button class="ix-filter" data-filter="web3-yes">Web3 callers</button>
      <button class="ix-filter" data-filter="web2-yes">Web2 callers</button>
    </div>

    <div class="ix-table-wrap">
      <table class="ix-table" id="ix-table">
        <thead>
          <tr>
            <th data-sort="name">Instruction</th>
            <th data-sort="bytes" class="sort-desc">Bytes (.text)</th>
            <th data-sort="auth">Auth</th>
            <th data-sort="web3">Web3 caller</th>
            <th data-sort="web2">Web2 caller</th>
            <th data-sort="status">Status</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>

  <%# ── Auth model ─────────────────────────────────────────────── %>
  <section class="card p-5 sm:p-6">
    <div class="flex items-baseline justify-between flex-wrap gap-2 mb-1">
      <h2 class="text-heading text-lg font-bold">Auth model — who can call what</h2>
      <span class="label-upper text-muted">signer matrix</span>
    </div>
    <p class="text-secondary text-sm mb-4">
      Five signer roles. The role decides whether the Rails backend (Alex Bot) can run an instruction unaided
      or needs a browser-side Phantom round-trip. Vault signer set: <span class="font-mono">Alex Bot · Alex · Mason</span>.
    </p>

    <div class="ix-auth-grid">
      <div class="ix-auth-card auth-init">
        <div class="ix-auth-h">INIT_AUTHORITY</div>
        <div class="ix-auth-who">Alex's Phantom key (pinned in mainnet binary)</div>
        <ul><li>initialize — once, ever</li></ul>
      </div>
      <div class="ix-auth-card auth-one">
        <div class="ix-auth-h">1-of-3 vault signer</div>
        <div class="ix-auth-who">Alex Bot signs alone (server-driven)</div>
        <ul>
          <li>create_contest (payer) · create_season</li>
          <li>set_contest_lock_time · set_contest_conclusion_time</li>
          <li>mint_entry_token · close_contest</li>
        </ul>
      </div>
      <div class="ix-auth-card auth-two">
        <div class="ix-auth-h">2-of-3 multisig</div>
        <div class="ix-auth-who">2 of {Alex Bot · Alex · Mason} — Phantom cosign</div>
        <ul>
          <li>settle_contest · cancel_contest</li>
          <li>pause · unpause · sweep_operator_revenue</li>
          <li>register_currency · deactivate_currency</li>
          <li>+ amend an already-passed lock / conclusion</li>
        </ul>
      </div>
      <div class="ix-auth-card auth-user">
        <div class="ix-auth-h">User wallet signs</div>
        <div class="ix-auth-who">Phantom OR managed keypair (consent)</div>
        <ul>
          <li>set_username</li>
          <li>enter_contest (USDC transfer)</li>
          <li>enter_contest_with_token (token consume)</li>
        </ul>
      </div>
      <div class="ix-auth-card auth-perm">
        <div class="ix-auth-h">Permissionless</div>
        <div class="ix-auth-who">Admin pays rent; wallet is data, not a signer</div>
        <ul><li>create_user_account</li></ul>
      </div>
    </div>
  </section>

  <footer class="text-muted text-xs space-y-1 pt-2">
    <div>
      Generated <%= ix_meta[:generated_on] %>. Bytes are measured from a debug-info rebuild of the <%= ix_meta[:source_version] %> source
      (<span class="font-mono">CARGO_PROFILE_RELEASE_DEBUG=2 … cargo-build-sbf</span> → <span class="font-mono">llvm-objdump --syms | rustfilt</span>, deduped by address, bucketed by instruction module).
    </div>
    <div>
      Section sizes from <span class="font-mono">llvm-objdump --section-headers</span> on the stripped deploy <span class="font-mono">.so</span>.
      Auth roles from <span class="font-mono">programs/turf_vault/src</span>; callers from <span class="font-mono">app/services/solana/vault.rb</span> + their call sites.
      Refresh after a turf-vault program release.
    </div>
  </footer>
</div>

<script type="application/json" id="ix-map-data"><%== ix_data.to_json %></script>

<style>
  /* Scoped to #ix-map. Colours come from the studio-engine theme vars so
     light/dark both work; color-mix tints them for pill backgrounds. */
  #ix-map .font-mono { font-family: ui-monospace, "SF Mono", Menlo, monospace; }

  #ix-map .ix-stats { display: grid; gap: 12px; grid-template-columns: repeat(4, 1fr); }
  #ix-map .ix-stat {
    background: var(--color-inset); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 12px 14px;
  }
  #ix-map .ix-stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin-bottom: 6px; }
  #ix-map .ix-stat-value { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 17px; color: var(--color-text); font-variant-numeric: tabular-nums; line-height: 1.2; }
  #ix-map .ix-stat-unit { font-size: 12px; color: var(--color-text-muted); }

  /* ── Filters ── */
  #ix-map .ix-controls { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  #ix-map .ix-filter {
    background: var(--color-inset); border: 1px solid var(--color-border);
    color: var(--color-text-secondary); padding: 5px 11px; border-radius: 999px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12px; cursor: pointer; transition: all .12s;
  }
  #ix-map .ix-filter:hover { color: var(--color-text); border-color: var(--color-border-strong); }
  #ix-map .ix-filter.is-active { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }

  /* ── Table ── */
  #ix-map .ix-table-wrap { overflow-x: auto; }
  #ix-map .ix-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  #ix-map .ix-table th {
    text-align: left; padding: 9px 8px; border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted); font-weight: 600; font-size: 11px; letter-spacing: 0.06em;
    text-transform: uppercase; cursor: pointer; user-select: none; white-space: nowrap;
  }
  #ix-map .ix-table th:hover { color: var(--color-text); }
  #ix-map .ix-table th.sort-asc::after { content: " ▲"; color: var(--color-primary); }
  #ix-map .ix-table th.sort-desc::after { content: " ▼"; color: var(--color-primary); }
  #ix-map .ix-table td { padding: 11px 8px; border-bottom: 1px solid var(--color-border); vertical-align: top; }
  #ix-map .ix-table tr.ix-row { cursor: pointer; }
  #ix-map .ix-table tr.ix-row:hover { background: color-mix(in srgb, var(--color-primary) 7%, transparent); }
  #ix-map .ix-table tr.ix-row.is-open { background: color-mix(in srgb, var(--color-primary) 10%, transparent); }
  #ix-map .ix-name { font-family: ui-monospace, "SF Mono", Menlo, monospace; color: var(--color-text); font-weight: 500; }
  #ix-map .ix-bytes { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-variant-numeric: tabular-nums; color: var(--color-text); }
  #ix-map .ix-bar { display: inline-block; vertical-align: middle; height: 4px; border-radius: 2px; background: var(--color-primary); margin-left: 6px; opacity: .7; }
  #ix-map td.ix-dim { color: var(--color-text-secondary); }
  #ix-map .ix-na { color: var(--color-text-muted); }

  /* ── Pills ── */
  #ix-map .pill {
    display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 11px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace; white-space: nowrap;
  }
  #ix-map .pill--success { background: color-mix(in srgb, var(--color-success) 14%, transparent); color: var(--color-success); border: 1px solid color-mix(in srgb, var(--color-success) 35%, transparent); }
  #ix-map .pill--primary { background: color-mix(in srgb, var(--color-primary) 14%, transparent); color: var(--color-primary); border: 1px solid color-mix(in srgb, var(--color-primary) 35%, transparent); }
  #ix-map .pill--warning { background: color-mix(in srgb, var(--color-warning) 16%, transparent); color: var(--color-warning); border: 1px solid color-mix(in srgb, var(--color-warning) 38%, transparent); }
  #ix-map .pill--danger  { background: color-mix(in srgb, var(--color-danger) 14%, transparent); color: var(--color-danger); border: 1px solid color-mix(in srgb, var(--color-danger) 35%, transparent); }
  #ix-map .pill--cta     { background: color-mix(in srgb, var(--color-cta) 16%, transparent); color: var(--color-cta); border: 1px solid color-mix(in srgb, var(--color-cta) 38%, transparent); }
  #ix-map .pill--muted   { background: color-mix(in srgb, var(--color-text-muted) 12%, transparent); color: var(--color-text-secondary); border: 1px solid var(--color-border); }

  #ix-map .icf-tag {
    display: inline-block; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 10px;
    background: color-mix(in srgb, var(--color-cta) 12%, transparent); color: var(--color-cta);
    padding: 1px 6px; border-radius: 999px; border: 1px solid color-mix(in srgb, var(--color-cta) 30%, transparent); margin-left: 6px;
  }

  /* ── Expanded detail ── */
  #ix-map tr.ix-detail td { padding: 0; border-bottom: 1px solid var(--color-border); }
  #ix-map .ix-panel { padding: 16px 14px; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; background: var(--color-inset); }
  #ix-map .ix-panel h4 { font-size: 11px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 6px; }
  #ix-map .ix-panel .path { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12px; color: var(--color-primary); word-break: break-word; }
  #ix-map .ix-panel .meta { color: var(--color-text-secondary); font-size: 12.5px; margin-top: 4px; }
  #ix-map .ix-panel .meta code { font-family: ui-monospace, "SF Mono", Menlo, monospace; color: var(--color-text); }
  #ix-map .ix-panel ul.notes { margin: 6px 0 0; padding-left: 18px; }
  #ix-map .ix-panel ul.notes li { color: var(--color-text-secondary); font-size: 12.5px; margin-bottom: 3px; }
  #ix-map .ix-panel .full { grid-column: 1 / -1; }

  /* ── Auth grid ── */
  #ix-map .ix-auth-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, 1fr); }
  #ix-map .ix-auth-card { background: var(--color-inset); border: 1px solid var(--color-border); border-radius: 10px; padding: 13px 15px; }
  #ix-map .ix-auth-h { font-size: 11px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-text-muted); margin-bottom: 5px; font-weight: 600; }
  #ix-map .ix-auth-who { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12px; color: var(--color-text); margin-bottom: 8px; }
  #ix-map .ix-auth-card ul { margin: 0; padding-left: 16px; font-size: 12px; color: var(--color-text-secondary); }
  #ix-map .ix-auth-card ul li { margin-bottom: 2px; }
  #ix-map .ix-auth-card.auth-init { border-top: 2px solid var(--color-warning); }
  #ix-map .ix-auth-card.auth-one  { border-top: 2px solid var(--color-primary); }
  #ix-map .ix-auth-card.auth-two  { border-top: 2px solid var(--color-cta); }
  #ix-map .ix-auth-card.auth-user { border-top: 2px solid var(--color-success); }
  #ix-map .ix-auth-card.auth-perm { border-top: 2px solid var(--color-border-strong); }

  @media (max-width: 820px) {
    #ix-map .ix-stats { grid-template-columns: repeat(2, 1fr); }
    #ix-map .ix-auth-grid { grid-template-columns: 1fr; }
    #ix-map .ix-panel { grid-template-columns: 1fr; }
  }
</style>

<script>
(function () {
  "use strict";
  var root = document.getElementById("ix-map");
  if (!root) return;
  var DATA = JSON.parse(document.getElementById("ix-map-data").textContent);
  var table = document.getElementById("ix-table");
  var tbody = table.querySelector("tbody");
  var maxBytes = Math.max.apply(null, DATA.map(function (i) { return i.bytes; }));

  var STATUS_PILL = { live: "pill--success", one: "pill--primary", admin: "pill--warning", dead: "pill--danger" };
  var AUTH_PILL = { init: "pill--warning", one: "pill--primary", two: "pill--cta", user: "pill--success", perm: "pill--muted" };

  var sortState = { col: "bytes", dir: "desc" };
  var filterState = "all";

  function esc(s) {
    return String(s == null ? "" : s).replace(/[&<>"]/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
    });
  }
  function dim(s) { return s === "—" ? '<span class="ix-na">—</span>' : esc(s); }

  function passesFilter(ix) {
    switch (filterState) {
      case "all": return true;
      case "live": return ix.status === "live";
      case "admin": return ix.status === "admin";
      case "one": return ix.status === "one";
      case "dead": return ix.status === "dead";
      case "web3-yes": return ix.web3.file.indexOf("NOT CALLED") !== 0 && ix.web3.file !== "—";
      case "web2-yes": return ix.web2.file.indexOf("ZERO callers") !== 0;
      default: return true;
    }
  }

  function sortRows(rows) {
    var k = sortState.col, dir = sortState.dir === "asc" ? 1 : -1;
    return rows.slice().sort(function (a, b) {
      var va, vb;
      if (k === "bytes") { va = a.bytes; vb = b.bytes; }
      else if (k === "name") { va = a.name; vb = b.name; }
      else if (k === "auth") { va = a.auth; vb = b.auth; }
      else if (k === "web3") { va = a.web3Short; vb = b.web3Short; }
      else if (k === "web2") { va = a.web2Short; vb = b.web2Short; }
      else { va = a.statusLabel; vb = b.statusLabel; }
      if (typeof va === "number") return (va - vb) * dir;
      return String(va).localeCompare(String(vb)) * dir;
    });
  }

  function render() {
    tbody.innerHTML = "";
    sortRows(DATA.filter(passesFilter)).forEach(function (ix) {
      var barW = Math.round(56 * ix.bytes / maxBytes);
      var icf = ix.icf ? ' <span class="icf-tag" title="Shares bytes via identical-code-folding with: ' + esc(ix.icf.join(", ")) + '">ICF</span>' : "";
      var tr = document.createElement("tr");
      tr.className = "ix-row";
      tr.innerHTML =
        '<td><span class="ix-name">' + esc(ix.name) + "</span>" + icf + "</td>" +
        '<td><span class="ix-bytes">' + ix.bytes.toLocaleString() + '</span><span class="ix-bar" style="width:' + barW + 'px"></span></td>' +
        '<td><span class="pill ' + (AUTH_PILL[ix.authClass] || "pill--muted") + '">' + esc(ix.auth) + "</span></td>" +
        '<td class="ix-dim">' + dim(ix.web3Short) + "</td>" +
        '<td class="ix-dim">' + dim(ix.web2Short) + "</td>" +
        '<td><span class="pill ' + (STATUS_PILL[ix.status] || "pill--muted") + '">' + esc(ix.statusLabel) + "</span></td>";
      tr.addEventListener("click", function () { toggleDetail(tr, ix); });
      tbody.appendChild(tr);
    });
  }

  function metaLine(label, value) {
    if (!value || value === "—") return "";
    return '<div class="meta"><strong>' + label + ":</strong> " + esc(value) + "</div>";
  }

  function toggleDetail(tr, ix) {
    var next = tr.nextElementSibling;
    if (next && next.classList.contains("ix-detail")) { next.remove(); tr.classList.remove("is-open"); return; }
    tbody.querySelectorAll("tr.ix-detail").forEach(function (d) { d.remove(); });
    tbody.querySelectorAll("tr.ix-row.is-open").forEach(function (r) { r.classList.remove("is-open"); });
    tr.classList.add("is-open");

    var icfHTML = ix.icf
      ? '<div class="meta"><strong>ICF shared with:</strong> ' + esc(ix.icf.join(", ")) + " — remove every sibling in the set to free the shared bytes.</div>"
      : "";
    var det = document.createElement("tr");
    det.className = "ix-detail";
    det.innerHTML =
      '<td colspan="6"><div class="ix-panel">' +
        "<div>" +
          "<h4>Web3 path (browser / Phantom)</h4>" +
          '<div class="path">' + esc(ix.web3.file) + "</div>" +
          (ix.web3.fn && ix.web3.fn !== "—" ? '<div class="meta">Fn: <code>' + esc(ix.web3.fn) + "</code></div>" : "") +
          metaLine("Trigger", ix.web3.trigger) +
          metaLine("Signer", ix.web3.signer) +
        "</div>" +
        "<div>" +
          "<h4>Web2 path (Rails / Alex Bot)</h4>" +
          '<div class="path">' + esc(ix.web2.file) + "</div>" +
          (ix.web2.vault ? '<div class="meta">Builder: <code>' + esc(ix.web2.vault) + "</code></div>" : "") +
          metaLine("Trigger", ix.web2.trigger) +
          metaLine("Signer", ix.web2.signer) +
        "</div>" +
        '<div class="full">' +
          "<h4>Notes</h4><ul class=\"notes\">" + ix.notes.map(function (n) { return "<li>" + esc(n) + "</li>"; }).join("") + "</ul>" +
          icfHTML +
        "</div>" +
      "</div></td>";
    tr.parentNode.insertBefore(det, tr.nextSibling);
  }

  table.querySelectorAll("th").forEach(function (th) {
    th.addEventListener("click", function () {
      var col = th.dataset.sort;
      if (!col) return;
      if (sortState.col === col) sortState.dir = sortState.dir === "asc" ? "desc" : "asc";
      else { sortState.col = col; sortState.dir = col === "bytes" ? "desc" : "asc"; }
      table.querySelectorAll("th").forEach(function (t) { t.classList.remove("sort-asc", "sort-desc"); });
      th.classList.add(sortState.dir === "asc" ? "sort-asc" : "sort-desc");
      render();
    });
  });

  root.querySelectorAll(".ix-filter").forEach(function (b) {
    b.addEventListener("click", function () {
      root.querySelectorAll(".ix-filter").forEach(function (x) { x.classList.remove("is-active"); });
      b.classList.add("is-active");
      filterState = b.dataset.filter;
      render();
    });
  });

  render();
})();
</script>

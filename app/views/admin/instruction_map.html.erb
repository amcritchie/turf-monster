  no DB / RPC read (see AdminController#instruction_map). Per-instruction
  .text bytes are MEASURED from a debug-info rebuild of the v0.19 source
  (CARGO_PROFILE_RELEASE_DEBUG=2 ... cargo-build-sbf, llvm-objdump --syms |
  rustfilt, deduped by address, bucketed by instruction module). Auth roles
  are from programs/turf_vault/src; caller sites are from this app's
  app/services/solana/vault.rb builders and their call sites.
  Refresh after a turf-vault program release.
%>

<%
  # ── Program-level facts (refresh per turf-vault release) ────────────────
  ix_meta = {
    source_version: "v0.19",        # programs/turf_vault/Cargo.toml
    live_version:   "v0.18",        # deployed devnet program
    binary_bytes:   501_528,        # llvm-objdump --section-headers (stripped deploy .so)
    text_bytes:     425_304,        # .text section (stripped deploy .so)
    handler_bytes:  184_640,        # measured handler-attributable .text (debug rebuild)
    perm_sol:       3.45,           # permanent ProgramData rent at deploy
    error_range:    "6000–6038",    # 39 VaultError variants
    generated_on:   "2026-06-02",
  }

  # ── Per-instruction records ─────────────────────────────────────────────
  # bytes: measured .text bytes (handler fn + Anchor try_accounts validator),
  #        totals include ICF-shared blocks (see `icf`).
  ix_data = [
    {
      name: "initialize", bytes: 28_904, status: "one", statusLabel: "one-time",

<% content_for :title, "Currencies" %>

<% zero = "11111111111111111111111111111111" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-heading">Currencies</h1>
    <%= link_to "Treasury", admin_pending_transactions_path, class: "text-primary hover:text-primary-300 text-sm font-medium underline" %>
  </div>

  <p class="text-secondary text-sm mb-6">
    On-chain <span class="font-mono">accepted_currencies</span> registry.
    register / deactivate / sweep are 2-of-3 multisig — they queue a transaction
    in the Treasury for the operator to cosign.
  </p>

  <% if @rpc_error %>
    <%= render "components/empty_state",
          message: "Couldn't read the vault state.",
          detail:  "RPC error: #{@rpc_error}" %>
  <% elsif @vault_state.nil? %>
    <%= render "components/empty_state",
          message: "VaultState not initialized.",
          detail:  "Run Vault Init first." %>
  <% else %>
    <div class="card p-4 mb-6">
      <p class="text-xs font-semibold text-muted mb-1 uppercase tracking-wide">Treasury authority</p>
      <p class="font-mono text-xs text-body break-all"><%= @treasury_authority %></p>
    </div>

    <div class="space-y-3 mb-8">
      <% @currencies.each do |c| %>
        <% registered = c[:mint] != zero %>
        <div class="card p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-mono text-xs text-muted">slot <%= c[:slot] %></span>
                <% if !registered %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Empty</span>
                <% elsif c[:active] %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Active</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Inactive</span>
                <% end %>
                <% if registered %>
                  <span class="text-xs text-muted">kind <%= c[:kind] %></span>
                <% end %>
              </div>
              <% if registered %>
                <p class="font-mono text-xs text-body break-all">mint: <%= c[:mint] %></p>
                <p class="font-mono text-xs text-muted break-all">op_rev: <%= c[:op_rev_ata] %></p>
              <% else %>
                <p class="text-xs text-muted">No currency registered in this slot.</p>
              <% end %>
            </div>

            <% if registered && c[:active] %>
              <div class="flex flex-col gap-2 flex-shrink-0">
                <%= button_to "Deactivate", admin_deactivate_currency_path(idx: c[:slot]),
                      method: :post,
                      data: { turbo_confirm: "Queue a deactivate for slot #{c[:slot]}?" },
                      class: "btn btn-outline btn-sm" %>
                <%= button_to "Sweep", admin_sweep_operator_revenue_path(mint: c[:mint]),
                      method: :post,
                      data: { turbo_confirm: "Queue a sweep of this currency's operator revenue to the treasury?" },
                      class: "btn btn-outline btn-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="card p-4">
      <p class="text-xs font-semibold text-muted mb-3 uppercase tracking-wide">Register a currency</p>
      <%= form_with url: admin_register_currency_path, method: :post, local: true, class: "flex flex-wrap items-end gap-3" do |f| %>
        <div class="flex-1 min-w-[16rem]">
          <label class="block text-xs text-secondary mb-1" for="currency-mint">Mint address</label>
          <%= f.text_field :mint, id: "currency-mint", placeholder: "Base58 mint pubkey",
                class: "w-full rounded-md border border-subtle bg-surface px-3 py-2 text-sm font-mono" %>
        </div>
        <div>
          <label class="block text-xs text-secondary mb-1" for="currency-kind">Kind</label>
          <%= f.select :kind, [["0 — stablecoin (payout)", 0], ["1 — other", 1]], {},
                id: "currency-kind", class: "rounded-md border border-subtle bg-surface px-3 py-2 text-sm" %>
        </div>
        <%= f.submit "Queue register", class: "btn btn-primary btn-sm" %>
      <% end %>
    </div>
  <% end %>

  <div class="json-debug mt-8">
    <pre><%= JSON.pretty_generate(@currencies) %></pre>
  </div>
</div>

<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-2">Top Up Your Wallet</h1>
  <p class="text-sm text-muted mb-8">Buy USDC with a card or bank transfer — it lands directly in your connected Phantom wallet.</p>

  <div class="card shadow p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-bold text-heading">MoonPay</h2>
        <p class="text-sm text-muted">Card / Apple Pay / Google Pay / bank transfer</p>
      </div>
      <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Self-custody</span>
    </div>

    <div class="bg-inset rounded-lg p-4 mb-4 text-sm text-secondary">
      <p class="mb-2"><span class="font-bold text-heading">Destination:</span></p>
      <p class="font-mono text-xs break-all"><%= @user.solana_address %></p>
    </div>

    <ul class="text-sm text-secondary space-y-2 mb-6">
      <li class="flex gap-2"><span class="text-primary">&check;</span> USDC arrives directly in your Phantom wallet</li>
      <li class="flex gap-2"><span class="text-primary">&check;</span> Turf Monster never custodies your funds</li>
      <li class="flex gap-2"><span class="text-primary">&check;</span> Minimum purchase $20 (MoonPay limit)</li>
    </ul>

    <%= button_to moonpay_deposit_wallet_path, method: :post, class: "btn btn-primary w-full" do %>
      Continue to MoonPay &rarr;
    <% end %>

    <p class="text-xs text-muted mt-3 text-center">You'll be redirected to MoonPay to complete your purchase securely.</p>
  </div>

  <div class="text-center">
    <%= link_to "&larr; Back to wallet".html_safe, wallet_path, class: "text-sm text-secondary hover:text-primary" %>
  </div>
</div>

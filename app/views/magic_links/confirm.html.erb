<%# "Signing you in…" interstitial for GET /magic_link/:token — just a spinner.

    SCANNER-SAFE, no manual tap: the GET does NOT consume the token server-side —
    it renders a form that AUTO-SUBMITS via JS on load, so a real browser POSTs
    instantly and signs in. No-JS scanners issue a GET, never run the script, and
    so can't burn the single-use token.

    Rendered on the minimal `loading` layout (no navbar/app-CSS), and fully
    self-contained (inline styles) so it paints instantly with just a spinner.
    The consume button is a hidden fallback, revealed only for no-JS or if the
    auto-submit hasn't redirected after a few seconds. %>
<div style="text-align:center;">
  <div role="status" aria-label="Signing you in"
       style="width:88px;height:88px;margin:0 auto;border-radius:9999px;
              border:8px solid rgba(255,255,255,0.14);border-top-color:#4BAF50;
              animation:magic-spin 0.8s linear infinite;"></div>

  <div id="magic-fallback" style="display:none;margin-top:2rem;color:#cdd9c9;">
    <p style="margin:0 0 1rem;font-size:15px;">Taking longer than expected?</p>
    <% consume_path = @consume_path || magic_link_consume_path(token: @token) %>
    <%= button_to consume_path,
          method: :post,
          form: { id: "magic-consume-form", data: { turbo: "false" } },
          style: "display:inline-block;padding:14px 34px;font-size:16px;font-weight:700;color:#ffffff;background:#4BAF50;border:none;border-radius:10px;cursor:pointer;" do %>
      Sign in to Turf Totals
    <% end %>
  </div>
</div>

<style>@keyframes magic-spin { to { transform: rotate(360deg); } }</style>
<noscript><style>#magic-fallback { display: block !important; } div[role="status"] { display: none; }</style></noscript>

<script>
  (function () {
    var form = document.getElementById('magic-consume-form');
    if (form && !form.dataset.autoSubmitted) {
      form.dataset.autoSubmitted = '1';
      // Auto-submit so the human signs in on link-click with no extra tap. A
      // no-JS scanner GET never reaches this, so the single-use token stays safe.
      if (typeof form.requestSubmit === 'function') form.requestSubmit();
      else form.submit();
    }
    // If we're somehow still here after a few seconds, surface the manual button.
    setTimeout(function () {
      var fb = document.getElementById('magic-fallback');
      if (fb) fb.style.display = 'block';
    }, 4000);
  })();
</script>

<section class="max-w-md mx-auto mt-12">
  <div class="card p-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-heading">Complete Your Profile</h2>
      <p class="text-secondary mt-2">Choose a username to get started</p>
    </div>

    <%= form_with model: @user, url: save_profile_account_path, method: :post, class: "space-y-6" do |f| %>
      <div>
        <label class="label-upper mb-2 block">Profile Picture <span class="text-muted">(optional)</span></label>
        <%= render "components/avatar_cropper", form_field_name: "user[avatar]" %>
      </div>

      <div>
        <label class="label-upper mb-2 block">Username</label>
        <%= f.text_field :username, class: "input-field", placeholder: "Choose a username", autofocus: true, required: true, minlength: 3, maxlength: 30, pattern: "[a-zA-Z0-9_-]+" %>
        <p class="text-xs text-muted mt-1">3-30 characters. Letters, numbers, hyphens, and underscores.</p>
      </div>

      <div>
        <%= f.submit "Save Profile", class: "btn btn-primary btn-lg w-full" %>
      </div>
    <% end %>
  </div>
</section>

<% if @profile_error_message.present? %>
  <%# Validation failed — surface a titled toast. This app starts Alpine early
      and streams x-data via a MutationObserver, so no fixed lifecycle event
      reliably lands a page-load toast. Poll until the toast-manager component
      is live, then dispatch through its documented `toast` event. %>
  <script>
    (function () {
      var detail = {
        type: 'alert',
        title: <%= @profile_error_title.to_json.html_safe %>,
        message: <%= @profile_error_message.to_json.html_safe %>
      };
      var tries = 0;
      (function poll() {
        var container = document.getElementById('toast-container');
        var host = container && container.closest('[x-data]');
        var data = (host && window.Alpine && Alpine.$data) ? Alpine.$data(host) : null;
        if (data && typeof data.add === 'function') {
          window.dispatchEvent(new CustomEvent('toast', { detail: detail }));
        } else if (tries++ < 60) {
          setTimeout(poll, 100);
        }
      })();
    })();
  </script>
<% end %>

<%# Cropper.js is loaded on this page so the shared crop-photo modal
    (Alpine.store('modals').open('crop-photo', ...)) has its dependency
    when the user clicks the avatar to upload. %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-8">Account Settings</h1>

  <%# -- Profile (avatar + username) -- %>
  <div class="card shadow p-6 mb-6">
    <div x-data="profileAvatarUploader()"
         @crop-photo-confirmed.window="onCropConfirmed($event.detail.blob)"
         class="flex flex-col items-center">
      <%# Hidden form auto-submitted after the user confirms a crop. %>
      <%= form_with model: @user, url: account_path, method: :patch,
                    html: { multipart: true, "x-ref": "form", class: "hidden" } do |f| %>
        <input type="file" name="user[avatar]" x-ref="hiddenFileInput">
      <% end %>
      <input type="file" x-ref="filePicker" @change="onFileSelected($event)" accept="image/*" class="hidden">

      <%# Clickable avatar — hover reveals "Update" overlay. Inline width/
          height because Tailwind w-24/h-24 weren't compiled here (the JIT
          only emits classes it sees at build time — see CLAUDE.md "Tailwind
          class compilation"). Squeezing on flex-col + items-center left the
          avatar as a pill instead of a circle. %>
      <div @click="$refs.filePicker.click()"
           style="width: 96px; height: 96px;"
           class="relative rounded-full cursor-pointer group overflow-hidden mb-3 flex-shrink-0">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "rounded-full object-cover", style: "width: 96px; height: 96px;", alt: @user.display_name %>
        <% else %>
          <div class="rounded-full flex items-center justify-center font-bold text-white text-3xl"
               style="width: 96px; height: 96px; background-color: <%= @user.avatar_color %>">
            <%= @user.avatar_initials %>
          </div>
        <% end %>
        <div class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
          <span class="text-white text-xs font-bold">Update</span>
        </div>
      </div>

      <div class="text-xl font-bold text-heading mb-3"><%= current_user.display_name %></div>

      <button type="button" @click="$store.modals.open('username')" class="btn btn-outline btn-sm">
        Change username
      </button>
    </div>

    <script>
      function profileAvatarUploader() {
        return {
          onFileSelected: function(event) {
            var file = event.target.files[0];
            if (!file) return;
            var reader = new FileReader();
            reader.onload = function(e) {
              Alpine.store('modals').open('crop-photo', { imageUrl: e.target.result });
            };
            reader.readAsDataURL(file);
            event.target.value = '';
          },
          onCropConfirmed: function(blob) {
            if (!blob) return;
            var dt = new DataTransfer();
            dt.items.add(new File([blob], 'avatar.png', { type: 'image/png' }));
            this.$refs.hiddenFileInput.files = dt.files;
            this.$refs.form.requestSubmit();
          }
        };
      }
    </script>
  </div>

  <%# -- Identities (wallet + balances + Google + email) -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Identities</h2>

    <% if @user.solana_connected? %>
      <div class="mb-4">
        <h3 class="text-sm font-bold text-heading mb-2">Solana Wallet</h3>
        <div class="flex items-center gap-2 flex-wrap">
          <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-body font-mono text-sm break-all"><%= @user.solana_address %></span>
          <% if @user.managed_wallet? %>
            <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Managed</span>
          <% else %>
            <span class="text-xs text-violet px-2 py-0.5 rounded bg-violet/10">Phantom</span>
          <% end %>
        </div>
      </div>

      <%# Balance tiles row — USDC | USDT | Entry Tokens | SOL | Seeds %>
      <div class="grid grid-cols-5 gap-2 mb-3">
        <%# All five tiles share an icon row with a fixed 28px height so the
            labels + values line up across emoji icons and the 24px SVGs/PNG. %>
        <%# USDC %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <img src="/usdc-mark.svg" alt="USDC" style="width: 24px; height: 24px;">
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">USDC</span>
          <span class="font-mono font-bold text-primary text-sm mt-0.5">
            <% if @wallet_balances && @wallet_balances[:usdc] %>
              <%= sprintf('$%.2f', @wallet_balances[:usdc]) %>
            <% else %>—<% end %>
          </span>
        </div>

        <%# USDT %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <%= image_tag "tokens/usdt.png", alt: "USDT", style: "width: 24px; height: 24px;" %>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">USDT</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5">
            <% if @wallet_balances && @wallet_balances[:usdt] %>
              <%= sprintf('%.2f', @wallet_balances[:usdt]) %>
            <% else %>—<% end %>
          </span>
        </div>

        <%# Entry Tokens %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <span style="font-size: 22px; line-height: 1;">🎟️</span>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">Entry Tokens</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5"><%= @user.entry_token_balance %></span>
        </div>

        <%# SOL %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <img src="/solana-mark.svg" alt="SOL" style="width: 24px; height: 24px;">
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">SOL</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5">
            <% if @wallet_balances && @wallet_balances[:sol] %>
              <%= sprintf('%.2f', @wallet_balances[:sol]) %>
            <% else %>—<% end %>
          </span>
        </div>

        <%# Seeds %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <span style="font-size: 22px; line-height: 1;">🌱</span>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">Seeds</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5">
            <%= @user_seeds.nil? ? "—" : @user_seeds %>
          </span>
        </div>
      </div>

      <% if Solana::Config.devnet? %>
        <a href="https://explorer.solana.com/address/<%= @user.solana_address %>?cluster=devnet"
           target="_blank" class="inline-block text-xs text-secondary hover:text-primary transition mb-6">
          View on Solana Explorer &rarr;
        </a>
      <% end %>
    <% else %>
      <div class="mb-6">
        <%= render "shared/solana_wallet_connect", link_mode: true %>
      </div>
    <% end %>

    <%# Google Account %>
    <div class="mb-6">
      <h3 class="text-sm font-bold text-heading mb-2">Google Account</h3>
      <% if @user.google_connected? %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-body">Connected via Google</span>
          </div>
          <%= button_to "Unlink", unlink_google_account_path, method: :post,
            class: "btn btn-danger btn-sm",
            data: { turbo_confirm: "Unlink your Google account?" } %>
        </div>
      <% else %>
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
          class: "btn btn-google gap-3 w-full" do %>
          <%= render "components/google_logo" %>
          Link Google Account
        <% end %>
      <% end %>
    </div>

    <%# Email — full PATCH /account flow. OPSEC-046: changing email
        requires the user to confirm their current password, so we reveal
        a hidden current_password field via Alpine when the value differs
        from the saved address (password users only). %>
    <div x-data="{ initial: '<%= j @user.email.to_s %>', current: '<%= j @user.email.to_s %>' }">
      <h3 class="text-sm font-bold text-heading mb-2">Email</h3>
      <%= form_with model: @user, url: account_path, method: :patch do |f| %>
        <div class="flex gap-2">
          <%= f.email_field :email,
                            class: "input-field flex-1",
                            placeholder: "you@example.com",
                            "x-model": "current" %>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
        <% if @user.has_password? %>
          <input type="password" name="current_password"
                 x-show="current !== initial"
                 x-cloak
                 class="input-field mt-2"
                 placeholder="Confirm current password to change email">
        <% end %>
      <% end %>
    </div>
  </div>

  <%# -- Log out + Buy Entry Tokens (side by side) -- %>
  <div class="grid grid-cols-2 gap-4 mb-6">
    <%= link_to "Log out", logout_path, class: "btn btn-outline w-full" %>
    <%= link_to "Buy Entry Tokens", tokens_buy_path, class: "btn btn-primary w-full" %>
  </div>

  <%# -- Change Password -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4"><%= @user.has_password? ? "Change Password" : "Set Password" %></h2>
    <%= form_tag change_password_account_path, method: :post do %>
      <% if @user.has_password? %>
        <div class="mb-4">
          <label for="current_password" class="block text-sm text-secondary mb-2 font-medium">Current Password</label>
          <input type="password" name="current_password" id="current_password"
            class="input-field"
            placeholder="Current password">
        </div>
      <% end %>
      <div class="mb-4">
        <label for="new_password" class="block text-sm text-secondary mb-2 font-medium">New Password</label>
        <input type="password" name="new_password" id="new_password"
          class="input-field"
          placeholder="New password (min 6 chars)">
      </div>
      <div class="mb-4">
        <label for="new_password_confirmation" class="block text-sm text-secondary mb-2 font-medium">Confirm New Password</label>
        <input type="password" name="new_password_confirmation" id="new_password_confirmation"
          class="input-field"
          placeholder="Confirm new password">
      </div>
      <button type="submit" class="btn btn-secondary">
        <%= @user.has_password? ? "Update Password" : "Set Password" %>
      </button>
    <% end %>
  </div>
</div>

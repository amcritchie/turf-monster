<%# Cropper.js is loaded on this page so the shared crop-photo modal
    (Alpine.store('modals').open('crop-photo', ...)) has its dependency
    when the user clicks the avatar to upload. %>
<%= render "studio/cropper_assets" %>

<%# Auto-open the email-change-pending modal after a held email change.
    AccountsController#update redirects here with flash[:email_change_pending]
    carrying { current_email, new_email }; we render it into a JSON script
    tag and open the informational modal on load.

    Timing: the email form is a Turbo form_with, so the redirect lands via
    Turbo Drive (body swap), NOT a hard load — the open MUST fire on the
    Turbo render. We bind to turbo:load (fires on every Turbo navigation,
    incl. the post-redirect render AND the initial hard load) with a
    one-shot guard so a back/forward turbo:load can't replay a stale flash.
    Flash is single-render, so the JSON tag is absent on any later visit;
    even so we null-check before opening. Alpine.store('modals') is wired on
    alpine:init (already past by the time a Turbo navigation completes), but
    we poll briefly in case turbo:load wins the race against Alpine boot on
    a cold first paint. turbo-stream <script> tags don't execute, but this
    is a redirect + normal page render, so an inline page script runs fine. %>
<% if flash[:email_change_pending].present? %>
  <%# Flash round-trips through the session cookie as JSON, so the hash
      comes back with STRING keys regardless of how the controller set it.
      with_indifferent_access lets us read it symbol-style here. %>
  <% pending = flash[:email_change_pending].with_indifferent_access %>
  <script type="application/json" id="email-change-pending-data">
    <%= raw({ currentEmail: pending[:current_email], newEmail: pending[:new_email] }.to_json) %>
  </script>
<% end %>
<script>
  (function() {
    var fired = false;
    function openEmailChangePending() {
      if (fired) return;
      var el = document.getElementById('email-change-pending-data');
      if (!el) return;
      var data;
      try { data = JSON.parse(el.textContent); } catch (e) { return; }
      var attempts = 0;
      (function tryOpen() {
        var m = (window.Alpine && Alpine.store) ? Alpine.store('modals') : null;
        if (m && typeof m.open === 'function') {
          fired = true;
          m.open('email-change-pending', { currentEmail: data.currentEmail, newEmail: data.newEmail });
          // Drop the one-shot payload so a later turbo:load (bfcache restore,
          // re-navigation) can't replay it.
          el.remove();
          return;
        }
        if (attempts++ < 50) setTimeout(tryOpen, 50); // up to ~2.5s for Alpine boot
      })();
    }
    document.addEventListener('turbo:load', openEmailChangePending);
    // Initial hard load before Turbo intercepts (direct nav to /account with
    // the flash, e.g. a non-Turbo redirect path) — turbo:load also covers
    // this, but DOMContentLoaded is a belt-and-suspenders for the cold start.
    if (document.readyState !== 'loading') openEmailChangePending();
    else document.addEventListener('DOMContentLoaded', openEmailChangePending);
  })();
</script>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-8">Account Settings</h1>

  <%# -- Profile (avatar + username) -- %>
  <div class="card shadow p-6 mb-6">
    <div x-data="imageUploadHost({ aspectRatio: 1, filename: 'avatar.png', saving: 'Saving photo…', dismissible: true, toast: false })"
         @crop-photo-confirmed.window="applyCrop($event.detail.blob)"
         class="flex flex-col items-center">
      <%# Hidden form auto-submitted after the user confirms a crop. %>
      <%= form_with model: @user, url: account_path, method: :patch,
                    html: { multipart: true, "x-ref": "form", class: "hidden" } do |f| %>
        <input type="file" name="user[avatar]" x-ref="fileInput">
      <% end %>
      <input type="file" x-ref="filePicker" @change="onFileSelected($event)" accept="image/*" class="hidden">

      <%# Clickable avatar — hover reveals "Update" overlay. Inline width/
          height because Tailwind w-24/h-24 weren't compiled here (the JIT
          only emits classes it sees at build time — see docs/UI_PATTERNS.md
          "Tailwind Compilation Constraints"). Squeezing on flex-col + items-center left the
          avatar as a pill instead of a circle. %>
      <div @click="$refs.filePicker.click()"
           style="width: 96px; height: 96px;"
           class="relative rounded-full cursor-pointer group overflow-hidden mb-3 flex-shrink-0">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "rounded-full object-cover", style: "width: 96px; height: 96px;", alt: @user.display_name %>
        <% else %>
          <div class="rounded-full flex items-center justify-center font-bold text-white text-3xl"
               style="width: 96px; height: 96px; background-color: <%= @user.avatar_color %>">
            <%= @user.avatar_initials %>
          </div>
        <% end %>
        <div class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
          <span class="text-white text-xs font-bold">Update</span>
        </div>
      </div>

      <div class="text-xl font-bold text-heading mb-3"><%= current_user.display_name %></div>

      <button type="button" @click="$store.modals.open('username')" class="btn btn-outline btn-sm">
        Change username
      </button>
    </div>

  </div>


  <%# -- Identities (wallet + balances + Google + email) -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Identities</h2>

    <% if @user.solana_connected? %>
      <div class="mb-4">
        <h3 class="text-sm font-bold text-heading mb-2">Solana Wallet</h3>
        <div class="flex items-center gap-2 flex-wrap">
          <svg class="w-4 h-4 text-green-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-body font-mono text-sm break-all"><%= @user.solana_address %></span>
          <%# Badge keys on wallet_kind (phantom takes precedence), NOT
              managed_wallet? — every account gets an after_create managed
              wallet, so managed_wallet? is always true and mislabeled Phantom
              users as "Managed". %>
          <% if @user.wallet_kind == :phantom %>
            <span class="text-xs text-violet px-2 py-0.5 rounded bg-violet/10">Phantom</span>
          <% else %>
            <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Managed</span>
          <% end %>
        </div>
      </div>

      <%# Balance tiles row — USDC | USDT | Entry Tokens | SOL | Seeds.
          Values are ON-CHAIN truth, hydrated client-side: the layout's
          hydrateNavbar fires refreshSession() on every page load, and the
          Refresh Wallet button (walletRefresh factory) re-pulls on demand.
          refreshSession fills the data-wallet-tile spans here PLUS the
          navbar pill, token badge, $store.session cents, and the seeds bar
          — one call, every component. The server renders "—" placeholders
          (the render path is RPC-free by design — see
          perform_solana_preload). %>
      <div x-data="walletRefresh()">
      <div class="grid grid-cols-5 gap-2 mb-3">
        <%# All five tiles share an icon row with a fixed 28px height so the
            labels + values line up across emoji icons and the 24px SVGs/PNG. %>
        <%# USDC %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <img src="/usdc-mark.svg" alt="USDC" style="width: 24px; height: 24px;">
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">USDC</span>
          <span class="font-mono font-bold text-primary text-sm mt-0.5" data-wallet-tile="usdc">—</span>
        </div>

        <%# USDT %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <%= image_tag "tokens/usdt.png", alt: "USDT", style: "width: 24px; height: 24px;" %>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">USDT</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5" data-wallet-tile="usdt">—</span>
        </div>

        <%# Entry Tokens %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <span style="font-size: 22px; line-height: 1;">🎟️</span>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">Entry Tokens</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5" data-wallet-tile="tokens"><%= @user.entry_token_balance %></span>
        </div>

        <%# SOL %>
        <div class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <img src="/solana-mark.svg" alt="SOL" style="width: 24px; height: 24px;">
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">SOL</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5" data-wallet-tile="sol">—</span>
        </div>

        <%# Seeds — ticks up live on quest completion (navbar-seeds-update);
            seedsTile self-heals the value from the seedsNavbar cache when the
            server read is cold (the "—" below shows pre-Alpine only). %>
        <div x-data="seedsTile({ initial: <%= @user_seeds.to_i %> })"
             class="bg-inset rounded-lg p-3 flex flex-col items-center text-center">
          <div class="flex items-center justify-center mb-1" style="height: 28px;">
            <span style="font-size: 22px; line-height: 1;">🌱</span>
          </div>
          <span class="text-[10px] uppercase tracking-wide text-muted">Seeds</span>
          <span class="font-mono font-bold text-heading text-sm mt-0.5" x-text="seeds">
            <%= @user_seeds.nil? ? "—" : @user_seeds %>
          </span>
        </div>
      </div>

      <%# Wallet actions — Refresh Wallet re-pulls every on-chain value via
          refreshSession(); Cash out for managed users (the server can sign on
          their behalf), Manage callout for self-custodied users (server can't
          sign; they cash out from their imported wallet). Phantom-only users
          see only Refresh — they cash out in their own wallet app. The actual
          withdraw form lives at /wallet — #cash-out auto-opens it. %>
      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <button type="button" @click="refresh()" :disabled="refreshing"
                class="btn btn-outline btn-sm">
          <span x-show="!refreshing" class="inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
            </svg>
            Refresh Wallet
          </span>
          <span x-show="refreshing" class="inline-flex items-center gap-2" style="display: none;">
            <span class="cta-spinner" aria-hidden="true"></span>
            Refreshing…
          </span>
        </button>
        <%# Buy USDC (Coinbase CDP onramp) — same flow as /wallet, for both
            managed (web2) and Phantom (web3) wallets; sized to this row. %>
        <%= render "shared/buy_usdc_button", button_class: "btn btn-primary btn-sm" %>
        <% if @user.can_use_managed_withdraw? %>
          <%= link_to "Cash out", "#{wallet_path}#cash-out", class: "btn btn-outline btn-sm" %>
        <% elsif @user.self_custodied? %>
          <span class="text-xs text-emerald-300 px-2 py-0.5 rounded bg-emerald-500/10">Self-custodied — cash out from your own wallet</span>
        <% end %>
        <% if Solana::Config.devnet? %>
          <a href="https://explorer.solana.com/address/<%= @user.solana_address %>?cluster=devnet"
             target="_blank" class="text-xs text-secondary hover:text-primary transition">
            View on Solana Explorer &rarr;
          </a>
        <% end %>
      </div>
      <%= render "shared/buy_usdc_geo_note" %>
      </div><%# /walletRefresh %>
    <% else %>
      <div class="mb-6">
        <%= render "shared/solana_wallet_connect", link_mode: true %>
      </div>
    <% end %>

    <%# Google Account %>
    <div class="mb-6">
      <h3 class="text-sm font-bold text-heading mb-2">Google Account</h3>
      <% if @user.google_connected? %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-body">Connected via Google</span>
          </div>
          <%= button_to "Unlink", unlink_google_account_path, method: :post,
            class: "btn btn-danger btn-sm",
            data: { turbo_confirm: "Unlink your Google account?" } %>
        </div>
      <% else %>
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
          class: "btn btn-google gap-3 w-full" do %>
          <%= render "components/google_logo" %>
          Link Google Account
        <% end %>
      <% end %>
    </div>

    <%# Email — full PATCH /account flow. Passwordless (Lazarus audit #4):
        changing an existing email is confirmed out-of-band via a link sent to
        the CURRENT address (AccountsController#update), so there's no in-app
        re-auth field. Setting a first email applies directly + verifies. %>
    <div x-data="{ initial: '<%= j @user.email.to_s %>', current: '<%= j @user.email.to_s %>' }">
      <h3 class="text-sm font-bold text-heading mb-2">Email</h3>
      <%= form_with model: @user, url: account_path, method: :patch do |f| %>
        <div class="flex gap-2">
          <%= f.email_field :email,
                            class: "input-field flex-1",
                            placeholder: "you@example.com",
                            "x-model": "current" %>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
        <% if @user.email.present? %>
          <p x-show="current.toLowerCase() !== initial.toLowerCase()" x-cloak
             class="text-xs text-muted mt-2">
            For your security, we'll email a confirmation link to your current address before the change takes effect.
          </p>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# -- Bring Friends / referral widget -- %>
  <%
    referral_target_path = @referral_share_contest ? contest_path(@referral_share_contest) : root_path
    referral_url = referral_link_url(referral_target_path)
    referral_share_title = "Weekly World Cup DFS ⚽️ - Turf Totals"
    referral_encoded_url   = ERB::Util.url_encode(referral_url)
    referral_encoded_title = ERB::Util.url_encode(referral_share_title)
    referral_twitter_url  = "https://twitter.com/intent/tweet?text=#{referral_encoded_title}&url=#{referral_encoded_url}"
    referral_facebook_url = "https://www.facebook.com/sharer/sharer.php?u=#{referral_encoded_url}"
    referral_whatsapp_url = "https://wa.me/?text=#{ERB::Util.url_encode("#{referral_share_title}\n#{referral_url}")}"
    invitees_in_contest = current_user.invitees_in_contest_count
    invitees_total = current_user.invitees_count
    target_count = 2
    progress_filled = [invitees_in_contest, target_count].min
    token_earned = invitees_in_contest >= target_count
  %>
  <div x-data="{ copied: false, infoOpen: false }" class="card shadow p-6 mb-6 relative">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2 min-w-0">
        <h2 class="text-lg font-bold text-heading">Bring ✌️ Friends, Get a Free Entry</h2>
        <button type="button" @click="infoOpen = !infoOpen"
                class="w-4 h-4 rounded-full bg-surface-alt text-muted hover:text-heading hover:bg-inset flex items-center justify-center text-[10px] font-bold leading-none transition flex-shrink-0"
                aria-label="How invites work">i</button>
      </div>
      <div class="flex items-center gap-1">
        <a href="<%= referral_twitter_url %>" target="_blank" rel="noopener" class="p-1.5 rounded-md text-muted hover:text-heading hover:bg-surface-alt transition" title="Share on X">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="<%= referral_facebook_url %>" target="_blank" rel="noopener" class="p-1.5 rounded-md text-muted hover:text-heading hover:bg-surface-alt transition" title="Share on Facebook">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="<%= referral_whatsapp_url %>" target="_blank" rel="noopener" class="p-1.5 rounded-md text-muted hover:text-heading hover:bg-surface-alt transition" title="Share on WhatsApp">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
      </div>
    </div>

    <%# Info popover — same explainer used on the contest page card %>
    <div x-show="infoOpen" x-cloak
         x-transition:enter="transition ease-out duration-150"
         x-transition:enter-start="opacity-0 -translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-100"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click.outside="infoOpen = false"
         @keydown.escape.window="infoOpen = false"
         class="absolute left-6 top-14 z-20 w-72 max-w-[calc(100%-3rem)] bg-surface border border-subtle rounded-lg shadow-2xl p-4">
      <div class="flex items-start justify-between mb-2">
        <h4 class="text-heading font-semibold text-sm">How it works</h4>
        <button type="button" @click="infoOpen = false" class="text-muted hover:text-heading text-lg leading-none" aria-label="Close">&times;</button>
      </div>
      <p class="text-secondary text-xs leading-relaxed mb-3">
        You get a free contest entry once <strong class="text-heading">two friends</strong> sign up <em>and</em> submit a contest entry of their own. The referral is locked in the moment they click your link &mdash; even before they sign up.
      </p>
      <%= link_to "Read full terms &rarr;".html_safe, "/terms#referrals", class: "text-primary hover:underline text-xs font-medium" %>
    </div>

    <%# Copy-link row %>
    <% copy_js = "navigator.clipboard.writeText('#{referral_url}'); copied = true; setTimeout(() => copied = false, 1500)" %>
    <div class="flex items-center gap-2 mb-4">
      <div @click="<%= copy_js %>" class="flex-1 min-w-0 bg-inset border border-subtle rounded-lg px-3 py-2 text-xs font-mono text-muted truncate cursor-pointer hover:border-primary/40 transition"><%= referral_url %></div>
      <button @click="<%= copy_js %>" class="btn btn-sm whitespace-nowrap transition-colors" :class="copied ? 'btn-secondary' : 'btn-primary'" style="min-width:5.5rem">
        <span x-show="!copied" x-cloak.remove>Copy Link</span>
        <span x-show="copied" x-cloak>Copied!</span>
      </button>
    </div>

    <%# Progress — two states: a prominent card with friend silhouettes the
        moment at least one invitee enters a contest (progress_filled > 0),
        and a single subtle line of helper text before that. Pre-progress
        the silhouettes were noisy at 0/0; gate them behind real progress
        so the card stays quiet until the user has something to celebrate. %>
    <% if progress_filled.positive? %>
      <div class="bg-inset rounded-lg p-4">
        <div class="flex items-center justify-center gap-4 mb-3">
          <% target_count.times do |i| %>
            <% filled = i < progress_filled %>
            <div class="rounded-full flex items-center justify-center transition-all"
                 style="width: 56px; height: 56px; <%= filled ? 'background-color: rgb(var(--color-primary-500-rgb) / 0.15); border: 2px solid rgb(var(--color-primary-500-rgb));' : 'background-color: transparent; border: 2px dashed var(--color-subtle);' %>">
              <% if filled %>
                <svg class="w-7 h-7 text-primary" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
              <% else %>
                <svg class="w-7 h-7 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="text-center">
          <% if token_earned %>
            <div class="flex items-center justify-center gap-2 flex-wrap">
              <span class="text-heading font-bold text-sm"><%= invitees_in_contest %> friends entered</span>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-primary/15 text-primary border border-primary/40">
                🎟️ ENTRY TOKEN COMING SOON
              </span>
            </div>
          <% else %>
            <p class="text-heading text-sm">
              <strong>1 of 2 friends</strong> has entered a contest &mdash;
              <span class="text-secondary">bring one more for a free entry token.</span>
            </p>
          <% end %>
        </div>
      </div>
    <% elsif invitees_total.positive? %>
      <p class="text-secondary text-xs text-center">
        <strong class="text-heading"><%= invitees_total %> <%= "friend".pluralize(invitees_total) %></strong> signed up &mdash;
        once two enter a contest, you&rsquo;ll earn a free entry token.
      </p>
    <% else %>
      <p class="text-secondary text-xs text-center">
        Two friends who enter a contest = one free entry token for you.
      </p>
    <% end %>
  </div>

  <%# -- Newsletter (placed below Bring Friends per the funnel order) --
      Each x-show state carries a matching min-height so toggling subscribed
      <-> not-subscribed doesn't change the card height (no jump). subscribed
      is server-seeded + kept in sync by the newsletter-state-changed event. %>
  <div x-data="{ subscribed: <%= current_user.subscribed_to_newsletter? %> }"
       @newsletter-state-changed.window="subscribed = !!$event.detail.subscribed"
       class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Newsletter</h2>

    <%# Subscribed state %>
    <div x-show="subscribed" x-cloak class="flex items-center justify-between gap-3 flex-wrap" style="min-height: 3rem;">
      <div class="flex items-center gap-2 min-w-0">
        <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
        <span class="text-body">Subscribed</span>
      </div>
      <button type="button" @click="$store.modals.open('unsubscribe-confirm')"
              class="text-sm text-secondary hover:text-heading transition underline-offset-2 hover:underline">
        Unsubscribe
      </button>
    </div>

    <%# Not-subscribed state %>
    <div x-show="!subscribed" x-cloak class="flex items-center justify-between gap-3 flex-wrap" style="min-height: 3rem;">
      <p class="text-secondary text-sm min-w-0">
        <% if current_user.first_newsletter_join? %>
          Join the newsletter for <span class="text-primary font-semibold">25 seeds</span> — sports news and contest updates.
        <% else %>
          Join the newsletter — sports news and contest updates.
        <% end %>
      </p>
      <button type="button" @click="$store.modals.open('newsletter-subscribe')"
              class="btn btn-primary btn-sm flex-shrink-0">
        Subscribe
      </button>
    </div>
  </div>

  <%# -- Quests progress -- %>
  <%= render "quests" %>

  <%# -- Log out + Buy Entry Tokens (side by side) -- %>
  <div class="grid grid-cols-2 gap-4 mb-6">
    <%= link_to "Log out", logout_path, class: "btn btn-outline w-full", onclick: "try{localStorage.removeItem('pendingContestEntry')}catch(e){}" %>
    <%= link_to "Buy Entry Tokens", tokens_buy_path, class: "btn btn-primary w-full" %>
  </div>

</div>

<p style="margin:0 0 16px;font-size:16px;line-height:1.6;color:#3f4a3c;">Hi <%= @user.display_name %> 👋🏻</p>

<% if @contest %>
  <p style="margin:0 0 28px;font-size:16px;line-height:1.6;color:#3f4a3c;">
    You're almost in <strong style="color:#1f2a1c;"><%= @contest.name %></strong> — verify your email and you'll
    land right back on the contest to finish your entry.
  </p>
<% else %>
  <p style="margin:0 0 28px;font-size:16px;line-height:1.6;color:#3f4a3c;">
    Tap the button below to verify the email address on your Turf Monster account.
  </p>
<% end %>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin:0 auto;">
  <tr><td align="center" bgcolor="#4BAF50" style="border-radius:10px;">
    <a href="<%= @verify_url %>" style="display:inline-block;padding:16px 40px;font-size:17px;font-weight:700;color:#ffffff;text-decoration:none;border-radius:10px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Verify my email →</a>
  </td></tr>
</table>

<p style="margin:28px 0 0;font-size:13px;line-height:1.5;color:#6b756a;text-align:center;">
  This link expires in 24 hours. Didn't request this? You can safely ignore it.
</p>

<p style="margin:24px 0 0;font-size:12px;line-height:1.4;color:#8a948a;text-align:center;">
  Button not working? Copy and paste this link:<br>
  <a href="<%= @verify_url %>" style="font-size:9px;line-height:1.3;color:#3d8b40;word-break:break-all;"><%= @verify_url %></a>
</p>

<p style="margin:24px 0 0;font-size:13px;color:#6b756a;text-align:center;">— Turf Monster</p>

<%# Navbar gear — settings dropdown.
    Logged-out: not rendered (this partial is only included from
    _user_nav, which itself guards on logged_in?).
    EVERYONE gets the curated user menu (My Profile / My Contests / How to Play
    / Proof of Reserves / Refresh Wallet). Admins get the SAME menu with an
    admin section appended — the admin menu is a superset, not a separate menu.
    Log out is last for all. %>
<% return unless current_user %>

<%# `group` on each row scopes group-hover to that row so the leading emoji can
    swap on hover (see emoji_swap). %>
<% link_class   = "group block px-4 py-2 text-sm text-body hover:text-heading hover:bg-surface-alt transition font-medium" %>
<% muted_class  = "group block px-4 py-2 text-sm text-body hover:text-heading hover:bg-surface-alt transition" %>
<% header_class = "label-upper font-bold px-4 py-1" %>

<%# Fixed-width emoji gutter that swaps `base` → `hover` when its row is hovered. %>
<% emoji_swap = ->(base, hover) {
     content_tag(:span, class: "nav-emoji-swap") do
       content_tag(:span, base, class: "nav-emoji-base") +
         content_tag(:span, hover, class: "nav-emoji-hover")
     end
   } %>

<div x-data="{ open: false }" class="relative leading-none">
  <button @click="open = !open" class="flex text-secondary hover:text-heading transition" title="<%= current_user.admin? ? 'Admin' : 'Settings' %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
    </svg>
  </button>

  <div x-show="open" @click.outside="open = false"
       x-transition:enter="transition ease-out duration-100" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100"
       x-transition:leave="transition ease-in duration-75" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95"
       class="absolute right-0 mt-2 w-48 bg-surface border border-subtle rounded-lg shadow-lg z-50 py-1" style="display: none;">

    <%# === Curated user menu — shown to EVERYONE ===
        Order: My Profile → My Contests → How to Play → Proof of Reserves →
        Refresh Wallet. Each leads with an emoji in a fixed-width gutter so the
        labels stay column-aligned. Admins get the admin section appended below
        (admin links stay text-only). %>
    <%# Next quest — dynamic pointer to the user's next step in the flow. username
        + newsletter open their modals (same as /account); join, send-message +
        invite link to the contest. Invite is ongoing, so it stays once reached. %>
    <% nq = current_user.respond_to?(:next_quest) ? current_user.next_quest : nil %>
    <% if nq %>
      <% quest_contest_path = SeasonConfig.main_contest ? contest_path(SeasonConfig.main_contest) : contests_path %>
      <% case nq
         when :join %>
        <%= link_to quest_contest_path, class: link_class do %><%= emoji_swap.("🎯", "▶️") %>Next: Join a contest<% end %>
      <% when :username %>
        <button type="button" @click="open = false; $store.modals.open('username')" class="<%= link_class %> w-full text-left"><%= emoji_swap.("✨", "✏️") %>Next: Change username</button>
      <% when :chat %>
        <%= link_to quest_contest_path, class: link_class do %><%= emoji_swap.("💬", "✍️") %>Next: Send a message<% end %>
      <% when :newsletter %>
        <button type="button" @click="open = false; $store.modals.open('newsletter-subscribe')" class="<%= link_class %> w-full text-left"><%= emoji_swap.("📬", "✅") %>Next: Join the newsletter</button>
      <% when :invite %>
        <%= link_to quest_contest_path, class: link_class do %><%= emoji_swap.("🤝", "🎁") %>Next: Invite friends<% end %>
      <% end %>
      <div class="border-t border-subtle my-1"></div>
    <% end %>
    <%= link_to account_path, class: link_class do %><%= emoji_swap.("🙂", "✏️") %>My Profile<% end %>
    <%= link_to my_contests_path, class: link_class do %><%= emoji_swap.("🏆", "⚔️") %>My Contests<% end %>
    <%= link_to help_how_to_play_path, class: link_class do %><%= emoji_swap.("🎮", "🤔") %>How to Play<% end %>
    <%= link_to proof_of_reserves_path, class: link_class do %><%= emoji_swap.("🪎", "🏦") %>Proof of Reserves<% end %>
    <%# Refresh Wallet — runs the standard wallet data resync (USDC + tokens +
        seeds) and shows the navbar spinner while it's in flight. An action, so
        it's a <button>, not a link. Closes the menu on click. %>
    <button type="button"
            @click="open = false; if (window.showNavSpinner) window.showNavSpinner(); if (window.refreshSession) { window.refreshSession().finally(function() { if (window.hideNavSpinner) window.hideNavSpinner(); }); }"
            class="<%= link_class %> w-full text-left"><%= emoji_swap.("👛", "♻️") %>Refresh Wallet</button>

    <% if current_user.admin? %>
      <%# === Admin section — appended to the user menu for admins ===
          (curated shortlist of admin/hub.html.erb). %>
      <div class="border-t border-subtle my-1"></div>
      <%= link_to "Contests", contests_path, class: link_class %>
      <%= link_to "Seasons", admin_seasons_path, class: link_class %>

      <div class="border-t border-subtle my-1"></div>
      <div class="<%= header_class %>">FIFA</div>
      <% active_slate = Slate.joins(:slate_matchups).distinct.order(created_at: :desc).first %>
      <% if active_slate %>
        <%= link_to "Slate Simulator", manage_admin_slate_path(active_slate), class: link_class %>
      <% end %>
      <%= link_to "Slate Formula", slates_path, class: link_class %>
      <% featured_landing_page = LandingPage.active.order(updated_at: :desc).first %>
      <% if featured_landing_page %>
        <%= link_to "Landing Page", landing_page_path(featured_landing_page), class: link_class %>
      <% end %>

      <div class="border-t border-subtle my-1"></div>
      <div class="<%= header_class %>">Admin</div>
      <%# Admin Dashboard — settings home (default og image, etc.). Static path
          (like Jobs below) so the navbar never depends on a route helper; the
          page itself ships in a separate PR. %>
      <%= link_to "Dashboard", "/admin/dashboard", class: link_class %>
      <% if Admin::VaultInitController.vault_uninitialized? %>
        <%= link_to admin_vault_init_path, class: link_class do %>
          Vault Init
          <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-yellow-400 text-black align-middle">!</span>
        <% end %>
      <% else %>
        <%= link_to admin_vault_state_path, class: link_class do %>
          Vault State
          <% if Admin::VaultStateController.vault_paused? %>
            <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-500 text-white align-middle">🚨 PAUSED</span>
          <% end %>
        <% end %>
      <% end %>
      <%= link_to "Landing Pages", admin_landing_pages_path, class: link_class %>
      <%= link_to "Geo Settings", admin_geo_path, class: link_class %>
      <%= link_to "Error Logs", error_logs_path, class: link_class %>
      <%= link_to "Jobs", "/admin/jobs", class: link_class %>

      <div class="border-t border-subtle my-1"></div>
      <%= link_to "Link Hub", admin_hub_path, class: muted_class %>
    <% end %>

    <%# Log out — everyone, last item. Studio-engine ships /logout as
        a GET (sessions#destroy) so a plain link is correct here. %>
    <div class="border-t border-subtle my-1"></div>
    <%= link_to logout_path, class: muted_class, data: { turbo: false }, onclick: "try{localStorage.removeItem('pendingContestEntry')}catch(e){}" do %><%= emoji_swap.("👋🏻", "⏏️") %>Log out<% end %>
  </div>
</div>

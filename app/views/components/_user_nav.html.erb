<%# Shared right-side navbar user section.
    Locals (all optional):
      balance_html     — raw HTML for balance display (e.g. Turf Monster wallet balance)
      extra_icons_html — raw HTML for app-specific icon buttons (e.g. refresh button)
      show_logout_link — boolean, show explicit "Log out" link (Studio uses this)
      div2_html        — raw HTML to replace default Div 2 (e.g. Turf Monster seeds bar)
%>
<% balance_html     ||= nil %>
<% extra_icons_html ||= nil %>
<% show_logout_link ||= false %>
<% div2_html        ||= nil %>
<% gear_toggle_action = "$store.sidebars.gearOpen = !$store.sidebars.gearOpen" %>
<% gear_expanded_attr = "$store.sidebars && $store.sidebars.gearOpen ? 'true' : 'false'" %>
<% gear_toggle_label = current_user&.admin? ? "Toggle admin menu" : "Toggle settings menu" %>

<div class="flex gap-2">
  <% if logged_in? %>
    <%# Left column: Div 1 + Div 2 stacked %>
    <div class="flex-1">
      <%# Div 1 (Bigger): balance + icons + username — margin-left matches Div 2's seeds bar offset so cash aligns with bar start %>
      <div class="flex items-center gap-1 leading-none" style="padding-right: 6px; margin-left: -6px;">
        <% if balance_html.present? %>
          <%= raw balance_html %>
        <% end %>
        <%= render "components/entry_token_badge" %>
        <span class="hidden md:flex items-center gap-2 ml-auto">
          <span class="hidden md:block"><%= render "components/gear_sidebar_trigger" %></span>
          <%= render "components/theme_toggle_morph" %>
        </span>
        <button type="button"
                class="dm-coral max-w-[5rem] min-[400px]:max-w-[6rem] md:max-w-[7rem] text-heading font-semibold hover:text-primary transition-all duration-300 leading-none md:ml-0 ml-auto overflow-hidden whitespace-nowrap text-left bg-transparent border-0 p-0"
                @click.stop="<%= gear_toggle_action %>"
                aria-label="<%= gear_toggle_label %>"
                aria-controls="gear-sidebar gear-sidebar-mobile"
                aria-haspopup="dialog"
                :aria-expanded="<%= gear_expanded_attr %>"
                data-username-display="true"
                x-bind:class="scrolled ? 'text-base' : 'text-lg'"
                x-data="{ overflows: false, init() { this.overflows = this.$el.scrollWidth > this.$el.clientWidth } }"
                x-bind:style="overflows ? '-webkit-mask-image: linear-gradient(to right, black 50%, transparent); mask-image: linear-gradient(to right, black 50%, transparent);' : ''">
          <%= current_user.display_name %>
        </button>
      </div>
      <%# Div 2 (Smaller): 5-section seeds bar + level (right) — see components/_seeds_bar %>
      <% solana_label = current_user.respond_to?(:truncated_solana) && current_user.try(:solana_connected?) ? current_user.truncated_solana : nil %>
      <div class="mt-0.5" style="margin-left: -6px;">
        <%= render "components/seeds_bar",
              seeds_data: display_seeds_data,
              compact: true,
              label: solana_label,
              shimmer_interval: 9 %>
      </div>
    </div>
    <%# Div 3 (Avatar): spans both rows %>
    <button type="button"
            class="dm-green hover:opacity-80 transition flex-shrink-0 flex items-center bg-transparent border-0 p-0"
            @click.stop="<%= gear_toggle_action %>"
            aria-label="<%= gear_toggle_label %>"
            aria-controls="gear-sidebar gear-sidebar-mobile"
            aria-haspopup="dialog"
            :aria-expanded="<%= gear_expanded_attr %>"
            data-profile-image-toggle="true">
      <%= render "components/avatar", user: current_user, size: "nav" %>
    </button>
  <% else %>
    <span class="hidden md:block"><%= render "components/gear_sidebar_trigger" %></span>
    <span class="hidden md:flex"><%= render "components/theme_toggle" %></span>
    <div class="flex items-center gap-3 ml-auto">
      <%# Opens the in-page auth modal (credentials step: Google + wallet + email
          magic-link). href=/signin is the no-JS fallback — the page still exists,
          we just don't route to it from here for now. %>
      <%= link_to "Sign in", signin_path, class: "btn btn-primary btn-sm",
            "@click.prevent": "$store.modals.open('auth', { step: 'credentials', mode: 'signup', submitting: null, formError: '', phantomError: '', googleError: '' })" %>
    </div>
  <% end %>
</div>

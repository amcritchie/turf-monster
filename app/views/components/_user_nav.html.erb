<%# Shared right-side navbar user section.
    Locals (all optional):
      balance_html     — raw HTML for balance display (e.g. Turf Monster wallet balance)
      extra_icons_html — raw HTML for app-specific icon buttons (e.g. refresh button)
      show_logout_link — boolean, show explicit "Log out" link (Studio uses this)
      div2_html        — raw HTML to replace default Div 2 (e.g. Turf Monster seeds bar)
%>
<% balance_html     ||= nil %>
<% extra_icons_html ||= nil %>
<% show_logout_link ||= false %>
<% div2_html        ||= nil %>

<style>
  .username-cap { max-width: 5rem; }
  @media (min-width: 400px) { .username-cap { max-width: 6rem; } }
  @media (min-width: 768px) { .username-cap { max-width: 7rem; } }
  /* Free-entry badge punch — fires when window.animateFreeEntryBadge()
     adds .free-entry-punch (e.g. right after a token-funded entry
     confirms). Slight scale + wobble; resets cleanly. */
  .free-entry-badge { display: inline-block; transform-origin: center; }
  .free-entry-punch { animation: free-entry-punch 0.65s cubic-bezier(.36,.07,.19,.97) both; }
  @keyframes free-entry-punch {
    0%   { transform: scale(1)   rotate(0deg); }
    20%  { transform: scale(1.45) rotate(-15deg); }
    40%  { transform: scale(1.2)  rotate(12deg); }
    60%  { transform: scale(1.3)  rotate(-6deg); }
    100% { transform: scale(1)   rotate(0deg); }
  }
</style>

<div class="flex gap-2">
  <% if logged_in? %>
    <%# Left column: Div 1 + Div 2 stacked %>
    <div class="flex-1">
      <%# Div 1 (Bigger): balance + icons + username — margin-left matches Div 2's seeds bar offset so cash aligns with bar start %>
      <div class="flex items-center gap-1 leading-none" style="padding-right: 6px; margin-left: -6px;">
        <% if balance_html.present? %>
          <%= raw balance_html %>
        <% end %>
        <% free_entries = current_user.entry_token_balance rescue 0 %>
        <%# 🎟️ free-entry indicator — present when the user has any
            unconsumed entry tokens. window.animateFreeEntryBadge()
            adds .free-entry-punch right after a token-funded entry
            confirms (server returns token_consumed: true). %>
        <%= link_to "🎟️", root_path,
              title: "#{free_entries} unconsumed entry token#{'s' if free_entries != 1} — click to enter a contest",
              class: "free-entry-badge px-1.5 py-0.5 rounded-full bg-primary/15 text-primary border border-primary/40 leading-none whitespace-nowrap hover:bg-primary/25 transition #{'hidden' unless free_entries.positive?}",
              style: "font-size: 12px;",
              data: { free_entry_badge: true } %>
        <% account_link = defined?(account_path) ? account_path : "#" %>
        <span class="hidden md:flex items-center gap-2 ml-auto">
          <span class="hidden md:block"><%= render "components/admin_dropdown" %></span>
          <%= render "components/theme_toggle_morph" %>
        </span>
        <%= link_to account_link, class: "dm-coral username-cap text-heading font-semibold hover:text-primary transition-all duration-300 leading-none md:ml-0 ml-auto overflow-hidden whitespace-nowrap",
              "x-bind:class": "scrolled ? 'text-base' : 'text-lg'",
              data: { username_display: true },
              "x-data": "{ overflows: false, init() { this.overflows = this.$el.scrollWidth > this.$el.clientWidth } }",
              "x-bind:style": "overflows ? '-webkit-mask-image: linear-gradient(to right, black 50%, transparent); mask-image: linear-gradient(to right, black 50%, transparent);' : ''" do %>
          <%= current_user.display_name %>
        <% end %>
      </div>
      <%# Div 2 (Smaller): 5-section seeds bar + level (right) — see components/_seeds_bar %>
      <% solana_label = current_user.respond_to?(:truncated_solana) && current_user.try(:solana_connected?) ? current_user.truncated_solana : nil %>
      <div class="mt-0.5" style="margin-left: -6px;">
        <%= render "components/seeds_bar",
              seeds_data: display_seeds_data,
              compact: true,
              label: solana_label,
              shimmer_interval: 9 %>
      </div>
    </div>
    <%# Div 3 (Avatar): spans both rows %>
    <% account_link = defined?(account_path) ? account_path : "#" %>
    <%= link_to account_link, class: "dm-green hover:opacity-80 transition flex-shrink-0 flex items-center" do %>
      <%= render "components/avatar", user: current_user, size: "nav" %>
    <% end %>
  <% else %>
    <span class="hidden md:block"><%= render "components/admin_dropdown" %></span>
    <span class="hidden md:flex"><%= render "components/theme_toggle" %></span>
    <div class="flex items-center gap-3 ml-auto">
      <%= link_to "Log in", login_path, class: "text-heading hover:text-primary text-sm font-semibold transition" %>
      <%= link_to "Sign up", signup_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>

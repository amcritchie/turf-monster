<%# locals: (seeds_data:, compact: false, label: nil, title: nil, shimmer_interval: nil) %>
<%#
  Renders the 5-section seeds bar.
  - seeds_data: { seeds:, level:, toward_next:, progress:, seeds_to_next: } from controllers/load_seeds_data helper
  - compact: true → navbar variant (14px tall, level + label text overlay, no counter below)
  -          false → card variant (22px tall, level badge + rotating counter, confetti on level-up)
  - label:   optional text shown on the left of the bar (compact variant only — typically current_user.truncated_solana)
  - title:   optional heading shown left of the level badge (card variant only)
  - shimmer_interval: seconds to wait before the one-shot shimmer sweep fires (nil = fire immediately on load)
%>
<%# seeds_data is nil while the navbar cache is cold ("loading") — the server
    no longer blocks the render on the seeds RPC. Fall back to a zero payload:
    the Alpine factory's normalStart() reconciles data-initial-* against the
    `seedsNavbar` localStorage cache (max wins), so the bar shows the last-known
    value, and refreshBalance's 'navbar-seeds-update' event fills the fresh
    server number once /admin/usdc_balance lands. %>
<% seeds_data ||= { seeds: 0, level: 1, toward_next: 0, progress: 0, seeds_to_next: User::SEEDS_PER_LEVEL } %>
<% lvl = seeds_data[:level].to_i %>
<% lvl = 1 if lvl < 1 %>
<% toward_next = seeds_data[:toward_next].to_i %>
<% pct = seeds_data[:progress].to_i %>
<%# Absolute total used by normalStart() to break ties against the
    `seedsNavbar` localStorage cache. The cache is updated only on the
    client-side confirmEntry path; any other on-chain seed delta (admin
    actions, Phantom-direct entries, RPC lag at confirm time, level-ups
    that happened in a different browser) leaves the cache trailing the
    chain truth until the next confirm. The server-rendered total is the
    fresh-from-chain number this request just read via sync_balance, so
    passing it down lets the JS pick max(server, cache) and self-heal
    the cache when it's behind. %>
<% server_total_seeds = seeds_data[:seeds].to_i %>
<% shimmer_anim = "seedsShimmer 2.5s ease-in-out #{shimmer_interval.to_f}s 1 both" %>

<%# seedsBar factory — MUST be inline because Alpine processes x-data
    BEFORE importmap modules load in this app's setup (verified
    2026-05-24: window.seedsBar was undefined at x-data parse time
    even with Alpine.data registration). Same pattern as the inline
    solanaModal store in layouts/application.html.erb.
    A duplicate module copy lives at app/javascript/seeds_bar.js for
    unit-testability; that one harmlessly re-assigns window.seedsBar
    later. %>
<script>
  window.seedsBar = function () {
    return {
      displaySeeds: 0,
      displayLevel: 1,
      levelingUp: false,
      finalToward: 0,
      _timers: [],

      init() {
        var initialToward = parseInt(this.$root.dataset.initialToward, 10) || 0;
        var initialLevel = parseInt(this.$root.dataset.initialLevel, 10) || 1;
        this._serverSeedsTotal = parseInt(this.$root.dataset.initialSeedsTotal, 10) || 0;
        this.displaySeeds = initialToward;
        this.displayLevel = initialLevel;
        this.finalToward = initialToward;

        var self = this;
        var raw = localStorage.getItem("seedsLevelUp");
        if (raw) {
          localStorage.removeItem("seedsLevelUp");
          try { self.runLevelUpSequence(JSON.parse(raw)); return; } catch (_) {}
        }
        self.normalStart();
      },

      destroy() {
        this._timers.forEach(clearTimeout);
        this._timers = [];
      },

      _schedule(fn, ms) {
        this._timers.push(setTimeout(fn, ms));
      },

      normalStart() {
        // Reconcile two sources of seed truth:
        //   - server: this._serverSeedsTotal (fresh sync_balance for THIS request)
        //   - cache:  readNavData() (last confirmEntry-side optimistic update)
        // Pick the higher value — server wins when the cache is stale (the
        // common case after Phantom direct entry, admin actions, or a long
        // gap), and cache wins for the ~hundreds-of-ms Helius lag right after
        // a confirm where on-chain reads still trail the just-confirmed TX.
        // Then write the winner back to localStorage so the cache self-heals
        // on first render — subsequent tabs / reloads stop seeing the stale
        // value without any further intervention.
        var data = this.readNavData();
        var cacheTotal  = (data && typeof data.seeds_total === "number") ? data.seeds_total : 0;
        var serverTotal = this._serverSeedsTotal || 0;

        if (cacheTotal > serverTotal && data) {
          this.displayLevel = data.level;
          this.finalToward = data.toward_next;
        } else if (serverTotal > cacheTotal) {
          // Server is fresher — displayLevel / finalToward already carry the
          // server's value from init(). Sync localStorage so other tabs +
          // future loads converge.
          try {
            var perLevel = <%= User::SEEDS_PER_LEVEL %>;
            localStorage.setItem("seedsNavbar", JSON.stringify({
              seeds_total: serverTotal,
              level: this.displayLevel,
              toward_next: this.finalToward,
              progress: Math.round(this.finalToward / perLevel * 100)
            }));
          } catch (_) {}
        }

        this.displaySeeds = 0;
        var self = this;
        this._schedule(function () { self.displaySeeds = self.finalToward; }, 150);
      },

      readNavData() {
        try {
          var raw = localStorage.getItem("seedsNavbar");
          if (!raw) return null;
          return JSON.parse(raw);
        } catch (_) { return null; }
      },

      playLevelUpFill(o) {
        var self = this;
        self.displaySeeds = o.oldPct || 0;
        self._schedule(function () { self.displaySeeds = 100; }, 300);
        self._schedule(function () {
          if (o.newLevel !== undefined && o.newLevel !== null) self.displayLevel = o.newLevel;
          if (o.fireConfetti) self.spawnFirework();
        }, 1500);
        self._schedule(function () { self.displaySeeds = 0; }, 2800);
        self._schedule(function () { self.displaySeeds = o.finalProgress; }, 3000);
      },

      runLevelUpSequence(lu) {
        var self = this;
        self.levelingUp = true;
        self.displayLevel = lu.oldLevel;
        var data = self.readNavData();
        self.playLevelUpFill({
          oldPct: lu.oldToward,
          newLevel: lu.newLevel,
          finalProgress: data ? data.toward_next : 0,
          fireConfetti: true
        });
        self._schedule(function () { self.levelingUp = false; }, 3000);
      },

      spawnFirework() {
        var container = this.$refs.confettiZone;
        if (!container) return;
        var colors = window.CONFETTI_COLORS || ["#4BAF50", "#8E82FE", "#06D6A0", "#FF7C47", "#EF4444"];
        var particles = 72;
        for (var i = 0; i < particles; i++) {
          var el = document.createElement("div");
          el.style.cssText = "position:absolute;width:5px;height:5px;border-radius:50%;pointer-events:none;";
          el.style.left = "50%";
          el.style.top = "50%";
          el.style.background = colors[Math.floor(Math.random() * colors.length)];
          container.appendChild(el);
          var angle = (Math.PI * 2 * i / particles) + (Math.random() - 0.5) * 0.4;
          var distance = 80 + Math.random() * 100;
          var dx = Math.cos(angle) * distance;
          var dy = Math.sin(angle) * distance;
          var dur = 700 + Math.random() * 600;
          el.animate([
            { transform: "translate(-50%, -50%) scale(1.8)", opacity: 1 },
            { transform: "translate(calc(-50% + " + dx + "px), calc(-50% + " + dy + "px)) scale(0.2)", opacity: 0 }
          ], { duration: dur, easing: "cubic-bezier(0.16, 1, 0.3, 1)", fill: "forwards", delay: Math.random() * 100 });
          setTimeout(function (e) { e.remove(); }.bind(null, el), 1500);
        }
      },

      replay() {
        var self = this;
        self.displayLevel = Math.max(1, self.displayLevel - 1);
        self.playLevelUpFill({
          oldPct: 60,
          newLevel: self.displayLevel + 1,
          finalProgress: self.finalToward,
          fireConfetti: false
        });
        self._schedule(function () { self.levelingUp = true; }, 1500);
        self._schedule(function () { self.levelingUp = false; }, 2800);
      },

      // Passive seeds-update: progress the bar (+ level-up animation if crossing a
      // level). NO confetti/pop here — this fires on the navbar's load-time balance
      // refresh too, so any celebration here pops on page load. Quest-completion
      // confetti is fired deliberately by completeQuest() from the Quest badge.
      handleSeedsUpdate(d) {
        var self = this;
        if (d.levelUp) {
          if (d.oldLevel !== undefined && d.oldLevel !== null) self.displayLevel = d.oldLevel;
          self.levelingUp = true;
          self.playLevelUpFill({
            oldPct: d.oldPct,
            newLevel: d.newLevel,
            finalProgress: d.progress,
            fireConfetti: true
          });
          self._schedule(function () { self.levelingUp = false; }, 3000);
        } else {
          if (d.level !== undefined && d.level !== null) self.displayLevel = d.level;
          self.displaySeeds = d.progress;
        }
      }
    };
  };
</script>

<div x-data="seedsBar()"
     data-initial-toward="<%= toward_next %>"
     data-initial-level="<%= lvl %>"
     data-initial-seeds-total="<%= server_total_seeds %>"
     @navbar-replay-level.window="replay()"
     @navbar-seeds-update.window="handleSeedsUpdate($event.detail)">

  <% if compact %>
    <%# ── Navbar variant: 14px bar with text overlay (matches existing _user_nav Div 2 sizing) ── %>
    <div class="dm-orange relative overflow-hidden rounded" style="height: 14px;">
      <%# 5-segment bar (continuous fill via --bar-progress) %>
      <div class="absolute inset-0 seeds-bar-continuous flex gap-1" :style="{ '--bar-progress': displaySeeds }">
        <template x-for="i in 5" :key="i">
          <div class="flex-1 relative overflow-hidden rounded-md"
               style="background: rgb(var(--color-primary-500-rgb) / 0.06);">
            <%# Bar-wide gradient: bg image is 500% of segment (= bar width), bg-position shows this segment's 1/5 slice. Clip-path animates via --bar-progress to reveal only the fill area. %>
            <div class="absolute inset-0 pointer-events-none"
                 :style="{
                   backgroundPosition: ((i - 1) * 25) + '% 0',
                   clipPath: 'inset(0 calc(100% - clamp(0%, calc((var(--bar-progress) - ' + ((i - 1) * 20) + ') * 5%), 100%)) 0 0)'
                 }"
                 style="background-image: linear-gradient(90deg, color-mix(in srgb, var(--color-cta) 30%, transparent), color-mix(in srgb, var(--color-cta) 60%, transparent)); background-size: 500% 100%; background-repeat: no-repeat;"></div>
            <%# Per-section shimmer — sized to whole bar so all 5 share one continuous wave.
                Skipped when the bar is nearly empty (toward_next < 9) — a shimmer on a blank bar reads as noise. %>
            <% if toward_next >= 9 %>
              <div class="absolute top-0 bottom-0 pointer-events-none"
                   :style="{ left: -(i - 1) * 100 + '%', width: '500%' }"
                   style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.45) 50%, transparent 100%); animation: <%= shimmer_anim %>;"></div>
            <% end %>
          </div>
        </template>
      </div>

      <%# Text layer 1: muted (visible outside bar fill) — matches existing seeds-text 10px sizing %>
      <div class="absolute inset-0 flex items-center justify-between px-1.5 text-muted font-mono pointer-events-none" style="font-size: 10px; z-index: 1;">
        <span><%= label %></span>
        <span class="flex items-center gap-1 pointer-events-auto">
          <a href="#" @click.prevent="replay()" x-show="$store.devMode" x-cloak
             class="text-[9px] font-bold text-yellow-400 hover:text-yellow-300 transition">Replay</a>
          <span :class="levelingUp && 'nav-level-pop'" x-text="'Level ' + displayLevel">Level <%= lvl %></span>
        </span>
      </div>

      <%# Text layer 2: white (clip-path reveals as bar fills) %>
      <div class="absolute inset-0 flex items-center justify-between px-1.5 font-mono pointer-events-none"
           style="color: white; font-size: 10px; z-index: 2; clip-path: inset(0 100% 0 0);"
           :style="{ 'clip-path': 'inset(0 ' + (100 - displaySeeds) + '% 0 0)' }">
        <span><%= label %></span>
        <span class="flex items-center gap-1">
          <span x-show="$store.devMode" x-cloak class="text-[9px] font-bold" style="visibility: hidden;">Replay</span>
          <span :class="levelingUp && 'nav-level-pop'" x-text="'Level ' + displayLevel">Level <%= lvl %></span>
        </span>
      </div>
    </div>

  <% else %>
    <%# ── Card variant: title + level badge + 22px bar + rotating counter + confetti ── %>
    <div class="flex items-center justify-between mb-3">
      <% if title.present? %>
        <h3 class="text-heading font-semibold text-sm"><%= title %></h3>
      <% else %>
        <span></span>
      <% end %>
      <div class="relative flex items-center gap-2" x-ref="confettiZone" style="overflow: visible;">
        <a href="#" @click.prevent="replay()" x-show="$store.devMode" x-cloak
           class="text-[10px] font-bold text-yellow-400 hover:text-yellow-300 transition">Replay</a>
        <%# Per-level styled pill (level-badge-N from application.tailwind.css)
            with a one-shot sheen sweep that fires 5s after load. The Ruby
            class supplies the initial styling so there's no FOUC; Alpine's
            :class updates the level-badge-N when displayLevel transitions
            during a level-up animation (and toggles level-up-pop on the
            pop moment). %>
        <span class="badge-with-sheen" style="--sheen-delay: 9s;">
          <span class="level-badge level-badge-<%= lvl %>"
                :class="`level-badge-${displayLevel}${levelingUp ? ' level-up-pop' : ''}`"
                x-text="'Level ' + displayLevel">
            Level <%= lvl %>
          </span>
        </span>
      </div>
    </div>

    <div class="seeds-bar-continuous flex gap-1.5"
         style="height: 22px;"
         :style="{ '--bar-progress': displaySeeds }">
      <template x-for="i in 5" :key="i">
        <div class="flex-1 relative overflow-hidden rounded-lg"
             style="background: rgb(var(--color-primary-500-rgb) / 0.06);">
          <%# Bar-wide gradient: bg image is 500% of segment (= bar width), bg-position shows this segment's 1/5 slice. Clip-path animates via --bar-progress to reveal only the fill area. %>
          <div class="absolute inset-0 pointer-events-none"
               :style="{
                 backgroundPosition: ((i - 1) * 25) + '% 0',
                 clipPath: 'inset(0 calc(100% - clamp(0%, calc((var(--bar-progress) - ' + ((i - 1) * 20) + ') * 5%), 100%)) 0 0)'
               }"
               style="background-image: linear-gradient(90deg, color-mix(in srgb, var(--color-cta) 30%, transparent), color-mix(in srgb, var(--color-cta) 60%, transparent)); background-size: 500% 100%; background-repeat: no-repeat;"></div>
          <% if toward_next >= 9 %>
            <div class="absolute top-0 bottom-0 pointer-events-none"
                 :style="{ left: -(i - 1) * 100 + '%', width: '500%' }"
                 style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.5) 50%, transparent 100%); animation: <%= shimmer_anim %>;"></div>
          <% end %>
        </div>
      </template>
    </div>

    <%# Rotating-integer counter %>
    <div class="flex items-center justify-end mt-2 font-mono text-[11px] text-secondary">
      <span class="inline-flex items-baseline gap-1 font-mono font-bold text-sm" style="color: var(--color-cta);">
        <%= render "components/digit_reel",
              value: "displaySeeds", max: 100, width: "3.1ch", cell_em: 1.25,
              transition: "'transform 1.2s cubic-bezier(0.16, 1, 0.3, 1)'" %>
        <span class="text-secondary text-xs font-normal">seeds</span>
      </span>
    </div>
  <% end %>
</div>

<%# Navbar 🎟️ Entry token badge.

    Visible when current_user has any unconsumed entry tokens (web2 token
    economy — see Contest::FORMATS notes in CLAUDE.md). Clicking opens a
    short-lived popover with the live count; the badge itself doesn't
    navigate.

    JS contract:
      [data-free-entry-badge]   — selector used by solana_utils.js for
                                  updateNavTokens / refreshBalance /
                                  animateFreeEntryBadge / fireConfettiFromBadge.
      .free-entry-badge         — CSS class for the .free-entry-punch
                                  animation triggered after a token-funded
                                  entry confirms.
      data-token-count          — live token count; updateNavTokens()
                                  writes here so the popover reads the
                                  current value on each open instead of
                                  the server-rendered snapshot.
      .hidden                   — lives on the button (not the wrapper)
                                  so the JS selectors above can surface
                                  the badge after a mint without a reload.
%>
<% free_entries = current_user.entry_token_balance rescue 0 %>
<% plural_suffix = free_entries == 1 ? "" : "s" %>

<%# .free-entry-badge / .free-entry-punch / @keyframes free-entry-punch
    live in application.tailwind.css (migrated 2026-05-24).
    entryTokenBadge() Alpine factory is in app/javascript/entry_token_badge.js. %>
<div class="relative leading-none" x-data="entryTokenBadge({ initialCount: <%= free_entries %> })">
  <button type="button"
          @click="toggle()"
          title="<%= free_entries %> unconsumed entry token<%= plural_suffix %>"
          class="free-entry-badge inline-flex items-center justify-center gap-1 px-2.5 py-1 rounded-full bg-primary/15 border border-primary/40 text-primary font-bold leading-none whitespace-nowrap hover:bg-primary/25 transition cursor-pointer <%= 'hidden' unless free_entries.positive? %>"
          style="font-size: 13px; line-height: 1;"
          data-free-entry-badge="true"
          data-token-count="<%= free_entries %>">
    <span style="font-size: 16px; line-height: 1;">🎟️</span>
    <span>Entry</span>
  </button>
  <div x-show="open"
       @click.outside="close()"
       x-transition:enter="transition ease-out duration-150"
       x-transition:enter-start="opacity-0 scale-95"
       x-transition:enter-end="opacity-100 scale-100"
       x-transition:leave="transition ease-in duration-500"
       x-transition:leave-start="opacity-100 scale-100"
       x-transition:leave-end="opacity-0 scale-95"
       class="absolute left-1/2 -translate-x-1/2 mt-2 px-3 py-2 bg-surface border border-primary/40 rounded-lg shadow-lg z-50 whitespace-nowrap"
       style="display: none;">
    <div class="flex items-center gap-1.5 text-primary font-bold text-sm leading-none">
      <span style="font-size: 16px;">🎟️</span>
      <span><span x-text="count"></span> Entry Token<span x-show="count !== 1">s</span></span>
    </div>
  </div>
</div>

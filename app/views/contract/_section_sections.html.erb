<%#
  ELF section breakdown — stacked bar + legend.
    locals: sections (Array of { name:, bytes:, color:, desc: }), binary_size
%>
<section class="card p-6 sm:p-8 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4 mb-2">
    <h2 class="text-heading font-bold text-xl">Where the <%= (binary_size / 1024.0).round %> KB goes</h2>
    <span class="text-[11px] font-mono text-muted uppercase tracking-wider">ELF section headers</span>
  </div>
  <p class="text-secondary text-sm mb-5 max-w-3xl">
    Solana charges rent on every byte in the ProgramData account, regardless of what's in it.
    The ELF section layout decides what those bytes <em>are</em>.
  </p>

  <%# Stacked bar (desktop) — full-width split by byte percentage %>
  <div class="hidden sm:flex h-10 w-full rounded-lg overflow-hidden border border-subtle">
    <% total = sections.sum { |s| s[:bytes] } %>
    <% sections.each do |s| %>
      <% pct = 100.0 * s[:bytes] / total %>
      <div class="flex items-center justify-center text-[11px] font-mono text-black/70"
           style="width: <%= sprintf("%.2f", pct) %>%; background: <%= s[:color] %>;"
           title="<%= s[:name] %> &mdash; <%= number_with_delimiter(s[:bytes]) %> bytes (<%= sprintf("%.1f", pct) %>%)">
        <span class="truncate px-1"><%= pct >= 4 ? s[:name] : "" %></span>
      </div>
    <% end %>
  </div>

  <%# Mobile: rows instead of stacked bar (text gets crushed at < 640px) %>
  <div class="sm:hidden space-y-2">
    <% sections.each do |s| %>
      <% pct = 100.0 * s[:bytes] / sections.sum { |x| x[:bytes] } %>
      <div class="flex items-center gap-3 text-sm">
        <div class="w-3 h-3 rounded-sm flex-none" style="background: <%= s[:color] %>;"></div>
        <div class="flex-1 truncate text-heading font-mono"><%= s[:name] %></div>
        <div class="font-mono text-secondary tabular-nums text-xs"><%= sprintf("%.1f", pct) %>%</div>
      </div>
    <% end %>
  </div>

  <%# Legend — descriptions for each section %>
  <div class="mt-5 grid gap-3 sm:grid-cols-2">
    <% sections.each do |s| %>
      <% pct = 100.0 * s[:bytes] / sections.sum { |x| x[:bytes] } %>
      <div class="flex items-start gap-3 text-sm">
        <div class="w-3.5 h-3.5 rounded-sm flex-none mt-1" style="background: <%= s[:color] %>;"></div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline justify-between gap-2">
            <strong class="text-heading font-mono"><%= s[:name] %></strong>
            <span class="font-mono text-xs text-muted tabular-nums whitespace-nowrap">
              <%= number_with_delimiter(s[:bytes]) %> &middot; <%= sprintf("%.1f", pct) %>%
            </span>
          </div>
          <div class="text-secondary text-[13px] leading-snug mt-0.5"><%= s[:desc] %></div>
        </div>
      </div>
    <% end %>
  </div>
</section>

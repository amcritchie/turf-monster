<%#
  Auth model — the 4 signer roles. Same shape as the infographic's
  grid; updated for v0.19 (no deposit/withdraw; currency registry +
  derived lock/conclusion time-gates).
%>
<section class="card p-6 sm:p-8 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4 mb-2">
    <h2 class="text-heading font-bold text-xl">Who can call what</h2>
    <span class="text-[11px] font-mono text-muted uppercase tracking-wider">signer matrix</span>
  </div>
  <p class="text-secondary text-sm mb-5 max-w-3xl">
    Four signer roles. Each instruction is bound to exactly one role &mdash; the contract refuses to
    execute when the wrong key signs.
  </p>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">

    <%# INIT_AUTHORITY — one-time only %>
    <div class="bg-surface-alt border border-subtle border-t-2 border-t-warning rounded-lg p-4 sm:p-5">
      <div class="text-[10px] sm:text-xs uppercase tracking-wider text-secondary font-semibold mb-1">INIT_AUTHORITY</div>
      <div class="font-mono text-sm text-heading mb-3">Alex's Phantom key</div>
      <ul class="space-y-1 text-[12px] sm:text-[13px] text-secondary list-disc list-outside pl-4">
        <li>initialize <span class="text-muted">(once, ever)</span></li>
      </ul>
    </div>

    <%# 1-of-3 routine — any single signer %>
    <div class="bg-surface-alt border border-subtle border-t-2 border-t-violet rounded-lg p-4 sm:p-5">
      <div class="text-[10px] sm:text-xs uppercase tracking-wider text-secondary font-semibold mb-1">1-of-3 vault signer</div>
      <div class="font-mono text-sm text-heading mb-3">Alex Bot &middot; Alex &middot; Mason</div>
      <ul class="space-y-1 text-[12px] sm:text-[13px] text-secondary list-disc list-outside pl-4">
        <li>create_season &middot; create_contest</li>
        <li>set_contest_lock_time</li>
        <li>set_contest_conclusion_time</li>
        <li>mint_entry_token &middot; close_contest</li>
      </ul>
    </div>

    <%# 2-of-3 multisig — treasury operations %>
    <div class="bg-surface-alt border border-subtle border-t-2 border-t-primary rounded-lg p-4 sm:p-5">
      <div class="text-[10px] sm:text-xs uppercase tracking-wider text-secondary font-semibold mb-1">2-of-3 multisig</div>
      <div class="font-mono text-sm text-heading mb-3">2 of {Bot &middot; Alex &middot; Mason}</div>
      <ul class="space-y-1 text-[12px] sm:text-[13px] text-secondary list-disc list-outside pl-4">
        <li>register_currency &middot; deactivate_currency</li>
        <li>settle_contest &middot; cancel_contest</li>
        <li>sweep_operator_revenue</li>
        <li>pause &middot; unpause</li>
      </ul>
    </div>

    <%# User wallet — Phantom or managed keypair %>
    <div class="bg-surface-alt border border-subtle border-t-2 border-t-mint rounded-lg p-4 sm:p-5">
      <div class="text-[10px] sm:text-xs uppercase tracking-wider text-secondary font-semibold mb-1">User wallet signs</div>
      <div class="font-mono text-sm text-heading mb-3">Phantom or managed keypair</div>
      <ul class="space-y-1 text-[12px] sm:text-[13px] text-secondary list-disc list-outside pl-4">
        <li>enter_contest</li>
        <li>enter_contest_with_token</li>
        <li>set_username</li>
        <li>create_user_account <span class="text-muted">(permissionless)</span></li>
      </ul>
    </div>

  </div>
</section>

<% content_for :title, "The Contract — Turf Monster" %>
<% content_for :head do %>
  <meta property="og:title" content="Turf Monster — The Contract">
  <meta property="og:description" content="The exact smart contract that holds your prize pools, on chain. See every instruction, every signer role, every byte.">
  <meta property="og:type" content="article">
  <meta property="og:image" content="<%= request.base_url %>/logo.png">
<% end %>

<%#
  Public transparency page for the turf-vault smart contract (v0.19).
  Renders identically for guests and logged-in users; expands operator
  sections when current_user.admin?. Same single route /contract for both.

  Phase 1 (this file): static infographic. Section/binary byte counts are
  MEASURED (llvm-objdump on the deploy .so + a debug-info rebuild for the
  per-instruction split); the admin playbook's web2/web3 caller map is
  re-audited against app/services/solana/vault.rb and its call sites. The
  version pill + network read live from Solana::Config so they can't drift;
  the byte/caller data is hand-maintained — refresh after a turf-vault
  release (see docs/SOLANA.md "Post-deploy IDL re-pin").

  Phase 2 (placeholder): live deployment state (paused, registered
  currencies, op-revenue balances) — Carl's Rails refactor first.
  Hook points are marked "Phase 2" wherever they apply.
%>

<%
  is_admin = current_user&.admin?

  # Version pill — major.minor from the committed IDL's metadata (what the
  # app is pinned to), so it tracks the re-pinned IDL on every turf-vault
  # deploy while matching the page's "v0.NN" convention.
  prog_version = (Solana::Config.idl_version rescue nil).then { |v| v ? "v#{v.split('.').first(2).join('.')}" : "v0.19" }

  # ─── Hero stats (v0.19, embedded-IDL build) ───────────────────────
  binary_size          = 501_528            # bytes — `llvm-objdump --section-headers turf_vault.so`
  lamports_per_byte    = 6_960              # rent formula constant
  perm_rent_lamports   = (binary_size + 128) * lamports_per_byte
  buffer_lamports      = perm_rent_lamports # buffer = same size as binary
  program_acct_rent    = (36 + 128) * lamports_per_byte
  tx_fee_lamports      = 1_000_000
  perm_total_lamports  = perm_rent_lamports + program_acct_rent + tx_fee_lamports
  total_float_lamports = perm_total_lamports + buffer_lamports

  perm_sol      = perm_total_lamports / 1e9   # ~3.45 SOL — forever-locked
  buffer_sol    = buffer_lamports / 1e9       # ~3.45 SOL — refunded after deploy
  float_sol     = total_float_lamports / 1e9  # ~6.90 SOL — needed on hand at deploy
  v015_perm_sol = 3.248

  # ─── Section layout (exact byte counts from llvm-objdump
  #   --section-headers on the embedded-IDL build) ──────────────────
  sections = [
    { name: ".text",        bytes: 425_304, color: "#6ad7ff", desc: "BPF bytecode — every Anchor handler, every Rust core/alloc/serde routine pulled in by it." },
    { name: ".rel.dyn",     bytes:  39_664, color: "#c5a3ff", desc: "Relocation entries the BPF loader applies at load time to fix up addresses." },
    { name: ".rodata",      bytes:  21_976, color: "#ffce6b", desc: "Read-only strings: error names, msg!() log strings, account-field names embedded by Anchor, plus the embedded IDL JSON for `anchor idl fetch`." },
    { name: ".data.rel.ro", bytes:  12_888, color: "#7af0a9", desc: "Relocatable read-only constants — Anchor discriminators, instruction-method tables." },
    { name: "dyn meta",     bytes:     830, color: "#5d6790", desc: ".dynamic + .dynsym + .dynstr — minimal dynamic-linking metadata." },
    { name: "ELF hdr+pad",  bytes: binary_size - 425_304 - 39_664 - 21_976 - 12_888 - 830, color: "#243155", desc: "ELF header, program headers, .shstrtab, section padding." }
  ]

  # ─── .text buckets (v0.19 embedded-IDL build: includes the Idl*
  #   instruction handlers + embedded IDL JSON access machinery).
  #   Handler-logic total is MEASURED (debug-info rebuild, per-symbol
  #   attribution); the remaining buckets are objdump-derived estimates
  #   that sum with it to the exact .text size. ─────────────────────
  text_buckets = [
    { name: "Handler logic (18 instructions)",        bytes: 184_640, color: "#6ad7ff",
      detail: "Each handler's handle_X function plus the Anchor-generated try_accounts validator. The validators dwarf the business logic. Measured per-instruction from a debug-info rebuild." },
    { name: "Anchor framework runtime",               bytes:  44_000, color: "#c5a3ff",
      detail: "anchor_lang account-info helpers, ErrorCode formatters, AccountSerialize / Deserialize machinery, Bumps-struct support." },
    { name: "Rust core + alloc",                      bytes:  54_500, color: "#bfc8e6",
      detail: "core::* and alloc::* monomorphizations: slice indexing, format machinery, Vec growth. Pulled in by msg!() and Vec usage." },
    { name: "Anchor IDL embed",                       bytes:  29_000, color: "#ffce6b",
      detail: "The embedded IDL JSON plus the 6 Idl* instruction handlers (IdlCreateAccount, IdlResize, IdlClose, IdlWrite, IdlSetAuthority, IdlSetBuffer). Lets Solscan and `anchor idl fetch` decode the program without our source." },
    { name: "Solana + SPL Token (required for USDC/USDT)", bytes:  36_000, color: "#7af0a9",
      detail: "solana_program::* invoke helpers, system-program builders, classic SPL Token instruction builders, Pack/Unpack codecs, ATA helpers. Every USDC and USDT transfer routes through these — they're not optional, they're literally how SPL tokens move on Solana." },
    { name: "Token-2022 (unused, Anchor 0.32.1 quirk)", bytes:   8_000, color: "#ffb86b",
      detail: "spl_token_2022 + spl_transfer_hook + spl_token_group + spl_elgamal instruction builders. The contract doesn't use any Token-2022 mints, but Anchor 0.32.1 pulls these in unconditionally — known framework bug. ~0.06 SOL of permanent rent wasted; resolved automatically when we upgrade to Anchor 0.33+." },
    { name: "Turf state &amp; errors",                bytes:  21_500, color: "#ff7e7e",
      detail: "VaultState/UserAccount/Contest/ContestEntry/EntryTokenAccount/Season/AcceptedCurrency serializers plus the 39 VaultError variants (codes 6000–6038)." },
    { name: "Anchor program dispatch",                bytes:  15_800, color: "#a5b1d6",
      detail: "The 8-byte-discriminator switch generated by #[program] that routes each TX to one of the 18 handlers." },
    { name: "serde / borsh / panic / misc",           bytes:  31_864, color: "#5d6790",
      detail: "borsh deserializers, panic_fmt / begin_panic for require!() failures, compiler_builtins for soft-float multiplication, sha256 for mint_entry_token's source_ref hashing." }
  ]

  # ─── User-facing instructions (always shown, even to guests) ───────
  user_instructions = [
    {
      name: "enter_contest",
      bytes: 20_784,
      auth: "user signs",
      auth_class: "user",
      summary: "Pay your entry fee from your own wallet's USDC (or USDT) ATA, in one signed transaction. Your stats counter ticks up.",
      detail: "Replaces v0.15.1's `enter_contest_direct`. You sign an SPL transfer from your ATA to the contest's per-currency operator-revenue ATA. The instruction creates the ContestEntry PDA, awards seeds from the current Season, and increments your UserAccount.entries counter."
    },
    {
      name: "enter_contest_with_token",
      bytes: 16_664,
      auth: "user signs",
      auth_class: "user",
      summary: "Consume one of your unused free-entry tokens to enter a contest at no cash cost.",
      detail: "You sign as the token owner. The instruction marks the EntryTokenAccount as consumed and creates a ContestEntry with currency_idx = u8::MAX (token-funded). No SPL transfer occurs — the operator covers the prize-pool side."
    },
    {
      name: "set_username",
      bytes: 3_992,
      auth: "user signs",
      auth_class: "user",
      summary: "Change your on-chain display name. Validated against a reserved-prefix list (admin, system, turf, ...) and required to be printable ASCII, 3+ characters.",
      detail: "Phantom users sign in the browser. Custodial / managed-wallet users sign via the server-held encrypted keypair. Admin alone cannot rename someone — wallet consent is required."
    },
    {
      name: "create_user_account",
      bytes: 6_664,
      auth: "permissionless",
      auth_class: "auth1",
      summary: "First-touch onboarding. Creates your on-chain UserAccount PDA — the stats record that tracks your seeds, entries, wins, and total payouts.",
      detail: "Permissionless and idempotent: anyone can pay the rent to create another wallet's UserAccount. Turf Monster's server (Alex Bot) does this for every new signup via an after_commit job."
    },
    {
      name: "create_contest",
      bytes: 21_784,
      auth: "1-of-3 + creator",
      auth_class: "auth1",
      summary: "Open a new contest, funded with a USDC prize pool that you (the creator) transfer from your ATA at creation time.",
      detail: "Dual-signer: a vault signer pays the SOL rent for the new Contest PDA and per-contest prize-pool ATA; the creator signs the USDC transfer that funds the prizes. Stores the per-currency entry-fee schedule the contest will honor."
    }
  ]

  # ─── Operator instructions, grouped by auth level. v0.19 = 18 total
  #   (16 numbered + pause/unpause). Each carries its current Rails/JS
  #   caller (web2 = server-signed, web3 = browser/Phantom) and a wiring
  #   `status` — re-audited against app/services/solana/vault.rb. The
  #   admin playbook renders the caller map; `status: "unused"` means the
  #   builder exists but nothing in the app calls it yet. ─────────────
  operator_instructions = {
    "INIT_AUTHORITY (one-time)" => [
      { name: "initialize", bytes: 28_904, auth_class: "init", status: "one-time",
        web3: "/admin/vault_init (Phantom cosign)", web2: "rake solana:init_vault · admin/vault_init_controller.rb:47",
        playbook: "Runs exactly once, ever. Creates the singleton VaultState PDA, pins the payout mint to canonical Circle USDC, and registers USDC + USDT as the first two accepted currencies. Mainnet build requires the admin signature to match the hardcoded INIT_AUTHORITY (Alex's Phantom key)." }
    ],
    "1-of-3 routine ops" => [
      { name: "create_season",      bytes:  8_168, auth_class: "auth1", status: "admin-only",
        web3: "—", web2: "admin/seasons_controller.rb:31",
        playbook: "Open a new season with an immutable seed-award schedule. Locked at season-creation time so contests can't be retroactively re-rewarded." },
      { name: "create_contest",     bytes: 21_784, auth_class: "auth1", status: "live",
        web3: "/contests/new · /contests/generator", web2: "contests_controller #create → #finalize · Contest#create_onchain! (console)",
        playbook: "User-facing — see above. Any single vault signer can pay rent; the creator funds prizes." },
      { name: "set_contest_lock_time", bytes: 6_144, auth_class: "auth1", status: "live",
        web3: "/contests/:slug Lock (lock_contest.js)", web2: "contests_controller#lock (server fallback) · #prepare_lock_time:930",
        playbook: "Set or clear a contest's derived lock timestamp. enter_contest{,_with_token} reject entries once chain Clock time passes it. 'Lock now' = pass the current time; 0 clears the lock. Replaces lock_contest/unlock_contest (v0.17). Amending an already-passed lock escalates to 2-of-3." },
      { name: "set_contest_conclusion_time", bytes: 6_368, auth_class: "auth1", status: "live",
        web3: "/contests/:slug Conclude (lock_contest.js)", web2: "contests_controller#prepare_conclusion_time:979",
        playbook: "Set or clear a contest's derived conclusion timestamp (v0.18). Once chain Clock passes it, the lock time is final and can't be moved. First set is 1-of-3; amending an already-set conclusion escalates to 2-of-3. Currently driven only by the Phantom path." },
      { name: "mint_entry_token",   bytes:  8_984, auth_class: "auth1", status: "live",
        web3: "—", web2: "TokenPurchaseJob:80 · admin/free_entries_controller.rb:130",
        playbook: "Issue a free-entry voucher (EntryTokenAccount PDA). Sources: OPERATOR (manual), STRIPE (post-purchase mint), MOONPAY. v0.19 seeds the PDA on sha256(source_ref) for true idempotency, so Sidekiq retries are safe." },
      { name: "close_contest",      bytes:  9_648, auth_class: "auth1", status: "unused",
        web3: "—", web2: "no caller yet",
        playbook: "Reclaim SOL rent from a settled or cancelled contest's PDA AND its prize-pool ATA. Sweeps any dust to operator-revenue before closing the ATA. Builder exists but is not yet wired to any admin action — settled-contest rent stays locked until it is." }
    ],
    "2-of-3 treasury ops" => [
      { name: "register_currency",       bytes: 15_208, auth_class: "auth2", status: "unused",
        web3: "—", web2: "no caller yet (no admin-currency UI)",
        playbook: "Add a new currency to accepted_currencies + create its operator-revenue ATA. Rejects duplicates (active or deactivated). Builder exists but there's no admin screen yet — USDC + USDT are registered at initialize." },
      { name: "deactivate_currency",     bytes:  3_848, auth_class: "auth2", status: "unused",
        web3: "—", web2: "no caller yet",
        playbook: "Flip a currency to active = false. Existing open contests using that currency keep working until their natural lifecycle ends; new contests cannot specify it as an entry fee. No re-activation — if you need it back, register in a new slot." },
      { name: "settle_contest",          bytes: 14_024, auth_class: "auth2", status: "live",
        web3: "/admin/pending_transactions cosign (cosign.js)", web2: "Contest#settle_onchain!:413 → Treasury queue",
        playbook: "Final scores in, payouts out. Pays from the contest's prize-pool PDA directly to each winner's ATA via per-entry CPI. Rails sets compute-unit limit to 400,000 to cover up to ~50 winners in a single TX." },
      { name: "cancel_contest",          bytes:  8_504, auth_class: "auth2", status: "unused",
        web3: "—", web2: "no caller yet",
        playbook: "Refund the prize pool to the creator. Entry fees STAY in operator revenue — entrant compensation happens off-chain via mint_entry_token goodwill credits. Builder exists but the cancel-contest admin action isn't wired yet." },
      { name: "sweep_operator_revenue",  bytes:  7_000, auth_class: "auth2", status: "unused",
        web3: "—", web2: "no caller yet",
        playbook: "Drain a per-currency operator-revenue ATA to the treasury wallet (Squads vault PDA, pinned at initialize). One currency per call. amount = 0 sweeps everything. Builder exists but the sweep admin action isn't wired yet." },
      { name: "pause",                   bytes:  3_832, auth_class: "auth2", status: "admin-only",
        web3: "/admin/vault_state", web2: "admin/vault_state_controller.rb:42",
        playbook: "Emergency stop. Blocks enter_contest + enter_contest_with_token. Cancel / settle / sweep stay available so the operator can still wind down. Logs a 64-byte UTF-8 reason on-chain." },
      { name: "unpause",                 bytes:  3_088, auth_class: "auth2", status: "admin-only",
        web3: "/admin/vault_state", web2: "admin/vault_state_controller.rb:60",
        playbook: "Lift the emergency stop. Bytes are lower than pause because of ICF: the shared multisig-validation block got assigned to pause when LLVM folded the identical code." }
    ],
    "User wallet signs" => [
      { name: "enter_contest",             bytes: 20_784, auth_class: "user", status: "live",
        web3: "/contests/:slug board", web2: "contests#enter (managed) · Entry#enter_onchain!:249",
        playbook: "User-facing — see above." },
      { name: "enter_contest_with_token",  bytes: 16_664, auth_class: "user", status: "live",
        web3: "—", web2: "contests#enter (token branch)",
        playbook: "User-facing — see above. Live for managed wallets only; the Phantom build_* variant has no caller yet." },
      { name: "set_username",              bytes:  3_992, auth_class: "user", status: "live",
        web3: "/account rename modal", web2: "accounts#save_username (custodial)",
        playbook: "User-facing — see above." },
      { name: "create_user_account",       bytes:  6_664, auth_class: "user", status: "live",
        web3: "—", web2: "CreateOnchainUserAccountJob:14 (+ lazy before entry/deposit)",
        playbook: "User-facing — see above. Permissionless: operators routinely mint these for new signups (admin pays rent, wallet is data not a signer)." }
    ]
  }

  # Only the calculator reads this; the other sections render their
  # numbers via inline ERB. Keep the JSON small to avoid bloating
  # initial page HTML.
  contract_page_config = {
    binary_size:       binary_size,
    lamports_per_byte: lamports_per_byte,
    perm_lamports:     perm_total_lamports,
    float_lamports:    total_float_lamports
  }
%>

<script type="application/json" id="contract-page-config">
<%= contract_page_config.to_json.html_safe %>
</script>

<%#
  Inline Alpine factory. Lives here (not in shared/_alpine_factories)
  because it has one render site and reads its config from the JSON
  block above. Defined BEFORE Alpine processes x-data — importmap
  modules load too late (see feedback_alpine_factory_importmap_timing).
%>
<script>
  window.contractCostCalculator = function () {
    var cfg = (function () {
      var el = document.getElementById("contract-page-config");
      return JSON.parse(el.textContent);
    })();
    return {
      solPrice: 165,
      binarySize: cfg.binary_size,
      pdLamports: (cfg.binary_size + 128) * cfg.lamports_per_byte,
      // perm = ProgramData rent + Program-account rent + deploy TX fees.
      get permSol()    { return cfg.perm_lamports  / 1e9; },
      // buffer = a second account the same size as the binary, paid up-front
      // during deploy and refunded once `close-buffer` runs.
      get bufferSol()  { return cfg.float_lamports / 1e9 - cfg.perm_lamports / 1e9; },
      // float = total SOL on hand at deploy time (perm + refundable buffer).
      get floatSol()   { return cfg.float_lamports / 1e9; },
      get permUsd()    { return this.permSol   * this.solPrice; },
      get bufferUsd()  { return this.bufferSol * this.solPrice; },
      get floatUsd()   { return this.floatSol  * this.solPrice; },
      fmtSol(n)        { return Number(n).toFixed(3); },
      fmtUsd(n)        { return "$" + Math.round(Number(n)).toLocaleString(); },
      fmtLamports(n)   { return Number(n).toLocaleString(); }
    };
  };
</script>

<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6">

  <header class="border-b border-subtle pb-6 mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-2 py-0.5 rounded text-xs font-mono bg-surface-alt text-secondary"><%= prog_version %></span>
      <span class="px-2 py-0.5 rounded text-xs font-mono bg-surface-alt text-secondary"><%= Solana::Config::NETWORK rescue "devnet" %></span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-extrabold text-heading mb-2">The Contract</h1>
    <p class="text-secondary text-base sm:text-lg max-w-3xl">
      The exact smart contract that holds your prize pools, on chain.
      Every instruction. Every signer role. Every byte.
      <%= is_admin ? content_tag(:span, "Admin view — operator sections expanded below.", class: "text-primary font-semibold") : "" %>
    </p>
  </header>

  <%= render "section_intro" %>
  <%= render "section_hero", perm_sol: perm_sol, float_sol: float_sol, buffer_sol: buffer_sol, binary_size: binary_size, v015_perm_sol: v015_perm_sol %>
  <%= render "section_sections", sections: sections, binary_size: binary_size %>
  <%= render "section_buckets", text_buckets: text_buckets %>
  <%= render "section_instructions", user_instructions: user_instructions %>
  <%= render "section_auth" %>

  <% if is_admin %>
    <%= render "section_admin_playbook", operator_instructions: operator_instructions %>
    <%= render "section_admin_state" %>
  <% end %>

  <%= render "section_calculator", binary_size: binary_size %>

  <footer class="border-t border-subtle pt-6 mt-8 text-xs text-muted">
    <p class="mb-1 font-mono">turf-vault <%= prog_version %> &middot; Anchor 0.32.1 &middot; Rust 1.89.0</p>
    <p class="mb-1">Repo: <code class="text-secondary">/Users/alex/projects/turf-vault</code> &middot; 18 instructions &middot; errors 6000&ndash;6038</p>
    <p>Section bytes from <code class="text-secondary">llvm-objdump --section-headers turf_vault.so</code>; per-instruction bytes from a debug-info rebuild (deduped by address). Caller map re-audited against <code class="text-secondary">app/services/solana/vault.rb</code>.</p>
  </footer>

</div>

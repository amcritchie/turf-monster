<%#
  Public, user-facing instructions only. The 5 things users
  themselves can trigger by signing a transaction. Operators
  see the full 18-instruction list in section_admin_playbook.

    locals: user_instructions (Array of hashes)
%>
<section class="card p-6 sm:p-8 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4 mb-2">
    <h2 class="text-heading font-bold text-xl">What you can call yourself</h2>
    <span class="text-[11px] font-mono text-muted uppercase tracking-wider">
      <%= user_instructions.size %> user-signed instructions
    </span>
  </div>
  <p class="text-secondary text-sm mb-5 max-w-3xl">
    These are the instructions you (the contestant) sign directly. Your wallet's signature
    is the only thing that authorizes them &mdash; no operator can call them on your behalf.
  </p>

  <% max_bytes = user_instructions.map { |ix| ix[:bytes] }.max %>
  <div class="grid gap-3 sm:gap-4">
    <% user_instructions.each do |ix| %>
      <%
        auth_pill_classes = case ix[:auth_class]
          when "user"  then "bg-mint/10 text-mint border-mint/30"
          when "auth1" then "bg-violet/10 text-violet border-violet/30"
          else "bg-surface-alt text-secondary border-subtle"
        end
        bar_pct = 100.0 * ix[:bytes] / max_bytes
      %>
      <details class="card-hover bg-surface-alt rounded-lg border border-subtle overflow-hidden group">
        <summary class="cursor-pointer list-none p-4 sm:p-5">
          <%# Mobile-first stack; desktop spreads to a row %>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
              <code class="font-mono text-heading font-semibold text-sm sm:text-base truncate"><%= ix[:name] %></code>
              <span class="px-2 py-0.5 rounded-full text-[10px] sm:text-[11px] font-mono border whitespace-nowrap <%= auth_pill_classes %>">
                <%= ix[:auth] %>
              </span>
            </div>
            <div class="flex items-center gap-3 text-xs text-muted">
              <span class="font-mono tabular-nums"><%= number_with_delimiter(ix[:bytes]) %> bytes</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180 flex-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>
          <p class="text-secondary text-[13px] sm:text-sm mt-3 leading-snug"><%= ix[:summary] %></p>
          <%# Inline byte-share bar for at-a-glance scale %>
          <div class="mt-3 h-1 bg-surface rounded-full overflow-hidden">
            <div class="h-full bg-primary/50 rounded-full" style="width: <%= sprintf("%.1f", bar_pct) %>%;"></div>
          </div>
        </summary>
        <div class="px-4 sm:px-5 pb-4 sm:pb-5 -mt-1">
          <p class="text-body text-[13px] sm:text-sm leading-relaxed"><%= ix[:detail] %></p>
        </div>
      </details>
    <% end %>
  </div>
</section>

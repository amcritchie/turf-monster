<%# No CDN needed — Phantom injects its own provider %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Turf Monster" class="w-20 h-20 rounded-full shadow-lg mx-auto mb-4">
      <h1 class="text-3xl font-extrabold text-heading tracking-tight">Turf <span class="text-primary">Monster</span></h1>
      <p class="text-secondary mt-2">Create your account</p>
    </div>

    <div class="card shadow p-8">
      <%# Errors surface via the standard toast system — see
          RegistrationsController#create's flash.now[:alert] on failure.
          No inline error block here on purpose. %>
      <%= form_with model: @user, url: signup_path, method: :post do |f| %>
        <%# Funnel attribution — carried from a landing page or ?reference= link %>
        <%= f.hidden_field :reference, value: cookies[:reference] if cookies[:reference].present? %>
        <div class="mb-5">
          <label for="user_email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
          <%= f.email_field :email, id: "user_email", autofocus: true,
            class: "input-field",
            placeholder: "you@example.com" %>
        </div>

        <div class="mb-6">
          <label for="user_password" class="block text-sm text-secondary mb-2 font-medium">Password</label>
          <%# Show/hide toggle — Alpine swaps the type attribute at runtime,
              overriding the static type="password" Rails outputs. Reduces
              signup friction (password fat-fingers were the #1 manual
              support ticket pre-launch); we dropped the Confirm Password
              field at the same time so the reveal IS the confirmation. %>
          <div class="relative" x-data="{ show: false }">
            <%= f.password_field :password, id: "user_password",
              class: "input-field pr-12",
              placeholder: "Choose a password",
              "x-bind:type" => "show ? 'text' : 'password'" %>
            <button type="button" @click="show = !show"
                    :aria-label="show ? 'Hide password' : 'Show password'"
                    class="absolute inset-y-0 right-0 px-3 flex items-center text-muted hover:text-primary transition">
              <%# eye (closed) — shown when password is hidden %>
              <svg x-show="!show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              </svg>
              <%# eye-slash — shown when password is revealed %>
              <svg x-show="show" x-cloak xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-full">
          Sign Up
        </button>
      <% end %>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
        <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
      </div>

      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
        class: "btn btn-google btn-lg w-full gap-3" do %>
        <%= render "components/google_logo" %>
        Sign up with Google
      <% end %>

      <div class="mt-3">
        <%= render "shared/solana_wallet_connect" %>
      </div>

      <p class="text-center text-secondary text-sm mt-6">
        Already have an account?
        <%= link_to "Log in", login_path, class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
      </p>
    </div>
  </div>
</div>

<%# Local override of the engine signup page. Unified create-or-login: renders
    the same shared auth card as the login page (Google -> wallet hub ->
    magic-link email). Kept as a distinct route so inbound /signup deep links +
    funnel attribution keep working. %>
<%= render "shared/auth_card",
      subheading:        "Create your account",
      footer_prompt:     "Already have an account?",
      footer_link_label: "Log in",
      footer_link_path:  login_path %>

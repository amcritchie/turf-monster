<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Signing in…</title>
</head>
<body style="margin:0;background:#1a1430;color:#cbd5e1;font-family:system-ui,-apple-system,sans-serif;display:flex;align-items:center;justify-content:center;height:100vh">
  <p>You can close this window.</p>
  <script>
    (function () {
      var payload = <%= @oauth_payload.to_json.html_safe %>;
      payload.source = 'tt-oauth';
      try {
        if (window.opener && !window.opener.closed) {
          window.opener.postMessage(payload, window.location.origin);
        }
      } catch (e) {}
      window.close();
    })();
  </script>
</body>
</html>

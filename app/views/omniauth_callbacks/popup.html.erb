<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Continue with Google</title>
  </head>
  <body style="margin:0;min-height:100vh;display:grid;place-items:center;background:#1a1535;color:#f8fafc;font-family:system-ui,sans-serif;">
    <% action = @age_attestation ? "/auth/google_oauth2?age_attestation=1" : "/auth/google_oauth2" %>
    <%= form_tag action, method: :post, id: "google-oauth-popup-form", data: { turbo: false } do %>
      <button type="submit" style="border:0;border-radius:8px;background:#4baf50;color:#fff;padding:12px 20px;font-weight:700;cursor:pointer;">
        Continue with Google
      </button>
    <% end %>

    <script>
      document.getElementById("google-oauth-popup-form").submit();
    </script>
  </body>
</html>

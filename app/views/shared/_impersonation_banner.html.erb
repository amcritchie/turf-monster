<%# OPSEC-046 impersonation banner. Server-rendered and deliberately JS-free:
    button_to emits a native form POST (with a hidden _method=delete), so the
    "Return" escape hatch works even if Alpine/Turbo never load. %>
<% message = capture do %>
  Logged in as <strong><%= current_user.display_name %></strong><span class="hidden sm:inline" style="opacity:0.85;"> - admin impersonation</span>
<% end %>
<% actions = capture do %>
  <%= button_to "Return to #{true_user.display_name}",
                admin_stop_impersonating_path,
                method: :delete,
                form_class: "shrink-0",
                class: "inline-flex items-center font-semibold rounded px-3 py-1 whitespace-nowrap",
                style: "background:#ffffff; color:#b91c1c;" %>
<% end %>

<%= render "shared/app_banner",
           tone: :impersonation,
           density: :normal,
           message: message,
           actions: actions %>

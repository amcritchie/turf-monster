<%#
  Reusable email input + live, client-side validity indicator.

  A drop-in decorator over an <input type="email">. It mirrors the (tightened)
  server-side User#email format check (URI::MailTo::EMAIL_REGEXP plus a real
  dotted TLD) through window.emailValidator (defined in shared/_alpine_factories)
  for instant feedback. The passive typing/blur path never blocks — the field
  still posts through its own name (or feeds its enclosing x-model) exactly as
  before — painting a spinner / green check / red X on the right edge and
  toasting once when a committed value is invalid. emailValidator.init() ALSO
  installs a capture-phase submit guard on the enclosing form that blocks an
  explicit submit (Enter / button) of an invalid or empty email and plays the
  reject shake. The server stays the real boundary.

  Locals (all optional, sensible defaults via local_assigns.fetch):
    name          - input name attr (default "email"; pass false/nil to omit,
                    e.g. the auth modal which dispatches its x-model value
                    instead of natively posting)
    id            - input id attr (default: the name)
    value         - prefill value (default "")
    placeholder   - (default "you@example.com")
    required      - (default false)
    autocomplete  - (default "email")
    autofocus     - (default false)
    input_class   - base input classes to match the host form (default
                    "input-field"); "pr-10" is always appended so text never
                    sits under the indicator
    x_model       - optional Alpine x-model target resolved in an ENCLOSING
                    scope (the emailValidator child scope does not define it, so
                    it binds upward — e.g. the auth modal's parent "email")
    x_ref         - optional x-ref name
    disabled_expr - optional Alpine :disabled expression (e.g. "props.submitting")
%>
<%
  name          = local_assigns.fetch(:name, "email")
  field_id      = local_assigns.fetch(:id, name)
  field_value   = local_assigns.fetch(:value, "")
  placeholder   = local_assigns.fetch(:placeholder, "you@example.com")
  required      = local_assigns.fetch(:required, false)
  autocomplete  = local_assigns.fetch(:autocomplete, "email")
  autofocus     = local_assigns.fetch(:autofocus, false)
  input_class   = local_assigns.fetch(:input_class, "input-field")
  x_model       = local_assigns.fetch(:x_model, nil)
  x_ref         = local_assigns.fetch(:x_ref, nil)
  disabled_expr = local_assigns.fetch(:disabled_expr, nil)
%>
<div class="relative" x-data="emailValidator()">
  <input type="email" inputmode="email"
         class="<%= input_class %> pr-10"
         :class="{ 'email-reject': _rejecting }"
         placeholder="<%= placeholder %>"
         autocomplete="<%= autocomplete %>"
         <%= "required" if required %>
         <%= "autofocus" if autofocus %>
         <% if name %>name="<%= name %>"<% end %>
         <% if field_id %>id="<%= field_id %>"<% end %>
         value="<%= field_value %>"
         <% if x_model %>x-model="<%= x_model %>"<% end %>
         <% if x_ref %>x-ref="<%= x_ref %>"<% end %>
         <% if disabled_expr %>:disabled="<%= disabled_expr %>"<% end %>
         @input="onInput($event)"
         @change="onInput($event)"
         @blur="onBlur($event)">

  <%# Right-edge validity indicator. pointer-events-none so it never eats a
      click/focus on the input behind it. Colors use the theme tokens
      (var(--color-success) / var(--color-danger)) so they track dark/light,
      mirroring the engine toast icons. x-cloak hides each state until Alpine
      strips it (default status is idle, so nothing flashes on load). %>
  <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
    <span x-show="status === 'loading'" x-cloak class="cta-spinner text-secondary" aria-hidden="true"></span>
    <svg x-show="status === 'valid'" x-cloak xmlns="http://www.w3.org/2000/svg" class="w-5 h-5"
         style="color: var(--color-success)" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
    </svg>
    <svg x-show="status === 'invalid'" x-cloak xmlns="http://www.w3.org/2000/svg" class="w-5 h-5"
         style="color: var(--color-danger)" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
    </svg>
  </div>
</div>

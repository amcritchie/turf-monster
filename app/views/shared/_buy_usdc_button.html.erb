<%# locals: (button_class: "btn btn-primary") %>
<%# Shared "Buy USDC" button — the Coinbase CDP onramp entry point.
    Flag-gated (AppFlags.cdp_ramp?) and wallet-gated (solana_connected?), so it
    serves BOTH web2 (managed) and web3 (Phantom) wallets identically — no
    per-mode branching. In a geo-blocked state it renders a disabled button
    (pair it with shared/buy_usdc_geo_note for the explainer); otherwise it
    opens the global cdp-ramp modal at its buy preflight. Consumed by /account
    and /wallet. Pass button_class to size it for the surrounding row
    (e.g. "btn btn-primary btn-sm"). %>
<% if AppFlags.cdp_ramp? && current_user&.solana_connected? %>
  <% buy_usdc_label = capture do %><span class="inline-flex items-center gap-1.5"><img src="/usdc-mark.svg" alt="" aria-hidden="true" class="w-4 h-4">Buy USDC</span><% end %>
  <% if geo_blocked? %>
    <button type="button" disabled data-cdp-buy-button
            class="<%= button_class %> opacity-50 cursor-not-allowed"><%= buy_usdc_label %></button>
  <% else %>
    <button type="button" data-cdp-buy-button
            @click="$store.modals.open('cdp-ramp', { flow: 'buy', step: 'preflight' })"
            class="<%= button_class %>"><%= buy_usdc_label %></button>
  <% end %>
<% end %>

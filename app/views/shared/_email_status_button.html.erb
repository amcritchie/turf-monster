<%
  details = email_delivery_banner_details
  provider_icon = details.fetch(:provider_icon)
  status_icon = details.fetch(:status_icon)
  title = details.fetch(:tooltip)
  capture_enabled = defined?(Studio) && Studio.respond_to?(:local_email_capture?) && Studio.local_email_capture?
  email_status_attrs = {
    class: "group relative inline-flex items-center font-semibold rounded px-3 py-1 whitespace-nowrap gap-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white/90",
    style: "background:transparent; border:1px solid rgba(255,255,255,0.9); color:#ffffff; text-decoration:none; position:relative; transition:background-color 150ms ease, color 150ms ease, border-color 150ms ease;",
    title: title,
    "aria-label": title,
    onmouseover: "this.style.background='#ffffff'; this.style.borderColor='#ffffff'; this.style.color='#be185d'; this.querySelector('[data-email-status-tooltip]').style.opacity='1';",
    onmouseout: "this.style.background='transparent'; this.style.borderColor='rgba(255,255,255,0.9)'; this.style.color='#ffffff'; this.querySelector('[data-email-status-tooltip]').style.opacity='0';",
    onfocus: "this.style.background='#ffffff'; this.style.borderColor='#ffffff'; this.style.color='#be185d'; this.querySelector('[data-email-status-tooltip]').style.opacity='1';",
    onblur: "this.style.background='transparent'; this.style.borderColor='rgba(255,255,255,0.9)'; this.style.color='#ffffff'; this.querySelector('[data-email-status-tooltip]').style.opacity='0';"
  }
%>

<% email_status_content = capture do %>
  <span>Email</span>
  <span aria-hidden="true"><%= status_icon %></span>
  <% if provider_icon.present? %>
    <%= image_tag provider_icon,
                  alt: "",
                  "aria-hidden": true,
                  width: 20,
                  height: 20,
                  class: "rounded",
                  style: "width:20px; height:20px; object-fit:cover;" %>
  <% else %>
    <span aria-hidden="true">❓</span>
  <% end %>
  <span data-email-status-tooltip
        class="pointer-events-none absolute right-0 top-full z-[140] mt-2 w-max max-w-[260px] rounded bg-white px-3 py-2 text-xs font-semibold text-slate-900 opacity-0 shadow-lg ring-1 ring-black/10 transition-opacity duration-150 group-hover:opacity-100 group-focus-visible:opacity-100"
        style="position:absolute; right:0; top:100%; z-index:140; margin-top:8px; max-width:260px; width:max-content; border-radius:4px; background:#ffffff; color:#111827; padding:8px 12px; font-size:12px; font-weight:700; line-height:1.2; opacity:0; pointer-events:none; box-shadow:0 8px 18px rgba(0,0,0,0.18); transition:opacity 150ms ease;">
    <%= title %>
  </span>
<% end %>

<% if capture_enabled %>
  <%= link_to "/_studio/local_emails", **email_status_attrs do %>
    <%= email_status_content %>
  <% end %>
<% else %>
  <%= tag.span email_status_content, **email_status_attrs.merge(role: "status", tabindex: "0") %>
<% end %>

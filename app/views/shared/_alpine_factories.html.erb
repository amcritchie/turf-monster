<%#
  Single source of truth for Alpine x-data factory functions.

  Why this exists: the importmap modules in app/javascript/*_factory.js
  load AFTER Alpine has already processed x-data attributes (verified
  2026-05-24 via Playwright console traces — Alpine 3.15.12 logs
  "alpine already loaded" by the time our modules execute).

  Any factory referenced as x-data="factoryName(...)" must be defined
  on window BEFORE Alpine starts. A synchronous inline <script> like
  the one below runs during HTML parse, well before Alpine's deferred
  CDN script + the deferred importmap entry. So window.factoryName
  is guaranteed available when Alpine evaluates the x-data expression.

  The companion modules at app/javascript/<name>.js remain as
  importmap-testable duplicates; they harmlessly re-assign the same
  window globals after Alpine has already used these inline definitions.

  Add a new factory: paste it below as `window.factoryName = function(...) {...}`.
%>
<script>
  // === questNewsletter — contest quest mission 2 (newsletter join) =====
  window.questNewsletter = function (opts) {
    opts = opts || {};
    return {
      saving: false,
      error: null,
      consent: true,
      needsEmail: !!opts.needsEmail,
      url: opts.url,
      // web3 (no email on file): open the capture modal first; web2: join now.
      start() {
        if (this.saving || !this.consent) return;
        if (this.needsEmail) {
          var self = this;
          window.Alpine.store("modals").open("newsletter-email", {
            onSubmit: function (email) { self.join(email); }
          });
        } else {
          this.join(null);
        }
      },
      async join(email) {
        if (this.saving) return;
        this.saving = true;
        this.error = null;
        try {
          var csrf = (document.querySelector("meta[name='csrf-token']") || {}).content || "";
          var fetcher = window.authedFetch || window.fetch;
          var resp = await fetcher(this.url, {
            method: "POST",
            headers: { "Content-Type": "application/json", "X-CSRF-Token": csrf, "Accept": "application/json" },
            body: JSON.stringify({ email: email || null })
          });
          if (!resp) { this.saving = false; return; } // 401 short-circuit (login modal already shown)
          var data = await resp.json();
          if (!data.success) throw new Error(data.error || "Could not join the newsletter.");
          window.questNewsletterSuccess(data);
        } catch (e) {
          this.error = (e && e.message) || "Could not join the newsletter.";
          this.saving = false;
        }
      }
    };
  };

  // === completeQuest — the unified "completed quest" celebration ==========
  // Fired by all three contest-page quest completions (username->chat,
  // chat->newsletter, newsletter->invite). Choreography (timing dials inline):
  //   1. confetti bursts from the just-finished card's "Quest x/4" badge
  //   2. seeds bar progresses (+ level-up animation) via StateFanout
  //   3. after the bar settles, the quest card advances — current fades + slides
  //      right, next fades in + pops (quest-advance event + _quest_card CSS)
  // Confetti + advance fire even on a deferred grant (the quest IS done); only
  // the bar tick-up is gated on seeds_earned.
  window.completeQuest = function (payload, opts) {
    opts = opts || {};
    // Beat the celebration out so it doesn't all fire the instant the modal
    // closes. BEAT (ms) is the gap between steps — tune in one place.
    var BEAT = 300;
    // beat 1 (+0.3s) — confetti from the just-finished card's badge
    setTimeout(function () { try { window.fireQuestBadgeConfetti(); } catch (e) {} }, BEAT);
    // beat 2 (+0.6s) — seeds bar climbs (+ level-up). StateFanout's own delay is
    // 0 now; the beat owns the timing.
    if (payload && payload.seeds_earned && window.StateFanout) {
      setTimeout(function () {
        try { window.StateFanout.apply("seeds", payload, { source: "quest-complete", dispatchDelay: 0 }); } catch (e) {}
      }, BEAT * 2);
    }
    // beat 3 — after the bar settles (advanceDelay), advance the card: current
    // fades + slides right, next fades in + pops.
    if (opts.to) {
      // The server doesn't send payload.levelUp — derive whether this award
      // crossed a level line (SEEDS_PER_LEVEL) so the bar + free-entry modal
      // get their beat before the card advances.
      var perLevel = <%= User::SEEDS_PER_LEVEL %>;
      var sTotal = (payload && payload.seeds_total) || 0;
      var sEarned = (payload && payload.seeds_earned) || 0;
      var advanceDelay = (Math.floor(sTotal / perLevel) > Math.floor((sTotal - sEarned) / perLevel)) ? 2800 : 1500;
      setTimeout(function () {
        try { window.dispatchEvent(new CustomEvent("quest-advance", { detail: { to: opts.to } })); } catch (e) {}
      }, BEAT * 2 + advanceDelay);
    }
  };

  // Burst canvas-confetti from the currently-visible quest card's "Quest x/4"
  // badge (the completing card is still on-screen — the advance is delayed).
  window.fireQuestBadgeConfetti = function () {
    if (typeof confetti === "undefined") return;
    var steps = Array.prototype.slice.call(document.querySelectorAll("[data-quest-step]"));
    var visible = steps.filter(function (el) { return el.offsetParent !== null; })[0];
    var badge = visible && visible.querySelector("[data-quest-badge]");
    var rect = badge && badge.getBoundingClientRect();
    var origin = (rect && rect.width)
      ? { x: (rect.left + rect.width / 2) / window.innerWidth, y: (rect.top + rect.height / 2) / window.innerHeight }
      : { x: 0.72, y: 0.4 };
    var colors = window.CONFETTI_COLORS || ["#4BAF50", "#8E82FE", "#06D6A0", "#FF7C47", "#FFD700", "#00BFFF", "#FF6B9D", "#C084FC"];
    confetti({ particleCount: 90, angle: 90, spread: 360, origin: origin, colors: colors, zIndex: 9999, startVelocity: 24, gravity: 0.6, ticks: 180, scalar: 0.9 });
    setTimeout(function () {
      confetti({ particleCount: 45, angle: 90, spread: 360, origin: origin, colors: colors, zIndex: 9999, startVelocity: 14, gravity: 0.8, ticks: 140, scalar: 0.7 });
    }, 160);
  };

  // Center-burst confetti for a celebration MODAL (free-entry level-up). The
  // quest-badge variant aims at an on-page element; this fires from the upper-
  // center where the modal card sits. zIndex sits above the modal host.
  window.fireFreeEntryConfetti = function () {
    if (typeof confetti === "undefined") return;
    var colors = window.CONFETTI_COLORS || ["#4BAF50", "#8E82FE", "#06D6A0", "#FF7C47", "#FFD700", "#00BFFF", "#FF6B9D", "#C084FC"];
    var origin = { x: 0.5, y: 0.38 };
    confetti({ particleCount: 110, angle: 90, spread: 360, origin: origin, colors: colors, zIndex: 10000, startVelocity: 28, gravity: 0.6, ticks: 200, scalar: 1.0 });
    setTimeout(function () {
      confetti({ particleCount: 50, angle: 90, spread: 360, origin: origin, colors: colors, zIndex: 10000, startVelocity: 16, gravity: 0.8, ticks: 150, scalar: 0.8 });
    }, 160);
  };

  // Newsletter is quest 3 → completing it advances to the invite step. Global so
  // the email-capture modal path reaches it too.
  window.questNewsletterSuccess = function (data) {
    window.completeQuest(data, { to: "invite" });
  };

  // === questCard — contest quest step machine (client-side advance) =====
  window.questCard = function (opts) {
    opts = opts || {};
    return {
      step: opts.step || "username",
      done: opts.done || {},
      // Ladder order; invite is terminal (always shown). When advancing, skip any
      // step already completed elsewhere (e.g. newsletter subscribed on /account)
      // so a done quest never re-appears on the contest ladder.
      _ladder: ["username", "chat", "newsletter", "invite"],
      _nextUndone(from) {
        var i = this._ladder.indexOf(from);
        if (i < 0) return from;
        for (var j = i; j < this._ladder.length; j++) {
          var s = this._ladder[j];
          if (s === "invite" || !this.done[s]) return s;
        }
        return "invite";
      },
      init() {
        var self = this;
        window.addEventListener("quest-advance", function (e) {
          if (e && e.detail && e.detail.to) {
            self.step = self._nextUndone(e.detail.to);
            self._maybePingChat();
          }
        });
        // If the card lands on the chat mission on first render, pop the chat
        // panel too so the eye follows the southwest arrow down to it.
        this._maybePingChat();
      },
      // When the chat mission is showing, tell the Contest Chat panel to pop
      // (a tiny listener on the panel adds a one-shot pulse class). Dispatched
      // on init AND on every advance to the chat step. setTimeout lets the
      // crossfade/x-show settle before the pulse so it doesn't fight the
      // step transition.
      _maybePingChat() {
        if (this.step !== "chat") return;
        setTimeout(function () {
          try { window.dispatchEvent(new CustomEvent("quest-chat-active")); } catch (e) {}
        }, 350);
      }
    };
  };

  // === seedsTile — /account balances "Seeds" tile. Ticks up live on a
  //     navbar-seeds-update (a quest completion) and self-heals its value from
  //     the seedsNavbar cache when the server seeds read is cold (shows "—"). ==
  window.seedsTile = function (opts) {
    opts = opts || {};
    return {
      seeds: 0,
      _iv: null,
      init() {
        var server = parseInt(opts.initial, 10);
        this.seeds = Math.max(isNaN(server) ? 0 : server, this._cacheTotal());
        var self = this;
        window.addEventListener("navbar-seeds-update", function () { self._tickTo(self._cacheTotal()); });
      },
      destroy() { clearInterval(this._iv); },
      _cacheTotal() {
        try {
          var d = JSON.parse(localStorage.getItem("seedsNavbar") || "null");
          return (d && typeof d.seeds_total === "number") ? d.seeds_total : 0;
        } catch (e) { return 0; }
      },
      // Count up from the current value to target over ~0.7s. No-op if target
      // isn't higher (a re-subscribe / non-earning update leaves it steady).
      _tickTo(target) {
        if (typeof target !== "number" || target <= this.seeds) return;
        clearInterval(this._iv);
        var self = this, start = this.seeds, delta = target - start, steps = 24, i = 0;
        this._iv = setInterval(function () {
          i++;
          self.seeds = (i >= steps) ? target : Math.round(start + delta * (i / steps));
          if (i >= steps) clearInterval(self._iv);
        }, 28);
      }
    };
  };

  // === entryTokenBadge — navbar 🎟️ pill + popover ==================
  window.entryTokenBadge = function (opts) {
    opts = opts || {};
    return {
      open: false,
      count: parseInt(opts.initialCount, 10) || 0,
      _timer: null,
      _onTokensUpdated: null,
      init() {
        var self = this;
        this._onTokensUpdated = function (e) {
          var n = e && e.detail && parseInt(e.detail.count, 10);
          if (!isNaN(n)) self.count = n;
        };
        window.addEventListener("entry-tokens-updated", this._onTokensUpdated);
      },
      destroy() {
        window.removeEventListener("entry-tokens-updated", this._onTokensUpdated);
        clearTimeout(this._timer);
      },
      toggle() {
        this.open = !this.open;
        clearTimeout(this._timer);
        if (this.open) {
          var self = this;
          this._timer = setTimeout(function () { self.open = false; }, 2000);
        }
      },
      close() { this.open = false; clearTimeout(this._timer); }
    };
  };

  // === contestLockPicker — /contests/new + /contests/edit calendar =
  window.contestLockPicker = function (opts) {
    opts = opts || {};
    return {
      sport: opts.sport || "",
      lockDate: "", lockTime: "", calOpen: false,
      viewYear: new Date().getFullYear(),
      viewMonth: new Date().getMonth(),
      tzAbbr: (function () {
        var s = new Date().toLocaleTimeString("en-US", { timeZoneName: "short" });
        return s.split(" ").pop();
      })(),
      tzIana: Intl.DateTimeFormat().resolvedOptions().timeZone,
      months: ["January","February","March","April","May","June","July","August","September","October","November","December"],
      days: ["Su","Mo","Tu","We","Th","Fr","Sa"],
      init: function () {
        if (opts.utcIso) {
          var local = new Date(opts.utcIso);
          if (!isNaN(local.getTime())) {
            this.lockDate = local.getFullYear() + "-" + String(local.getMonth() + 1).padStart(2, "0") + "-" + String(local.getDate()).padStart(2, "0");
            this.lockTime = String(local.getHours()).padStart(2, "0") + ":" + String(local.getMinutes()).padStart(2, "0");
            this.viewYear = local.getFullYear();
            this.viewMonth = local.getMonth();
            this.sync();
          }
          return;
        }
        if (this.sport === "fifa") this.selectFifa();
        else if (this.sport === "nfl") this.selectNfl();
      },
      sync: function () {
        var hidden   = document.getElementById("contest_starts_at");
        var dateSnap = document.getElementById("locks_at_date_selected");
        var timeSnap = document.getElementById("locks_at_time_selected");
        var tzSnap   = document.getElementById("locks_at_timezone_selected");
        if (!hidden) return;
        if (this.lockDate && this.lockTime) {
          var local = new Date(this.lockDate + "T" + this.lockTime);
          hidden.value = local.toISOString().substring(0, 16);
          dateSnap.value = this.lockDate;
          timeSnap.value = this.lockTime;
          tzSnap.value   = this.tzIana;
        } else {
          hidden.value = dateSnap.value = timeSnap.value = tzSnap.value = "";
        }
      },
      selectFifa: function () {
        this.sport = "fifa"; this.lockDate = "2026-06-11"; this.lockTime = "13:00";
        this.viewYear = 2026; this.viewMonth = 5; this.sync();
      },
      selectNfl: function () {
        this.sport = "nfl"; this.lockDate = "2026-09-09"; this.lockTime = "18:15";
        this.viewYear = 2026; this.viewMonth = 8; this.sync();
      },
      get displayDate() {
        if (!this.lockDate) return "";
        var parts = this.lockDate.split("-");
        return this.months[parseInt(parts[1]) - 1].substring(0, 3) + " " + parseInt(parts[2]) + ", " + parts[0];
      },
      prevMonth: function () {
        if (this.viewMonth === 0) { this.viewMonth = 11; this.viewYear--; } else { this.viewMonth--; }
      },
      nextMonth: function () {
        if (this.viewMonth === 11) { this.viewMonth = 0; this.viewYear++; } else { this.viewMonth++; }
      },
      calDays: function () {
        var first = new Date(this.viewYear, this.viewMonth, 1).getDay();
        var count = new Date(this.viewYear, this.viewMonth + 1, 0).getDate();
        var cells = [];
        for (var i = 0; i < first; i++) cells.push(null);
        for (var d = 1; d <= count; d++) cells.push(d);
        return cells;
      },
      pickDay: function (d) {
        var m  = String(this.viewMonth + 1).padStart(2, "0");
        var dd = String(d).padStart(2, "0");
        this.lockDate = this.viewYear + "-" + m + "-" + dd;
        this.calOpen = false;
        this.sync();
      },
      isSelected: function (d) {
        if (!this.lockDate) return false;
        var m  = String(this.viewMonth + 1).padStart(2, "0");
        var dd = String(d).padStart(2, "0");
        return this.lockDate === this.viewYear + "-" + m + "-" + dd;
      },
      isToday: function (d) {
        var t = new Date();
        return d === t.getDate() && this.viewMonth === t.getMonth() && this.viewYear === t.getFullYear();
      }
    };
  };

  // === cardListFilter — /players + /teams index search+filter =====
  window.cardListFilter = function (opts) {
    opts = opts || {};
    var dsKey = (opts.searchAttr || "data-name")
      .replace(/^data-/, "")
      .replace(/-([a-z])/g, function (_, c) { return c.toUpperCase(); });
    return {
      search: "",
      visibleCount: 0,
      filters: opts.filters || {},
      _selector: opts.selector,
      _dsKey: dsKey,
      init() {
        var self = this;
        this.apply();
        this.$watch("search", function () { self.apply(); });
        Object.keys(this.filters).forEach(function (k) {
          self.$watch("filters." + k, function () { self.apply(); });
        });
      },
      apply() {
        if (!this._selector) return;
        var q = this.search.toLowerCase().trim();
        var filters = this.filters;
        var cards = document.querySelectorAll(this._selector);
        var dsKey = this._dsKey;
        var count = 0;
        cards.forEach(function (card) {
          var searchVal = (card.dataset[dsKey] || "").toLowerCase();
          var matchSearch = !q || searchVal.includes(q);
          var matchFilters = Object.keys(filters).every(function (k) {
            var v = filters[k];
            return v === "all" || card.dataset[k] === v;
          });
          var visible = matchSearch && matchFilters;
          card.style.display = visible ? "" : "none";
          if (visible) count++;
        });
        this.visibleCount = count;
      }
    };
  };

  // === usernameRenameForm — modals/_username.html.erb ==============
  window.usernameRenameForm = function (opts) {
    opts = opts || {};
    return {
      initial: opts.initialUsername || "",
      username: opts.initialUsername || "",
      saving: false,
      error: null,
      get changed() { return this.username && this.username !== this.initial; },
      async save() {
        if (!this.changed || this.saving) return;
        this.saving = true; this.error = null;
        var csrf = document.querySelector("meta[name='csrf-token']")?.content || "";
        var fetcher = window.authedFetch || fetch;
        var headers = { "Content-Type": "application/json", "X-CSRF-Token": csrf, "Accept": "application/json" };
        try {
          var resp = await fetcher(opts.updateUrl, {
            method: "POST", headers: headers,
            body: JSON.stringify({ username: this.username })
          });
          if (!resp) return;
          var data = await resp.json();
          if (data.error) throw new Error(data.error);
          if (data.success) { this._afterSuccess(data); return; }
          if (data.needs_signature) {
            var sig = await this._signAndBroadcast(data.serialized_tx);
            var confirmResp = await fetcher(opts.confirmUrl, {
              method: "POST", headers: headers,
              body: JSON.stringify({ token: data.token, tx_signature: sig })
            });
            if (!confirmResp) return;
            var cdata = await confirmResp.json();
            if (cdata.error) throw new Error(cdata.error);
            this._afterSuccess(cdata);
          }
        } catch (e) {
          this.error = this._friendlyError(e);
          this.saving = false;
        }
      },
      // Context-aware success beat — MUST mirror app/javascript/username_rename_form.js
      // (this inline copy is what Alpine uses at x-data parse time; the module is the
      // importmap-testable duplicate). Contest page (questCard present) → advance the
      // quest card to the CHAT step + close, no reload. Elsewhere (/account) → swap
      // the username modal for the quest-success "+25 seeds!" celebration. Both fire
      // StateFanout so the seeds bar animates.
      _afterSuccess(data) {
        var hasQuestCard = !!document.querySelector('[x-data^="questCard"]');
        if (hasQuestCard) {
          window.completeQuest(data, { to: "chat" }); // unified celebration: badge confetti → bar → advance
          try { this.$store.modals.close(); } catch (e) {}
        } else {
          if (data && data.seeds_earned && window.StateFanout) {
            try { window.StateFanout.apply("seeds", data, { source: "quest-username", dispatchDelay: 200 }); } catch (e) {}
          }
          try {
            this.$store.modals.swap("quest-success", {
              seeds_earned: data && data.seeds_earned,
              seeds_total:  data && data.seeds_total,
              seeds_level:  data && data.seeds_level
            });
          } catch (e) {
            try { this.$store.modals.close(); } catch (_) {}
          }
        }
      },
      async _signAndBroadcast(serializedTxB64) {
        var provider = window.walletProvider && window.walletProvider.detect();
        if (!provider) throw new Error("Connect your Phantom wallet to rename.");
        await provider.connect();
        var txBytes = Uint8Array.from(atob(serializedTxB64), function (c) { return c.charCodeAt(0); });
        var tx = solanaWeb3.Transaction.from(txBytes);
        var signed = await provider.signTransaction(tx);
        var conn = new solanaWeb3.Connection(document.body.dataset.solanaRpcUrl, "confirmed");
        var sig = await conn.sendRawTransaction(signed.serialize(), { skipPreflight: true, maxRetries: 3 });
        await conn.confirmTransaction(sig, "confirmed");
        return sig;
      },
      _friendlyError(e) {
        if (e && e.code === 4001) return "Signature rejected";
        return (e && e.message) || "Could not save username";
      }
    };
  };

  // === emailValidator — shared/_email_field.html.erb live email check ======
  // Mirror of the (tightened) server-side User#email format validation —
  // URI::MailTo::EMAIL_REGEXP PLUS a real dotted TLD. The server stays the real
  // boundary. The passive typing/blur path NEVER blocks: it only decorates the
  // field (spinner / green check / red X) and toasts once on a settled-invalid
  // value. init() ALSO self-installs a capture-phase submit guard on the
  // enclosing form, so an explicit submit (Enter / button) with an invalid OR
  // empty email is blocked + shaken BEFORE the form's bubble-phase @submit
  // (Alpine) ever fires — with zero changes to either host form's x-data.
  window.emailValidator = function (opts) {
    opts = opts || {};
    // Faithful JS port of Ruby's URI::MailTo::EMAIL_REGEXP — local-part "@"
    // dotted-label domain, same intent as the server check it mirrors. The
    // backtick in the char-class is a literal here (regex literal inside a
    // <script>, not an x-data attribute) so it is safe.
    var EMAIL_RE = /^[a-zA-Z0-9.!#$%&'*+\/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/;
    // Cheap "ready to judge" gate: an "@" plus a dotted TLD of >=2 letters.
    // Decides when to START validating mid-type, so we never flash an error at
    // a half-typed "alex@gmai".
    var COMPLETE_RE = /@[^@\s]+\.[a-zA-Z]{2,}$/;
    // Real-email gate: the URI::MailTo port PLUS a dotted TLD of >=2 letters,
    // so dotless domains ("alex@gmail") and 1-letter TLDs ("alex@gmail.c") are
    // INVALID. Mirrors the tightened server-side User#email check.
    var TLD_RE = /\.[a-zA-Z]{2,}$/;
    return {
      status: "idle", // "idle" | "loading" | "valid" | "invalid"
      _timer: null,
      _lastToasted: null,
      _rejecting: false, // drives :class="{ 'email-reject': _rejecting }" (shake)
      _input: null,      // the field's <input>, cached in init()
      _form: null,       // the enclosing <form>, cached in init()
      _formGuard: null,  // the capture-phase submit listener, for destroy()
      get valid() { return this.status === "valid"; },
      isValid: function (v) { return EMAIL_RE.test(v) && TLD_RE.test(v); },
      looksComplete: function (v) { return COMPLETE_RE.test(v); },
      _value: function (e) { return (e && e.target ? e.target.value : "").trim(); },
      // Self-installed submit gate. Both host forms submit via Alpine's
      // @submit.prevent (BUBBLE phase). A capture-phase listener runs FIRST;
      // stopPropagation() there prevents the bubble handler (submit() /
      // $dispatch('auth-magic-link-submit', ...)) from ever firing for an
      // invalid/empty email — so no x-data change is needed on either form. A
      // valid email falls through and the form submits normally.
      init: function () {
        var input = this.$el.querySelector("input");
        if (!input) return;
        this._input = input;
        var form = input.closest("form");
        if (!form) return;
        this._form = form;
        var self = this;
        this._formGuard = function (e) {
          if (!self.isValid(self._value({ target: self._input }))) {
            e.preventDefault();
            e.stopPropagation();
            self.reject();
          }
        };
        form.addEventListener("submit", this._formGuard, true);
      },
      onInput: function (e) {
        clearTimeout(this._timer);
        var v = this._value(e);
        if (!v) { this.status = "idle"; return; }
        if (this.looksComplete(v)) {
          this.status = "loading";
          var self = this;
          this._timer = setTimeout(function () { self.resolve(v); }, opts.delay || 500);
        } else {
          // Still typing something incomplete — stay quiet, no nag.
          this.status = "idle";
        }
      },
      onBlur: function (e) {
        clearTimeout(this._timer);
        var v = this._value(e);
        if (!v) { this.status = "idle"; return; }
        // They committed the field — answer immediately, no debounce.
        this.resolve(v);
      },
      resolve: function (v) {
        if (this.isValid(v)) {
          this.status = "valid";
          return;
        }
        this.status = "invalid";
        // Passive (typing/blur) path: dedupe so a debounce-then-blur on the
        // SAME bad value toasts once.
        if (this._lastToasted === v) return;
        this._lastToasted = v;
        this._toast(v);
      },
      // Explicit submit rejection (from the capture-phase form guard). Unlike
      // the passive resolve() path it ALWAYS toasts — the user just submitted,
      // so they want the feedback — and fires the shake. Leaves _lastToasted
      // untouched so the typing-path dedupe stays intact.
      reject: function () {
        this.status = "invalid";
        this._toast(this._value({ target: this._input }));
        var self = this;
        // false -> rAF -> true restarts the CSS animation reliably, so it
        // replays even when the same bad value is submitted twice in a row.
        this._rejecting = false;
        requestAnimationFrame(function () {
          self._rejecting = true;
          setTimeout(function () { self._rejecting = false; }, 600);
        });
      },
      _toast: function (v) {
        window.dispatchEvent(new CustomEvent("toast", { detail: {
          type: "alert",
          title: "Check your email",
          message: this.message(v),
          duration: 5000
        } }));
      },
      message: function (v) {
        if (!v) return "Enter your email address.";
        if (v.indexOf("@") === -1) return "Enter a valid email — it's missing an @.";
        if (!TLD_RE.test(v)) return "Add the domain, like .com";
        return "That doesn't look like a valid email address.";
      },
      destroy: function () {
        clearTimeout(this._timer);
        if (this._form && this._formGuard) {
          this._form.removeEventListener("submit", this._formGuard, true);
        }
      }
    };
  };

  // === cdpRampFlow — Coinbase CDP buy / cash-out modal ==================
  // Drives modals/_cdp_ramp.html.erb (step machine on the modal entry's
  // props.step — see that partial for the step map). Owns:
  //   - the session mint (POST /cdp/onramp_sessions | /cdp/offramp_sessions)
  //     + window.open of the hosted Coinbase widget (NEVER an iframe —
  //     explicitly unsupported, docs/CDP_RAMP_INTEGRATION.md spec section 14).
  //     The popup is opened SYNCHRONOUSLY inside the click gesture (blank tab,
  //     navigated when the URL lands) so popup blockers allow it.
  //   - the local status poll (GET /cdp/ramp_status/:ref — OUR row, never
  //     Coinbase; the Sidekiq poll jobs own the CDP reconciliation).
  //   - the offramp send step: 30-minute countdown to props.deadlineAt,
  //     managed Confirm & send (POST /cdp/offramp/confirm_send) and the
  //     Phantom path via window.buildAndSendOfframpUsdcTransfer
  //     (app/javascript/cdp_offramp_send.js).
  //   - terminal fanout: StateFanout.apply('cdp_ramp', ...) so the navbar
  //     balance + any listeners catch up.
  window.cdpRampFlow = function () {
    return {
      _pollTimer: null,
      _tickTimer: null,
      _pollBusy: false,
      now: Date.now(),
      sendBusy: false,
      sendStatus: "",
      get props() {
        var c = this.$store.modals.current();
        return (c && c.props) || {};
      },
      get isBuy() { return this.props.flow === "buy"; },
      // wallet_mode comes from the status payload / return-page deep link.
      // Default to the managed (web2) branch — its send is an explicit
      // server-side confirm, the safer assumption when the mode is unknown.
      get walletWeb3() { return this.props.walletMode === "web3"; },
      get deadlineMs() {
        var d = this.props.deadlineAt;
        if (!d) return null;
        var t = Date.parse(d);
        return isNaN(t) ? null : t;
      },
      get remainingMs() {
        var d = this.deadlineMs;
        return d == null ? null : Math.max(0, d - this.now);
      },
      get remainingLabel() {
        var ms = this.remainingMs;
        if (ms == null) return "--:--";
        var s = Math.floor(ms / 1000), m = Math.floor(s / 60), r = s % 60;
        return m + ":" + (r < 10 ? "0" : "") + r;
      },
      get windowExpired() { return this.remainingMs !== null && this.remainingMs <= 0; },
      init() {
        var self = this;
        var p = this.props;
        // Gallery preview affordance: MODAL_VARIANTS is a static constant and
        // can't carry a live ISO deadline, so demoCountdownMinutes synthesizes
        // one at mount (0 → already expired, for the late-send preview).
        if (p.demoCountdownMinutes != null && !p.deadlineAt) {
          p.deadlineAt = new Date(Date.now() + p.demoCountdownMinutes * 60000).toISOString();
        }
        this._tickTimer = setInterval(function () { self.now = Date.now(); }, 1000);
        // Deep-link resume (return page opens the modal mid-flow): polling
        // steps restart their poll loop on mount.
        this._resumePolling();
      },
      destroy() {
        clearInterval(this._tickTimer);
        this._stopPoll();
      },
      _resumePolling() {
        var s = this.props.step;
        if (s === "waiting" || s === "awaiting-cdp" || s === "send" || s === "settling") {
          this._startPoll();
        }
      },
      // Preflight CTA → mint a session token server-side, open the hosted
      // widget in a new tab, advance to the watching step.
      async start() {
        var p = this.props;
        if (p.step !== "preflight") return;
        var popup = null;
        try { popup = window.open("", "_blank"); } catch (e) { popup = null; }
        p.step = "opening"; // direct patch — no slide while the request runs
        try {
          var data = await this._post(this.isBuy ? "/cdp/onramp_sessions" : "/cdp/offramp_sessions", {});
          p = this.props;
          if (!data) { // authedFetch handled a 401/429 (its own modal is up)
            p.step = "preflight";
            if (popup && !popup.closed) { try { popup.close(); } catch (e) {} }
            return;
          }
          p.partnerUserRef = data.partner_user_ref || p.partnerUserRef;
          p.coinbaseUrl = data.url;
          if (popup && !popup.closed) popup.location = data.url;
          else window.open(data.url, "_blank");
          this._setStep(this.isBuy ? "waiting" : "awaiting-cdp");
          this._startPoll();
        } catch (e) {
          if (popup && !popup.closed) { try { popup.close(); } catch (e2) {} }
          p = this.props;
          p.errorText = (e && e.message) || "Could not start a Coinbase session.";
          p.step = "error";
        }
      },
      // Managed (web2) offramp send — the explicit fresh confirmation the
      // server requires before it moves user funds (spec section 10 guard).
      async confirmSend() {
        var p = this.props;
        if (this.sendBusy || this.windowExpired) return;
        this.sendBusy = true;
        p.sendError = "";
        try {
          var data = await this._post("/cdp/offramp/confirm_send", { partner_user_ref: p.partnerUserRef });
          this.sendBusy = false;
          if (!data) return; // authedFetch handled it
          this._setStep("settling");
          this._startPoll();
        } catch (e) {
          this.sendBusy = false;
          this.props.sendError = (e && e.message) || "Could not start the transfer.";
        }
      },
      // Phantom (web3) offramp send — server builds, Phantom signs, client
      // broadcasts, signature verified + recorded server-side. The helper
      // module owns that whole arc; we just surface its progress.
      async phantomSend() {
        var p = this.props;
        if (this.sendBusy || this.windowExpired) return;
        this.sendBusy = true;
        p.sendError = "";
        var self = this;
        try {
          if (!window.buildAndSendOfframpUsdcTransfer) {
            throw new Error("Wallet helper still loading - try again in a second.");
          }
          await window.buildAndSendOfframpUsdcTransfer({
            partnerUserRef: p.partnerUserRef,
            toAddress: p.toAddress,
            onStatus: function (msg) { self.sendStatus = msg; }
          });
          this.sendBusy = false;
          this.sendStatus = "";
          this._setStep("settling");
          this._startPoll();
        } catch (e) {
          this.sendBusy = false;
          this.sendStatus = "";
          this.props.sendError = (e && e.message) || "The transfer did not complete.";
        }
      },
      _startPoll() {
        if (this._pollTimer || !this.props.partnerUserRef) return;
        var self = this;
        this._pollTimer = setInterval(function () { self._poll(); }, 5000);
        this._poll();
      },
      _stopPoll() {
        if (this._pollTimer) { clearInterval(this._pollTimer); this._pollTimer = null; }
      },
      async _poll() {
        var p = this.props;
        if (!p.partnerUserRef || this._pollBusy) return;
        this._pollBusy = true;
        try {
          var fetcher = window.authedFetch || window.fetch;
          var resp = await fetcher("/cdp/ramp_status/" + encodeURIComponent(p.partnerUserRef), {
            headers: { "Accept": "application/json" }, cache: "no-store"
          });
          if (resp && resp.ok) this._applyStatus(await resp.json());
        } catch (e) { /* transient — keep polling */ }
        this._pollBusy = false;
      },
      _applyStatus(data) {
        if (!data) return;
        var p = this.props;
        p.localStatus = data.status;
        p.cdpStatus = data.cdp_status;
        if (data.wallet_mode) p.walletMode = data.wallet_mode;
        if (data.to_address) p.toAddress = data.to_address;
        if (data.cashout_deadline_at) p.deadlineAt = data.cashout_deadline_at;
        if (data.sell_amount) { p.sellAmount = data.sell_amount; p.sellCurrency = data.sell_amount_currency; }
        if (data.tx_hash) p.txHash = data.tx_hash;
        if (data.sent_signature) p.sentSignature = data.sent_signature;

        if (data.status === "success") {
          this._finish(true, data);
        } else if (data.status === "failed" || data.status === "expired" || data.status === "abandoned") {
          this._finish(false, data);
        } else if (p.step === "awaiting-cdp" && data.to_address) {
          // CDP knows about the sell + gave us the destination — send time.
          this._setStep("send");
        } else if (p.step === "send" && (data.status === "sending" || data.status === "sent")) {
          // Send confirmed elsewhere (another tab / the return page) — follow it.
          this._setStep("settling");
        }
      },
      _finish(success, data) {
        this._stopPoll();
        try {
          if (window.StateFanout) {
            window.StateFanout.apply("cdp_ramp", {
              direction: this.isBuy ? "onramp" : "offramp",
              status: data.status,
              partner_user_ref: data.partner_user_ref,
              tx_hash: data.tx_hash,
              sent_signature: data.sent_signature
            }, { source: "cdp-ramp-modal" });
          }
        } catch (e) { /* fanout must never block the terminal step */ }
        this._setStep(success ? "done" : "failed");
      },
      // advance() runs the host's directional slide, but its guard no-ops the
      // call when the card is mid-animation. Poll- and promise-driven step
      // changes can land in that 220ms window, so verify after the slide
      // would have finished and patch directly if the advance was dropped.
      _setStep(step) {
        var self = this;
        this.$store.modals.advance({ step: step });
        setTimeout(function () {
          var c = self.$store.modals.current();
          if (c && c.props && c.props.flow && c.props.step !== step) c.props.step = step;
        }, 700);
      },
      async _post(url, body) {
        var csrf = (document.querySelector("meta[name='csrf-token']") || {}).content || "";
        var fetcher = window.authedFetch || window.fetch;
        var resp = await fetcher(url, {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": csrf, "Accept": "application/json" },
          body: JSON.stringify(body || {})
        });
        if (!resp) return null; // authedFetch already surfaced 401/429 UX
        var data = await resp.json().catch(function () { return {}; });
        if (!resp.ok) throw new Error(data.error || "Request failed - please try again.");
        return data;
      }
    };
  };

  // seedsBar factory stays defined inline in components/_seeds_bar.html.erb
  // because its body is ~150 lines and it has a single render site (navbar);
  // pulling it here would bloat this shared file without saving page weight.
</script>

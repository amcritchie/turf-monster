<%# locals: (x_model: "ageAttested", error_model: "ageError") %>
<%# Legal-age attestation checkbox (underwriting compliance, 2026-06).
    Rendered on every account-creation surface: the /signin auth card, the
    in-contest auth modal, and the Connect Wallet picker. Binds x-model into
    the caller's Alpine scope; the caller gates its CTAs on that property.
    The SERVER is the real boundary — every signup endpoint rejects new
    account creation without the attestation (see ApplicationController
    AGE_ATTESTATION_ERROR).

    SELF-GATING on AppFlags.age_attestation? — when the flag is off this
    partial renders nothing and the callers initialize their ageAttested
    Alpine state to true, so every CTA gate passes without a checkbox. %>
<% if AppFlags.age_attestation? %>
<%
  x_model     = local_assigns.fetch(:x_model, "ageAttested")
  error_model = local_assigns.fetch(:error_model, "ageError")
%>
<div>
  <label class="flex items-start gap-2.5 text-xs text-secondary leading-snug cursor-pointer select-none">
    <%# data-age-attestation is the stable hook for Playwright (e2e/helpers.js
        attestAge) — keep it if the markup changes. %>
    <input type="checkbox" x-model="<%= x_model %>" @change="<%= error_model %> = false"
           data-age-attestation
           class="mt-0.5 w-4 h-4 shrink-0 rounded accent-primary cursor-pointer">
    <span>
      I confirm I am of legal age to participate in skill-based contests in my
      state (18+ in most states; 19+ in AL/NE; 21+ in IA/MA/VA).
    </span>
  </label>
  <p x-show="<%= error_model %>" x-cloak class="text-xs text-red-400 mt-1.5 ml-6">
    Please confirm you are of legal age to continue.
  </p>
</div>
<% end %>

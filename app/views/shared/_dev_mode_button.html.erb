<button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
        class="rounded cursor-pointer font-semibold whitespace-nowrap"
        style="appearance:none; background:transparent; border:1px solid rgba(255,255,255,0.9); color:#ffffff; cursor:pointer; font:inherit; font-weight:700; padding:4px 12px; text-decoration:none; position:relative; transition:background-color 150ms ease, color 150ms ease, border-color 150ms ease;"
        onmouseover="this.style.background='#ffffff'; this.style.borderColor='#ffffff'; this.style.color='#be185d';"
        onmouseout="this.style.background='transparent'; this.style.borderColor='rgba(255,255,255,0.9)'; this.style.color='#ffffff';"
        onfocus="this.style.background='#ffffff'; this.style.borderColor='#ffffff'; this.style.color='#be185d';"
        onblur="this.style.background='transparent'; this.style.borderColor='rgba(255,255,255,0.9)'; this.style.color='#ffffff';">DEV MODE</button>

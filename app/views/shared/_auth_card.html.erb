<%# Unified Sign in card. Login and signup are one create-or-login flow (magic
    link / Google / Solana wallet all find-or-create), so there is a single
    canonical page at /signin rendering this — no separate "sign up" variant and
    no required locals. CTA order: Google -> Solana wallet hub -> (or) -> email
    magic link. No password field — email auth is a one-tap magic link. %>
<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= brand_logo px: 80, classes: "w-20 h-20 shadow-lg mx-auto mb-4" %>
      <h1 class="text-3xl font-extrabold text-heading tracking-tight">Turf <span class="text-primary">Totals</span></h1>
      <p class="text-secondary mt-2">Sign in to play</p>
    </div>

    <div class="card shadow p-8" x-data="{ ageAttested: false, ageError: false }">
      <%# Legal-age attestation — gates account creation. Google + email are
          gated here; the Solana button opens the Connect Wallet picker, which
          carries the checked state in and renders its own checkbox for guests.
          Server-side enforcement on every signup endpoint is the boundary. %>
      <div class="mb-4">
        <%= render "shared/age_attestation" %>
      </div>

      <%# 1. Google — the attestation rides the OAuth round-trip as a request
          phase query param (read back via omniauth.params in the callback). %>
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
          form: {
            ":action" => "ageAttested ? '/auth/google_oauth2?age_attestation=1' : '/auth/google_oauth2'",
            "@submit" => "if (!ageAttested) { $event.preventDefault(); ageError = true }"
          },
          class: "btn btn-neutral btn-lg w-full gap-3" do %>
        <%= render "components/google_logo" %>
        Google
      <% end %>

      <%# 2. Solana wallet hub %>
      <div class="mt-3">
        <%= render "shared/solana_wallet_connect" %>
      </div>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
        <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
      </div>

      <%# 3. Email magic link — no password. Submits to /magic_link via fetch
          and opens the "check your inbox" modal (reuses the auth modal's
          magic-link-sent step) instead of a toast. The funnel reference cookie
          is read server-side at link-consume time, so no hidden field here. %>
      <%# Initial "Email Link" submit. Opens the "check your inbox" modal
          (reuses the auth modal's magic-link-sent step) optimistically after
          firing window.postMagicLink. A real first-time sender won't hit the
          magic-link throttle; proper 429 handling (suppressing the modal +
          surfacing the throttle message) is coming via the global rate-limit
          interceptor — see docs/RATE_LIMITING.md. Gating this on data.success
          regressed the e2e smoke test under the parallel suite's shared-IP
          throttle, so keep the long-standing optimistic open and only surface
          genuine network failures here. (The resend path DOES read the result
          — that's the operator-reported bug this PR fixes.) %>
      <form x-data="{
              sending: false,
              error: '',
              async submit(email) {
                if (!email || this.sending) return;
                if (!this.ageAttested) { this.ageError = true; return; }
                this.error = '';
                this.sending = true;
                try {
                  await window.postMagicLink(email, { ageAttested: true });
                  $store.modals.open('auth', { step: 'magic-link-sent', sentEmail: email });
                } catch (e) {
                  this.error = 'Could not send the link — check your connection and try again.';
                } finally { this.sending = false; }
              }
            }"
            @submit.prevent="submit(document.getElementById('email').value)" novalidate>
        <div class="mb-4">
          <label for="email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
          <%# Live client-side validity decorator (UX only — the form still
              posts via the input's name; server validation is the boundary).
              The form reads the value by id (document.getElementById('email'))
              because x-ref now lives in this field's own emailValidator scope,
              which the form's $refs cannot see. %>
          <%= render "shared/email_field",
                name: "email", id: "email",
                value: params[:email], placeholder: "you@example.com",
                required: true, autofocus: true %>
        </div>
        <button type="submit" :disabled="sending" class="btn btn-neutral btn-lg w-full disabled:cursor-wait">
          <span x-text="sending ? 'Sending…' : 'Email Link'">Email Link</span>
        </button>
        <p x-show="error" x-cloak class="text-xs text-red-400 text-center mt-2" x-text="error"></p>
        <p class="text-xs text-muted text-center mt-2">We'll email you a one-tap link — no password needed.</p>
      </form>
    </div>
  </div>
</div>

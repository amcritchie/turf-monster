<%# Shared sign-in / sign-up card. Under unified create-or-login the two pages
    are identical except for copy, so both sessions/new and registrations/new
    render this. CTA order: Google -> Solana wallet hub -> (or) -> email magic
    link. No password field — email auth is a one-tap magic link.
    locals: (subheading:, footer_prompt:, footer_link_label:, footer_link_path:) %>
<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Turf Monster" class="w-20 h-20 rounded-full shadow-lg mx-auto mb-4">
      <h1 class="text-3xl font-extrabold text-heading tracking-tight">Turf <span class="text-primary">Totals</span></h1>
      <p class="text-secondary mt-2"><%= subheading %></p>
    </div>

    <div class="card shadow p-8">
      <%# 1. Google %>
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
          class: "btn btn-neutral btn-lg w-full gap-3" do %>
        <%= render "components/google_logo" %>
        Google
      <% end %>

      <%# 2. Solana wallet hub %>
      <div class="mt-3">
        <%= render "shared/solana_wallet_connect" %>
      </div>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
        <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
      </div>

      <%# 3. Email magic link — no password. Submits to /magic_link via fetch
          and opens the "check your inbox" modal (reuses the auth modal's
          magic-link-sent step) instead of a toast. The funnel reference cookie
          is read server-side at link-consume time, so no hidden field here. %>
      <%# Initial "Email Link" submit. Shares window.postMagicLink (layout-inline)
          with the auth modal's resend — same request shape, same { success }
          contract. postMagicLink never throws on a non-2xx (fetch resolves),
          so we read data.success and only open "check your inbox" on a real
          success; a throttle/failure surfaces inline instead of opening an
          empty confirmation the user can't act on. %>
      <form x-data="{
              sending: false,
              error: '',
              async submit(email) {
                if (!email || this.sending) return;
                this.error = '';
                this.sending = true;
                try {
                  var data = await window.postMagicLink(email);
                  if (data && data.success) {
                    $store.modals.open('auth', { step: 'magic-link-sent', sentEmail: email });
                  } else {
                    this.error = (data && data.error) || 'Could not send the link. Try again.';
                  }
                } catch (e) {
                  this.error = 'Could not send the link — check your connection and try again.';
                } finally { this.sending = false; }
              }
            }"
            @submit.prevent="submit($refs.mlEmail.value)" novalidate>
        <div class="mb-4">
          <label for="email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
          <input type="email" name="email" id="email" x-ref="mlEmail" required autofocus
                 value="<%= params[:email] %>"
                 class="input-field" placeholder="you@example.com">
        </div>
        <button type="submit" :disabled="sending" class="btn btn-neutral btn-lg w-full disabled:cursor-wait">
          <span x-text="sending ? 'Sending…' : 'Email Link'">Email Link</span>
        </button>
        <p x-show="error" x-cloak class="text-xs text-red-400 text-center mt-2" x-text="error"></p>
        <p class="text-xs text-muted text-center mt-2">We'll email you a one-tap link — no password needed.</p>
      </form>

      <p class="text-center text-secondary text-sm mt-6">
        <%= footer_prompt %>
        <%= link_to footer_link_label, footer_link_path, class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
      </p>
    </div>
  </div>
</div>

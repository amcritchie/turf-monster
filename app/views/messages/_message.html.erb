<%# Single chat message. Rendered on initial page load AND via Turbo Stream
    broadcast (Message#broadcast_new_message) — so it must NOT use current_user
    or any per-viewer state. The "Hide" button is revealed by CSS only inside
    a .chat-admin panel (see contests/_chat_panel). %>
<% if message.system? %>
  <%# System/announcement line (e.g. a join announcement): centered, avatar-less,
      reads as an event in the room rather than a typed message. Admins can still
      hide it — the Hide button is revealed by .chat-admin CSS like the bubbles. %>
  <div id="message_<%= message.id %>" class="group flex items-center justify-center gap-2 py-0.5">
    <p class="text-xs text-muted text-center break-words"><%= message.body %></p>
    <button type="button"
            class="chat-admin-only flex-shrink-0 text-xs font-medium text-muted hover:text-red-400 transition opacity-0 group-hover:opacity-100"
            data-message-url="<%= contest_message_path(message.contest, message) %>"
            onclick="hideChatMessage(this)">Hide</button>
  </div>
<% else %>
<%# data-react-url is read by reactToMessage()/the picker (closest lookup) to
    POST a toggle. `relative` anchors the hover quick-reaction bar. %>
<div id="message_<%= message.id %>" class="group relative flex items-start gap-2.5"
     data-react-url="<%= toggle_reaction_contest_message_path(message.contest, message) %>">
  <%= render "components/avatar", user: message.user, size: "nav" %>
  <div class="min-w-0 flex-1">
    <div class="flex items-baseline gap-2">
      <span class="text-sm font-bold text-heading truncate"><%= message.user.display_name %></span>
      <span class="text-xs text-muted flex-shrink-0"><%= message.created_at.strftime("%-l:%M %p") %></span>
      <button type="button"
              class="chat-admin-only ml-auto flex-shrink-0 text-xs font-medium text-muted hover:text-red-400 transition opacity-0 group-hover:opacity-100"
              data-message-url="<%= contest_message_path(message.contest, message) %>"
              onclick="hideChatMessage(this)">Hide</button>
    </div>
    <p class="text-sm text-secondary break-words whitespace-pre-wrap leading-snug mt-0.5"><%= message.body %></p>
    <%= render "messages/reactions", message: message %>
  </div>

  <%# Hover quick-reaction bar (Slack/Discord style). Gated to chat
      participants by the .chat-react-only / .chat-can-react CSS pair (mirrors
      the admin Hide button), revealed on message hover via opacity. Quick set:
      contest sport → ❤️ → 🐊 → 😭, then "+" opens the full picker. %>
  <div class="chat-react-only absolute -top-3 right-1 items-center gap-0.5 p-0.5 rounded-full bg-surface border border-subtle shadow-lg z-10 opacity-0 group-hover:opacity-100 transition"
       aria-label="Add reaction">
    <% [message.contest.sport_emoji, "❤️", "🐊", "😭"].each do |e| %>
      <button type="button"
              class="chat-react-quick inline-flex items-center justify-center w-7 h-7 rounded-full text-base leading-none transition"
              onclick="reactToMessage(this, '<%= e %>')"><%= e %></button>
    <% end %>
    <button type="button"
            class="chat-react-add inline-flex items-center justify-center w-7 h-7 rounded-full leading-none text-muted transition"
            title="Find another reaction"
            onclick="openReactionPicker(this)" aria-label="Find another reaction">+</button>
  </div>
</div>
<% end %>

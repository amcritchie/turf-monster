<%# Reaction pills for one message. This element IS the broadcast target
    (id "message_<id>_reactions") — Reaction#broadcast_change replaces it whole
    via Turbo Stream on every add/remove, so it must stay viewer-agnostic
    (rendered identically on the wire for everyone). The "did *I* react"
    highlight is applied client-side by markMyReactions() in contests/_chat_panel
    using data-reactor-ids vs the viewer's own id — never here.

    data-reactor-ids carries the user ids who used each emoji (numeric, already
    public via the chat author list); title shows their names on hover. %>
<div id="message_<%= message.id %>_reactions"
     class="flex flex-wrap items-center gap-1 <%= 'mt-1.5' if message.reactions.any? %>">
  <% message.reactions.group_by(&:emoji).each do |emoji, rs| %>
    <button type="button"
            class="chat-reaction-pill inline-flex items-center gap-1 pl-1.5 pr-2 h-6 rounded-full text-xs transition"
            data-emoji="<%= emoji %>"
            data-reactor-ids="<%= rs.map(&:user_id).join(',') %>"
            title="<%= rs.map { |r| r.user.display_name }.join(', ') %>"
            onclick="reactToMessage(this, this.dataset.emoji)">
      <span class="leading-none"><%= emoji %></span>
      <span class="chat-reaction-count text-muted"><%= rs.size %></span>
    </button>
  <% end %>
</div>

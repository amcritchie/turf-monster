<%# Quest mission 1 — change username for a one-time 35-seed bonus. Header copy
    "Change Your Username" (its own row). The pulsing "Change Username" button is
    FLOATED into the description so the body copy wraps around it (not a separate
    column beside it). Opens the existing username modal; on first confirmed
    change the server grants 35 seeds and username_rename_form.js fires the
    tick-up, then reloads (advancing to mission 2). No mb-* — direct grid child. %>
<div x-data="{}" class="card shadow p-5 relative">
  <style>
    /* Pulse beat once every 3s (ring expands + fades, tiny pop), then rests. */
    @keyframes questPulse {
      0%        { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
      10%       { transform: scale(1.03); box-shadow: 0 0 0 6px rgba(74, 222, 128, 0.25); }
      22%       { transform: scale(1);    box-shadow: 0 0 0 10px rgba(74, 222, 128, 0); }
      100%      { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }
    .quest-pulse { animation: questPulse 3s ease-out infinite; }
    @media (prefers-reduced-motion: reduce) { .quest-pulse { animation: none; } }
  </style>

  <span class="inline-block text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap mb-3">Quest 1 of 3</span>

  <h3 class="text-heading font-semibold text-sm">Change Your Username</h3>

  <%# flow-root contains the float (no overflow-hidden, so the pulse ring isn't
      clipped); the button floats top-right and the copy wraps around it. %>
  <div class="flow-root mt-3">
    <button type="button" @click="$store.modals.open('username')"
            class="btn btn-sm btn-primary quest-pulse whitespace-nowrap float-right ml-4 mb-2">
      Change Username
    </button>
    <p class="text-secondary text-xs leading-relaxed">
      You're <span class="font-mono text-heading">@<%= current_user.username %></span> for now. Pick a name that's yours — your first change mints <strong class="text-heading">35 seeds</strong> on-chain.
    </p>
  </div>
</div>

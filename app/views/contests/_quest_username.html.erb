<%# Quest mission 1 of 4 — change username for a one-time 25-seed bonus.
    Layout: Row 1 = "Change Your Username" header + "Quest 1 of 4" badge.
            Row 2 = description | "Change Username" CTA (pulses 3s). Mobile:
            stacked, arrow points down. sm+: 50/50 side-by-side, arrow points right.
    Opens the existing username modal; on first confirmed change the server
    grants 25 seeds (from Season.quest_seeds) and username_rename_form.js fires
    the tick-up, then advances the quest card in place to mission 2 (chat) — no
    reload. No mb-* — direct grid child. %>
<div x-data="{}" @click="$store.modals.open('username')"
     class="card shadow p-5 relative h-full cursor-pointer">
  <style>
    /* Pulse beat once every 3s (ring expands + fades, tiny pop), then rests. */
    @keyframes questPulse {
      0%        { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
      10%       { transform: scale(1.03); box-shadow: 0 0 0 6px rgba(74, 222, 128, 0.25); }
      22%       { transform: scale(1);    box-shadow: 0 0 0 10px rgba(74, 222, 128, 0); }
      100%      { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }
    .quest-pulse { animation: questPulse 3s ease-out infinite; }
    @media (prefers-reduced-motion: reduce) { .quest-pulse { animation: none; } }
  </style>

  <%# Row 1 — header + quest badge %>
  <div class="flex items-center justify-between gap-3 mb-3">
    <h3 class="text-heading font-semibold text-sm">Change Your Username</h3>
    <span data-quest-badge class="inline-block text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">Quest 1 of 4</span>
  </div>

  <%# Row 2 — description (50%) | CTA (50%) %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <p class="text-secondary text-xs leading-relaxed">
      Your username is <span class="font-mono text-heading">@<%= current_user.username %></span> now. Pick a name that's right for you <span class="text-primary font-semibold sm:hidden">&darr;</span><span class="text-primary font-semibold hidden sm:inline">&rarr;</span>
    </p>
    <button type="button" @click.stop="$store.modals.open('username')"
            class="btn btn-primary quest-pulse w-full h-full">
      Change Username
    </button>
  </div>
</div>

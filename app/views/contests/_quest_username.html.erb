<%# Quest mission 1 — change username for a one-time 35-seed bonus. The button
    opens the existing username modal; on first confirmed change the server
    grants 35 seeds and username_rename_form.js fires the tick-up, then reloads
    (advancing the quest to mission 2). No mb-* — direct grid child. %>
<div x-data="{}" class="card shadow p-5 relative">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-heading font-semibold text-sm">Make It Yours, Get 35 Seeds</h3>
    <span class="text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap">Quest 1 of 3</span>
  </div>
  <p class="text-secondary text-xs leading-relaxed mb-4">
    You're <span class="font-mono text-heading">@<%= current_user.username %></span> for now. Pick a name that's yours — your first change mints <strong class="text-heading">35 seeds</strong> on-chain.
  </p>
  <button type="button" @click="$store.modals.open('username')" class="btn btn-sm btn-primary w-full">
    Change Username
  </button>
</div>

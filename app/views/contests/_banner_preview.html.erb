<%# Current banner preview on the contest edit screen. update_banner replaces
    this (#contest-banner-preview) via Turbo Stream after an immediate save. %>
<div id="contest-banner-preview" class="rounded-lg overflow-hidden border border-subtle" style="aspect-ratio: 4 / 1;">
  <% if @contest.contest_image.attached? %>
    <%= image_tag @contest.contest_image, class: "w-full h-full object-cover", alt: "Current banner" %>
  <% else %>
    <div class="w-full h-full flex items-center justify-center text-xs text-muted"
         style="background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-900))">
      No banner yet
    </div>
  <% end %>
</div>

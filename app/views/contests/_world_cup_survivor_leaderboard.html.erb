<%
  # Rank: alive entries first, then eliminated — both by rounds survived (desc).
  ranked      = @entries.sort_by { |e| [e.alive? ? 0 : 1, -e.rounds_survived] }
  alive_count = @entries.count(&:alive?)
  total_seats = @contest.max_entries || @entries.size
  collapse    = total_seats > 8
%>

<section class="card overflow-hidden mb-8">
  <div class="flex items-center justify-between px-4 py-3 border-b border-subtle">
    <h2 class="text-lg font-semibold text-body flex items-center gap-2">
      <span>🏆</span> Survivors
    </h2>
    <span class="text-xs text-muted">
      <span class="text-primary font-semibold"><%= alive_count %></span> alive
      &middot; <%= @entries.size %>/<%= total_seats %>
    </span>
  </div>

  <div class="p-3 space-y-2"<% if collapse %> x-data="{ expanded: false }"<% end %>>
    <% lb_row = 0 %>
    <% ranked.each_with_index do |entry, i| %>
      <%
        alive = entry.alive?
        rank  = i + 1
        is_me = current_user && entry.user_id == current_user.id
      %>
      <div <% if collapse && lb_row >= 8 %>x-show="expanded" x-cloak <% end %>class="card overflow-hidden <%= is_me ? 'ring-1 ring-primary/40' : '' %>">
        <div class="flex items-center gap-3 px-4 py-3">
          <div class="w-7 text-center font-mono font-bold <%= alive ? 'text-heading' : 'text-muted' %>"><%= rank %></div>
          <%= render "components/avatar", user: entry.user, size: "sm" %>
          <span class="font-semibold truncate text-sm flex-1 min-w-0 <%= alive ? 'text-heading' : 'text-muted' %>">
            <%= entry.user.display_name %><% if is_me %> <span class="text-primary text-xs">(you)</span><% end %>
          </span>
          <% if alive %>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-primary/15 text-primary flex-shrink-0">ALIVE</span>
          <% else %>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-surface-alt text-muted flex-shrink-0">OUT&nbsp;·&nbsp;R<%= entry.eliminated_round %></span>
          <% end %>
          <span class="text-right font-mono text-sm flex-shrink-0 <%= alive ? 'text-violet' : 'text-muted' %>" style="min-width:3.25rem">
            <%= entry.rounds_survived %>&nbsp;<span class="text-muted text-xs">rd<%= 's' unless entry.rounds_survived == 1 %></span>
          </span>
        </div>
      </div>
      <% lb_row += 1 %>
    <% end %>

    <%# Empty seats — survivor entry happens on the board, so no CTA here. %>
    <% (total_seats - @entries.size).times do |j| %>
      <% seat_rank = @entries.size + j + 1 %>
      <div <% if collapse && lb_row >= 8 %>x-show="expanded" x-cloak <% end %>class="card overflow-hidden" style="opacity:0.5">
        <div class="flex items-center gap-3 px-4 py-3">
          <div class="w-7 text-center font-mono font-bold text-muted"><%= seat_rank %></div>
          <div class="w-7 h-7 rounded-full bg-surface-alt border border-subtle flex-shrink-0"></div>
          <span class="text-sm text-muted">Open seat</span>
        </div>
      </div>
      <% lb_row += 1 %>
    <% end %>

    <% if collapse %>
      <div x-show="!expanded" @click="expanded = true"
           class="relative cursor-pointer flex items-center justify-center"
           style="margin-top:-8.5rem;height:8.5rem;background:linear-gradient(to bottom, transparent 0%, rgba(255,255,255,0.12) 60%);z-index:1;">
        <span class="text-sm font-semibold text-heading" style="text-shadow:0 1px 4px rgba(0,0,0,0.5);">Show all <%= total_seats %> seats &#9662;</span>
      </div>
      <button x-show="expanded" x-cloak @click="expanded = false" class="w-full text-center py-2 text-sm text-primary hover:text-primary-300 transition">Show less &#9652;</button>
    <% end %>
  </div>
</section>

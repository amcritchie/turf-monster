<div class="max-w-lg mx-auto py-8">
  <h1 class="text-2xl font-bold text-heading mb-6">New Contest</h1>

  <div class="card shadow p-8">
    <% if @contest.errors.any? %>
      <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
        <% @contest.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @contest, url: contests_path, method: :post, id: "contest-form" do |f| %>
      <%# Default to FIFA when no slate is prefilled (a prefilled slate sets
          @default_sport from its sport); init() then runs selectFifa(). %>
      <div x-data="contestLockPicker({ sport: '<%= j(@default_sport.presence || "fifa") %>' })">
      <!-- Sport selector -->
      <div class="mb-6">
        <label class="block text-sm text-secondary mb-3 font-medium">Sport</label>
        <div class="grid grid-cols-2 gap-3">
          <div @click="selectFifa()"
               :class="sport === 'fifa' ? 'border-primary bg-primary/10 ring-1 ring-primary' : 'border-subtle hover:border-strong'"
               class="cursor-pointer rounded-lg border p-4 transition text-center">
            <span class="text-2xl">&#9917;</span>
            <span class="font-bold text-heading text-lg ml-2">FIFA</span>
          </div>
          <div @click="selectNfl()"
               :class="sport === 'nfl' ? 'border-primary bg-primary/10 ring-1 ring-primary' : 'border-subtle hover:border-strong'"
               class="cursor-pointer rounded-lg border p-4 transition text-center">
            <span class="text-2xl">&#127944;</span>
            <span class="font-bold text-heading text-lg ml-2">NFL</span>
          </div>
        </div>
      </div>

      <%# Name + slug. Name is repeatable/branded; slug is the globally-unique
          key that seeds the on-chain Contest PDA + every URL. The slug input
          auto-fills from the name (lowercase, spaces→hyphens, non-url-safe
          stripped) UNTIL the operator edits the slug field, then it stops
          syncing so a hand-picked slug is never clobbered. %>
      <div x-data="{
             slug: '<%= j(@contest.slug.to_s) %>',
             slugTouched: <%= @contest.slug.present? ? 'true' : 'false' %>,
             slugify(v) {
               return (v || '').toString().toLowerCase().trim()
                 .replace(/[^a-z0-9]+/g, '-')
                 .replace(/^-+|-+$/g, '');
             },
             onName(v) { if (!this.slugTouched) { this.slug = this.slugify(v); } },
             onSlugInput() { this.slugTouched = true; }
           }">
        <div class="mb-5">
          <label for="contest_name" class="block text-sm text-secondary mb-2 font-medium">Name</label>
          <%= f.text_field :name, id: "contest_name", autofocus: true,
            class: "input-field", placeholder: "World Cup Group A",
            "@input": "onName($event.target.value)" %>
        </div>

        <div class="mb-5">
          <label for="contest_slug" class="block text-sm text-secondary mb-2 font-medium">Slug</label>
          <%= f.text_field :slug, id: "contest_slug",
            class: "input-field font-mono", placeholder: "world-cup-group-a",
            "x-model": "slug",
            "@input": "onSlugInput()" %>
          <p class="text-xs text-muted mt-1">
            Unique across all contests. Lowercase letters, numbers, and hyphens.
            Seeds the on-chain contest ID + the contest URL. Auto-filled from the
            name until you edit it.
          </p>
        </div>
      </div>

      <div class="mb-5">
        <label for="contest_slate_id" class="block text-sm text-secondary mb-2 font-medium">Slate</label>
        <%# No prompt — pre-select the first slate (earliest starts_at) by
            default; a prefilled @contest.slate_id still wins when present. %>
        <%= f.collection_select :slate_id, Slate.where.not(name: "Default").where.not(starts_at: nil).order(:starts_at), :id, :name,
          {},
          { id: "contest_slate_id", class: "input-field" } %>
      </div>

      <div class="mb-6" x-data="{ format: '<%= @contest.contest_type || 'small' %>' }">
        <label class="block text-sm text-secondary mb-3 font-medium">Format</label>
        <%= f.hidden_field :contest_type, "x-model": "format" %>

        <div class="grid grid-cols-2 gap-3">
          <% Contest.selectable_formats.each do |key, config| %>
            <div @click="format = '<%= key %>'"
                 :class="format === '<%= key %>' ? 'border-primary bg-primary/10 ring-1 ring-primary' : 'border-subtle hover:border-strong'"
                 class="cursor-pointer rounded-lg border p-4 transition">
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-heading text-lg capitalize"><%= key %></span>
                <span class="text-xs font-mono text-secondary"><%= dollars(config[:entry_fee_cents] / 100.0) %> entry</span>
              </div>
              <div class="text-sm text-secondary space-y-1">
                <p>Max <span class="font-semibold text-heading"><%= config[:max_entries] %></span> entries</p>
                <p>Guarantee: <span class="font-semibold text-primary"><%= dollars(config[:payouts].values.sum / 100.0) %></span></p>
                <div class="mt-2 text-xs text-muted">
                  <% config[:payouts].each do |rank, cents| %>
                    <span class="inline-block mr-2"><%= rank.ordinalize %>: <%= dollars(cents / 100.0) %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Locks At -->
      <div class="mb-5">
        <label class="block text-sm text-secondary mb-2 font-medium">Locks At</label>
        <input type="hidden" name="contest[starts_at]" id="contest_starts_at">
        <input type="hidden" name="contest[locks_at_date_selected]" id="locks_at_date_selected">
        <input type="hidden" name="contest[locks_at_time_selected]" id="locks_at_time_selected">
        <input type="hidden" name="contest[locks_at_timezone_selected]" id="locks_at_timezone_selected">
        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <label class="block text-xs text-muted mb-1">Date</label>
            <button type="button" @click="calOpen = !calOpen" class="input-field w-full text-left flex items-center justify-between">
              <span :class="displayDate ? 'text-heading' : 'text-muted'" x-text="displayDate || 'Select date'"></span>
              <svg class="text-muted" style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </button>

            <!-- Calendar dropdown -->
            <div x-show="calOpen" x-cloak @click.outside="calOpen = false"
                 x-transition:enter="transition ease-out duration-150"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 class="absolute z-10 mt-1 bg-surface border border-subtle rounded-lg shadow-lg p-3"
                 style="width: 280px; left: 50%; transform: translateX(-50%);">
              <!-- Month nav -->
              <div class="flex items-center justify-between mb-2">
                <button type="button" @click="prevMonth()" class="p-1 rounded hover:bg-surface-alt text-secondary">
                  <svg style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
                </button>
                <span class="text-sm font-semibold text-heading" x-text="months[viewMonth] + ' ' + viewYear"></span>
                <button type="button" @click="nextMonth()" class="p-1 rounded hover:bg-surface-alt text-secondary">
                  <svg style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                </button>
              </div>
              <!-- Day headers -->
              <div class="grid grid-cols-7 mb-1">
                <template x-for="dh in days" :key="dh">
                  <div class="text-center text-xs text-muted font-medium py-1" x-text="dh"></div>
                </template>
              </div>
              <!-- Day cells -->
              <div class="grid grid-cols-7">
                <template x-for="(cell, i) in calDays()" :key="i">
                  <div class="text-center">
                    <template x-if="cell">
                      <button type="button" @click="pickDay(cell)"
                              :class="isSelected(cell) ? 'bg-primary text-white font-bold' : isToday(cell) ? 'text-primary font-bold' : 'text-body hover:bg-surface-alt'"
                              class="w-8 h-8 rounded-full text-sm transition"
                              x-text="cell"></button>
                    </template>
                    <template x-if="!cell">
                      <span class="w-8 h-8 inline-block"></span>
                    </template>
                  </div>
                </template>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-xs text-muted mb-1">Time <span class="text-secondary" x-text="'(' + tzAbbr + ')'"></span></label>
            <input type="time" x-model="lockTime" @change="sync()" class="input-field">
          </div>
        </div>
        <p class="text-xs text-muted mt-1">When the contest locks and stops accepting entries.</p>
      </div>
      </div>

      <%# Banner — same shared crop modal as the contest editor (studio cropper).
          The editor saves immediately (the contest exists); here the contest
          doesn't exist yet, so the cropped blob is HELD in the hidden
          contest_image input and submitted with the Create-Contest finalize
          step. cropper_assets loads cropper.js + the cropPhotoModal factory. %>
      <%= render "studio/cropper_assets" %>
      <div class="mb-6" x-data="contestBannerCrop()"
           @crop-photo-confirmed.window="holdCrop($event.detail.blob)">
        <label class="block text-sm text-secondary mb-2 font-medium">Banner Image</label>

        <!-- Drop zone / open-cropper trigger (no preview yet) -->
        <div x-show="!previewUrl"
             @click="open()"
             @dragover.prevent="dragging = true"
             @dragleave.prevent="dragging = false"
             @drop.prevent="dropFile($event)"
             :class="dragging ? 'border-primary bg-primary/10' : 'border-subtle hover:border-strong'"
             class="border-2 border-dashed rounded-lg p-6 text-center cursor-pointer transition">
          <svg class="mx-auto mb-2 text-muted" style="width:2rem;height:2rem" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
          </svg>
          <p class="text-sm text-secondary">Drop an image here or <span class="text-primary font-medium">browse</span></p>
          <p class="text-xs text-muted mt-1">PNG, JPG, WebP &mdash; you'll crop it next</p>
        </div>

        <!-- Preview (cropped) -->
        <div x-show="previewUrl" class="relative rounded-lg overflow-hidden border border-subtle">
          <img :src="previewUrl" class="w-full h-32 object-cover">
          <div class="absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition flex items-center justify-center gap-2">
            <button type="button" @click="open()" class="btn btn-sm text-white" style="background:rgba(0,0,0,0.6)">Replace</button>
            <button type="button" @click="clear()" class="btn btn-sm text-white" style="background:rgba(0,0,0,0.6)">Remove</button>
          </div>
          <div class="px-3 py-2 bg-surface-alt text-xs text-secondary truncate" x-text="fileName"></div>
        </div>

        <%= f.file_field :contest_image, "x-ref": "fileInput", class: "hidden", accept: "image/*" %>
      </div>

      <script>
        // Contest-banner cropper for /contests/new. Opens the SAME shared crop
        // modal as the contest editor (studio cropper, dispatch mode). The
        // contest doesn't exist yet, so instead of submitting a form, holdCrop()
        // drops the cropped blob into the hidden contest_image input + shows a
        // preview; the Create-Contest finalize step submits that file.
        function contestBannerCrop() {
          var CROP = { aspectRatio: 4, maxWidth: 2000, maxHeight: 500, transparent: true, autoCropArea: 1, dispatch: true };
          return {
            previewUrl: null,
            fileName: '',
            dragging: false,
            open() {
              if (window.Alpine && Alpine.store('modals')) Alpine.store('modals').open('crop-photo', CROP);
            },
            dropFile(e) {
              this.dragging = false;
              var file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
              if (!file) return;
              var reader = new FileReader();
              reader.onload = function (ev) {
                Alpine.store('modals').open('crop-photo', Object.assign({}, CROP, { imageUrl: ev.target.result }));
              };
              reader.readAsDataURL(file);
            },
            holdCrop(blob) {
              if (!blob) return;
              var dt = new DataTransfer();
              dt.items.add(new File([blob], 'banner.png', { type: 'image/png' }));
              this.$refs.fileInput.files = dt.files;
              if (this.previewUrl) { try { URL.revokeObjectURL(this.previewUrl); } catch (_) {} }
              this.previewUrl = URL.createObjectURL(blob);
              this.fileName = 'banner.png';
              if (window.Alpine && Alpine.store('modals')) Alpine.store('modals').close();
            },
            clear() {
              if (this.previewUrl) { try { URL.revokeObjectURL(this.previewUrl); } catch (_) {} }
              this.previewUrl = null;
              this.fileName = '';
              if (this.$refs.fileInput) this.$refs.fileInput.value = '';
            }
          };
        }
      </script>

      <div>
        <button type="submit" class="btn btn-primary btn-lg w-full" data-creating-label="Creating contest + on-chain TX…">
          Create Contest
        </button>
        <p class="text-xs text-muted text-center mt-2">
          You sign the on-chain Contest PDA creation with your Phantom wallet. The prize pool USDC
          transfers from your wallet to the vault. The DB row is created only after the on-chain
          transaction confirms — no orphans possible.
        </p>
      </div>
    <% end %>

    <%# Phantom-driven contest creation. POST /contests builds a fully unsigned
        TX (admin fee-payer + creator signature slots reserved). Phantom signs
        first, then POST /contests/finalize validates the signed wire, admin
        cosigns, simulates, broadcasts, verifies, and creates the DB row. %>
    <script type="application/json" id="contest-new-config">
      <%= {
        hasPhantom: current_user&.phantom_wallet?,
        userWallet: current_user&.web3_solana_address,
        csrfToken:  form_authenticity_token,
        finalizePath: finalize_contests_path,
        rebuildPath: rebuild_create_tx_contests_path,
        usdcBalance: display_balance&.to_f, # null when the navbar cache is cold → click-time check fails open (server re-checks with a fresh RPC)
        tierPrizes:  Contest.selectable_formats.transform_values { |c| c[:payouts].values.sum / 100.0 },
        tierEntryFees: Contest.selectable_formats.transform_values { |c| c[:entry_fee_cents] / 100.0 }
      }.to_json.html_safe %>
    </script>
    <script>
      (function() {
        var cfg = JSON.parse(document.getElementById('contest-new-config').textContent);
        var form = document.getElementById('contest-form');
        var btn = form.querySelector('button[type="submit"]');
        var origLabel = btn.textContent.trim();

        function setBusy(label) { btn.disabled = true; btn.textContent = label; }
        function setIdle() { btn.disabled = false; btn.textContent = origLabel; }

        function showWalletRequiredModal() {
          var modal = Alpine.store('solanaModal');
          modal.show('Phantom Wallet Required', '');
          modal.error('Contest creation is a web3 transaction — log in with a Phantom wallet to create a contest.', 'Phantom Wallet Required');
          modal.setRecovery('Sign in with Phantom', function() { window.location.href = '/signin'; }, { phantom: true });
        }

        function showInsufficientUsdcModal(prizeNeeded, balanceHave) {
          var modal = Alpine.store('solanaModal');
          var fmt = function(n) { return '$' + n.toFixed(2); };
          modal.show('Insufficient USDC', '');
          modal.error(
            'This tier needs ' + fmt(prizeNeeded) + ' USDC for the prize pool. Your wallet has ' + fmt(balanceHave) + '. Mint $500 test USDC to your wallet, or pick a smaller tier.',
            'Insufficient USDC'
          );
          modal.setRecovery('Mint $500 Test USDC', mintTestUsdcAndRetry);
        }

        async function mintTestUsdcAndRetry() {
          var modal = Alpine.store('solanaModal');
          modal.show('Minting USDC', 'Minting $500 test USDC to your wallet…');
          try {
            var resp = await window.authedFetch('/faucet', {
              method: 'POST',
              headers: { 'X-CSRF-Token': cfg.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ amount: 500 })
            });
            if (!resp) { modal.close(); return; }  // 429 wait modal (or 401 login) shown by authedFetch
            var data = await resp.json();
            if (!data.success) throw new Error(data.error || 'Mint failed');

            // Refresh the in-page balance so the click-time check passes on retry
            cfg.usdcBalance = (cfg.usdcBalance || 0) + (data.amount || 500);

            modal.show('Minted $500 USDC', 'Retrying contest creation…');
            // Programmatic re-submit goes through the same submit handler;
            // the affordability check now passes with the bumped balance.
            form.requestSubmit();
          } catch (err) {
            console.error('[contest create — mint]', err);
            modal.error(err.message || String(err), 'Mint Failed');
            modal.setRecovery('Try Again', mintTestUsdcAndRetry);
          }
        }

        form.addEventListener('submit', async function(e) {
          e.preventDefault();

          if (!cfg.hasPhantom || !window.walletProvider || !window.walletProvider.isAvailable()) {
            showWalletRequiredModal();
            return;
          }

          // Click-time affordability check — fail before touching Phantom or the
          // server when the user can't fund this tier's prize pool. The server
          // re-checks in #create with a fresh RPC lookup (this client value is
          // cached 60s) so a stale balance can't sneak a doomed TX past.
          var selectedTier = (form.querySelector('input[name="contest[contest_type]"]') || {}).value;
          var prizeNeeded  = cfg.tierPrizes && cfg.tierPrizes[selectedTier] != null ? cfg.tierPrizes[selectedTier] : 0;
          // Fail OPEN when the balance is unknown (null = cold navbar cache);
          // the server re-checks with a fresh RPC in #create, so an unknown
          // value must not hard-block. Only block on a known-insufficient #.
          var balanceHave  = cfg.usdcBalance;
          if (balanceHave != null && prizeNeeded > balanceHave) {
            showInsufficientUsdcModal(prizeNeeded, balanceHave);
            return;
          }

          setBusy('Preparing on-chain TX…');
          var modal = Alpine.store('solanaModal');
          modal.show('Preparing Transaction', 'Building the on-chain create_contest instruction…');

          try {
            var provider = window.walletProvider.detect();
            var connectResp = await provider.connect();
            var pubkeyB58 = connectResp.publicKey.toBase58();
            if (cfg.userWallet && pubkeyB58 !== cfg.userWallet) {
              throw new Error('Wrong wallet connected. Switch to ' + cfg.userWallet.substring(0, 8) + '… in Phantom and try again.');
            }

            // Step 1 — POST the form params multipart; server returns the unsigned TX
            var prepareForm = new FormData(form);
            // The image isn't on-chain — strip it out of the prepare call to keep the response small
            prepareForm.delete('contest[contest_image]');
            var prepareResp = await fetch(form.action, {
              method: 'POST',
              headers: { 'X-CSRF-Token': cfg.csrfToken, 'Accept': 'application/json' },
              body: prepareForm
            });
            var prepareData = await prepareResp.json();
            if (!prepareData.success) throw new Error(prepareData.error || 'Failed to build transaction');

            // Step 1.5 — re-issue the unsigned TX with a FRESH blockhash
            // immediately before signing. The blockhash baked at /contests time
            // goes stale while the user reads/decides; a stale blockhash makes
            // the send fail. The rebuild still goes through the server so the
            // exact tx is bound to the signed params_token.
            // The rebuilt TX inherits the ComputeBudget priority-fee +
            // CU-limit ixs from the server-side builder.
            // Mirrors mcritchie's fetchFreshTx. params_token still binds finalize.
            console.log('[contest-create] rebuilding TX with fresh blockhash via', cfg.rebuildPath);
            var rebuildResp = await fetch(cfg.rebuildPath, {
              method: 'POST',
              headers: { 'X-CSRF-Token': cfg.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ params_token: prepareData.params_token })
            });
            var rebuildData = await rebuildResp.json();
            console.log('[contest-create] rebuild response:', { success: rebuildData.success, error: rebuildData.error, serialized_tx_len: rebuildData.serialized_tx ? rebuildData.serialized_tx.length : null });
            if (!rebuildData.success) throw new Error(rebuildData.error || 'Failed to refresh transaction');

            modal.show('Sign Transaction', 'Approve the prize-pool USDC transfer in Phantom…');

            // Step 2 — deserialize (fresh-blockhash TX), inspect, sign, then
            // send the signed-but-not-broadcast wire back to Rails.
            var txBytes = Uint8Array.from(atob(rebuildData.serialized_tx), function(c) { return c.charCodeAt(0); });
            var tx = solanaWeb3.Transaction.from(txBytes);
            try {
              var rbh = tx.recentBlockhash;
              var progIds = tx.instructions.map(function(ix) { return ix.programId.toBase58(); });
              var acctCount = tx.instructions.reduce(function(n, ix) { return n + ix.keys.length; }, 0);
              console.log('[contest-create] deserialized TX:', {
                recentBlockhash: rbh,
                instructionCount: tx.instructions.length,
                programIds: progIds,
                totalAccountKeys: acctCount,
                hasComputeBudgetPrice: progIds.indexOf('ComputeBudget111111111111111111111111111111') !== -1
              });
            } catch (logErr) { console.warn('[contest-create] TX inspection failed (non-fatal):', logErr); }

            var signedTx = await provider.signTransaction(tx);
            console.log('[contest-create] signed by Phantom; raw byte length:', signedTx.serialize().length);

            var signedBytes = signedTx.serialize({ requireAllSignatures: false, verifySignatures: false });
            var signedBinary = '';
            var signedChunk = 0x8000;
            for (var si = 0; si < signedBytes.length; si += signedChunk) {
              signedBinary += String.fromCharCode.apply(null, signedBytes.subarray(si, si + signedChunk));
            }
            var signedTxB64 = btoa(signedBinary);

            // Step 3 — POST signed_tx + params_token + image to finalize.
            modal.show('Broadcasting', 'Server is validating and submitting the transaction…');
            var finalizeForm = new FormData();
            finalizeForm.append('contest_pda', prepareData.contest_pda);
            finalizeForm.append('params_token', prepareData.params_token);
            finalizeForm.append('signed_tx', signedTxB64);
            var imageFile = form.querySelector('input[type="file"][name="contest[contest_image]"]').files[0];
            if (imageFile) finalizeForm.append('contest_image', imageFile);

            var finalResp = await fetch(cfg.finalizePath, {
              method: 'POST',
              headers: { 'X-CSRF-Token': cfg.csrfToken, 'Accept': 'application/json' },
              body: finalizeForm
            });
            var finalData = await finalResp.json();
            if (!finalData.success) throw new Error(finalData.error || 'Failed to save contest');

            modal.show('Done', 'Redirecting to your new contest…');
            window.location.href = finalData.redirect;
          } catch (err) {
            console.error('[contest-create] FAILED:', err);
            modal.error(err.message || String(err), 'Contest Creation Failed');
            setIdle();
          }
        });
      })();
    </script>
  </div>

  <p class="text-center text-secondary text-sm mt-4">
    <%= link_to "Back to contests", root_path, class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
  </p>
</div>

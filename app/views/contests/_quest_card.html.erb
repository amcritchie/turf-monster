<%# Quest card — client-side step machine so missions advance with NO page
    reload (username -> newsletter -> invite). @quest_step seeds the initial
    step; username_rename_form.js + questNewsletterSuccess dispatch a
    'quest-advance' window event to move forward. All reachable steps render
    (hidden via x-cloak/x-show) so the advance is instant + fades smoothly.
    h-full keeps grid height parity with the "Earn a Free Entry" card.
    No mb-* — direct grid child. %>
<div x-data="questCard({ step: '<%= @quest_step || :invite %>' })" class="h-full">
  <div x-show="step === 'username'" x-cloak x-transition.opacity.duration.400ms class="h-full">
    <%= render "contests/quest_username" %>
  </div>
  <div x-show="step === 'newsletter'" x-cloak x-transition.opacity.duration.400ms class="h-full">
    <%= render "contests/quest_newsletter" %>
  </div>
  <div x-show="step === 'invite'" x-cloak x-transition.opacity.duration.400ms class="h-full">
    <%= render "contests/share_invite" %>
  </div>
</div>

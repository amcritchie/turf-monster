<% content_for(:title) { "#{@contest.name} — Live" } %>
<div class="max-w-5xl mx-auto px-4 py-6">
  <%# Single live stream for all real-time read updates (leaderboard / games /
      goal-feed). Chat keeps its own [@contest, :messages] subscription inside
      the chat panel — don't duplicate it here. %>
  <%= turbo_stream_from @contest, :live %>

  <%# Active-games carousel factory. Defined inline (not importmap) so it exists
      before Alpine processes x-data — including on broadcast-replaced games
      content. Dwell 10s → smooth-scroll one full content-width (lands back on an
      identical first row via cloned cards) → snap to 0 → dwell. Only rotates
      when the row overflows; honors prefers-reduced-motion. %>
  <script>
    window.gamesCarousel = function () {
      return {
        _timer: null,
        init() {
          if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          this.$nextTick(() => this.setup());
        },
        setup() {
          var vp = this.$refs.viewport, track = this.$refs.track;
          if (!vp || !track) return;
          if (track.scrollWidth <= vp.clientWidth + 4) return; // fits — no rotation
          this._origWidth = track.scrollWidth;
          // Clone the originals so scrolling one content-width lands on an
          // identical first row before we snap back to 0 (seamless loop).
          Array.prototype.slice.call(track.children).forEach(function (c) {
            track.appendChild(c.cloneNode(true));
          });
          this._dwellThenScroll();
        },
        _dwellThenScroll() {
          var self = this;
          this._timer = setTimeout(function () { self._scroll(); }, 10000);
        },
        _scroll() {
          var track = this.$refs.track, self = this;
          var dur = Math.max(2500, (this._origWidth / 90) * 1000); // ~90 px/s
          track.style.transition = 'transform ' + dur + 'ms linear';
          track.style.transform = 'translateX(-' + this._origWidth + 'px)';
          track.addEventListener('transitionend', function onEnd() {
            track.removeEventListener('transitionend', onEnd);
            self._reset();
          });
        },
        _reset() {
          var track = this.$refs.track;
          track.style.transition = 'none';
          track.style.transform = 'translateX(0)';
          void track.offsetWidth; // reflow so the next transition animates
          this._dwellThenScroll();
        },
        destroy() { if (this._timer) clearTimeout(this._timer); }
      };
    };
  </script>

  <%# Header %>
  <div class="mb-6 flex items-start justify-between gap-3">
    <div class="min-w-0">
      <% if @contest.slate %>
        <p class="text-sm text-secondary font-medium"><%= @contest.slate.name %></p>
      <% end %>
      <h1 class="text-2xl md:text-3xl font-extrabold text-heading flex items-center gap-2 flex-wrap">
        <%= @contest.name %>
        <span class="inline-flex items-center gap-1 text-[11px] font-bold uppercase tracking-wider text-red-400">
          <span class="h-2 w-2 rounded-full bg-red-500 animate-pulse"></span> Live
        </span>
      </h1>
    </div>
    <%= link_to "← Contest", contest_path(@contest), class: "btn btn-outline btn-sm flex-shrink-0" %>
  </div>

  <%# Games — wrapper owns the id; Contest::LiveBroadcast updates its inner HTML. %>
  <div id="contest_<%= @contest.id %>_games">
    <%= render "contests/live_games", **@games, contest: @contest %>
  </div>

  <%# Leaderboard + Chat — mirrors the show page (2 cols desktop, tabs mobile). %>
  <div x-data="{ tab: 'leaderboard' }" class="mb-8">
    <div class="flex gap-1 mb-4 md:hidden bg-surface-alt rounded-lg p-1">
      <button type="button" @click="tab = 'leaderboard'"
              :class="tab === 'leaderboard' ? 'bg-primary text-white' : 'text-secondary hover:text-heading'"
              class="flex-1 py-2 rounded-md text-sm font-semibold transition">Leaderboard</button>
      <button type="button" @click="tab = 'chat'"
              :class="tab === 'chat' ? 'bg-primary text-white' : 'text-secondary hover:text-heading'"
              class="flex-1 py-2 rounded-md text-sm font-semibold transition">Chat</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:items-start">
      <%# Wrapper owns the id; the broadcaster updates its inner HTML (the compact
          leaderboard partial), so the wrapper + id survive every re-rank. %>
      <div id="contest_<%= @contest.id %>_leaderboard" :class="tab === 'leaderboard' ? '' : 'hidden'" class="md:block">
        <%= render "contests/turf_totals_leaderboard", compact: true %>
      </div>
      <div x-cloak :class="tab === 'chat' ? '' : 'hidden'" class="md:block">
        <%= render "contests/chat_panel", contest: @contest %>
      </div>
    </div>
  </div>

  <%# Hidden goal feed — broadcast_append_to drops data-only nodes here; the
      observer below turns each into a toast, then removes it. %>
  <div id="contest_<%= @contest.id %>_goal_feed" class="hidden" aria-hidden="true"></div>
</div>

<script>
  (function () {
    var feed = document.getElementById('contest_<%= @contest.id %>_goal_feed');
    if (!feed || feed.dataset.observed) return;  // guard double-attach across Turbo visits
    feed.dataset.observed = '1';

    function fire(node) {
      if (node.nodeType !== 1) return;
      var d = node.dataset;
      var matchup = ((d.homeTeam || '') + ' ' + (d.homeScore || '0') + '–' + (d.awayScore || '0') + ' ' + (d.awayTeam || '')).trim();
      var detail;
      if (d.event === 'final') {
        detail = { type: 'notice', title: 'Full time', message: matchup, duration: 4000 };
      } else {
        var title = (((d.teamEmoji ? d.teamEmoji + ' ' : '') + (d.team || 'Goal')) + ' scored!').trim();
        var msg = (d.player ? d.player + ' · ' : '') + matchup;
        detail = { type: 'notice', title: title, message: msg, duration: 3500 };
      }
      try { window.dispatchEvent(new CustomEvent('toast', { detail: detail })); } catch (_) {}
      node.remove();
    }

    // Drain anything already present (broadcast could land before attach).
    Array.prototype.slice.call(feed.children).forEach(fire);
    new MutationObserver(function (muts) {
      muts.forEach(function (m) { Array.prototype.slice.call(m.addedNodes).forEach(fire); });
    }).observe(feed, { childList: true });
  })();
</script>

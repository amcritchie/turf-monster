<div class="max-w-lg mx-auto py-8">
  <h1 class="text-2xl font-bold text-heading mb-6">Edit Contest</h1>

  <div class="card shadow p-8">
    <% if @contest.errors.any? %>
      <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
        <% @contest.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%# Banner — immediate-save via the shared crop modal (update_banner). Its
        OWN form (HTML can't nest it inside the main edit form below). cropper.js
        is loaded here for the shared crop-photo modal. %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <div class="mb-5"
         x-data="contestBannerHost({ aspectRatio: 4, maxWidth: 2000, maxHeight: 500, transparent: true })"
         @crop-photo-confirmed.window="applyCrop($event.detail.blob)">
      <label class="block text-sm text-secondary mb-2 font-medium">Banner</label>
      <%= render "contests/banner_preview" %>
      <button type="button" @click="open()" class="btn btn-outline btn-sm mt-2 inline-flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Edit banner
      </button>
      <%= form_with model: @contest, url: banner_contest_path(@contest), method: :patch,
            html: { multipart: true, id: "contest-banner-form", "x-ref": "form" } do |bf| %>
        <%= bf.file_field :contest_image, class: "hidden", "x-ref": "fileInput" %>
      <% end %>
    </div>

    <%= form_with model: @contest, method: :patch, html: { multipart: true } do |f| %>
      <div class="mb-5">
        <label for="contest_name" class="block text-sm text-secondary mb-2 font-medium">Name</label>
        <%= f.text_field :name, id: "contest_name", class: "input-field" %>
      </div>

      <div class="mb-5">
        <label for="contest_tagline" class="block text-sm text-secondary mb-2 font-medium">Tagline</label>
        <%= f.text_field :tagline, id: "contest_tagline", class: "input-field", placeholder: "Matchday 1 — World Cup 2026 Group Stage" %>
      </div>

      <div class="mb-5">
        <label for="contest_status" class="block text-sm text-secondary mb-2 font-medium">Status</label>
        <%= f.select :status, Contest.statuses.keys.map { |s| [s.capitalize, s] }, {},
          id: "contest_status", class: "input-field" %>
      </div>

      <div class="mb-5" x-data="contestLockPicker({ utcIso: '<%= @contest.starts_at&.iso8601 %>' })">
        <label class="block text-sm text-secondary mb-2 font-medium">Locks At</label>
        <input type="hidden" name="contest[starts_at]" id="contest_starts_at">
        <input type="hidden" name="contest[locks_at_date_selected]" id="locks_at_date_selected">
        <input type="hidden" name="contest[locks_at_time_selected]" id="locks_at_time_selected">
        <input type="hidden" name="contest[locks_at_timezone_selected]" id="locks_at_timezone_selected">
        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <label class="block text-xs text-muted mb-1">Date</label>
            <button type="button" @click="calOpen = !calOpen" class="input-field w-full text-left flex items-center justify-between">
              <span :class="displayDate ? 'text-heading' : 'text-muted'" x-text="displayDate || 'Select date'"></span>
              <svg class="text-muted" style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </button>

            <!-- Calendar dropdown -->
            <div x-show="calOpen" x-cloak @click.outside="calOpen = false"
                 x-transition:enter="transition ease-out duration-150"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 class="absolute z-10 mt-1 bg-surface border border-subtle rounded-lg shadow-lg p-3"
                 style="width: 280px; left: 50%; transform: translateX(-50%);">
              <!-- Month nav -->
              <div class="flex items-center justify-between mb-2">
                <button type="button" @click="prevMonth()" class="p-1 rounded hover:bg-surface-alt text-secondary">
                  <svg style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
                </button>
                <span class="text-sm font-semibold text-heading" x-text="months[viewMonth] + ' ' + viewYear"></span>
                <button type="button" @click="nextMonth()" class="p-1 rounded hover:bg-surface-alt text-secondary">
                  <svg style="width:1rem;height:1rem" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                </button>
              </div>
              <!-- Day headers -->
              <div class="grid grid-cols-7 mb-1">
                <template x-for="dh in days" :key="dh">
                  <div class="text-center text-xs text-muted font-medium py-1" x-text="dh"></div>
                </template>
              </div>
              <!-- Day cells -->
              <div class="grid grid-cols-7">
                <template x-for="(cell, i) in calDays()" :key="i">
                  <div class="text-center">
                    <template x-if="cell">
                      <button type="button" @click="pickDay(cell)"
                              :class="isSelected(cell) ? 'bg-primary text-white font-bold' : isToday(cell) ? 'text-primary font-bold' : 'text-body hover:bg-surface-alt'"
                              class="w-8 h-8 rounded-full text-sm transition"
                              x-text="cell"></button>
                    </template>
                    <template x-if="!cell">
                      <span class="w-8 h-8 inline-block"></span>
                    </template>
                  </div>
                </template>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-xs text-muted mb-1">Time <span class="text-secondary" x-text="'(' + tzAbbr + ')'"></span></label>
            <input type="time" x-model="lockTime" @change="sync()" class="input-field">
          </div>
        </div>
        <p class="text-xs text-muted mt-1">When the contest locks and stops accepting entries.</p>
      </div>

      <div class="mb-6">
        <label for="contest_rank" class="block text-sm text-secondary mb-2 font-medium">Rank</label>
        <%= f.number_field :rank, id: "contest_rank", class: "input-field", placeholder: "100" %>
        <p class="text-xs text-muted mt-1">Lowest rank = shown on root page. Use increments of 100.</p>
      </div>

      <div class="mb-6">
        <label class="flex items-center gap-2.5 cursor-pointer">
          <%= f.check_box :chat_enabled, class: "w-4 h-4", style: "accent-color: var(--color-primary)" %>
          <span class="text-sm text-secondary font-medium">Enable contest chat</span>
        </label>
        <p class="text-xs text-muted mt-1">Players can post messages on the contest page. Uncheck to close the chat room.</p>
      </div>

      <button type="submit" class="btn btn-primary btn-lg w-full">Save Changes</button>
    <% end %>
  </div>

  <p class="text-center text-secondary text-sm mt-4">
    <%= link_to "Back", root_path, class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
  </p>
</div>

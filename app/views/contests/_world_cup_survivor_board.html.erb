<%
  entered  = @my_entry.present?
  alive    = @my_entry&.alive?
  cr       = @current_round
  fee_c    = @contest.entry_fee_cents.to_i
  prize    = @contest.guaranteed_prize_dollars.to_i
  enter_label = fee_c > 0 ? "Enter Contest — $#{fee_c / 100}" : "Enter the Free Roll"

  # Off-chain picks, keyed by round — your own picks are always visible to you.
  my_picks_by_round = entered ? @my_entry.survivor_picks.index_by(&:survivor_round_id) : {}
  # Teams used in rounds OTHER than the current one — locked out (no reuse).
  used_team_slugs   = entered ? @my_entry.survivor_picks.reject { |p| p.survivor_round_id == cr&.id }.map(&:team_slug) : []
  cr_games = cr ? cr.games.includes(:home_team, :away_team).order(:kickoff_at).to_a : []
%>

<script type="application/json" id="survivor-config">
<%# Contest/round data only — auth + wallet state comes from $store.session. %>
<%= {
  contestSlug:        @contest.slug,
  entryFeeCents:      fee_c,
  contestOnchain:     @contest.onchain?,
  contestName:        @contest.name,
  currentRoundId:     cr&.id,
  currentRoundLocked: cr ? cr.picks_locked? : true,
  myPick:             (entered && cr ? my_picks_by_round[cr.id]&.team_slug : nil),
  usedTeams:          used_team_slugs,
  pendingRecoveryPtxSlug: @pending_recovery_ptx&.slug
}.to_json.html_safe %>
</script>

<script>
// survivorBoard — inline because Alpine evaluates x-data before importmap modules load.
window.survivorBoard = function() {
  var cfg = JSON.parse(document.getElementById('survivor-config').textContent);

  return {
    csrfToken:          document.querySelector('meta[name="csrf-token"]')?.content,
    contestId:          cfg.contestSlug,
    contestName:        cfg.contestName,
    contestOnchain:     cfg.contestOnchain,
    myPick:             cfg.myPick,
    usedTeams:          cfg.usedTeams || [],
    currentRoundId:     cfg.currentRoundId,
    currentRoundLocked: cfg.currentRoundLocked,
    submitting:         false,

    teamUsed(slug) { return this.usedTeams.indexOf(slug) !== -1; },
    isMyPick(slug) { return this.myPick === slug; },

    init() {
      // Stranded on-chain entry recovery — see _turf_totals_board.html.erb
      // for the full mechanism. Server populates pendingRecoveryPtxSlug
      // when this user has a pending/submitted PendingTransaction on
      // this contest from an interrupted entry flow.
      var self = this;
      if (cfg.pendingRecoveryPtxSlug) {
        setTimeout(function () { self.recoverPendingEntry(cfg.pendingRecoveryPtxSlug); }, 200);
      }
    },

    async recoverPendingEntry(ptxSlug) {
      var modal = Alpine.store('solanaModal');
      modal.show('Checking Your Last Entry', 'Looking up your previous on-chain transaction…', { dismissible: false });
      var maxAttempts = 6;
      var attempts = 0;
      while (attempts < maxAttempts) {
        attempts++;
        try {
          var resp = await window.authedFetch('/contests/' + this.contestId + '/recover_pending_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ ptx_slug: ptxSlug })
          });
          if (!resp) return;
          var data = await resp.json();
          if (data.status === 'confirmed') {
            modal.success(data.tx_signature, "You're in! Good luck.");
            if (data.redirect) modal.onClose = function () { window.location.href = data.redirect; };
            return;
          }
          if (data.status === 'failed' || data.status === 'error' || data.status === 'missing') {
            modal.close();
            if (data.error) {
              try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: 'Entry not recovered', message: data.error, duration: 6000 } })); } catch (_) {}
            }
            return;
          }
        } catch (_) { /* network blip — keep polling */ }
        await new Promise(function (r) { setTimeout(r, 5000); });
      }
      modal.close();
      try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: "Couldn't confirm last entry yet", message: "We'll keep watching — reload in a minute to retry.", duration: 6000 } })); } catch (_) {}
    },

    showError(message) {
      // Shared toast manager (alert renders the red error icon + "Error"
      // header) — same as the turf-totals board, not a bespoke inline popup.
      try {
        window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', message: message || '', duration: 6000 } }));
      } catch (_) {}
    },

    // Submit / change this entry's pick for the current round.
    async pickTeam(slug) {
      if (this.currentRoundLocked || this.submitting) return;
      if (this.teamUsed(slug)) { this.showError('You already used that team this tournament.'); return; }

      var prev = this.myPick;
      this.myPick = slug; // optimistic
      this.submitting = true;
      try {
        var resp = await window.authedFetch('/contests/' + this.contestId + '/pick', {
          method: 'POST',
          headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ round_id: this.currentRoundId, team_slug: slug })
        });
        if (!resp) { this.myPick = prev; this.submitting = false; return; }
        var data = await resp.json();
        if (!data.success) { this.myPick = prev; this.showError(data.error || 'Pick failed.'); }
      } catch (e) {
        this.myPick = prev;
        this.showError('Network error — pick not saved.');
      }
      this.submitting = false;
    },

    // Enter the contest. Phantom wallets pay directly on-chain; managed/other
    // wallets go through the server enter path. Mirrors the Turf Totals flow.
    async confirmEntry() {
      var sess = Alpine.store('session');
      if (sess.isGuest) { window.location.href = '/signin'; return; }
      if (this.submitting) return;
      this.submitting = true;

      // web3 (Phantom session) on an on-chain contest signs directly;
      // web2 (managed wallet) goes through the server /enter path.
      var useOnchainFlow = sess.isWeb3 && this.contestOnchain;
      var modal = Alpine.store('solanaModal');

      try {
        if (useOnchainFlow) {
          var provider = window.walletProvider.detect();
          modal.show('Preparing Transaction', 'Building on-chain transaction…');
          var connectResp = await provider.connect();
          var pubkeyB58 = connectResp.publicKey.toBase58();
          if (sess.address && pubkeyB58 !== sess.address) {
            throw new Error('Wrong wallet connected. Switch to ' + sess.address.substring(0, 8) + '…');
          }

          // Single-signature flow — see _turf_totals_board.html.erb for
          // the full rationale. The on-chain TX signature below is itself
          // the wallet-ownership proof; the prior per-entry SIWS check
          // was defense-in-depth that doubled signing prompts without
          // strengthening on-chain integrity.

          // prepare_entry is just-in-time: the server rebuilds the
          // unsigned entry TX (build_enter_contest → build_partial_unsigned)
          // which RE-FETCHES get_latest_blockhash AND prepends the ComputeBudget
          // priority-fee + CU-limit ixs. We call it immediately before signing
          // so the blockhash is maximally fresh (mirrors create's rebuild_create_tx).
          console.log('[contest-entry] POST prepare_entry (fresh blockhash + priority fee)…');
          var prepareResp = await window.authedFetch('/contests/' + this.contestId + '/prepare_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({})
          });
          if (!prepareResp) { this.submitting = false; return; } // 401 — login modal surfaced
          var prepareData = await prepareResp.json();
          console.log('[contest-entry] prepare_entry response:', { success: prepareData.success, error: prepareData.error, entry_pda: prepareData.entry_pda, ptx_slug: prepareData.ptx_slug, serialized_tx_len: prepareData.serialized_tx ? prepareData.serialized_tx.length : null });
          if (!prepareData.success) throw new Error(prepareData.error || 'Failed to prepare entry');
          var ptxSlug = prepareData.ptx_slug;

          modal.show('Sign Transaction', 'Approve the entry transaction in your wallet…');
          var txBytes = Uint8Array.from(atob(prepareData.serialized_tx), function(c) { return c.charCodeAt(0); });
          var tx = solanaWeb3.Transaction.from(txBytes);
          try {
            var progIds = tx.instructions.map(function(ix) { return ix.programId.toBase58(); });
            console.log('[contest-entry] deserialized TX:', {
              recentBlockhash: tx.recentBlockhash,
              instructionCount: tx.instructions.length,
              programIds: progIds,
              hasComputeBudgetPrice: progIds.indexOf('ComputeBudget111111111111111111111111111111') !== -1
            });
          } catch (logErr) { console.warn('[contest-entry] TX inspection failed (non-fatal):', logErr); }

          // Phantom-FIRST signing order (2026-06-05) — see
          // _turf_totals_board.html.erb for the full rationale. Phantom signs the
          // FULLY-UNSIGNED tx FIRST (both admin + user slots empty) to clear
          // Phantom's multi-signer-order "could be malicious" banner; the server
          // then cosigns (admin), simulates, broadcasts, confirms, verifies. No
          // client-side broadcast/simulate/poll/stamp anymore.
          var signedTx = await provider.signTransaction(tx);
          var signedBytes = signedTx.serialize({ requireAllSignatures: false, verifySignatures: false });
          console.log('[contest-entry] signed by Phantom (admin slot empty); raw byte length:', signedBytes.length);

          var sb = '';
          var sChunk = 0x8000;
          for (var bi = 0; bi < signedBytes.length; bi += sChunk) {
            sb += String.fromCharCode.apply(null, signedBytes.subarray(bi, bi + sChunk));
          }
          var signedB64 = btoa(sb);

          modal.show('Confirming On-chain', 'Cosigning and submitting to Solana…');
          var confirmResp = await window.authedFetch('/contests/' + this.contestId + '/confirm_onchain_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ signed_tx: signedB64, entry_id: prepareData.entry_id, entry_pda: prepareData.entry_pda, ptx_slug: ptxSlug })
          });
          if (!confirmResp) { this.submitting = false; return; } // 401 — login modal surfaced
          var confirmData = await confirmResp.json();
          if (!confirmData.success) throw new Error(confirmData.error || 'Failed to confirm entry');
          var txSig = confirmData.tx_signature;
          console.log('[contest-entry] server cosigned + confirmed on-chain:', txSig);

          modal.success(txSig, "You're in! Good luck.");
          modal.onClose = function() { window.location.href = confirmData.redirect || window.location.pathname; };
          if (typeof refreshBalanceDelayed === 'function') refreshBalanceDelayed();
        } else {
          modal.show('Submitting Entry', 'Processing your entry…');
          var enterResp = await window.authedFetch('/contests/' + this.contestId + '/enter', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Accept': 'application/json' }
          });
          if (!enterResp) {
            // null → authedFetch surfaced the right modal (401 login / 429
            // rate-limit). Close our "Submitting Entry" overlay so it doesn't
            // stack under it, and reset submitting.
            try { modal.close(); } catch (e) {}
            this.submitting = false;
            return;
          }
          var data = await enterResp.json();

          if (data.success) {
            if (data.tx_signature) {
              modal.success(data.tx_signature, "You're in! Good luck.");
              modal.onClose = function() { window.location.href = data.redirect || window.location.pathname; };
              if (typeof refreshBalanceDelayed === 'function') refreshBalanceDelayed();
            } else {
              modal.close();
              window.location.href = data.redirect || window.location.pathname;
            }
          } else {
            modal.error(data.error || 'Something went wrong');
            this.submitting = false;
          }
        }
      } catch (err) {
        console.error('[contest-entry] FAILED:', err);
        var msg = (typeof parseSolanaError === 'function')
          ? parseSolanaError(err.message || 'Entry failed')
          : (err.message || 'Entry failed');
        if (modal && modal.visible) { modal.error(msg); } else { this.showError(msg); }
        this.submitting = false;
      }
    }
  };
};
</script>

<div x-data="survivorBoard()" x-cloak>

  <!-- Status / CTA banner -->
  <% if !entered %>
    <div class="card p-6 mb-6 text-center">
      <div class="text-3xl mb-2">🏆 ⚽️</div>
      <h2 class="text-xl font-bold text-heading mb-1">Last one standing wins $<%= prize %></h2>
      <p class="text-sm text-secondary max-w-md mx-auto mb-4">
        Pick one team each round. If they <strong class="text-heading">win or draw</strong> you survive —
        a loss knocks you out. No team twice. <%= @survivor_rounds.size %> rounds, last survivor takes the prize.
      </p>
      <% if @contest.open? %>
        <button type="button" data-testid="survivor-enter" @click="confirmEntry()" :disabled="submitting"
                class="btn btn-primary btn-lg disabled:cursor-wait">
          <span x-text="submitting ? 'Entering…' : '<%= j enter_label %>'"></span>
        </button>
        <% unless logged_in? %>
          <p class="text-xs text-muted mt-2">You'll be asked to log in first.</p>
        <% end %>
      <% else %>
        <p class="text-sm text-muted font-medium">Entries are closed — the tournament has started.</p>
      <% end %>
    </div>
  <% else %>
    <div class="card p-4 mb-6 flex items-center gap-3 <%= alive ? 'ring-1 ring-primary/40' : '' %>">
      <div class="text-2xl"><%= alive ? '✅' : '💀' %></div>
      <div class="flex-1 min-w-0">
        <% if alive %>
          <p class="font-bold text-heading">You're alive</p>
          <p class="text-sm text-secondary">Survived <%= @my_entry.rounds_survived %> round<%= 's' unless @my_entry.rounds_survived == 1 %> — keep picking to stay in.</p>
        <% else %>
          <p class="font-bold text-muted">Eliminated in Round <%= @my_entry.eliminated_round %></p>
          <p class="text-sm text-muted">You're out — but you can still watch it play out.</p>
        <% end %>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-bold flex-shrink-0 <%= alive ? 'bg-primary/15 text-primary' : 'bg-surface-alt text-muted' %>">
        <%= alive ? 'ALIVE' : 'OUT' %>
      </span>
    </div>
  <% end %>

  <!-- Current-round picker -->
  <% if entered && alive && cr && !cr.picks_locked? && cr_games.any? %>
    <div class="mb-6">
      <div class="flex items-center justify-between gap-2 mb-3">
        <h3 class="text-sm font-semibold text-secondary"><%= cr.name %> — pick a team to survive</h3>
        <% if cr.picks_lock_at %>
          <span class="text-xs text-muted whitespace-nowrap">locks <%= cr.picks_lock_at.strftime('%b %-d, %-I:%M %p') %></span>
        <% end %>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <% cr_games.each do |game| %>
          <div class="card p-2 flex items-center gap-1">
            <% game_teams = [game.home_team, game.away_team] %>
            <% game_teams.each_with_index do |team, idx| %>
              <% next unless team %>
              <% if idx == 1 %><span class="text-[10px] text-muted font-bold px-0.5">vs</span><% end %>
              <button type="button" data-testid="survivor-team"
                      @click="pickTeam('<%= j team.slug %>')"
                      :disabled="submitting || teamUsed('<%= j team.slug %>')"
                      :class="isMyPick('<%= j team.slug %>') ? 'ring-2 ring-primary bg-primary/10' : 'hover:bg-surface-alt'"
                      class="flex-1 min-w-0 rounded-lg p-2 text-center transition disabled:opacity-40 disabled:cursor-not-allowed">
                <div class="text-xl leading-none"><%= team.emoji %></div>
                <div class="text-xs font-semibold text-heading truncate mt-0.5"><%= team.short_name %></div>
                <div class="text-[10px] text-muted" x-show="teamUsed('<%= j team.slug %>')" x-cloak>used</div>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
      <p class="text-xs text-muted mt-2" x-show="myPick" x-cloak>
        Pick saved — you can change it until the round locks.
      </p>
    </div>
  <% elsif entered && alive && cr && cr.picks_locked? %>
    <div class="card p-4 mb-6 text-center text-sm text-muted">
      Picks for <%= cr.name %> are locked. Results post once the matches finish.
    </div>
  <% elsif entered && alive && cr && cr_games.empty? %>
    <div class="card p-4 mb-6 text-center text-sm text-muted">
      <%= cr.name %> fixtures aren't set yet — check back once the bracket is drawn.
    </div>
  <% end %>

  <!-- Rounds rail -->
  <div class="mb-8">
    <h3 class="text-sm font-semibold text-secondary mb-3">Tournament Rounds</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
      <% @survivor_rounds.each do |round| %>
        <%
          is_current = cr && round.id == cr.id
          pick = my_picks_by_round[round.id]
        %>
        <div class="card p-2.5 <%= is_current ? 'ring-1 ring-primary/50' : '' %>">
          <div class="flex items-center justify-between gap-1">
            <span class="text-xs font-bold text-heading truncate"><%= round.name %></span>
            <% if round.completed? %>
              <span class="text-[10px] text-muted flex-shrink-0">done</span>
            <% elsif round.picks_locked? %>
              <span class="text-[10px] text-yellow-500 flex-shrink-0">locked</span>
            <% elsif is_current %>
              <span class="text-[10px] text-primary font-semibold flex-shrink-0">pick now</span>
            <% end %>
          </div>
          <% if entered && pick %>
            <div class="mt-1.5 flex items-center gap-1">
              <span class="text-base"><%= pick.team&.emoji %></span>
              <span class="text-xs font-semibold text-secondary truncate"><%= pick.team&.short_name %></span>
              <% if pick.survived? %>
                <span class="ml-auto text-primary text-xs font-bold">✓</span>
              <% elsif pick.eliminated? %>
                <span class="ml-auto text-red-400 text-xs font-bold">✗</span>
              <% end %>
            </div>
          <% elsif entered %>
            <p class="mt-1.5 text-[10px] text-muted"><%= round.picks_locked? ? 'no pick' : '—' %></p>
          <% else %>
            <p class="mt-1.5 text-[10px] text-muted"><%= round.picks_lock_at&.strftime('%b %-d') || 'TBD' %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%= render "components/json_debug", record: @contest.as_json, label: "Contest JSON", collapsible: true %>
</div>

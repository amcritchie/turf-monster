<%# Quest mission 3 of 4 — join the newsletter for 25 seeds. Matches the username
    card: Row 1 = header + badge; Row 2 = description + consent (50%) | tall
    pulsing CTA (50%). web2 users one-click; web3 (no email) get the email-capture
    modal first. The questNewsletter factory (shared/_alpine_factories) owns the
    fetch + success — no risky logic in the x-data attribute. No mb-* — grid child. %>
<% needs_email = current_user.email.blank? %>
<div x-data="questNewsletter({ url: '<%= newsletter_subscribe_path %>', needsEmail: <%= needs_email %> })"
     class="card shadow p-5 relative h-full">
  <style>
    /* Pulse beat once every 3s (ring expands + fades, tiny pop), then rests. */
    @keyframes questPulse {
      0%        { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
      10%       { transform: scale(1.03); box-shadow: 0 0 0 6px rgba(74, 222, 128, 0.25); }
      22%       { transform: scale(1);    box-shadow: 0 0 0 10px rgba(74, 222, 128, 0); }
      100%      { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }
    .quest-pulse { animation: questPulse 3s ease-out infinite; }
    @media (prefers-reduced-motion: reduce) { .quest-pulse { animation: none; } }
  </style>

  <%# Row 1 — header + quest badge %>
  <div class="flex items-center justify-between gap-3 mb-3">
    <h3 class="text-heading font-semibold text-sm">Join the Newsletter</h3>
    <span data-quest-badge class="inline-block text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">Quest 3 of 4</span>
  </div>

  <%# Row 2 — description + consent (50%) | CTA (50%) %>
  <div class="grid grid-cols-2 gap-4">
    <div class="min-w-0">
      <p class="text-secondary text-xs leading-relaxed">
        Sports news &amp; contest updates.
      </p>
      <label class="flex items-center gap-2 text-xs text-secondary mt-2 select-none cursor-pointer">
        <input type="checkbox" x-model="consent" class="rounded border-subtle text-primary cursor-pointer">
        Subscribe to the Turf Monster newsletter
      </label>
      <p x-show="error" x-cloak x-text="error" class="text-xs mt-2" style="color:#f87171"></p>
    </div>
    <button type="button" @click="start()" :disabled="saving || !consent"
            class="btn btn-primary w-full h-full disabled:opacity-50 disabled:cursor-not-allowed"
            :class="{ 'quest-pulse': consent && !saving }">
      <span x-show="!saving">Subscribe</span>
      <span x-show="saving" x-cloak>Subscribing…</span>
    </button>
  </div>
</div>

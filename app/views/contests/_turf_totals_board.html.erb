<%
  cart_selections = {}
  cart_selection_order = []
  edit_entry = local_assigns[:edit_entry]
  source_entry = edit_entry || @cart_entry

  if source_entry
    source_entry.selections.order(:created_at, :id).each do |s|
      cart_selections[s.slate_matchup_id.to_s] = true
      cart_selection_order << s.slate_matchup_id.to_s
    end
  end

  # Edit mode: auto-drop the most-recently-added pick to land in
  # `picks_required - 1` state. Mirrors the create-mode blur-overlay
  # drop (further below) and forces a meaningful change rather than
  # a no-op confirm.
  if edit_entry && cart_selection_order.any?
    dropped = cart_selection_order.pop
    cart_selections.delete(dropped)
  end
%>

<style>
  /* First-pick nudge — a random one of the first four matchup cards (selectionBoard
     .pulseId) pulses until the first selection, using the SAME beat as quest 1's
     "Change Username" card: a green ring expands + a tiny scale once every 3s.
     Keep in sync with questPulse in _quest_username.html.erb. */
  @keyframes matchupPulse {
    0%   { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5); }
    3%   { transform: scale(1.03); box-shadow: 0 0 0 6px rgba(74, 222, 128, 0.25); }
    7%   { transform: scale(1);    box-shadow: 0 0 0 10px rgba(74, 222, 128, 0); }
    100% { transform: scale(1);    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
  }
  /* Same quest-1 flash (~0.7s), but every 10s with the first at 2s (2s delay →
     pulses at 2s, 12s, 22s…). The flash lives in 0-7% of the 10s loop, then rests. */
  .matchup-pulse { animation: matchupPulse 10s ease-out 2s infinite; }
  @media (prefers-reduced-motion: reduce) { .matchup-pulse { animation: none; } }
</style>

<script type="application/json" id="board-config">
<%
  matchup_data = {}
  # Multi-week span: the pick is a TEAM riding every week, priced by ONE
  # multiplier derived from expected points across the whole span. @matchups is
  # the anchor (week-one) set, so selections stay keyed exactly as they are on a
  # single-week board.
  multi_week   = @contest.multi_week?
  span_scores  = multi_week ? @contest.span_turf_scores : {}
  span_weeks   = multi_week ? @contest.week_slates : []
  span_opponents = {}
  if multi_week
    @contest.matchups_by_team.each do |team_slug, team_matchups|
      by_slate = team_matchups.index_by(&:slate_id)
      span_opponents[team_slug] = span_weeks.map { |slate| [slate, by_slate[slate.id]] }
    end
  end

  @matchups.each do |m|
    # The cart, summary, and every JS readout must show the SPAN multiplier on a
    # multi-week board \u2014 the anchor week's number would misprice the pick.
    shown_score = multi_week ? span_scores[m.team_slug] : m.turf_score
    matchup_data[m.id.to_s] = {
      name: m.team.name,
      emoji: m.team.emoji,
      opName: multi_week ? span_opponents[m.team_slug].to_a.filter_map { |_s, wm| wm&.opponent_team&.short_name }.join(" / ") : m.opponent_team&.short_name.to_s,
      turfScore: shown_score ? sprintf("%.1f", shown_score) : "\u2014",
      locked: m.locked?
    }
  end

  # Team cards, cheapest multiplier first (same ordering idea as the flat
  # multiplier view).
  span_team_cards = multi_week ? @matchups.sort_by { |m| span_scores[m.team_slug] || 999 } : []

  # Game pairs (group by game, each pair low-turf-first, pairs ordered by lower
  # turf_score). Computed ONCE here and reused by both firstMatchupIds below (the
  # pulse-target pool) and the game-view render, so the two never disagree on a
  # turf_score tie at the boundary (sort_by isn't stable).
  game_pairs = @matchups.group_by(&:game_slug).values.select { |pair| pair.size == 2 }
  game_pairs.each { |pair| pair.sort_by! { |m| m.turf_score || 999 } }
  game_pairs.sort_by! { |pair| pair.first.turf_score || 999 }
%>
<%#
  Contest/cart data only. Auth + wallet state (loggedIn, mode, userId,
  address) comes from the canonical #session-context / $store.session —
  see application.html.erb. Kept here: userEmail (a display value).
%>
<%= {
  matchupData: matchup_data,
  cartSelections: cart_selections,
  cartSelectionOrder: cart_selection_order,
  contestSlug: @contest&.slug,
  entryFeeCents: @contest.entry_fee_cents || 0,
  contestOnchain: @contest.onchain?,
  acceptsUsdt: @contest.accepts_usdt?,
  contestName: @contest.name,
  picksRequired: @contest.picks_required,
  firstMatchupIds: game_pairs.first(2).flatten.map { |m| m.id.to_s },
  userEmail: current_user&.email.to_s,
  seedsPerLevel: User::SEEDS_PER_LEVEL,
  pendingRecoveryPtxSlug: @pending_recovery_ptx&.slug,
  mode: edit_entry ? "edit" : "create",
  editEntrySlug: edit_entry&.slug
}.to_json.html_safe %>
</script>

<script>
// selectionBoard — MUST be inline because Alpine processes x-data before importmap modules load.
// Reads config from #board-config JSON element above.
window.selectionBoard = function() {
  var configEl = document.getElementById('board-config');
  if (!configEl) { console.error('board-config element not found'); return {}; }
  var cfg = JSON.parse(configEl.textContent);

  var matchupData = cfg.matchupData;

  return {
    selections: cfg.cartSelections,
    selectionOrder: cfg.cartSelectionOrder,
    cartOpen: Object.keys(cfg.cartSelections).length > 0 || cfg.mode === 'edit',
    blurDismissed: false,
    mode: cfg.mode || 'create',
    editEntrySlug: cfg.editEntrySlug || null,
    get isEditMode() { return this.mode === 'edit'; },
    shakeKey: 0,
    submitting: false,
    // First-pick nudge: a random one of the first four matchups border-pulses
    // until the first selection is made, then goes quiet (selectionCount > 0).
    pulseId: (Object.keys(cfg.cartSelections).length === 0 && cfg.firstMatchupIds && cfg.firstMatchupIds.length)
      ? cfg.firstMatchupIds[Math.floor(Math.random() * cfg.firstMatchupIds.length)] : null,
    contestId: cfg.contestSlug,
    csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
    // Auth/wallet state is read live from the canonical Alpine.store('session')
    // (see application.html.erb) — never copied here, so it can't go stale.
    get loggedIn() { var s = Alpine.store('session'); return s ? s.loggedIn : false; },
    entryFeeCents: cfg.entryFeeCents,
    userEmail: cfg.userEmail || '',
    contestOnchain: cfg.contestOnchain,
    // True iff this contest's on-chain entry_fee_by_currency funded slot 1
    // (USDT) at creation — pre-2026-06-10 contests are USDC-only forever
    // (the fee array is immutable after create_contest).
    acceptsUsdt: !!cfg.acceptsUsdt,
    contestName: cfg.contestName,
    picksRequired: cfg.picksRequired,
    sortMode: 'game',
    sortDir: 'asc',
    filterText: '',
    pickUrgent: false,
    // ALL of the auth/signup/tokens/redirect modal state has moved to
    // Alpine.store('modals') under modal id 'auth'. The wizard partial
    // (modals/_auth.html.erb) drives off props.step, and this board's
    // network methods read/write props on $store.modals.current(). The
    // form fields (email, password) live in the wizard partial's own
    // x-data. Helper methods _wizardOpen / _wizardStep / _wizardProps
    // below wrap the store access so call sites stay readable.
    profileModal: false,
    profileUsername: '',
    profileError: '',
    profileSubmitting: false,
    signupMethod: '',

    init() {
      // Stripe checkout runs in a NEW TAB (see the buy-tokens panel). When
      // Stripe returns the buyer to /tokens/processing, that page signals
      // back here — the entire "Confirming your purchase…" + success UI
      // lives in this modal so the buyer never visually leaves the contest.
      //
      // We listen on TWO channels because browsers may have dropped
      // window.opener on the new tab (implicit noopener on target=_blank
      // forms): a BroadcastChannel (modern, opener-independent) and the
      // classic window message event (legacy fallback).
      var board = this;
      var handleTokenSignal = function (data) {
        if (!data || data.source !== 'tt-tokens') return;
        var modals = Alpine.store('modals');
        var cur = modals.current();
        var curStep = (cur && cur.id === 'auth') ? cur.props.step : null;
        console.log('[tokens] board.handleTokenSignal received', { status: data.status, sessionId: data.sessionId, curModalId: cur && cur.id, curStep: curStep });

        if (data.status === 'returned' && data.sessionId) {
          // De-dupe: both channels may deliver the same signal.
          if (curStep === 'tokens-confirming' || curStep === 'tokens-minted') {
            console.log('[tokens] board.handleTokenSignal de-duped — already at', curStep);
            return;
          }
          // Stamp the moment the spinner went on screen — pollTokenStatus
          // awaits this minimum before the success swap so the spinner
          // doesn't flash by when the webhook beats the modal mounting.
          board._confirmingHold = window.StudioModals.holdAtLeast(1500);
          var freshProps = {
            step:          'tokens-confirming',
            errorText:     '',
            mintedCount:   0,
            mintedBalance: 0,
            redirectUrl:   '',
            txSignature:   ''
          };
          if (cur && cur.id === 'auth') {
            console.log('[tokens] board → reusing open auth modal, flipping step to tokens-confirming');
            Object.assign(cur.props, freshProps);
          } else {
            console.log('[tokens] board → no auth modal open, opening fresh at tokens-confirming');
            modals.open('auth', freshProps);
          }
          board.pollTokenStatus(data.sessionId);
          return;
        }

        if (data.status === 'minted') {
          console.log('[tokens] board.handleTokenSignal: legacy "minted" — closing modal, resetting holds');
          // Legacy fallback — the new tab fully completed the mint. Close
          // the modal and let the user do a fresh Hold to Confirm; we no
          // longer auto-submit the entry.
          if (cur && cur.id === 'auth') modals.close();
          try { board.resetHoldButtons(); } catch (_) {}
        }
      };

      window.addEventListener('message', function (e) {
        if (e.origin !== window.location.origin) {
          if (e.data && e.data.source === 'tt-tokens') {
            console.warn('[tokens] board: dropped postMessage from wrong origin', e.origin);
          }
          return;
        }
        if (e.data && e.data.source === 'tt-tokens') {
          console.log('[tokens] board ← window.message channel');
        }
        handleTokenSignal(e.data);
      });

      try {
        if ('BroadcastChannel' in window) {
          board._tokensChannel = new BroadcastChannel('tt-tokens');
          board._tokensChannel.onmessage = function (e) {
            console.log('[tokens] board ← BroadcastChannel(tt-tokens)');
            handleTokenSignal(e.data);
          };
          console.log('[tokens] board: BroadcastChannel(tt-tokens) listener attached');
        } else {
          console.warn('[tokens] board: BroadcastChannel unsupported — relying on window.postMessage only');
        }
      } catch (e) {
        console.error('[tokens] board: BroadcastChannel listener attach failed', e);
      }

      // PayPal/Venmo hand-off (provider=paypal). The paypalButtons factory
      // (tokens/_paypal_sdk.html.erb) dispatches this after a successful
      // server-side capture — same shape as the Stripe 'returned' signal
      // above, minus the cross-tab leg (the SDK popup keeps the buyer on
      // this page). Advance the wizard to tokens-confirming and poll
      // /tokens/status by order_id; everything downstream (minted state,
      // nav fanout, hold-to-confirm) is the shared path.
      window.addEventListener('paypal-order-captured', function (e) {
        var orderId = e.detail && e.detail.orderId;
        if (!orderId) return;
        var modals = Alpine.store('modals');
        var cur = modals.current();
        var curStep = (cur && cur.id === 'auth') ? cur.props.step : null;
        console.log('[tokens] board ← paypal-order-captured order=', orderId, 'curStep=', curStep);
        if (curStep === 'tokens-confirming' || curStep === 'tokens-minted') return;
        board._confirmingHold = window.StudioModals.holdAtLeast(1500);
        var freshProps = {
          step:          'tokens-confirming',
          errorText:     '',
          mintedCount:   0,
          mintedBalance: 0,
          redirectUrl:   '',
          txSignature:   ''
        };
        if (cur && cur.id === 'auth') {
          // advance() (not Object.assign) so the picker → confirming
          // transition runs the host's directional slide — the buyer just
          // acted in the popup, the slide reads as forward progress.
          modals.advance(freshProps);
        } else {
          modals.open('auth', freshProps);
        }
        board.pollTokenStatus(orderId, 'order_id');
      });

      // Hold-to-Confirm dispatch listener — the shared hold_button
      // partial fires this window event regardless of which DOM scope
      // it lives in. The auth-modal version of the button can't reach
      // d.confirmEntry() through el.closest('[x-data]') (that resolves
      // to the auth wizard's data, not the board's), so we route both
      // the in-board AND in-modal holds through this single channel.
      window.addEventListener('hold-confirm-entry', function () {
        // confirmEntry is async — a synchronous try/catch won't catch a
        // rejected promise. Tail with .catch so a failure in the entry
        // submission surfaces in the console instead of silently
        // freezing the hold button at "Almost there…".
        Promise.resolve()
          .then(function () { return board.confirmEntry(); })
          .catch(function (e) { console.error('[hold-confirm-entry] confirmEntry rejected:', e); });
      });

      // Hold-START funding pre-check (2026-06-13). The shared hold_button
      // fires this the instant a hold BEGINS (on_hold_start), regardless of
      // DOM scope — same window-event channel as hold-confirm-entry so the
      // in-modal hold buttons reach the board too. beginFundingCheck kicks
      // off a FRESH authoritative server balance read in PARALLEL with the
      // ~2s hold; confirmEntry() awaits the resolved verdict at hold-complete
      // (see the funding-gate there). Read-only — never touches the chain.
      window.addEventListener('hold-funding-check', function () {
        try { board.beginFundingCheck(); }
        catch (e) { console.error('[hold-funding-check] beginFundingCheck threw:', e); }
      });

      // Age gate (ENABLE_AGE_GATE): the DOB modal fired 'age-verified' after a
      // successful verify (it already flipped $store.session.ageVerified). Pick
      // the entry back up so the user flows straight to the next gate / entry
      // without re-holding. confirmEntry re-runs eligibilityBlocker — age now
      // passes, so it advances to tokens/balance or submits.
      window.addEventListener('age-verified', function () {
        Promise.resolve()
          .then(function () { return board.confirmEntry(); })
          .catch(function (e) { console.error('[age-verified] confirmEntry rejected:', e); });
      });

      // Reopen the post-signup step after submitProfile()'s reload —
      // Google → buy entry tokens; email → check your email.
      try {
        var stepRaw = sessionStorage.getItem('pendingAuthStep');
        if (stepRaw) {
          var step = JSON.parse(stepRaw);
          sessionStorage.removeItem('pendingAuthStep');
          if (step && step.contestSlug === this.contestId) {
            if (step.step === 'tokens') {
              // Post-signup pack-picker resume — deliberately STAYS the Get
              // Entry Tokens picker (not the Top Up Wallet modal). This restores
              // the buy-tokens step the user was on through the signup reload,
              // not the in-entry funds wall (that's the 'no_funding' blocker +
              // its chain-layer twin, both rerouted to showWalletTopup).
              //
              // If the magic-link welcome modal is showing (flag set by the
              // layout when flash[:magic_link_welcome] is present), give it its
              // ~3s success beat THEN swap to the tokens picker. Otherwise
              // (Google / direct) open immediately — no welcome to wait on.
              if (window.__magicLinkWelcome) {
                setTimeout(function () { board.showTokensPanel(); }, 3000);
              } else {
                this.showTokensPanel();
              }
            }
          }
        }
      } catch (e) {
        try { sessionStorage.removeItem('pendingAuthStep'); } catch (_) {}
      }

      // Restore the guest cart saved before an external auth redirect or the
      // magic-link email round trip. Source priority:
      //   1. ?picks= on the URL — carried by the magic-link return, so the
      //      lineup survives even when the link opens in a different browser
      //      or tab (where localStorage isn't shared). Server-validated.
      //   2. localStorage pendingContestEntry — same-browser fallback (Google
      //      full-page redirect, or the link opened in a new tab). A 30-min
      //      freshness guard stops a long-abandoned cart from auto-entering.
      // Only replay when logged in AND the cart matches this contest; auto-
      // enter when the saved intent included it.
      try {
        var contestId = this.contestId;
        var pending = null;

        var urlPicks = new URLSearchParams(window.location.search).get('picks');
        if (urlPicks) {
          var pickIds = urlPicks.split(',').map(function (s) { return parseInt(s, 10); }).filter(function (n) { return n > 0; });
          if (pickIds.length) {
            var sel = {}, order = pickIds.map(String);
            order.forEach(function (k) { sel[k] = true; });
            pending = { contestSlug: contestId, selections: sel, selectionOrder: order, autoEnter: true };
          }
          // Strip ?picks so a refresh/share doesn't re-trigger the auto-enter.
          try {
            var u = new URL(window.location.href);
            u.searchParams.delete('picks');
            window.history.replaceState({}, '', u.pathname + u.search + u.hash);
          } catch (_) {}
        }

        if (!pending) {
          var raw = localStorage.getItem('pendingContestEntry');
          if (raw) {
            var parsed = JSON.parse(raw);
            localStorage.removeItem('pendingContestEntry');
            var fresh = parsed && parsed.savedAt && (Date.now() - parsed.savedAt) < (30 * 60 * 1000);
            if (parsed && parsed.contestSlug === contestId && fresh) pending = parsed;
          }
        }

        if (pending) {
          if (pending.selections && Object.keys(pending.selections).length > 0) {
            this.selections = pending.selections;
            this.selectionOrder = pending.selectionOrder || Object.keys(pending.selections);
            this.cartOpen = true;
          }
          if (this.loggedIn && pending.autoEnter && this.selectionCount === this.picksRequired) {
            var self = this;
            // Let Alpine flush the state, then replay + enter. When the
            // magic-link welcome modal is showing, hold ~3s first so its
            // success beat isn't instantly covered by the tokens picker the
            // auto-enter opens (showTokensPanel swaps the welcome out at fire).
            var autoEnterDelay = window.__magicLinkWelcome ? 3000 : 50;
            setTimeout(function () {
              // Single-owner handoff: if the magic-link welcome modal is up,
              // neutralize ITS auto-redirect NOW (before the network-heavy
              // replay below) so it can't navigate to /tokens/buy mid-handoff —
              // afterLoginSuccess replays 6 selections + enters, and that tail
              // can outlast the welcome's 3.5s drain. The board owns the
              // transition; it swaps the welcome out for the picker on resolve.
              var wc = Alpine.store('modals').current();
              if (wc && wc.id === 'magic-link-welcome') wc.props.next = null;
              self.afterLoginSuccess();
            }, autoEnterDelay);
          }
        }
      } catch (e) {
        // Bad JSON or storage unavailable — quietly skip
        try { localStorage.removeItem('pendingContestEntry'); } catch (_) {}
      }

      // Stranded on-chain entry recovery. Server populates
      // cfg.pendingRecoveryPtxSlug when this user has a pending/submitted
      // PendingTransaction targeting one of their cart entries on this
      // contest — i.e. they signed an entry TX last session, refreshed
      // mid-flight, and we need to either auto-promote (TX landed) or
      // release (TX failed) the stranded entry.
      // Capture `this` HERE — the earlier `var self = this` lives inside the
      // saved-picks restore branch, so with nothing to restore `self` is
      // hoisted-but-undefined and this timeout threw (prod 2026-06-11).
      if (cfg.pendingRecoveryPtxSlug) {
        var board = this;
        setTimeout(function () { board.recoverPendingEntry(cfg.pendingRecoveryPtxSlug); }, 200);
      }
    },

    async recoverPendingEntry(ptxSlug) {
      var modal = Alpine.store('solanaModal');
      modal.show('Checking Your Last Entry', 'Looking up your previous on-chain transaction…', { dismissible: false });
      var maxAttempts = 6;     // ~30s of wall time with the 5s polling cadence
      var attempts = 0;
      while (attempts < maxAttempts) {
        attempts++;
        try {
          var resp = await window.authedFetch('/contests/' + this.contestId + '/recover_pending_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ ptx_slug: ptxSlug })
          });
          if (!resp) return; // 401 — authedFetch already opened the login modal
          var data = await resp.json();
          if (data.status === 'confirmed') {
            modal.success(data.tx_signature, "You're in! Good luck.");
            if (data.redirect) modal.onClose = function () { window.location.href = data.redirect; };
            return;
          }
          if (data.status === 'failed' || data.status === 'error' || data.status === 'missing') {
            modal.close();
            if (data.error) {
              try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: 'Entry not recovered', message: data.error, duration: 6000 } })); } catch (_) {}
            }
            return;
          }
          // status === 'processing' — wait then poll again.
        } catch (_) {
          // Network blip — keep polling.
        }
        await new Promise(function (r) { setTimeout(r, 5000); });
      }
      // Out of attempts. Leave the PT in submitted; admin can resolve.
      modal.close();
      try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: "Couldn't confirm last entry yet", message: "We'll keep watching — reload in a minute to retry.", duration: 6000 } })); } catch (_) {}
    },

    toggleSort(mode) {
      if (mode === 'turfScore' && this.sortMode === 'turfScore') {
        this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        this.sortMode = mode;
        this.sortDir = 'asc';
      }
    },

    matchesFilter: function() {
      var names = Array.from(arguments);
      if (!this.filterText) return true;
      var q = this.filterText.toLowerCase();
      return names.some(function(n) { return n.toLowerCase().includes(q); });
    },

    get selectionCount() {
      return Object.keys(this.selections).length;
    },

    get selectionSlots() {
      return this.selectionOrder.filter(id => this.selections[id]).map(matchupId => ({
        matchupId: matchupId,
        name: matchupData[matchupId]?.name || matchupId,
        emoji: matchupData[matchupId]?.emoji || '',
        opName: matchupData[matchupId]?.opName || '',
        turfScore: matchupData[matchupId]?.turfScore || ''
      }));
    },

    toggleSelection(matchupId) {
      if (matchupData[matchupId]?.locked) return;

      var oldSelections = Object.assign({}, this.selections);
      var oldOrder = this.selectionOrder.slice();

      if (this.selections[matchupId]) {
        var wasFull = this.selectionCount === this.picksRequired;
        var newSelections = Object.assign({}, this.selections);
        delete newSelections[matchupId];
        this.selections = newSelections;
        this.selectionOrder = this.selectionOrder.filter(function(id) { return id !== matchupId; });
        this.blurDismissed = false;
        if (wasFull) this.pickUrgent = true;
        if (this.selectionCount === 0) this.cartOpen = false;
      } else if (this.selectionCount < this.picksRequired) {
        this.selections = Object.assign({}, this.selections, { [matchupId]: true });
        this.selectionOrder = this.selectionOrder.concat([matchupId]);
        if (this.selectionCount === this.picksRequired) this.pickUrgent = false;
        // Open the cart on every pick-add. Redundant once it's already open,
        // but guarantees the sidebar reveals itself after each selection.
        this.cartOpen = true;
        this.triggerShake(matchupId);
      } else {
        // Replace oldest
        var removedId = this.selectionOrder[0];
        var newSel = Object.assign({}, this.selections);
        delete newSel[removedId];
        newSel[matchupId] = true;
        this.selections = newSel;
        this.selectionOrder = this.selectionOrder.slice(1).concat([matchupId]);
        this.blurDismissed = false;
        this.cartOpen = true;
        this.triggerShake(matchupId);
      }

      // Edit mode: picks are staged client-side and committed atomically by
      // updateEntry() on the Update click. Skip the per-toggle server hit so
      // we never leave a partially-updated active entry mid-edit.
      if (this.isEditMode) return;

      if (!this.loggedIn) return;

      var self = this;
      window.authedFetch('/contests/' + this.contestId + '/toggle_selection', {
        method: 'POST',
        headers: {
          'X-CSRF-Token': this.csrfToken,
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ matchup_id: matchupId })
      })
      .then(function(resp) {
        if (!resp) { self.selections = oldSelections; self.selectionOrder = oldOrder; return null; }
        return resp.json().then(function(data) { return { ok: resp.ok, data: data }; });
      })
      .then(function(result) {
        if (!result) return;
        if (!result.ok) {
          self.selections = oldSelections;
          self.selectionOrder = oldOrder;
          self.showError(result.data.error || 'Failed to save selection');
          return;
        }
        // Server is the source of truth. Adopt its authoritative selection set
        // so an optimistic mutation the server normalised/dropped can't leave
        // the client showing N/6 while the DB holds N-1 — which would otherwise
        // sail past the Hold-to-Confirm guard and 422 at #enter (incident
        // 2026-06-08, Bug 2). selectionCount is a getter over this.selections,
        // so it self-corrects once we reconcile.
        self.reconcileSelections(result.data.selections);
      })
      .catch(function() {
        self.selections = oldSelections;
        self.selectionOrder = oldOrder;
        self.showError('Network error. Selection not saved.');
      });
    },

    // Replace the client selection set with the server's authoritative one,
    // preserving the current display order for ids the server kept and
    // appending any server-present id we weren't already tracking. Keys are
    // matchup-id strings (matchupData + selectionOrder are string-keyed).
    reconcileSelections(serverSelections) {
      if (!serverSelections || typeof serverSelections !== 'object') return;
      var next = {};
      Object.keys(serverSelections).forEach(function(id) {
        if (serverSelections[id]) next[String(id)] = true;
      });
      this.selections = next;
      var kept = this.selectionOrder.filter(function(id) { return next[id]; });
      Object.keys(next).forEach(function(id) {
        if (kept.indexOf(id) === -1) kept.push(id);
      });
      this.selectionOrder = kept;
    },

    removeSelection(matchupId) {
      this.toggleSelection(matchupId);
    },

    triggerShake(matchupId) {
      this.shakeKey++;
      this._shakeMatchupId = matchupId;
      var self = this;
      setTimeout(function() { self._shakeMatchupId = null; }, 400);
    },

    isShaking(matchupId) {
      return this._shakeMatchupId === matchupId;
    },

    // Server-error → blocker dispatcher used by every entry-flow JSON
    // response (enter, prepare_entry, confirm_onchain_entry). Returns true
    // iff the response carried a structured blocker and routing happened;
    // the caller bails on true so the generic error UI doesn't fire on
    // top of the modal. Closes solanaModal if it's mid-flight so the
    // blocker modal isn't stacked underneath an on-chain-tx card.
    _handleBlockerResponse(data) {
      if (!data) return false;
      // Audit C1 — server refused to co-sign because the submitted tx didn't
      // match the entry it prepared (confirm_onchain_entry → 422, code
      // 'tx_rejected'). Good actors never hit this. Close the on-chain overlay,
      // drop the hold buttons, and surface the reassuring cosign-rejected modal
      // instead of throwing the generic error. Sits before the blocker check so
      // every entry-flow caller of this dispatcher gets it uniformly.
      if (data.code === 'tx_rejected') {
        if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
        this.submitting = false;
        this.resetHoldButtons();
        Alpine.store('modals').open('cosign-rejected', {});
        return true;
      }
      if (!data.blocker) return false;
      if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
      this.submitting = false;
      this.showEligibilityBlockerModal(data.blocker);
      return true;
    },

    // Dispatch entry-eligibility blocker → appropriate modal. Driven by
    // window.eligibilityBlocker (see solana_utils.js) — runs synchronously
    // off $store.session right after the loggedIn check. Same dispatcher
    // is reused by the post-execution error interpreter (Layer 2) so the
    // user sees identical UX whether the block was caught pre-flight or
    // surfaced from the chain.
    showEligibilityBlockerModal(blocker) {
      if (!blocker) return;
      switch (blocker.reason) {
        case 'not_logged_in':        this.showLoginModal(); break;
        case 'age_required':         this.showAgeVerifyModal(); break;
        // Funds-needed entry wall: the Coinbase-forward Top Up Wallet modal is
        // now the FIRST modal here (was the Get Entry Tokens pack picker). The
        // picker stays reachable via the hub's "More ways to add funds" rail.
        case 'no_funding':           this.showWalletTopup(); break;
        case 'insufficient_balance': this.showInsufficientBalanceModal(blocker); break;
        default:                     this.resetHoldButtons();
      }
    },

    // Age gate (ENABLE_AGE_GATE): open the date-of-birth verification modal.
    // It fires before the Get Entry Tokens modal (eligibilityBlocker order).
    // On success the modal sets $store.session.ageVerified and dispatches
    // 'age-verified' (listener wired in init) → we resume the entry so the
    // user flows straight through to the next gate (tokens/balance) or entry.
    showAgeVerifyModal() {
      this.resetHoldButtons();
      Alpine.store('modals').open('age-verify', { enterAnim: 'shake' });
    },

    // Open the standalone wallet-deposit modal. Hands the blocker's data
    // through as props so the modal can render the shortfall + needed
    // amount. Layer 2 (interpreter) doesn't know the client's current
    // balances, so we fall back to $store.session — that way the modal
    // always shows real numbers regardless of which layer triggered it.
    showInsufficientBalanceModal(blocker) {
      this.resetHoldButtons();
      var d = (blocker && blocker.data) || {};
      var sess = Alpine.store('session');
      Alpine.store('modals').open('wallet-deposit', {
        neededCents: d.neededCents | 0,
        usdcCents:   (d.usdcCents !== undefined ? d.usdcCents : (sess ? sess.usdcCents : 0)) | 0,
        usdtCents:   (d.usdtCents !== undefined ? d.usdtCents : (sess ? sess.usdtCents : 0)) | 0
      });
    },

    // Open the auth wizard at the credentials step (signup mode default).
    // The wizard partial's own x-data owns the email/password fields;
    // submit/error state for the network attempts lives on props so the
    // board's async methods can update them.
    showLoginModal() {
      // Drop any hold-button error state ("Entry Blocked") so the button is
      // back to its default while the user signs in.
      this.resetHoldButtons();
      Alpine.store('modals').open('auth', {
        step:          'credentials',
        mode:          'signup',
        picksRequired: this.picksRequired,
        submitting:    null,    // null | 'signup' | 'login' | 'phantom' | 'google'
        formError:     '',
        phantomError:  '',
        googleError:   ''
      });
    },

    // Persist current cart so it survives an external redirect or the magic-
    // link email round trip. localStorage (not sessionStorage) so it survives
    // the link opening in a NEW TAB; a savedAt stamp lets init() ignore stale
    // carts. Hydrated by init() after the user returns.
    saveCartForRedirect(autoEnter) {
      try {
        localStorage.setItem('pendingContestEntry', JSON.stringify({
          contestSlug: this.contestId,
          selections: this.selections,
          selectionOrder: this.selectionOrder,
          autoEnter: !!autoEnter,
          savedAt: Date.now()
        }));
      } catch (e) { /* localStorage unavailable — fall through */ }
    },

    // Helper — read the auth wizard's props off the store, or null if the
    // wizard isn't open. Used by every method that wants to mutate display
    // state without leaving stale fields on the board.
    _authProps() {
      var c = Alpine.store('modals').current();
      return (c && c.id === 'auth') ? c.props : null;
    },

    // Unified create-or-login magic link. The email path can't transition in
    // place (the user must click a link in their inbox), so we: preserve the
    // guest lineup for the round trip (localStorage for a same-browser new tab
    // + picks ride the signed return_to for a different browser/tab), POST the
    // request, then move the wizard to the 'magic-link-sent' confirmation step.
    // Called from the wizard via the 'auth-magic-link-submit' dispatch.
    async requestMagicLink(email, ageAttested) {
      var p = this._authProps();
      if (!p || p.submitting) return;
      p.formError = '';
      if (!email) {
        p.formError = 'Enter your email.';
        return;
      }
      p.submitting = 'magic-link';
      try {
        // Preserve the cart for the email round trip, then request the link.
        // picks ride as a comma string so the emailed link returns to the
        // contest with the lineup (window.postMagicLink owns the request shape).
        this.saveCartForRedirect(true);
        var picks = this.selectionOrder.slice(0, this.picksRequired).map(function (id) { return parseInt(id, 10); });

        var data = await window.postMagicLink(email, { contest: this.contestId, picks: picks.join(','), ageAttested: !!ageAttested });
        if (!data || !data.success) {
          p.formError = (data && data.error) || 'Could not send the link. Try again.';
          p.submitting = null;
          return;
        }

        // Move to the confirmation step in the same stack entry (advance keeps
        // the auth modal's x-data scope alive through the directional slide).
        Alpine.store('modals').advance({
          step:        'magic-link-sent',
          sentEmail:   email,
          sentContest: this.contestId,
          sentPicks:   picks.join(','),
          submitting:  null,
          formError:   ''
        });
      } catch (e) {
        var p2 = this._authProps();
        if (p2) { p2.formError = 'Network error. Try again.'; p2.submitting = null; }
      }
    },

    // Solana clicked in the auth modal → save the guest lineup, then progress
    // the modal to the "Connect Wallet" picker (modals/_wallet_connect). The
    // picker runs the SIWS connect itself (window.solanaConnectAndVerify) and
    // returns here (returnUrl = this contest) so the saved cart auto-enters.
    openWalletConnect(ageAttested) {
      this.saveCartForRedirect(true);
      // ageAttested pre-checks the picker's own attestation checkbox (the
      // auth modal already collected it) — see modals/_wallet_connect.
      Alpine.store('modals').swap('wallet-connect', { returnUrl: window.location.href, backTo: 'auth', ageAttested: !!ageAttested });
    },

    // Google sign-in via a popup window so the contest page stays put.
    // The popup hits /auth/google_popup, runs the OAuth round-trip, and
    // the callback renders a closer page that postMessages the result
    // back here and closes itself.
    loginWithGoogle(ageAttested) {
      var p = this._authProps();
      if (!p) return;
      p.googleError = '';
      // Legal-age attestation rides the popup URL → /auth/google_popup
      // forwards it into OmniAuth's request phase (omniauth.params).
      var popupUrl = ageAttested ? '/auth/google_popup?age_attestation=1' : '/auth/google_popup';
      // window.open must run synchronously inside the click handler, or the
      // browser blocks it.
      var popup = window.open(popupUrl, 'tt_google_oauth',
        'width=500,height=650,menubar=no,toolbar=no,location=no');
      if (!popup) {
        // Popup blocked — fall back to the full-page redirect.
        this.googleFullPageRedirect(ageAttested);
        return;
      }
      p.submitting = 'google';
      var self = this;
      var pollTimer = null;

      var onMessage = function(e) {
        if (e.origin !== window.location.origin) return;
        if (!e.data || e.data.source !== 'tt-oauth') return;
        window.removeEventListener('message', onMessage);
        if (pollTimer) clearInterval(pollTimer);
        var p2 = self._authProps();
        if (p2) p2.submitting = null;
        try { popup.close(); } catch (_) {}

        if (e.data.status === 'success') {
          var gSess = Alpine.store('session');
          if (gSess) { gSess.loggedIn = true; gSess.mode = 'web2'; }
          // Username is auto-assigned at signup — no profile step.
          self.saveCartForRedirect(true);
          window.location.reload();
        } else if (p2) {
          p2.googleError = e.data.error || 'Google sign-in failed.';
        }
      };
      window.addEventListener('message', onMessage);

      // If the user dismisses the popup without finishing, stop waiting.
      pollTimer = setInterval(function() {
        if (popup.closed) {
          clearInterval(pollTimer);
          window.removeEventListener('message', onMessage);
          var p3 = self._authProps();
          if (p3) p3.submitting = null;
        }
      }, 500);
    },

    // Fallback when the OAuth popup is blocked — full-page redirect. Save the
    // cart first so the entry resumes when the user returns.
    googleFullPageRedirect(ageAttested) {
      this.saveCartForRedirect(true);
      var form = document.createElement('form');
      form.method = 'POST';
      // Attestation must ride the QUERY string — OmniAuth's request phase
      // snapshots request.GET into omniauth.params, not the POST body.
      form.action = ageAttested ? '/auth/google_oauth2?age_attestation=1' : '/auth/google_oauth2';
      var csrf = document.createElement('input');
      csrf.type = 'hidden';
      csrf.name = 'authenticity_token';
      csrf.value = this.csrfToken;
      form.appendChild(csrf);
      document.body.appendChild(form);
      form.submit();
    },

    // Replay the in-memory guest cart to the server as a persisted cart
    // entry, so the 6 picks survive a detour (Stripe checkout, the email
    // confirm link). Returns false if a selection failed to save.
    async replaySelectionsToServer() {
      var ids = this.selectionOrder.slice();
      for (var i = 0; i < ids.length; i++) {
        try {
          var resp = await window.authedFetch('/contests/' + this.contestId + '/toggle_selection', {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ matchup_id: parseInt(ids[i], 10) })
          });
          if (!resp || !resp.ok) return false;
        } catch (e) { return false; }
      }
      return true;
    },

    // Open (or transition the wizard to) the buy-tokens picker step.
    // Called after Google signup, after the "out of entry tokens" error,
    // and from the pendingAuthStep restore in init(). Two paths:
    //   - Empty stack (cold open from navbar / direct CTA) → open() pushes
    //     a fresh auth entry and the host's default mount animation plays.
    //   - Auth wizard already on a different step (post-signup, post-
    //     confirm-error) → advance() patches props in place and the
    //     directional slide runs.
    showTokensPanel() {
      this.profileModal = false;
      var s   = Alpine.store('modals');
      var cur = s.current();
      var props = {
        step:          'tokens-picker',
        mintedCount:   0,
        mintedBalance: 0,
        errorText:     '',
        redirectUrl:   '',
        txSignature:   '',
        // Shake the card in on a fresh open — "not quite yet, grab a token
        // first." Only the fresh-mount path (no modal currently open) plays
        // the enter animation; the advance()/swap() paths below run their
        // directional in-flow slide instead (see ModalAnimations registry).
        enterAnim:     'shake'
      };
      if (cur && cur.id === 'auth') {
        s.advance(props);
      } else if (cur && cur.id === 'magic-link-welcome') {
        // Replace the welcome beat with the picker (directional slide) so the
        // welcome modal doesn't linger underneath after the hand-off.
        s.swap('auth', props);
      } else {
        s.open('auth', props);
      }
    },

    // Open (or swap into) the Coinbase-forward Top Up Wallet modal — the FIRST
    // funds modal a logged-in player sees at the entry blocker when they lack
    // funds (replaces the pack picker at that trigger; showTokensPanel above is
    // still the picker, reached via the hub's Stripe card + the post-signup
    // resume). wallet-topup is its OWN modal id, so unlike showTokensPanel
    // (which advance()s WITHIN the auth wizard) the choice is open-vs-swap:
    //   - any modal currently open (auth wizard, magic-link welcome beat) →
    //     swap() runs the host's cross-modal directional slide.
    //   - cold board (no modal open) → open() plays the fresh mount.
    showWalletTopup() {
      this.profileModal = false;
      var s   = Alpine.store('modals');
      var cur = s.current();
      if (cur && cur.id) {
        s.swap('wallet-topup', {});
      } else {
        s.open('wallet-topup', { enterAnim: 'shake' });
      }
    },


    // Poll /tokens/status until the payment webhook + TokenPurchaseJob
    // finish minting. Drives the wizard through tokens-confirming →
    // tokens-minted. Called from the BroadcastChannel / window message
    // listener when the Stripe tab hands the session_id back (refParam
    // omitted → 'session_id'), and from the paypal-order-captured
    // listener with refParam 'order_id'. Mutates the auth wizard's props
    // on the store; safely no-ops if the modal was closed mid-poll.
    pollTokenStatus(ref, refParam) {
      var self = this;
      var param = refParam || 'session_id';
      var elapsedMs = 0;
      var intervalMs = 1500;
      var timeoutMs = 45000;
      var attempt = 0;
      console.log('[tokens] pollTokenStatus.start ' + param + '=', ref, 'intervalMs=', intervalMs, 'timeoutMs=', timeoutMs);
      var tick = async function () {
        attempt++;
        try {
          var r = await fetch('/tokens/status?' + param + '=' + encodeURIComponent(ref), {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin'
          });
          if (r.ok) {
            var d = await r.json();
            console.log('[tokens] pollTokenStatus attempt=' + attempt + ' /tokens/status →', d);
            if (d.ready) {
              console.log('[tokens] pollTokenStatus: READY — awaiting min-visible hold then flipping to tokens-minted');
              // The hold was started when the 'returned' signal arrived
              // (window.StudioModals.holdAtLeast(1500) — see init's
              // handleTokenSignal). Awaits the min-visible duration
              // before swapping the spinner to the minted state.
              var hold = self._confirmingHold || window.StudioModals.holdAtLeast(0);
              hold.then(function () {
                var p = self._authProps();
                if (!p) {
                  console.warn('[tokens] pollTokenStatus: modal closed before mint readyswap — no-op');
                  return;
                }
                console.log('[tokens] pollTokenStatus: step → tokens-minted, mintedCount=', d.minted, 'balance=', d.balance);
                // advance() patches props + runs the host's directional
                // slide. The minted-state values land alongside the step
                // change so the new card renders with the right data
                // during slide-in.
                Alpine.store('modals').advance({
                  mintedCount:   d.minted,
                  mintedBalance: d.balance,
                  step:          'tokens-minted'
                });
                // Push the new token count to the navbar + celebrate
                // the mint. The badge punches (scale+wobble) so the
                // user catches the new 🎟️ in their peripheral vision,
                // and the confetti burst is positioned to shoot out
                // of it. A second burst fires later from the shared Entry
                // Confirmed card when the entry actually confirms.
                try { if (window.updateNavTokens) window.updateNavTokens(d.balance); } catch (_) {}
                // Also mirror the new count into $store.session so the
                // next confirmEntry()'s eligibilityBlocker reads fresh
                // state. updateNavTokens only touches the DOM badge;
                // the synchronous hold-time check reads from the Alpine
                // store directly (window.eligibilityBlocker in solana_utils.js).
                try {
                  var sess = window.Alpine && Alpine.store && Alpine.store('session');
                  if (sess) sess.tokensAvailable = parseInt(d.balance, 10) || 0;
                } catch (_) {}
                try { if (window.animateFreeEntryBadge) setTimeout(window.animateFreeEntryBadge, 60); } catch (_) {}
                try { if (window.fireConfettiFromBadge) setTimeout(window.fireConfettiFromBadge, 180); } catch (_) {}
              });
              // The modal STAYS OPEN in 'tokens-minted' — it renders the
              // in-modal Hold to Confirm Entry button. On success,
              // confirmEntry() calls resolveEntry() — swapping to the
              // shared onchain-tx "Entry Confirmed" card.
              return;
            }
          } else {
            console.warn('[tokens] pollTokenStatus attempt=' + attempt + ' /tokens/status non-OK', r.status);
          }
        } catch (e) {
          console.warn('[tokens] pollTokenStatus attempt=' + attempt + ' fetch error (will retry)', e);
        }

        elapsedMs += intervalMs;
        if (elapsedMs >= timeoutMs) {
          console.error('[tokens] pollTokenStatus TIMEOUT after', elapsedMs, 'ms — flipping to tokens-error');
          var p2 = self._authProps();
          if (p2) {
            p2.errorText = "Payment cleared but the on-chain mint is still settling. Refresh in a moment to finish your entry.";
            p2.step      = 'tokens-error';
          }
          return;
        }
        setTimeout(tick, intervalMs);
      };
      tick();
    },

    // After a reload-based login (see init()), push the guest cart to the
    // server and submit the entry.
    async afterLoginSuccess() {
      // Surface an entry-eligibility blocker (e.g. no entry tokens) BEFORE the
      // cart replay below. eligibilityBlocker reads only $store.session — no
      // server round-trip — so we can decide instantly. It lives in the
      // solana_utils importmap module, which loads just AFTER Alpine inits the
      // board, so wait briefly for it (bounded; falls through to the
      // server-authoritative path if it never appears). This turns the
      // post-magic-link "Get Entry Tokens" modal from a ~1.5s lag (6 sequential
      // toggle_selection POSTs in replaySelectionsToServer) into near-instant.
      // The cart still replays — behind the now-visible modal — so it is ready
      // once the user buys tokens and holds to confirm.
      var sess = Alpine.store('session');
      for (var i = 0; i < 20 && typeof window.eligibilityBlocker !== 'function'; i++) {
        await new Promise(function (resolve) { setTimeout(resolve, 25); });
      }
      var blocker = (typeof window.eligibilityBlocker === 'function')
        ? window.eligibilityBlocker(sess, this.entryFeeCents, { acceptsUsdt: this.acceptsUsdt })
        : null;
      if (blocker) {
        this.showEligibilityBlockerModal(blocker);
        await this.replaySelectionsToServer();
        return;
      }

      if (await this.replaySelectionsToServer()) {
        await this.confirmEntry();
      } else {
        this.showError('Could not save your picks. Please try again.');
      }
    },

    // Open the auth wizard at the redirect step. cta_redirect owns the
    // countdown + auto-navigation; the seconds arg is accepted for
    // backward compatibility but currently fixed at 5 in the partial
    // (only caller passes 5). Pass null for url to suppress the auto-
    // navigation (the partial keeps the drain visual + manual click
    // closes the modal).
    showRedirectModal(title, message, icon, url, _seconds, cta) {
      Alpine.store('modals').open('auth', {
        step:    'redirect',
        title:   title,
        message: message,
        icon:    icon,
        url:     url,
        cta:     cta
      });
    },

    setHoldSuccess() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'process', 'loading');
        el.classList.add('success');
      });
    },

    // After the hold completes but BEFORE the server confirms the entry.
    // Shows a spinning arc on the button so users don't see "Confirmed!"
    // until the submission actually lands. Cleared by setHoldSuccess/Error
    // or resetHoldButtons once the response arrives.
    setHoldLoading() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'process', 'success');
        el.classList.add('loading');
      });
    },

    setHoldError() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('success', 'process', 'loading');
        el.classList.add('error');
      });
    },

    // Clear all hold-button states back to the default ("Hold to Confirm").
    // Nothing else removes the `error` class, so without this a button that
    // hit the error state ("Entry Blocked") stays stuck there.
    resetHoldButtons() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'success', 'process', 'loading');
      });
    },

    // Authoritative hold-window funding pre-check (2026-06-13). Fired the
    // instant a hold STARTS (shared/_hold_button on_hold_start → the board's
    // 'hold-funding-check' listener), so the FRESH server balance read runs in
    // PARALLEL and is resolved by the time the hold completes ~2s later.
    // confirmEntry()'s funding-gate awaits this.
    //
    // SCOPE: managed (web2) sessions ONLY. This is the gate for the funds wall
    // the synchronous eligibilityBlocker CANNOT catch — a brand-new managed
    // wallet has no USDC ATA yet, so $store.session.usdcCents is null (unknown,
    // not 0) and the sync blocker deliberately fails OPEN (it must not false-
    // block a funded user whose navbar cache is merely cold). web3 is left
    // alone on purpose: it keeps its sync-blocker fail-open + on-chain
    // authority, and the endpoint is fail-CLOSED on an RPC flake — gating web3
    // on it would wrongly block a funded Phantom user (regressing fail-open-on-
    // flake). The server safety-net (resolve_web2_entry_funding!) is web2-only
    // too, so the two layers line up.
    beginFundingCheck() {
      // Reset every hold-start so a stale promise from a released-early hold
      // can't leak into a later submit; _fundingCheckAt below is the freshness
      // belt for the cross-flow case (release → buy tokens → in-modal hold).
      this._fundingCheck = null;
      this._fundingCheckAt = 0;
      var sess = Alpine.store('session');
      if (!sess || !sess.loggedIn) return;        // guest → the login gate handles it
      if (sess.mode !== 'web2') return;            // web3 unaffected (fail-open preserved)
      if ((this.entryFeeCents | 0) <= 0) return;   // free contest — nothing to fund
      if (typeof window.authedFetch !== 'function') return;
      this._fundingCheckAt = Date.now();
      this._fundingCheck = window.authedFetch('/contests/' + this.contestId + '/check_funding', {
        method: 'POST',
        headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' }
      }).then(function (resp) {
        // 401 (authedFetch surfaced the login modal → null) or non-OK → treat
        // as "unknown": confirmEntry proceeds and the server safety-net catches
        // a genuinely unfunded entry. Never block on an inconclusive read.
        if (!resp || !resp.ok) return null;
        return resp.json();
      }).catch(function () { return null; });       // network error → unknown → proceed
    },

    async runHoldValidations() {
      try {
        var res = await fetch('/geo/check', { headers: { 'Accept': 'application/json' } });
        var geo = await res.json();
        if (geo.blocked) {
          this.setHoldError();
          this.showRedirectModal('Location Restricted', 'Contest entries are not available in ' + (geo.state || 'your state') + '.', '\uD83D\uDCCD', '/', 5, 'OK');
          return false;
        }
      } catch(e) {
        // Geo check failed — allow through
      }

      if (!this.loggedIn) {
        this.showLoginModal();
        return false;
      }

      // Synchronous eligibility check against running $store.session — no
      // RPC at hold-time. Layer 1 of the entry-blocker design: catches the
      // 98% case (out of tokens, empty wallet) before the user finishes the
      // hold. The server-side enter still validates as the source of truth
      // for the 2% where running state is stale.
      var blocker = window.eligibilityBlocker(Alpine.store('session'), this.entryFeeCents, { acceptsUsdt: this.acceptsUsdt });
      if (blocker) {
        this.showEligibilityBlockerModal(blocker);
        return false;
      }

      return true;
    },

    // Which currency the on-chain entry should spend, from live $store.session
    // cents: USDC when it covers the fee, else USDT — but USDT only on
    // contests that funded entry_fee_by_currency slot 1 (acceptsUsdt).
    // Unknown balances (null — RPC flake) default to USDC; the server +
    // program stay authoritative either way.
    entryCurrency() {
      if (!this.acceptsUsdt) return 'usdc';
      var sess = Alpine.store('session');
      if (!sess) return 'usdc';
      var fee = this.entryFeeCents | 0;
      if (sess.usdcCents != null && (sess.usdcCents | 0) >= fee) return 'usdc';
      if (sess.usdtCents != null && (sess.usdtCents | 0) >= fee) return 'usdt';
      return 'usdc';
    },

    async confirmEntry() {
      // Re-entry guard: hold-button completes can fire 2+ events in the
      // same tick (debug-net 2026-05-27 caught 3 simultaneous POSTs from
      // a single user hold). Without this guard, the first POST wins,
      // the others 422 because the entry is already created on-chain,
      // and Alpine routes the 422 response into the "Get Entry Tokens"
      // fallback — visually masking the actual success.
      if (this.submitting) return;

      var sess = Alpine.store('session');
      if (sess.isGuest) {
        this.showLoginModal();
        return;
      }

      // Mirror the hold-time eligibility check at submit-time — the user
      // may have entered via auto-submit (e.g. post-login cart replay) or
      // their balance / token count may have changed since the hold check.
      var blocker = window.eligibilityBlocker(sess, this.entryFeeCents, { acceptsUsdt: this.acceptsUsdt });
      if (blocker) {
        this.showEligibilityBlockerModal(blocker);
        return;
      }

      // Hold-window funding gate (2026-06-13). beginFundingCheck() — fired at
      // hold-START — kicked off a FRESH authoritative server balance read in
      // parallel; by hold-COMPLETE it has had the full ~2s to resolve. This is
      // the authoritative gate for the managed-wallet (web2) funds wall the
      // synchronous eligibilityBlocker CANNOT catch: a brand-new managed wallet
      // has no USDC ATA yet, so $store.session.usdcCents reads null (unknown,
      // not 0) and the sync blocker fails OPEN — which previously let a $0 user
      // submit a doomed on-chain entry (cryptic "custom program error: 0x1").
      // Only a DEFINITIVE { fundable:false } aborts into the Top Up Wallet.
      //
      // Fail-OPEN by design — proceed (and rely on the server safety-net
      // resolve_web2_entry_funding!, which pre-checks USDC and returns
      // no_funding → Top Up Wallet) when the check is: absent (non-hold auto-
      // enter, or web3 — beginFundingCheck no-ops there), null (401/flake/non-
      // OK), still unresolved at hold-end, or stale from an earlier flow (the
      // 8s freshness belt covers the release → buy-tokens → in-modal-hold case,
      // where the user now HAS a token and must not be blocked by the old read).
      if (this._fundingCheck && (Date.now() - (this._fundingCheckAt || 0)) < 8000) {
        var pending = this._fundingCheck;
        this._fundingCheck = null;   // single-use — consume it for this attempt
        var funding = null;
        try {
          funding = await Promise.race([
            pending,
            new Promise(function (resolve) { setTimeout(function () { resolve(null); }, 1500); })
          ]);
        } catch (e) { funding = null; }
        if (funding && funding.fundable === false) {
          this.submitting = false;
          this.resetHoldButtons();
          this.showWalletTopup();
          return;
        }
      }

      // web3 = a Phantom-authenticated session — sign the entry directly.
      // web2 = managed wallet — POST /enter (server consumes an entry token).
      var useOnchainFlow = sess.isWeb3 && this.contestOnchain;

      this.setHoldLoading();
      this.submitting = true;

      var seedsPerLevel = cfg.seedsPerLevel;

      // Seeds fanout (localStorage + navbar event + structured log) is now
      // owned by the StateFanout registry — see app/javascript/state_fanout.js
      // and docs/UI_PATTERNS.md "State Fanout Pattern". Two call sites
      // below (phantom-direct + managed-wallet) hand off the server payload
      // and the source label; the handler does the rest.

      try {
        if (useOnchainFlow) {
          var provider = window.walletProvider.detect();
          Alpine.store('solanaModal').show('Preparing Transaction', 'Building onchain transaction...');

          var resp = await provider.connect();
          var pubkeyB58 = resp.publicKey.toBase58();

          if (sess.address && pubkeyB58 !== sess.address) {
            throw new Error('Wrong wallet connected. Switch to ' + sess.address.substring(0, 8) + '..., or reconnect your wallet on the Account page.');
          }

          // Single-signature flow: the actual on-chain TX (signTransaction
          // below) IS the wallet-ownership proof — Anchor rejects any
          // enter_contest_direct whose signer doesn't match the entry PDA's
          // owner. The previous SIWS signMessage step was defense-in-depth
          // that doubled the signing prompts without strengthening on-chain
          // integrity (current_user comes from the session cookie set at
          // login via the same SIWS flow). Removed 2026-05-24.

          // Currency pick (2026-06-10): USDC when it covers the fee, else USDT
          // on accepts-USDT contests. Decided once here so the prepare POST,
          // the Phantom prompt copy, and the user's mental model all agree.
          var entryCurrency = this.entryCurrency();

          // prepare_entry is just-in-time: the server rebuilds the UNSIGNED entry
          // TX (build_enter_contest → build_partial_unsigned) which RE-FETCHES
          // get_latest_blockhash AND prepends the ComputeBudget priority-fee +
          // CU-limit ixs. We call it immediately before signing so the blockhash
          // is maximally fresh (mirrors create's rebuild_create_tx).
          console.log('[contest-entry] POST prepare_entry (fresh blockhash + priority fee), currency=' + entryCurrency);
          var prepareResp = await window.authedFetch('/contests/' + this.contestId + '/prepare_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ currency: entryCurrency })
          });
          if (!prepareResp) return; // 401 — authedFetch surfaced the login modal
          var prepareData = await prepareResp.json();
          console.log('[contest-entry] prepare_entry response:', { success: prepareData.success, error: prepareData.error, entry_pda: prepareData.entry_pda, ptx_slug: prepareData.ptx_slug, serialized_tx_len: prepareData.serialized_tx ? prepareData.serialized_tx.length : null });
          var ptxSlug = prepareData.ptx_slug;
          if (!prepareData.success) {
            if (this._handleBlockerResponse(prepareData)) return;
            throw new Error(prepareData.error || 'Failed to prepare entry');
          }

          // Surface WHICH currency this entry spends (small label — the modal
          // copy is the natural spot; no redesign).
          Alpine.store('solanaModal').show('Sign Transaction', 'Approve the ' + entryCurrency.toUpperCase() + ' transfer in your wallet...');
          var txBytes = Uint8Array.from(atob(prepareData.serialized_tx), function(c) { return c.charCodeAt(0); });
          var tx = solanaWeb3.Transaction.from(txBytes);
          try {
            var progIds = tx.instructions.map(function(ix) { return ix.programId.toBase58(); });
            console.log('[contest-entry] deserialized TX:', {
              recentBlockhash: tx.recentBlockhash,
              instructionCount: tx.instructions.length,
              programIds: progIds,
              hasComputeBudgetPrice: progIds.indexOf('ComputeBudget111111111111111111111111111111') !== -1
            });
          } catch (logErr) { console.warn('[contest-entry] TX inspection failed (non-fatal):', logErr); }

          // Phantom-FIRST signing order (2026-06-05): Phantom signs the
          // FULLY-UNSIGNED tx FIRST (both admin + user slots empty). This clears
          // Phantom's multi-signer-order "could be malicious" Lighthouse banner
          // that fired when the server pre-signed and Phantom signed second.
          //
          // We DO NOT broadcast/simulate/poll client-side anymore. We hand the
          // Phantom-signed wire bytes (requireAllSignatures:false → admin slot
          // still empty) to the server, which cosigns with the admin keypair
          // (Transaction.cosign_wire), runs a simulateTransaction pre-flight,
          // broadcasts, waits for confirmation, then verifies + activates.
          var signedTx = await provider.signTransaction(tx);
          // requireAllSignatures:false — the admin slot is intentionally still
          // empty; the server fills it. verifySignatures:false — the tx isn't
          // fully signed yet, so don't let web3.js reject it on serialize.
          var signedBytes = signedTx.serialize({ requireAllSignatures: false, verifySignatures: false });
          console.log('[contest-entry] signed by Phantom (admin slot empty); raw byte length:', signedBytes.length);

          var sb = '';
          var sChunk = 0x8000;
          for (var bi = 0; bi < signedBytes.length; bi += sChunk) {
            sb += String.fromCharCode.apply(null, signedBytes.subarray(bi, bi + sChunk));
          }
          var signedB64 = btoa(sb);

          Alpine.store('solanaModal').show('Confirming Onchain', 'Cosigning and submitting to Solana...');
          var confirmResp = await window.authedFetch('/contests/' + this.contestId + '/confirm_onchain_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ signed_tx: signedB64, entry_id: prepareData.entry_id, entry_pda: prepareData.entry_pda, ptx_slug: ptxSlug })
          });
          if (!confirmResp) return; // 401 — authedFetch surfaced the login modal
          var confirmData = await confirmResp.json();
          if (!confirmData.success) {
            if (this._handleBlockerResponse(confirmData)) return;
            throw new Error(confirmData.error || 'Failed to confirm entry');
          }
          var txSig = confirmData.tx_signature;
          console.log('[contest-entry] server cosigned + confirmed on-chain:', txSig);
          this.setHoldSuccess();

          if (confirmData.seeds_earned) {
            var m = Alpine.store('solanaModal');
            m.seedsEarned = confirmData.seeds_earned;
            m.seedsTotal  = confirmData.seeds_total;
            m.seedsLevel  = confirmData.seeds_level;
          }
          // OPSEC-007: removed client→server PATCH /account/update_level. The
          // navbar reads seeds/level from `seedsNavbar` localStorage which the
          // StateFanout handler writes below — already populated from the
          // server response.
          window.StateFanout.apply('seeds', confirmData, { source: 'phantom-direct', seedsPerLevel: seedsPerLevel });
          // 999s auto-close while reviewing seeds animation. Restore to a normal countdown when shipping (e.g. 8s).
          var modal = Alpine.store('solanaModal');
          modal.success(txSig, 'Entry Confirmed', 999);
          modal.title = 'Good Luck';
          modal.lobbyUrl = confirmData.redirect || ('/contests/' + this.contestId);
          refreshBalanceDelayed();

        } else {
          // Suppress the solanaModal "Submitting Entry" overlay when
          // we're already inside the auth wizard at tokens-minted — the
          // hold button shows its own in-place "Submitting…" feedback, and
          // on success resolveEntry() swaps this wizard for the shared
          // Entry Confirmed card. Stacking a "Submitting Entry" onchain-tx
          // modal on the auth modal would be two stacked modals.
          var authProps      = this._authProps();
          var insideTokensModal = !!(authProps && authProps.step === 'tokens-minted');
          if (!insideTokensModal) {
            Alpine.store('solanaModal').show('Submitting Entry', 'Processing your entry...');
          }

          var response = await window.authedFetch('/contests/' + this.contestId + '/enter', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Accept': 'application/json' }
          });
          if (!response) {
            // authedFetch returned null → it surfaced the right modal (401 login
            // / 429 rate-limit wait). Close OUR "Submitting Entry" overlay and
            // reset the hold button so the entry flow recovers cleanly — no
            // double modal, no stuck spinner.
            if (!insideTokensModal) { try { Alpine.store('solanaModal').close(); } catch (e) {} }
            try { this.resetHoldButtons(); } catch (e) {}
            this.submitting = false;
            return;
          }
          var data = await response.json();

          if (data.success) {
            this.setHoldSuccess();
            // 🎟️ navbar punch — fires when the server reports the entry
            // was paid for by a token consume. Hooked here so both the
            // tokens-modal and the non-modal hold-to-confirm paths get
            // the same animation.
            if (data.token_consumed) {
              try { if (window.animateFreeEntryBadge) window.animateFreeEntryBadge(); } catch (_) {}
            }
            // Navbar seed-bar tick-up. Previously only fired on the Phantom
            // direct path; the managed-wallet path used to update the success
            // modal's display but left the navbar bar untouched. One call here
            // covers every managed-wallet branch (tokens modal w/ tx, tokens
            // modal w/o tx, plain hold-to-confirm) — they all flow through
            // `data.success`.
            window.StateFanout.apply('seeds', data, { source: 'managed-wallet', seedsPerLevel: seedsPerLevel });
            // Re-fetch the wizard props in case the entry submit took
            // long enough for the modal to be dismissed.
            var p = this._authProps();
            var inTokensMinted = !!(p && p.step === 'tokens-minted');

            if (data.tx_signature) {
              if (inTokensMinted) {
                // In-wizard token entry resolves to the SAME shared "Entry
                // Confirmed" card as the web3 path. resolveEntry() swaps the
                // auth wizard for the onchain-tx success modal (replace, not
                // stack — no two stacked modals). updateNavTokens fires
                // synchronously so the navbar count is right as the slide
                // begins; the success card fires its own confetti on mount.
                var nextBalance = Math.max(0, (p.mintedBalance || 0) - 1);
                try { if (window.updateNavTokens) window.updateNavTokens(nextBalance); } catch (_) {}
                Alpine.store('solanaModal').resolveEntry({
                  txSignature: data.tx_signature,
                  lobbyUrl:    data.redirect || '/',
                  seedsEarned: data.seeds_earned || 0,
                  seedsTotal:  data.seeds_total  || 0,
                  seedsLevel:  data.seeds_level  || 0
                });
                refreshBalanceDelayed();
              } else {
                var sm = Alpine.store('solanaModal');
                sm.seedsEarned = data.seeds_earned || 0;
                sm.seedsTotal  = data.seeds_total  || 0;
                sm.lobbyUrl    = data.redirect || '/';
                sm.success(data.tx_signature, 'Entry Confirmed');
                refreshBalanceDelayed();
              }
            } else {
              if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();

              if (inTokensMinted) {
                // Token entry with no on-chain tx — still resolve to the
                // shared Entry Confirmed card (the tx-link simply doesn't
                // render when the signature is null). Swaps the auth wizard
                // for the onchain-tx success modal (replace, not stack).
                var nextBalance2 = Math.max(0, (p.mintedBalance || 0) - 1);
                try { if (window.updateNavTokens) window.updateNavTokens(nextBalance2); } catch (_) {}
                Alpine.store('solanaModal').resolveEntry({
                  txSignature: null,
                  lobbyUrl:    data.redirect || '/',
                  seedsEarned: data.seeds_earned || 0,
                  seedsTotal:  data.seeds_total  || 0,
                  seedsLevel:  data.seeds_level  || 0
                });
                refreshBalanceDelayed();
              } else {
                window.location.href = data.redirect || '/';
              }
            }
          } else if (this._handleBlockerResponse(data)) {
            // Layer 2 — handled by _handleBlockerResponse.
          } else if (/entry token/i.test(data.error || '')) {
            // Defense-in-depth — older string-match for the "no tokens" raise
            // from the server (the chain-layer twin of the 'no_funding' eligibility
            // blocker). Routes to the same Top Up Wallet modal so the funds-needed
            // UX is identical whether the wall is caught pre-flight or surfaced
            // from the server. Kept so a deploy of the controller ahead of the
            // interpreter doesn't lose the funds panel.
            if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
            this.resetHoldButtons();
            this.submitting = false;
            this.showWalletTopup();
          } else {
            if (Alpine.store('solanaModal').visible) {
              Alpine.store('solanaModal').error(data.error || 'Something went wrong');
            } else {
              this.showError(data.error || 'Something went wrong');
            }
            this.resetHoldButtons();
            this.submitting = false;
          }
        }
      } catch (err) {
        console.error('[contest-entry] FAILED:', err);
        var msg = parseSolanaError(err.message || 'Failed to sign entry');
        if (Alpine.store('solanaModal').visible) {
          Alpine.store('solanaModal').error(msg);
        } else {
          this.showError(msg);
        }
        this.resetHoldButtons();
        this.submitting = false;
      }
    },

    showError(message) {
      // Route entry/selection errors through the shared toast manager (alert =
      // red error styling) — same path as the recovery/confirm toasts above,
      // instead of the old bespoke "Entry Failed" popup.
      try {
        window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: 'Entry Failed', message: message || '', duration: 6000 } }));
      } catch (_) {}
    },

    async clearSelections() {
      this.selections = {};
      this.selectionOrder = [];
      this.cartOpen = false;
      this.blurDismissed = false;
      this.pickUrgent = false;

      if (!this.loggedIn) return;
      // Edit mode never has a cart entry; clear_picks is a no-op there.
      if (this.isEditMode) return;

      try {
        // authedFetch so a general-tier 429 surfaces the wait modal instead of
        // being silently swallowed (clear_picks is in the general/ip allowlist).
        // It returns null on 429/401 after showing the modal; nothing else to do
        // here — this is a background cart sync.
        await window.authedFetch('/contests/' + this.contestId + '/clear_picks', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Accept': 'application/json'
          }
        });
      } catch (err) {
        // network — silent
      }
    },

    // Edit mode: PATCH the staged picks to /contests/:slug/entries/:slug.
    // DB-only — no on-chain signature required (the ContestEntry PDA carries
    // no pick commitment, so chain state stays valid as-is).
    async updateEntry() {
      if (this.submitting) return;
      if (this.selectionCount !== this.picksRequired) {
        this.showError('Make ' + this.picksRequired + ' picks before updating.');
        return;
      }
      this.submitting = true;
      var ids = this.selectionOrder.map(function(id) { return parseInt(id, 10); });
      try {
        var resp = await window.authedFetch(
          '/contests/' + this.contestId + '/entries/' + this.editEntrySlug,
          {
            method: 'PATCH',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ matchup_ids: ids })
          }
        );
        if (!resp) { this.submitting = false; return; }
        var data = await resp.json();
        if (resp.ok && data.success) {
          window.location.href = data.redirect || ('/contests/' + this.contestId);
        } else {
          this.showError((data && data.error) || 'Failed to update entry.');
          this.submitting = false;
        }
      } catch (e) {
        this.showError('Network error. Update not saved.');
        this.submitting = false;
      }
    },

    // Edit mode: discard staged picks and return to the leaderboard view.
    // Server-side state (the active entry's selections) is untouched.
    cancelEdit() {
      window.location.href = '/contests/' + this.contestId;
    }
  };
};
</script>

<div x-data="selectionBoard()" x-cloak
     @auth-magic-link-submit.window="requestMagicLink($event.detail.email, $event.detail.ageAttested); if ($event.detail) $event.detail.handled = true"
     @auth-wallet-hub-open.window="openWalletConnect($event.detail && $event.detail.ageAttested); if ($event.detail) $event.detail.handled = true"
     @auth-google-click.window="loginWithGoogle($event.detail && $event.detail.ageAttested); if ($event.detail) $event.detail.handled = true">

  <!-- Blur overlay (click to dismiss) -->
  <div x-show="selectionCount === <%= @contest.picks_required %> && !blurDismissed"
       @click="removeSelection(selectionOrder[selectionOrder.length - 1])"
       class="fixed inset-0 z-20 cursor-pointer"></div>

  <!-- Blurrable page content -->
  <div class="transition-all duration-300"
       :class="{ 'blur-sm select-none opacity-60': selectionCount === <%= @contest.picks_required %> && !blurDismissed }">

  <!-- Sort toggle + Matchup Cards -->
  <%
    # game_pairs is computed once up in the #board-config block (reused for the
    # pulse-target pool). Here we just need the flat turf_score sorts.
    matchups_asc = @matchups.sort_by { |m| m.turf_score || 999 }
    matchups_desc = matchups_asc.reverse
  %>
  <section class="mb-8 transition-all" :class="{ 'tm-sidebar-pushed': cartOpen }">
    <div class="flex items-center justify-between gap-2 mb-4">
      <div class="flex items-center gap-2">
        <% if multi_week %>
          <%# The multi-week board is one team-card grid ordered by span
              multiplier — there is no game view to sort against, so the toggle
              is replaced by the span label. %>
          <span class="text-sm text-muted font-medium">
            <%= @contest.week_span_label %> &middot; pick <%= @contest.picks_required %> teams
          </span>
        <% else %>
        <span class="text-sm text-muted font-medium">Sort by</span>
        <button @click="toggleSort('game')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all"
                :class="sortMode === 'game' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'game'">
          Game
        </button>
        <button @click="toggleSort('turfScore')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all flex items-center gap-1"
                :class="sortMode === 'turfScore' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'turfScore'">
          Advantage
          <span x-show="sortMode === 'turfScore'" x-text="sortDir === 'asc' ? '↑' : '↓'" class="text-xs"></span>
        </button>
        <% end %>
      </div>
      <div class="relative">
        <input type="text" x-model="filterText" placeholder="Filter teams..."
               class="input-field text-sm py-1.5 pl-3 pr-8 rounded-full" style="width:140px">
        <button x-show="filterText" @click="filterText = ''"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-secondary hover:text-heading transition text-lg leading-none">&times;</button>
      </div>
    </div>

    <!-- Game view: paired cards -->
    <% if multi_week %>
      <%# Multi-week board: ONE card per team, since the pick is a team riding
          every week. A game-paired view has no meaning here — the team plays a
          different opponent each week, so the pairing would be arbitrary. %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        <% span_team_cards.each do |matchup| %>
          <% opponents = span_opponents[matchup.team_slug] || [] %>
          <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(opponents.filter_map { |_s, wm| wm&.opponent_team&.name }.join(' ')) %>')">
            <%= render "contests/multi_week_team_card",
                  matchup: matchup,
                  multiplier: span_scores[matchup.team_slug],
                  opponents: opponents %>
          </div>
        <% end %>
      </div>
    <% else %>
    <div x-show="sortMode === 'game'" class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      <% game_pairs.each do |pair| %>
        <% left, right = pair %>
        <div x-show="matchesFilter('<%= j(left.team.name) %>', '<%= j(right.team.name) %>')">
          <%= render "contests/matchup_game_pair", left: left, right: right, locked: left.locked? %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, ascending -->
    <div x-show="sortMode === 'turfScore' && sortDir === 'asc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_asc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, descending -->
    <div x-show="sortMode === 'turfScore' && sortDir === 'desc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_desc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>
    <% end %>
  </section>

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8 transition-all" :class="{ 'tm-sidebar-pushed': cartOpen }">
      <div class="card shadow p-4 hover:shadow-lg hover:shadow-primary/10 transition-all max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-heading"><%= current_user.display_name %></p>
            <p class="text-sm text-secondary"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <%# display_balance is nil while the navbar cache is cold; show a
                neutral placeholder rather than crashing dollars(nil). This
                card is informational (cents precision) — no data-balance-display
                hook, since refreshBalance paints integer dollars into those. %>
            <p class="font-mono text-lg text-primary"><%= display_balance ? dollars(display_balance) : "$—" %></p>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  </div><!-- /blurrable -->

<%# Reopen FAB removed: the cart now opens on every pick-add and can no
    longer be dismissed while picks exist, so !cartOpen && selectionCount > 0
    is unreachable. %>

  <%# Cart Sidebar: Desktop (right panel). The shared sidebar primitive owns the
      fixed shell, nav-height positioning, transitions, and width. The cart
      keeps its no-close-until-clear behavior by omitting a close action. %>
  <% cart_actions_html = capture do %>
    <%# Clear-all chip — doubles as the count display and the close action:
        clearing every pick drops selectionCount to 0, which closes the cart
        (see clearSelections). Only renders once a pick exists. %>
    <button x-show="selectionCount > 0" @click="clearSelections()"
            class="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-surface-alt text-secondary hover:text-red-400 transition"
            aria-label="Clear all picks">
      Clear <span x-text="selectionCount"></span> / <%= @contest.picks_required %>
      <span class="text-sm leading-none">&times;</span>
    </button>
  <% end %>

  <% cart_body_html = capture do %>
    <%= render "contests/turf_totals_cart_slots" %>
  <% end %>

  <% cart_footer_html = capture do %>
    <div class="p-4 border-t border-subtle space-y-2">
      <% if @contest.locked? %>
        <%# Locked (derived time-gate or settled) — show a clear closed
            state instead of a dead Hold-to-Confirm. Reached e.g. when a
            magic-link signup finishes after the contest locks; the picks
            still rehydrate above so the user sees what they had. The
            server (Entry#confirm! + on-chain lock_timestamp) rejects late
            entries regardless; this just stops the misleading live button. %>
        <div class="w-full px-4 py-3 rounded-xl text-base font-bold bg-surface-alt text-muted text-center">
          🔒 Entries closed — this contest has locked
        </div>
      <% elsif edit_entry %>
        <%# Edit mode: plain Update button (no hold) + Cancel link. DB-only
            update, no on-chain signature required. %>
        <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
          <button type="button" @click="updateEntry()" :disabled="submitting"
                  class="w-full px-4 py-3 rounded-xl text-base font-bold bg-primary hover:bg-primary-700 disabled:bg-surface-alt disabled:text-muted text-white transition"
                  x-text="submitting ? 'Updating…' : 'Update Entry'"></button>
        </div>
        <button type="button" @click="cancelEdit()"
                class="w-full py-2 text-sm font-semibold text-secondary hover:text-heading transition">
          Cancel
        </button>
      <% else %>
        <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 2000,
          hold_id: "desktop",
          guard: "data.selectionCount === #{@contest.picks_required}",
          on_hold_start: "window.dispatchEvent(new CustomEvent('hold-funding-check'))",
          validate: "d.runHoldValidations()",
          validate_at: 750,
          on_success: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
          early_action: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
          early_action_at: 1500,
          early_action_guard: "d.contestOnchain && Alpine.store('session') && Alpine.store('session').isWeb3" %>
        </div>
        <%# Clear-all lives in the header chip ("Clear n / 6 x") now —
            no separate footer button needed. %>
      <% end %>
    </div>
  <% end %>

  <%= render "components/sidebar_panel",
        id: "entry-sidebar",
        title: "Your Picks",
        open: "cartOpen",
        actions_html: cart_actions_html,
        body_html: cart_body_html,
        footer_html: cart_footer_html,
        z_class: "z-40",
        aria_label: "Your picks" %>

  <%# Orb-glow CSS for the in-modal pack buttons (shared with the
      standalone /tokens/buy page via tokens/_pack_button). Rendered
      outside any modal x-if so the rules are in the DOM before the
      auth wizard mounts the buttons on first open. %>
  <%= render "tokens/pack_button_styles" %>

  <%# All auth/tokens/redirect modals moved to app/views/modals/_auth.html.erb,
      rendered through shared/_modal_host as the 'auth' modal id with internal
      step state. The board's show*() methods open the wizard at the right
      step; the wizard partial dispatches window events (auth-magic-link-submit,
      auth-wallet-hub-open, auth-google-click — the redirect step's CTA navigates
      through cta_redirect, no dispatch) that the selectionBoard root listens
      for (see x-data attribute above). %>

  <!-- Mobile spacer to prevent fixed cart from covering content -->
  <div x-show="selectionCount > 0" class="md:hidden" style="height:10rem"></div>

  <!-- Mobile Cart: Fixed bottom bar (hidden until first selection) -->
  <div x-show="selectionCount > 0"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden bg-surface border-t-2 border-strong rounded-t-xl px-4 py-3"
       style="position:fixed;bottom:0;left:0;right:0;z-index:9999;box-shadow:0 -6px 30px rgba(0,0,0,0.4)">
    <% if @contest.locked? %>
      <div class="w-full px-4 py-3 rounded-xl text-sm font-bold bg-surface-alt text-muted text-center mb-3">
        🔒 Entries closed
      </div>
    <% elsif edit_entry %>
      <%# Edit mode: plain Update button (no hold) + Cancel link. DB-only
          update, no on-chain signature required. %>
      <div x-show="selectionCount === <%= @contest.picks_required %>" class="mb-3">
        <button type="button" @click="updateEntry()" :disabled="submitting"
                class="w-full px-4 py-3 rounded-xl text-base font-bold bg-primary hover:bg-primary-700 disabled:bg-surface-alt disabled:text-muted text-white transition"
                x-text="submitting ? 'Updating…' : 'Update Entry'"></button>
      </div>
    <% else %>
    <div x-show="selectionCount === <%= @contest.picks_required %>" class="mb-5">
      <%= render 'shared/hold_button',
        default_text: "Hold to Confirm",
        hold_text: "Almost there...",
        success_text: "Confirmed!",
        duration: 2000,
        hold_id: "mobile",
        guard: "data.selectionCount === #{@contest.picks_required}",
        on_hold_start: "window.dispatchEvent(new CustomEvent('hold-funding-check'))",
        validate: "d.runHoldValidations()",
        validate_at: 750,
        on_success: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
        early_action: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
        early_action_at: 1500,
        early_action_guard: "d.contestOnchain && Alpine.store('session') && Alpine.store('session').isWeb3" %>
    </div>
    <% end %>
    <p x-show="selectionCount < <%= @contest.picks_required %>" class="text-heading font-bold text-sm text-center mb-3">Your Picks</p>
    <div class="grid grid-cols-3 gap-1.5">
      <template x-for="i in <%= @contest.picks_required %>" :key="i">
        <div>
          <template x-if="selectionSlots[i-1]">
            <div class="bg-surface-alt rounded-md px-1.5 py-1 border border-primary-700 text-center relative" style="min-height:2.75rem">
              <p class="text-heading font-semibold text-xs truncate" x-text="selectionSlots[i-1].emoji + ' ' + selectionSlots[i-1].name"></p>
              <p class="text-muted text-[10px] truncate">vs <span x-text="selectionSlots[i-1].opName"></span> <span class="text-primary font-mono" x-text="'x' + selectionSlots[i-1].turfScore"></span></p>
              <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                      class="absolute -top-1 -right-1 w-4 h-4 bg-surface border border-strong rounded-full text-muted hover:text-red-400 text-[10px] leading-none flex items-center justify-center">&times;</button>
            </div>
          </template>
          <template x-if="!selectionSlots[i-1]">
            <div class="border border-dashed border-strong rounded-md px-1.5 py-1 text-center flex items-center justify-center"
                 :class="i === selectionCount + 1 ? (i === <%= @contest.picks_required %> ? (pickUrgent ? 'pick-pulse-urgent' : 'pick-pulse-shimmer') : (i === 2 ? 'pick-pulse-shimmer' : 'pick-pulse')) : ''"
                 style="min-height:2.75rem">
              <p class="text-[10px]" :class="i === selectionCount + 1 ? 'text-secondary' : 'text-muted'">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <% if edit_entry %>
      <button type="button" @click="cancelEdit()" class="w-full text-center text-xs font-semibold text-secondary hover:text-heading transition mt-2">
        Cancel
      </button>
    <% else %>
      <button @click="clearSelections()" class="w-full text-center text-xs font-semibold text-secondary hover:text-red-400 transition mt-2">
        Clear <span x-text="selectionCount"></span> / <%= @contest.picks_required %>
      </button>
    <% end %>
  </div>

  <!-- JSON Debug Block -->
  <section class="transition-all" :class="{ 'tm-sidebar-pushed': cartOpen }">
    <%= render "components/json_debug", record: @contest.as_json.merge("slate_matchups" => @matchups.as_json(methods: [:locked?]), "entries" => contest_debug_entries(@entries)), label: "Contest JSON", collapsible: true %>
  </section>

</div>

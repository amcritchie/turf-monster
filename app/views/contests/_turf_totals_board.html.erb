<%
  cart_selections = {}
  cart_selection_order = []
  edit_entry = local_assigns[:edit_entry]
  source_entry = edit_entry || @cart_entry

  if source_entry
    source_entry.selections.order(:created_at, :id).each do |s|
      cart_selections[s.slate_matchup_id.to_s] = true
      cart_selection_order << s.slate_matchup_id.to_s
    end
  end

  # Edit mode: auto-drop the most-recently-added pick to land in
  # `picks_required - 1` state. Mirrors the create-mode blur-overlay
  # drop (further below) and forces a meaningful change rather than
  # a no-op confirm.
  if edit_entry && cart_selection_order.any?
    dropped = cart_selection_order.pop
    cart_selections.delete(dropped)
  end
%>

<style>
  /* Sidebar push cascade — reserves room for the 320px "Your Picks"
     sidebar when it's open, stepping down from full push at md to full
     overlay at 1749px+ so the matchup grid eases out of the sidebar's
     path as the viewport widens. Toggled via :class="{ 'cart-pushed':
     cartOpen }" on each board section below. Local to this partial. */
  @media (min-width:  768px) { .cart-pushed { margin-right: 20rem; } } /* 100% (320px) */
  @media (min-width: 1344px) { .cart-pushed { margin-right: 15rem; } } /*  75% (240px) */
  @media (min-width: 1479px) { .cart-pushed { margin-right: 10rem; } } /*  50% (160px) */
  @media (min-width: 1614px) { .cart-pushed { margin-right:  5rem; } } /*  25%  (80px) */
  @media (min-width: 1749px) { .cart-pushed { margin-right:    0; } } /*   0% (overlay) */
</style>

<script type="application/json" id="board-config">
<%
  matchup_data = {}
  @matchups.each do |m|
    matchup_data[m.id.to_s] = {
      name: m.team.name,
      emoji: m.team.emoji,
      opName: m.opponent_team&.short_name.to_s,
      turfScore: m.turf_score ? sprintf("%.1f", m.turf_score) : "\u2014",
      locked: m.locked?
    }
  end
%>
<%#
  Contest/cart data only. Auth + wallet state (loggedIn, mode, userId,
  address) comes from the canonical #session-context / $store.session —
  see application.html.erb. Kept here: userEmail (a display value).
%>
<%= {
  matchupData: matchup_data,
  cartSelections: cart_selections,
  cartSelectionOrder: cart_selection_order,
  contestSlug: @contest&.slug,
  entryFeeCents: @contest.entry_fee_cents || 0,
  contestOnchain: @contest.onchain?,
  contestName: @contest.name,
  picksRequired: @contest.picks_required,
  userEmail: current_user&.email.to_s,
  seedsPerLevel: User::SEEDS_PER_LEVEL,
  pendingRecoveryPtxSlug: @pending_recovery_ptx&.slug,
  mode: edit_entry ? "edit" : "create",
  editEntrySlug: edit_entry&.slug
}.to_json.html_safe %>
</script>

<script>
// selectionBoard — MUST be inline because Alpine processes x-data before importmap modules load.
// Reads config from #board-config JSON element above.
window.selectionBoard = function() {
  var configEl = document.getElementById('board-config');
  if (!configEl) { console.error('board-config element not found'); return {}; }
  var cfg = JSON.parse(configEl.textContent);

  var matchupData = cfg.matchupData;

  return {
    selections: cfg.cartSelections,
    selectionOrder: cfg.cartSelectionOrder,
    cartOpen: Object.keys(cfg.cartSelections).length > 0 || cfg.mode === 'edit',
    blurDismissed: false,
    mode: cfg.mode || 'create',
    editEntrySlug: cfg.editEntrySlug || null,
    get isEditMode() { return this.mode === 'edit'; },
    shakeKey: 0,
    submitting: false,
    error: null,
    errorTimer: null,
    contestId: cfg.contestSlug,
    csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
    // Auth/wallet state is read live from the canonical Alpine.store('session')
    // (see application.html.erb) — never copied here, so it can't go stale.
    get loggedIn() { var s = Alpine.store('session'); return s ? s.loggedIn : false; },
    entryFeeCents: cfg.entryFeeCents,
    userEmail: cfg.userEmail || '',
    contestOnchain: cfg.contestOnchain,
    contestName: cfg.contestName,
    picksRequired: cfg.picksRequired,
    sortMode: 'game',
    sortDir: 'asc',
    filterText: '',
    pickUrgent: false,
    // ALL of the auth/signup/tokens/redirect modal state has moved to
    // Alpine.store('modals') under modal id 'auth'. The wizard partial
    // (modals/_auth.html.erb) drives off props.step, and this board's
    // network methods read/write props on $store.modals.current(). The
    // form fields (email, password) live in the wizard partial's own
    // x-data. Helper methods _wizardOpen / _wizardStep / _wizardProps
    // below wrap the store access so call sites stay readable.
    profileModal: false,
    profileUsername: '',
    profileError: '',
    profileSubmitting: false,
    signupMethod: '',

    init() {
      // Stripe checkout runs in a NEW TAB (see the buy-tokens panel). When
      // Stripe returns the buyer to /tokens/processing, that page signals
      // back here — the entire "Confirming your purchase…" + success UI
      // lives in this modal so the buyer never visually leaves the contest.
      //
      // We listen on TWO channels because browsers may have dropped
      // window.opener on the new tab (implicit noopener on target=_blank
      // forms): a BroadcastChannel (modern, opener-independent) and the
      // classic window message event (legacy fallback).
      var board = this;
      var handleTokenSignal = function (data) {
        if (!data || data.source !== 'tt-tokens') return;
        var modals = Alpine.store('modals');
        var cur = modals.current();
        var curStep = (cur && cur.id === 'auth') ? cur.props.step : null;
        console.log('[tokens] board.handleTokenSignal received', { status: data.status, sessionId: data.sessionId, curModalId: cur && cur.id, curStep: curStep });

        if (data.status === 'returned' && data.sessionId) {
          // De-dupe: both channels may deliver the same signal.
          if (curStep === 'tokens-confirming' || curStep === 'tokens-minted') {
            console.log('[tokens] board.handleTokenSignal de-duped — already at', curStep);
            return;
          }
          // Stamp the moment the spinner went on screen — pollTokenStatus
          // awaits this minimum before the success swap so the spinner
          // doesn't flash by when the webhook beats the modal mounting.
          board._confirmingHold = window.StudioModals.holdAtLeast(1500);
          var freshProps = {
            step:          'tokens-confirming',
            errorText:     '',
            mintedCount:   0,
            mintedBalance: 0,
            redirectUrl:   '',
            txSignature:   ''
          };
          if (cur && cur.id === 'auth') {
            console.log('[tokens] board → reusing open auth modal, flipping step to tokens-confirming');
            Object.assign(cur.props, freshProps);
          } else {
            console.log('[tokens] board → no auth modal open, opening fresh at tokens-confirming');
            modals.open('auth', freshProps);
          }
          board.pollTokenStatus(data.sessionId);
          return;
        }

        if (data.status === 'minted') {
          console.log('[tokens] board.handleTokenSignal: legacy "minted" — closing modal, resetting holds');
          // Legacy fallback — the new tab fully completed the mint. Close
          // the modal and let the user do a fresh Hold to Confirm; we no
          // longer auto-submit the entry. (The pendingCheckEmail nudge
          // fires after the user's confirmEntry success path.)
          if (cur && cur.id === 'auth') modals.close();
          try { board.resetHoldButtons(); } catch (_) {}
        }
      };

      window.addEventListener('message', function (e) {
        if (e.origin !== window.location.origin) {
          if (e.data && e.data.source === 'tt-tokens') {
            console.warn('[tokens] board: dropped postMessage from wrong origin', e.origin);
          }
          return;
        }
        if (e.data && e.data.source === 'tt-tokens') {
          console.log('[tokens] board ← window.message channel');
        }
        handleTokenSignal(e.data);
      });

      try {
        if ('BroadcastChannel' in window) {
          board._tokensChannel = new BroadcastChannel('tt-tokens');
          board._tokensChannel.onmessage = function (e) {
            console.log('[tokens] board ← BroadcastChannel(tt-tokens)');
            handleTokenSignal(e.data);
          };
          console.log('[tokens] board: BroadcastChannel(tt-tokens) listener attached');
        } else {
          console.warn('[tokens] board: BroadcastChannel unsupported — relying on window.postMessage only');
        }
      } catch (e) {
        console.error('[tokens] board: BroadcastChannel listener attach failed', e);
      }

      // Hold-to-Confirm dispatch listener — the shared hold_button
      // partial fires this window event regardless of which DOM scope
      // it lives in. The auth-modal version of the button can't reach
      // d.confirmEntry() through el.closest('[x-data]') (that resolves
      // to the auth wizard's data, not the board's), so we route both
      // the in-board AND in-modal holds through this single channel.
      window.addEventListener('hold-confirm-entry', function () {
        // confirmEntry is async — a synchronous try/catch won't catch a
        // rejected promise. Tail with .catch so a failure in the entry
        // submission surfaces in the console instead of silently
        // freezing the hold button at "Almost there…".
        Promise.resolve()
          .then(function () { return board.confirmEntry(); })
          .catch(function (e) { console.error('[hold-confirm-entry] confirmEntry rejected:', e); });
      });

      // Reopen the post-signup step after submitProfile()'s reload —
      // Google → buy entry tokens; email → check your email.
      try {
        var stepRaw = sessionStorage.getItem('pendingAuthStep');
        if (stepRaw) {
          var step = JSON.parse(stepRaw);
          sessionStorage.removeItem('pendingAuthStep');
          if (step && step.contestSlug === this.contestId) {
            if (step.step === 'tokens') this.showTokensPanel();
            if (step.step === 'check-email') this.sendVerificationEmail();
          }
        }
      } catch (e) {
        try { sessionStorage.removeItem('pendingAuthStep'); } catch (_) {}
      }

      // Restore guest cart that was saved before an external auth redirect
      // (e.g. Google OAuth). Only replay when we're now logged in AND the
      // saved cart matches this contest. Auto-enter when the saved intent
      // included it.
      try {
        var raw = sessionStorage.getItem('pendingContestEntry');
        if (!raw) return;
        var pending = JSON.parse(raw);
        if (!pending || pending.contestSlug !== this.contestId) return;
        sessionStorage.removeItem('pendingContestEntry');

        // Hydrate Alpine cart state from saved selections
        if (pending.selections && Object.keys(pending.selections).length > 0) {
          this.selections = pending.selections;
          this.selectionOrder = pending.selectionOrder || Object.keys(pending.selections);
          this.cartOpen = true;
        }

        if (this.loggedIn && pending.autoEnter && this.selectionCount === this.picksRequired) {
          var self = this;
          // Let Alpine flush the state, then replay + enter
          setTimeout(function() { self.afterLoginSuccess(); }, 50);
        }
      } catch (e) {
        // Bad JSON or sessionStorage unavailable — quietly skip
        try { sessionStorage.removeItem('pendingContestEntry'); } catch (_) {}
      }

      // Stranded on-chain entry recovery. Server populates
      // cfg.pendingRecoveryPtxSlug when this user has a pending/submitted
      // PendingTransaction targeting one of their cart entries on this
      // contest — i.e. they signed an entry TX last session, refreshed
      // mid-flight, and we need to either auto-promote (TX landed) or
      // release (TX failed) the stranded entry.
      if (cfg.pendingRecoveryPtxSlug) {
        setTimeout(function () { self.recoverPendingEntry(cfg.pendingRecoveryPtxSlug); }, 200);
      }
    },

    async recoverPendingEntry(ptxSlug) {
      var modal = Alpine.store('solanaModal');
      modal.show('Checking Your Last Entry', 'Looking up your previous on-chain transaction…', { dismissible: false });
      var maxAttempts = 6;     // ~30s of wall time with the 5s polling cadence
      var attempts = 0;
      while (attempts < maxAttempts) {
        attempts++;
        try {
          var resp = await window.authedFetch('/contests/' + this.contestId + '/recover_pending_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ ptx_slug: ptxSlug })
          });
          if (!resp) return; // 401 — authedFetch already opened the login modal
          var data = await resp.json();
          if (data.status === 'confirmed') {
            modal.success(data.tx_signature, "You're in! Good luck.");
            if (data.redirect) modal.onClose = function () { window.location.href = data.redirect; };
            return;
          }
          if (data.status === 'failed' || data.status === 'error' || data.status === 'missing') {
            modal.close();
            if (data.error) {
              try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: 'Entry not recovered', message: data.error, duration: 6000 } })); } catch (_) {}
            }
            return;
          }
          // status === 'processing' — wait then poll again.
        } catch (_) {
          // Network blip — keep polling.
        }
        await new Promise(function (r) { setTimeout(r, 5000); });
      }
      // Out of attempts. Leave the PT in submitted; admin can resolve.
      modal.close();
      try { window.dispatchEvent(new CustomEvent('toast', { detail: { type: 'alert', title: "Couldn't confirm last entry yet", message: "We'll keep watching — reload in a minute to retry.", duration: 6000 } })); } catch (_) {}
    },

    toggleSort(mode) {
      if (mode === 'turfScore' && this.sortMode === 'turfScore') {
        this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        this.sortMode = mode;
        this.sortDir = 'asc';
      }
    },

    matchesFilter: function() {
      var names = Array.from(arguments);
      if (!this.filterText) return true;
      var q = this.filterText.toLowerCase();
      return names.some(function(n) { return n.toLowerCase().includes(q); });
    },

    get selectionCount() {
      return Object.keys(this.selections).length;
    },

    get selectionSlots() {
      return this.selectionOrder.filter(id => this.selections[id]).map(matchupId => ({
        matchupId: matchupId,
        name: matchupData[matchupId]?.name || matchupId,
        emoji: matchupData[matchupId]?.emoji || '',
        opName: matchupData[matchupId]?.opName || '',
        turfScore: matchupData[matchupId]?.turfScore || ''
      }));
    },

    toggleSelection(matchupId) {
      if (matchupData[matchupId]?.locked) return;

      var oldSelections = Object.assign({}, this.selections);
      var oldOrder = this.selectionOrder.slice();

      if (this.selections[matchupId]) {
        var wasFull = this.selectionCount === this.picksRequired;
        var newSelections = Object.assign({}, this.selections);
        delete newSelections[matchupId];
        this.selections = newSelections;
        this.selectionOrder = this.selectionOrder.filter(function(id) { return id !== matchupId; });
        this.blurDismissed = false;
        if (wasFull) this.pickUrgent = true;
        if (this.selectionCount === 0) this.cartOpen = false;
      } else if (this.selectionCount < this.picksRequired) {
        this.selections = Object.assign({}, this.selections, { [matchupId]: true });
        this.selectionOrder = this.selectionOrder.concat([matchupId]);
        if (this.selectionCount === this.picksRequired) this.pickUrgent = false;
        if (!this.cartOpen) this.cartOpen = true;
        this.triggerShake(matchupId);
      } else {
        // Replace oldest
        var removedId = this.selectionOrder[0];
        var newSel = Object.assign({}, this.selections);
        delete newSel[removedId];
        newSel[matchupId] = true;
        this.selections = newSel;
        this.selectionOrder = this.selectionOrder.slice(1).concat([matchupId]);
        this.blurDismissed = false;
        this.triggerShake(matchupId);
      }

      // Edit mode: picks are staged client-side and committed atomically by
      // updateEntry() on the Update click. Skip the per-toggle server hit so
      // we never leave a partially-updated active entry mid-edit.
      if (this.isEditMode) return;

      if (!this.loggedIn) return;

      var self = this;
      window.authedFetch('/contests/' + this.contestId + '/toggle_selection', {
        method: 'POST',
        headers: {
          'X-CSRF-Token': this.csrfToken,
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ matchup_id: matchupId })
      })
      .then(function(resp) {
        if (!resp) { self.selections = oldSelections; self.selectionOrder = oldOrder; return null; }
        return resp.json().then(function(data) { return { ok: resp.ok, data: data }; });
      })
      .then(function(result) {
        if (!result) return;
        if (!result.ok) {
          self.selections = oldSelections;
          self.selectionOrder = oldOrder;
          self.showError(result.data.error || 'Failed to save selection');
        }
      })
      .catch(function() {
        self.selections = oldSelections;
        self.selectionOrder = oldOrder;
        self.showError('Network error. Selection not saved.');
      });
    },

    removeSelection(matchupId) {
      this.toggleSelection(matchupId);
    },

    triggerShake(matchupId) {
      this.shakeKey++;
      this._shakeMatchupId = matchupId;
      var self = this;
      setTimeout(function() { self._shakeMatchupId = null; }, 400);
    },

    isShaking(matchupId) {
      return this._shakeMatchupId === matchupId;
    },

    // Server-error → blocker dispatcher used by every entry-flow JSON
    // response (enter, prepare_entry, confirm_onchain_entry). Returns true
    // iff the response carried a structured blocker and routing happened;
    // the caller bails on true so the generic error UI doesn't fire on
    // top of the modal. Closes solanaModal if it's mid-flight so the
    // blocker modal isn't stacked underneath an on-chain-tx card.
    _handleBlockerResponse(data) {
      if (!data || !data.blocker) return false;
      if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
      this.submitting = false;
      this.showEligibilityBlockerModal(data.blocker);
      return true;
    },

    // Dispatch entry-eligibility blocker → appropriate modal. Driven by
    // window.eligibilityBlocker (see solana_utils.js) — runs synchronously
    // off $store.session right after the loggedIn check. Same dispatcher
    // is reused by the post-execution error interpreter (Layer 2) so the
    // user sees identical UX whether the block was caught pre-flight or
    // surfaced from the chain.
    showEligibilityBlockerModal(blocker) {
      if (!blocker) return;
      switch (blocker.reason) {
        case 'not_logged_in':        this.showLoginModal(); break;
        case 'no_tokens':            this.showTokensPanel(); break;
        case 'insufficient_balance': this.showInsufficientBalanceModal(blocker); break;
        default:                     this.resetHoldButtons();
      }
    },

    // Open the standalone wallet-deposit modal. Hands the blocker's data
    // through as props so the modal can render the shortfall + needed
    // amount. Layer 2 (interpreter) doesn't know the client's current
    // balances, so we fall back to $store.session — that way the modal
    // always shows real numbers regardless of which layer triggered it.
    showInsufficientBalanceModal(blocker) {
      this.resetHoldButtons();
      var d = (blocker && blocker.data) || {};
      var sess = Alpine.store('session');
      Alpine.store('modals').open('wallet-deposit', {
        neededCents: d.neededCents | 0,
        usdcCents:   (d.usdcCents !== undefined ? d.usdcCents : (sess ? sess.usdcCents : 0)) | 0,
        usdtCents:   (d.usdtCents !== undefined ? d.usdtCents : (sess ? sess.usdtCents : 0)) | 0
      });
    },

    // Open the auth wizard at the credentials step (signup mode default).
    // The wizard partial's own x-data owns the email/password fields;
    // submit/error state for the network attempts lives on props so the
    // board's async methods can update them.
    showLoginModal() {
      // Drop any hold-button error state ("Entry Blocked") so the button is
      // back to its default while the user signs in.
      this.resetHoldButtons();
      Alpine.store('modals').open('auth', {
        step:          'credentials',
        mode:          'signup',
        submitting:    null,    // null | 'signup' | 'login' | 'phantom' | 'google'
        formError:     '',
        phantomError:  '',
        googleError:   ''
      });
    },

    // Persist current cart so it survives an external redirect (Google OAuth,
    // /login fallback). Hydrated by init() after the user returns.
    saveCartForRedirect(autoEnter) {
      try {
        sessionStorage.setItem('pendingContestEntry', JSON.stringify({
          contestSlug: this.contestId,
          selections: this.selections,
          selectionOrder: this.selectionOrder,
          autoEnter: !!autoEnter
        }));
      } catch (e) { /* sessionStorage unavailable — fall through */ }
    },

    // Helper — read the auth wizard's props off the store, or null if the
    // wizard isn't open. Used by every method that wants to mutate display
    // state without leaving stale fields on the board.
    _authProps() {
      var c = Alpine.store('modals').current();
      return (c && c.id === 'auth') ? c.props : null;
    },

    // Inline signup — creates the account and transitions the page IN
    // PLACE (no reload). Hydrates $store.session, swaps the navbar HTML,
    // replays the cart, then mutates the wizard's step to 'tokens-picker'
    // so the user goes straight from "Creating account…" to the pack
    // picker without any modal close/reopen flicker. Called from the
    // wizard partial via the 'auth-signup-submit' dispatch.
    async submitInlineSignup(email, password) {
      var p = this._authProps();
      if (!p || p.submitting) return;
      p.formError = '';
      if (!email || !password) {
        p.formError = 'Email and password are required.';
        return;
      }
      p.submitting = 'signup';
      try {
        var resp = await fetch('/registrations/inline', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ email: email, password: password })
        });
        var data = await resp.json();
        if (!resp.ok || !data.success) {
          p.formError = data.error || 'Could not create account.';
          p.submitting = null;
          return;
        }

        // Hydrate session, swap navbar, sync body[data-logged-in].
        var sess = Alpine.store('session');
        if (sess && data.session) { sess.hydrate(data.session); }
        if (data.navbar_html) {
          var oldNav = document.querySelector('header[data-navbar-root]');
          if (oldNav) {
            var tmp = document.createElement('div');
            tmp.innerHTML = data.navbar_html.trim();
            var newNav = tmp.firstElementChild;
            if (newNav) {
              oldNav.replaceWith(newNav);
              if (window.Alpine && Alpine.initTree) { Alpine.initTree(newNav); }
            }
          }
        }
        try { document.body.setAttribute('data-logged-in', 'true'); } catch (_) {}

        // Persist the cart server-side so it survives the Stripe detour.
        await this.replaySelectionsToServer();

        // Queue the "check your email" nudge to fire AFTER the entry is
        // confirmed (consumed in confirmEntry).
        try { sessionStorage.setItem('pendingCheckEmail', this.contestId); }
        catch (e) { /* sessionStorage unavailable */ }

        // Patch the current modal entry with the same directional slide
        // the host runs for swap() — credentials exits stage-right, the
        // picker enters stage-left. advance() (instead of swap()) keeps
        // the same stack entry so the auth modal's outer x-data scope
        // — including the email/password fields the user just typed —
        // survives the transition. The patch resets the form-flow flags
        // so the picker step starts clean; props not listed (mode, etc.)
        // are preserved.
        Alpine.store('modals').advance({
          step:          'tokens-picker',
          submitting:    null,
          formError:     '',
          phantomError:  '',
          googleError:   '',
          mintedCount:   0,
          mintedBalance: 0,
          errorText:     '',
          redirectUrl:   '',
          txSignature:   ''
        });
      } catch (e) {
        p.formError  = 'Network error. Try again.';
        p.submitting = null;
      }
    },

    async submitInlineLogin(email, password) {
      var p = this._authProps();
      if (!p || p.submitting) return;
      p.formError = '';
      if (!email || !password) {
        p.formError = 'Email and password are required.';
        return;
      }
      p.submitting = 'login';
      try {
        var resp = await fetch('/sessions/inline', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ email: email, password: password })
        });
        var data = await resp.json();
        if (!resp.ok || !data.success) {
          p.formError = data.error || 'Login failed.';
          p.submitting = null;
          return;
        }
        // Reload so the navbar + server-rendered logged-in sections
        // reflect the session. Cart is restored on load (see init()).
        this.saveCartForRedirect(true);
        window.location.reload();
      } catch (e) {
        p.formError  = 'Network error. Try again.';
        p.submitting = null;
      }
    },

    async loginWithPhantom() {
      var p = this._authProps();
      if (!p) return;
      p.phantomError = '';
      if (!window.walletProvider || !window.walletProvider.isAvailable()) {
        if (window.walletProvider && window.walletProvider.isMobile()) {
          // Save cart, then deep-link to Phantom — user returns via callback
          this.saveCartForRedirect(true);
          if (typeof startPhantomDeepLink === 'function') startPhantomDeepLink(false);
          return;
        }
        p.phantomError = 'Phantom not detected. Install the Phantom browser extension or open in the Phantom mobile app.';
        return;
      }

      p.submitting = 'phantom';
      try {
        var provider = window.walletProvider.detect();
        var connectResp = await provider.connect();
        var pubkeyB58 = connectResp.publicKey.toBase58();

        var nonceResp = await fetch('/auth/solana/nonce');
        var nonceData = await nonceResp.json();
        var domain = window.location.host;
        var sessUid = (Alpine.store('session') || {}).userId;
        var userIdLine = sessUid ? ('User-ID: ' + sessUid + '\n\n') : '';  // OPSEC-005
        var message = domain + ' wants you to sign in with your Solana account:\n' + pubkeyB58 + '\n\n' + userIdLine + 'Nonce: ' + nonceData.nonce;
        var encoded = new TextEncoder().encode(message);
        var signed = await provider.signMessage(encoded, 'utf8');
        var signatureB58 = encodeBase58(signed.signature);

        var verifyResp = await fetch('/auth/solana/verify', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ message: message, signature: signatureB58, pubkey: pubkeyB58 })
        });
        var verifyData = await verifyResp.json();
        if (!verifyResp.ok || !verifyData.success) {
          throw new Error(verifyData.error || 'Wallet verification failed.');
        }

        // Reload so the navbar + server-rendered logged-in UI reflect the
        // wallet session. Cart is restored on load (see init()).
        this.saveCartForRedirect(true);
        window.location.reload();
      } catch (e) {
        var msg = e.message || 'Phantom sign-in failed.';
        if (typeof parseSolanaError === 'function') msg = parseSolanaError(msg);
        // Re-fetch props in case the modal closed during the await.
        var p2 = this._authProps();
        if (p2) { p2.phantomError = msg; p2.submitting = null; }
      }
    },

    // Google sign-in via a popup window so the contest page stays put.
    // The popup hits /auth/google_popup, runs the OAuth round-trip, and
    // the callback renders a closer page that postMessages the result
    // back here and closes itself.
    loginWithGoogle() {
      var p = this._authProps();
      if (!p) return;
      p.googleError = '';
      // window.open must run synchronously inside the click handler, or the
      // browser blocks it.
      var popup = window.open('/auth/google_popup', 'tt_google_oauth',
        'width=500,height=650,menubar=no,toolbar=no,location=no');
      if (!popup) {
        // Popup blocked — fall back to the full-page redirect.
        this.googleFullPageRedirect();
        return;
      }
      p.submitting = 'google';
      var self = this;
      var pollTimer = null;

      var onMessage = function(e) {
        if (e.origin !== window.location.origin) return;
        if (!e.data || e.data.source !== 'tt-oauth') return;
        window.removeEventListener('message', onMessage);
        if (pollTimer) clearInterval(pollTimer);
        var p2 = self._authProps();
        if (p2) p2.submitting = null;
        try { popup.close(); } catch (_) {}

        if (e.data.status === 'success') {
          var gSess = Alpine.store('session');
          if (gSess) { gSess.loggedIn = true; gSess.mode = 'web2'; }
          // Username is auto-assigned at signup — no profile step.
          self.saveCartForRedirect(true);
          window.location.reload();
        } else if (p2) {
          p2.googleError = e.data.error || 'Google sign-in failed.';
        }
      };
      window.addEventListener('message', onMessage);

      // If the user dismisses the popup without finishing, stop waiting.
      pollTimer = setInterval(function() {
        if (popup.closed) {
          clearInterval(pollTimer);
          window.removeEventListener('message', onMessage);
          var p3 = self._authProps();
          if (p3) p3.submitting = null;
        }
      }, 500);
    },

    // Fallback when the OAuth popup is blocked — full-page redirect. Save the
    // cart first so the entry resumes when the user returns.
    googleFullPageRedirect() {
      this.saveCartForRedirect(true);
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/auth/google_oauth2';
      var csrf = document.createElement('input');
      csrf.type = 'hidden';
      csrf.name = 'authenticity_token';
      csrf.value = this.csrfToken;
      form.appendChild(csrf);
      document.body.appendChild(form);
      form.submit();
    },

    // Replay the in-memory guest cart to the server as a persisted cart
    // entry, so the 6 picks survive a detour (Stripe checkout, the email
    // confirm link). Returns false if a selection failed to save.
    async replaySelectionsToServer() {
      var ids = this.selectionOrder.slice();
      for (var i = 0; i < ids.length; i++) {
        try {
          var resp = await window.authedFetch('/contests/' + this.contestId + '/toggle_selection', {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ matchup_id: parseInt(ids[i], 10) })
          });
          if (!resp || !resp.ok) return false;
        } catch (e) { return false; }
      }
      return true;
    },

    // Open (or transition the wizard to) the buy-tokens picker step.
    // Called after Google signup, after the "out of entry tokens" error,
    // and from the pendingAuthStep restore in init(). Two paths:
    //   - Empty stack (cold open from navbar / direct CTA) → open() pushes
    //     a fresh auth entry and the host's default mount animation plays.
    //   - Auth wizard already on a different step (post-signup, post-
    //     confirm-error) → advance() patches props in place and the
    //     directional slide runs.
    showTokensPanel() {
      this.profileModal = false;
      var s   = Alpine.store('modals');
      var cur = s.current();
      var props = {
        step:          'tokens-picker',
        mintedCount:   0,
        mintedBalance: 0,
        errorText:     '',
        redirectUrl:   '',
        txSignature:   ''
      };
      if (cur && cur.id === 'auth') {
        s.advance(props);
      } else {
        s.open('auth', props);
      }
    },


    // Poll /tokens/status until the Stripe webhook + TokenPurchaseJob
    // finish minting. Drives the wizard through tokens-confirming →
    // tokens-minted. Called from the BroadcastChannel / window message
    // listener when the new tab hands the session_id back. Mutates the
    // auth wizard's props on the store; safely no-ops if the modal was
    // closed mid-poll.
    pollTokenStatus(sessionId) {
      var self = this;
      var elapsedMs = 0;
      var intervalMs = 1500;
      var timeoutMs = 45000;
      var attempt = 0;
      console.log('[tokens] pollTokenStatus.start sessionId=', sessionId, 'intervalMs=', intervalMs, 'timeoutMs=', timeoutMs);
      var tick = async function () {
        attempt++;
        try {
          var r = await fetch('/tokens/status?session_id=' + encodeURIComponent(sessionId), {
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin'
          });
          if (r.ok) {
            var d = await r.json();
            console.log('[tokens] pollTokenStatus attempt=' + attempt + ' /tokens/status →', d);
            if (d.ready) {
              console.log('[tokens] pollTokenStatus: READY — awaiting min-visible hold then flipping to tokens-minted');
              // The hold was started when the 'returned' signal arrived
              // (window.StudioModals.holdAtLeast(1500) — see init's
              // handleTokenSignal). Awaits the min-visible duration
              // before swapping the spinner to the minted state.
              var hold = self._confirmingHold || window.StudioModals.holdAtLeast(0);
              hold.then(function () {
                var p = self._authProps();
                if (!p) {
                  console.warn('[tokens] pollTokenStatus: modal closed before mint readyswap — no-op');
                  return;
                }
                console.log('[tokens] pollTokenStatus: step → tokens-minted, mintedCount=', d.minted, 'balance=', d.balance);
                // advance() patches props + runs the host's directional
                // slide. The minted-state values land alongside the step
                // change so the new card renders with the right data
                // during slide-in.
                Alpine.store('modals').advance({
                  mintedCount:   d.minted,
                  mintedBalance: d.balance,
                  step:          'tokens-minted'
                });
                // Push the new token count to the navbar + celebrate
                // the mint. The badge punches (scale+wobble) so the
                // user catches the new 🎟️ in their peripheral vision,
                // and the confetti burst is positioned to shoot out
                // of it. A second burst fires later when the entry
                // actually confirms ('tokens-submitted').
                try { if (window.updateNavTokens) window.updateNavTokens(d.balance); } catch (_) {}
                // Also mirror the new count into $store.session so the
                // next confirmEntry()'s eligibilityBlocker reads fresh
                // state. updateNavTokens only touches the DOM badge;
                // the synchronous hold-time check reads from the Alpine
                // store directly (window.eligibilityBlocker in solana_utils.js).
                try {
                  var sess = window.Alpine && Alpine.store && Alpine.store('session');
                  if (sess) sess.tokensAvailable = parseInt(d.balance, 10) || 0;
                } catch (_) {}
                try { if (window.animateFreeEntryBadge) setTimeout(window.animateFreeEntryBadge, 60); } catch (_) {}
                try { if (window.fireConfettiFromBadge) setTimeout(window.fireConfettiFromBadge, 180); } catch (_) {}
              });
              // The modal STAYS OPEN in 'tokens-minted' — it renders the
              // in-modal Hold to Confirm Entry button. On success → step
              // 'tokens-submitted' (set in confirmEntry).
              return;
            }
          } else {
            console.warn('[tokens] pollTokenStatus attempt=' + attempt + ' /tokens/status non-OK', r.status);
          }
        } catch (e) {
          console.warn('[tokens] pollTokenStatus attempt=' + attempt + ' fetch error (will retry)', e);
        }

        elapsedMs += intervalMs;
        if (elapsedMs >= timeoutMs) {
          console.error('[tokens] pollTokenStatus TIMEOUT after', elapsedMs, 'ms — flipping to tokens-error');
          var p2 = self._authProps();
          if (p2) {
            p2.errorText = "Payment cleared but the on-chain mint is still settling. Refresh in a moment to finish your entry.";
            p2.step      = 'tokens-error';
          }
          return;
        }
        setTimeout(tick, intervalMs);
      };
      tick();
    },

    // Email signup — request a verification email (its link returns the
    // user to this contest) and open the "check your email" modal through
    // the generic Alpine.store('modals') stack. Resend is handled by the
    // @modal-resend-verification listener on the selectionBoard root, so
    // the modal partial doesn't need this scope to dispatch back here.
    //
    // Two paths through the same fetch:
    //   first-time open (no modal yet) → open in 'default' state, patch
    //     sendError inline if the fetch fails. No resending spinner —
    //     the user opened a modal expecting "check your email" copy,
    //     not a loader.
    //   resend (modal already open) → advance() into 'resending' to slide
    //     in the spinner, then advance() into 'resent' on success or
    //     back to 'default' + sendError on failure. The slides give the
    //     user confirmation that something happened mid-flight.
    async sendVerificationEmail() {
      var s = Alpine.store('modals');
      var alreadyOpen = s.isOpen('check-email');
      if (alreadyOpen) {
        s.advance({ state: 'resending', sendError: '' });
      } else {
        s.open('check-email', { email: this.userEmail, state: 'default' });
      }

      var sendError = '';
      try {
        var resp = await fetch('/email_verification', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ contest: this.contestId })
        });
        var data = await resp.json();
        if (!resp.ok || !data.success) {
          sendError = data.error || 'Could not send the confirmation email.';
        }
      } catch (e) {
        sendError = 'Network error sending the email.';
      }

      if (alreadyOpen) {
        if (sendError) {
          s.advance({ state: 'default', sendError: sendError }, { direction: 'back' });
        } else {
          s.advance({ state: 'resent' });
        }
      } else if (sendError) {
        // First-time path — modal is already on screen in default state;
        // patch sendError inline without an animation (no state change).
        var cur = s.current();
        if (cur && cur.id === 'check-email') cur.props.sendError = sendError;
      }
    },

    // After a reload-based login (see init()), push the guest cart to the
    // server and submit the entry.
    async afterLoginSuccess() {
      if (await this.replaySelectionsToServer()) {
        await this.confirmEntry();
      } else {
        this.showError('Could not save your picks. Please try again.');
      }
    },

    // Open the auth wizard at the redirect step. cta_redirect owns the
    // countdown + auto-navigation; the seconds arg is accepted for
    // backward compatibility but currently fixed at 5 in the partial
    // (only caller passes 5). Pass null for url to suppress the auto-
    // navigation (the partial keeps the drain visual + manual click
    // closes the modal).
    showRedirectModal(title, message, icon, url, _seconds, cta) {
      Alpine.store('modals').open('auth', {
        step:    'redirect',
        title:   title,
        message: message,
        icon:    icon,
        url:     url,
        cta:     cta
      });
    },

    setHoldSuccess() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'process', 'loading');
        el.classList.add('success');
      });
    },

    // After the hold completes but BEFORE the server confirms the entry.
    // Shows a spinning arc on the button so users don't see "Confirmed!"
    // until the submission actually lands. Cleared by setHoldSuccess/Error
    // or resetHoldButtons once the response arrives.
    setHoldLoading() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'process', 'success');
        el.classList.add('loading');
      });
    },

    setHoldError() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('success', 'process', 'loading');
        el.classList.add('error');
      });
    },

    // Clear all hold-button states back to the default ("Hold to Confirm").
    // Nothing else removes the `error` class, so without this a button that
    // hit the error state ("Entry Blocked") stays stuck there.
    resetHoldButtons() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.classList.remove('error', 'success', 'process', 'loading');
      });
    },

    async runHoldValidations() {
      try {
        var res = await fetch('/geo/check', { headers: { 'Accept': 'application/json' } });
        var geo = await res.json();
        if (geo.blocked) {
          this.setHoldError();
          this.showRedirectModal('Location Restricted', 'Contest entries are not available in ' + (geo.state || 'your state') + '.', '\uD83D\uDCCD', '/', 5, 'OK');
          return false;
        }
      } catch(e) {
        // Geo check failed — allow through
      }

      if (!this.loggedIn) {
        this.showLoginModal();
        return false;
      }

      // Synchronous eligibility check against running $store.session — no
      // RPC at hold-time. Layer 1 of the entry-blocker design: catches the
      // 98% case (out of tokens, empty wallet) before the user finishes the
      // hold. The server-side enter still validates as the source of truth
      // for the 2% where running state is stale.
      var blocker = window.eligibilityBlocker(Alpine.store('session'), this.entryFeeCents);
      if (blocker) {
        this.showEligibilityBlockerModal(blocker);
        return false;
      }

      return true;
    },

    async confirmEntry() {
      // Re-entry guard: hold-button completes can fire 2+ events in the
      // same tick (debug-net 2026-05-27 caught 3 simultaneous POSTs from
      // a single user hold). Without this guard, the first POST wins,
      // the others 422 because the entry is already created on-chain,
      // and Alpine routes the 422 response into the "Get Entry Tokens"
      // fallback — visually masking the actual success.
      if (this.submitting) return;

      var sess = Alpine.store('session');
      if (sess.isGuest) {
        this.showLoginModal();
        return;
      }

      // Mirror the hold-time eligibility check at submit-time — the user
      // may have entered via auto-submit (e.g. post-login cart replay) or
      // their balance / token count may have changed since the hold check.
      var blocker = window.eligibilityBlocker(sess, this.entryFeeCents);
      if (blocker) {
        this.showEligibilityBlockerModal(blocker);
        return;
      }

      // web3 = a Phantom-authenticated session — sign the entry directly.
      // web2 = managed wallet — POST /enter (server consumes an entry token).
      var useOnchainFlow = sess.isWeb3 && this.contestOnchain;

      this.setHoldLoading();
      this.submitting = true;

      var seedsPerLevel = cfg.seedsPerLevel;

      try {
        if (useOnchainFlow) {
          var provider = window.walletProvider.detect();
          Alpine.store('solanaModal').show('Preparing Transaction', 'Building onchain transaction...');

          var resp = await provider.connect();
          var pubkeyB58 = resp.publicKey.toBase58();

          if (sess.address && pubkeyB58 !== sess.address) {
            throw new Error('Wrong wallet connected. Switch to ' + sess.address.substring(0, 8) + '..., or reconnect your wallet on the Account page.');
          }

          // Single-signature flow: the actual on-chain TX (signTransaction
          // below) IS the wallet-ownership proof — Anchor rejects any
          // enter_contest_direct whose signer doesn't match the entry PDA's
          // owner. The previous SIWS signMessage step was defense-in-depth
          // that doubled the signing prompts without strengthening on-chain
          // integrity (current_user comes from the session cookie set at
          // login via the same SIWS flow). Removed 2026-05-24.

          var prepareResp = await window.authedFetch('/contests/' + this.contestId + '/prepare_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({})
          });
          if (!prepareResp) return; // 401 — authedFetch surfaced the login modal
          var prepareData = await prepareResp.json();
          var ptxSlug = prepareData.ptx_slug;
          if (!prepareData.success) {
            if (this._handleBlockerResponse(prepareData)) return;
            throw new Error(prepareData.error || 'Failed to prepare entry');
          }

          Alpine.store('solanaModal').show('Sign Transaction', 'Approve the USDC transfer in your wallet...');
          var txBytes = Uint8Array.from(atob(prepareData.serialized_tx), function(c) { return c.charCodeAt(0); });
          var tx = solanaWeb3.Transaction.from(txBytes);
          var signedTx = await provider.signTransaction(tx);

          Alpine.store('solanaModal').show('Confirming Onchain', 'Submitting transaction to Solana...');
          var connection = new solanaWeb3.Connection(document.body.dataset.solanaRpcUrl, 'confirmed');
          var txSig = await connection.sendRawTransaction(signedTx.serialize(), { skipPreflight: true, maxRetries: 3 });

          // Stamp the signature on the server-side PendingTransaction
          // before waiting for confirmation — if the user refreshes during
          // the confirmation wait, the server still knows which signature
          // belongs to this entry. Fire-and-forget; a stamp failure must
          // not block the entry flow (the confirm_onchain_entry below also
          // resolves the PT as a fallback).
          if (ptxSlug) {
            try {
              await window.authedFetch('/contests/' + this.contestId + '/stamp_entry_signature', {
                method: 'POST',
                headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ ptx_slug: ptxSlug, tx_signature: txSig })
              });
            } catch (_) { /* non-fatal */ }
          }

          Alpine.store('solanaModal').show('Confirming Onchain', 'Waiting for Solana confirmation...');
          await connection.confirmTransaction(txSig, 'confirmed');

          Alpine.store('solanaModal').show('Confirming Entry', 'Saving entry...');
          var confirmResp = await window.authedFetch('/contests/' + this.contestId + '/confirm_onchain_entry', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ tx_signature: txSig, entry_id: prepareData.entry_id, entry_pda: prepareData.entry_pda })
          });
          if (!confirmResp) return; // 401 — authedFetch surfaced the login modal
          var confirmData = await confirmResp.json();
          if (!confirmData.success) {
            if (this._handleBlockerResponse(confirmData)) return;
            throw new Error(confirmData.error || 'Failed to confirm entry');
          }
          this.setHoldSuccess();

          if (confirmData.seeds_earned) {
            var m = Alpine.store('solanaModal');
            m.seedsEarned = confirmData.seeds_earned;
            m.seedsTotal = confirmData.seeds_total;
            m.seedsLevel = confirmData.seeds_level;

            localStorage.setItem('seedsNavbar', JSON.stringify({
              seeds_total: confirmData.seeds_total,
              level: confirmData.seeds_level,
              toward_next: confirmData.seeds_total % seedsPerLevel,
              progress: Math.round((confirmData.seeds_total % seedsPerLevel) / seedsPerLevel * 100)
            }));

            var oldSeeds = confirmData.seeds_total - confirmData.seeds_earned;
            var oldLevel = Math.floor(oldSeeds / seedsPerLevel) + 1;
            var newLevel = Math.floor(confirmData.seeds_total / seedsPerLevel) + 1;
            var newPct = Math.round((confirmData.seeds_total % seedsPerLevel) / seedsPerLevel * 100);
            if (newLevel > oldLevel) {
              var oldPct = Math.round((oldSeeds % seedsPerLevel) / seedsPerLevel * 100);
              localStorage.setItem('seedsLevelUp', JSON.stringify({
                oldLevel: oldLevel,
                newLevel: newLevel,
                oldPct: oldPct,
                oldToward: oldSeeds % seedsPerLevel
              }));
              // OPSEC-007: removed client→server PATCH /account/update_level. The
              // navbar reads seeds/level from `seedsNavbar` localStorage above —
              // already populated from `confirmData` which the server returned.
              // Delay the visible navbar animation 2s so the user sees the +X seeds badge in the modal first
              setTimeout(function() {
                window.dispatchEvent(new CustomEvent('navbar-seeds-update', { detail: { levelUp: true, oldLevel: oldLevel, oldPct: oldPct, newLevel: newLevel, progress: newPct } }));
              }, 2000);
            } else {
              setTimeout(function() {
                window.dispatchEvent(new CustomEvent('navbar-seeds-update', { detail: { levelUp: false, level: newLevel, progress: newPct } }));
              }, 2000);
            }
          }
          // 999s auto-close while reviewing seeds animation. Restore to a normal countdown when shipping (e.g. 8s).
          var modal = Alpine.store('solanaModal');
          modal.success(txSig, 'Entry Confirmed', 999);
          modal.title = 'Good Luck';
          modal.lobbyUrl = confirmData.redirect || ('/contests/' + this.contestId);
          refreshBalanceDelayed();

        } else {
          // Suppress the solanaModal "Submitting Entry" overlay when
          // we're already inside the auth wizard at tokens-minted — that
          // wizard handles its own in-place feedback (hold button
          // "Submitting…" → 'tokens-submitted' celebration card) so we
          // don't want two stacked modals.
          var authProps      = this._authProps();
          var insideTokensModal = !!(authProps && authProps.step === 'tokens-minted');
          if (!insideTokensModal) {
            Alpine.store('solanaModal').show('Submitting Entry', 'Processing your entry...');
          }

          var response = await window.authedFetch('/contests/' + this.contestId + '/enter', {
            method: 'POST',
            headers: { 'X-CSRF-Token': this.csrfToken, 'Accept': 'application/json' }
          });
          if (!response) return; // 401 — authedFetch surfaced the login modal
          var data = await response.json();

          if (data.success) {
            this.setHoldSuccess();
            // 🎟️ navbar punch — fires when the server reports the entry
            // was paid for by a token consume. Hooked here so both the
            // tokens-modal and the non-modal hold-to-confirm paths get
            // the same animation.
            if (data.token_consumed) {
              try { if (window.animateFreeEntryBadge) window.animateFreeEntryBadge(); } catch (_) {}
            }
            // Re-fetch the wizard props in case the entry submit took
            // long enough for the modal to be dismissed.
            var p = this._authProps();
            var inTokensMinted = !!(p && p.step === 'tokens-minted');

            if (data.tx_signature) {
              if (inTokensMinted) {
                // Stay in the wizard — show the on-chain receipt + CTA
                // in the 'tokens-submitted' card instead of stacking the
                // solanaModal on top. mintedBalance + navTokens fire
                // synchronously so the navbar count is accurate at the
                // moment the slide begins; the celebratory props (tx,
                // seeds, redirect) land via advance() alongside the
                // step change so the success card renders ready-to-go
                // when the slide-in starts.
                var nextBalance = Math.max(0, (p.mintedBalance || 0) - 1);
                try { if (window.updateNavTokens) window.updateNavTokens(nextBalance); } catch (_) {}
                Alpine.store('modals').advance({
                  mintedBalance: nextBalance,
                  txSignature:   data.tx_signature,
                  redirectUrl:   data.redirect || '/',
                  seedsEarned:   data.seeds_earned || 0,
                  seedsTotal:    data.seeds_total  || 0,
                  step:          'tokens-submitted'
                });
                refreshBalanceDelayed();
                // Modal-card confetti — delayed past the slide-in start
                // so the burst originates from the success card after it
                // settles in place (not the confirming card sliding off).
                try { if (window.fireConfettiFromModal) setTimeout(window.fireConfettiFromModal, 320); } catch (_) {}
              } else {
                var sm = Alpine.store('solanaModal');
                sm.seedsEarned = data.seeds_earned || 0;
                sm.seedsTotal  = data.seeds_total  || 0;
                sm.lobbyUrl    = data.redirect || '/';
                sm.success(data.tx_signature, 'Entry Confirmed');
                refreshBalanceDelayed();
              }
            } else {
              if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
              // Deferred email-verification nudge — set during email signup,
              // consumed when this entry confirms.
              var hasPendingEmail = false;
              try { hasPendingEmail = sessionStorage.getItem('pendingCheckEmail') === this.contestId; } catch (_) {}

              if (inTokensMinted) {
                // The entry just consumed one token — keep the navbar in
                // sync (server-side decrement already happened).
                var nextBalance2 = Math.max(0, (p.mintedBalance || 0) - 1);
                try { if (window.updateNavTokens) window.updateNavTokens(nextBalance2); } catch (_) {}
                if (hasPendingEmail) {
                  try { sessionStorage.removeItem('pendingCheckEmail'); } catch (_) {}
                  Alpine.store('modals').close();
                  this.sendVerificationEmail();
                } else {
                  Alpine.store('modals').advance({
                    mintedBalance: nextBalance2,
                    redirectUrl:   data.redirect || '/',
                    seedsEarned:   data.seeds_earned || 0,
                    seedsTotal:    data.seeds_total  || 0,
                    step:          'tokens-submitted'
                  });
                  // Modal-card confetti — delayed past the slide-in start
                  // so the burst originates from the settled success card.
                  try { if (window.fireConfettiFromModal) setTimeout(window.fireConfettiFromModal, 320); } catch (_) {}
                  refreshBalanceDelayed();
                }
              } else if (hasPendingEmail) {
                try { sessionStorage.removeItem('pendingCheckEmail'); } catch (_) {}
                this.sendVerificationEmail();
              } else {
                window.location.href = data.redirect || '/';
              }
            }
          } else if (this._handleBlockerResponse(data)) {
            // Layer 2 — handled by _handleBlockerResponse.
          } else if (/entry token/i.test(data.error || '')) {
            // Defense-in-depth — older string-match for the "no tokens"
            // raise from the server. Kept so a deploy of the controller
            // ahead of the interpreter doesn't lose the buy-tokens panel.
            if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
            this.resetHoldButtons();
            this.submitting = false;
            this.showTokensPanel();
          } else {
            if (Alpine.store('solanaModal').visible) {
              Alpine.store('solanaModal').error(data.error || 'Something went wrong');
            } else {
              this.showError(data.error || 'Something went wrong');
            }
            this.resetHoldButtons();
            this.submitting = false;
          }
        }
      } catch (err) {
        var msg = parseSolanaError(err.message || 'Failed to sign entry');
        if (Alpine.store('solanaModal').visible) {
          Alpine.store('solanaModal').error(msg);
        } else {
          this.showError(msg);
        }
        this.resetHoldButtons();
        this.submitting = false;
      }
    },

    showError(message) {
      this.error = message;
      if (this.errorTimer) clearTimeout(this.errorTimer);
      var self = this;
      this.errorTimer = setTimeout(function() { self.dismissError(); }, 5000);
    },

    async clearSelections() {
      this.selections = {};
      this.selectionOrder = [];
      this.cartOpen = false;
      this.blurDismissed = false;
      this.pickUrgent = false;

      if (!this.loggedIn) return;
      // Edit mode never has a cart entry; clear_picks is a no-op there.
      if (this.isEditMode) return;

      try {
        await fetch('/contests/' + this.contestId + '/clear_picks', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Accept': 'application/json'
          }
        });
      } catch (err) {
        // silent
      }
    },

    // Edit mode: PATCH the staged picks to /contests/:slug/entries/:slug.
    // DB-only — no on-chain signature required (the ContestEntry PDA carries
    // no pick commitment, so chain state stays valid as-is).
    async updateEntry() {
      if (this.submitting) return;
      if (this.selectionCount !== this.picksRequired) {
        this.showError('Make ' + this.picksRequired + ' picks before updating.');
        return;
      }
      this.submitting = true;
      var ids = this.selectionOrder.map(function(id) { return parseInt(id, 10); });
      try {
        var resp = await window.authedFetch(
          '/contests/' + this.contestId + '/entries/' + this.editEntrySlug,
          {
            method: 'PATCH',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ matchup_ids: ids })
          }
        );
        if (!resp) { this.submitting = false; return; }
        var data = await resp.json();
        if (resp.ok && data.success) {
          window.location.href = data.redirect || ('/contests/' + this.contestId);
        } else {
          this.showError((data && data.error) || 'Failed to update entry.');
          this.submitting = false;
        }
      } catch (e) {
        this.showError('Network error. Update not saved.');
        this.submitting = false;
      }
    },

    // Edit mode: discard staged picks and return to the leaderboard view.
    // Server-side state (the active entry's selections) is untouched.
    cancelEdit() {
      window.location.href = '/contests/' + this.contestId;
    },

    dismissError() {
      this.error = null;
      if (this.errorTimer) {
        clearTimeout(this.errorTimer);
        this.errorTimer = null;
      }
    }
  };
};
</script>

<div x-data="selectionBoard()" x-cloak
     @modal-resend-verification.window="sendVerificationEmail()"
     @auth-signup-submit.window="submitInlineSignup($event.detail.email, $event.detail.password)"
     @auth-login-submit.window="submitInlineLogin($event.detail.email, $event.detail.password)"
     @auth-phantom-click.window="loginWithPhantom()"
     @auth-google-click.window="loginWithGoogle()">

  <!-- Blur overlay (click to dismiss) -->
  <div x-show="selectionCount === <%= @contest.picks_required %> && !blurDismissed"
       @click="removeSelection(selectionOrder[selectionOrder.length - 1])"
       class="fixed inset-0 z-20 cursor-pointer"></div>

  <!-- Blurrable page content -->
  <div class="transition-all duration-300"
       :class="{ 'blur-sm select-none opacity-60': selectionCount === <%= @contest.picks_required %> && !blurDismissed }">

  <!-- Sort toggle + Matchup Cards -->
  <%
    # Game pairs: group by game, sort by lower turf_score
    game_pairs = @matchups.group_by(&:game_slug).values.select { |pair| pair.size == 2 }
    game_pairs.each { |pair| pair.sort_by! { |m| m.turf_score || 999 } }
    game_pairs.sort_by! { |pair| pair.first.turf_score || 999 }

    # Flat matchups sorted by turf_score (asc and desc)
    matchups_asc = @matchups.sort_by { |m| m.turf_score || 999 }
    matchups_desc = matchups_asc.reverse
  %>
  <section class="mb-8 transition-all" :class="{ 'cart-pushed': cartOpen }">
    <% unless local_assigns[:compact] || edit_entry %>
      <div class="mb-6">
        <%= render "contests/lobby_info_cards" %>
      </div>
    <% end %>
    <div class="flex items-center justify-between gap-2 mb-4">
      <div class="flex items-center gap-2">
        <span class="text-sm text-muted font-medium">Sort by</span>
        <button @click="toggleSort('game')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all"
                :class="sortMode === 'game' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'game'">
          Game
        </button>
        <button @click="toggleSort('turfScore')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all flex items-center gap-1"
                :class="sortMode === 'turfScore' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'turfScore'">
          Turf Score
          <span x-show="sortMode === 'turfScore'" x-text="sortDir === 'asc' ? '↑' : '↓'" class="text-xs"></span>
        </button>
      </div>
      <div class="relative">
        <input type="text" x-model="filterText" placeholder="Filter teams..."
               class="input-field text-sm py-1.5 pl-3 pr-8 rounded-full" style="width:140px">
        <button x-show="filterText" @click="filterText = ''"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-secondary hover:text-heading transition text-lg leading-none">&times;</button>
      </div>
    </div>

    <!-- Game view: paired cards -->
    <div x-show="sortMode === 'game'" class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      <% game_pairs.each do |pair| %>
        <% left, right = pair %>
        <div x-show="matchesFilter('<%= j(left.team.name) %>', '<%= j(right.team.name) %>')">
          <%= render "contests/matchup_game_pair", left: left, right: right, locked: left.locked? %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, ascending -->
    <div x-show="sortMode === 'turfScore' && sortDir === 'asc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_asc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, descending -->
    <div x-show="sortMode === 'turfScore' && sortDir === 'desc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_desc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Contest Header -->
  <section class="mb-8 transition-all" :class="{ 'cart-pushed': cartOpen }">
    <div class="card shadow p-4 md:p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-heading"><%= @contest.name %></h2>
          <p class="text-sm text-secondary mt-1">
            <% if @contest.starts_at %>
              Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
            <% end %>
          </p>
        </div>
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= contest_badge_classes(@contest.status) %>">
          <%= @contest.status.upcase %>
        </span>
      </div>
      <div class="grid grid-cols-3 gap-3 md:gap-4 text-center">
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Entry Fee</p>
          <% if logged_in? && current_user.managed_wallet? && !current_user.phantom_wallet? %>
            <p class="font-mono text-base md:text-lg text-heading">1 token</p>
            <p class="text-xs text-muted"><%= current_user.entry_token_balance %> available · <%= link_to "buy", tokens_buy_path, class: "underline" %></p>
          <% else %>
            <p class="font-mono text-base md:text-lg text-heading"><%= dollars(@contest.entry_fee_dollars) %></p>
          <% end %>
        </div>
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Guaranteed Prize</p>
          <p class="font-mono text-base md:text-lg text-primary"><%= dollars(@contest.guaranteed_prize_dollars) %></p>
        </div>
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Entries</p>
          <p class="font-mono text-base md:text-lg text-heading"><%= @entries.count %></p>
        </div>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View Contest Details", contest_path(@contest),
          class: "text-primary hover:text-primary-300 text-sm font-medium underline underline-offset-2" %>
      </div>
    </div>
  </section>

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8 transition-all" :class="{ 'cart-pushed': cartOpen }">
      <div class="card shadow p-4 hover:shadow-lg hover:shadow-primary/10 transition-all max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-heading"><%= current_user.display_name %></p>
            <p class="text-sm text-secondary"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <p class="font-mono text-lg text-primary"><%= dollars(display_balance) %></p>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  </div><!-- /blurrable -->

  <!-- FAB: selection count badge to reopen cart (desktop only) -->
  <button x-show="!cartOpen && selectionCount > 0"
          x-transition
          @click="cartOpen = true"
          class="hidden md:flex fixed bottom-6 right-6 z-30 w-14 h-14 bg-primary hover:bg-primary-700 text-white rounded-full shadow-lg shadow-primary/30 items-center justify-center text-lg font-bold transition">
    <span x-text="selectionCount"></span><span class="text-xs">/<%= @contest.picks_required %></span>
  </button>

  <%# Cart Sidebar: Desktop (right panel). Sits below the navbar via the
       --nav-h CSS variable (a ResizeObserver in _navbar.html.erb keeps it
       in sync with the sticky header's live height — no hardcoded px). %>
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
       class="hidden md:flex fixed right-0 w-80 bg-surface border-l border-subtle shadow-2xl z-40 flex-col"
       style="top:var(--nav-h, 6rem);height:calc(100% - var(--nav-h, 6rem))">
    <div class="flex flex-col h-full">
      <!-- Cart header -->
      <div class="flex items-center justify-between p-4 border-b border-subtle">
        <h3 class="text-lg font-bold text-heading">Your Picks</h3>
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold"
                :class="selectionCount === <%= @contest.picks_required %> ? 'bg-primary text-white' : 'bg-surface-alt text-secondary'">
            <span x-text="selectionCount"></span>/<%= @contest.picks_required %>
          </span>
          <button @click="cartOpen = false" class="text-secondary hover:text-heading transition text-xl leading-none">&times;</button>
        </div>
      </div>
      <!-- Pick slots -->
      <%= render "contests/turf_totals_cart_slots" %>
      <!-- Clear / Confirm buttons -->
      <div class="p-4 border-t border-subtle space-y-2">
        <% if edit_entry %>
          <%# Edit mode: plain Update button (no hold) + Cancel link. DB-only
              update, no on-chain signature required. %>
          <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
            <button type="button" @click="updateEntry()" :disabled="submitting"
                    class="w-full px-4 py-3 rounded-xl text-base font-bold bg-primary hover:bg-primary-700 disabled:bg-surface-alt disabled:text-muted text-white transition"
                    x-text="submitting ? 'Updating…' : 'Update Entry'"></button>
          </div>
          <button type="button" @click="cancelEdit()"
                  class="w-full py-2 text-sm font-semibold text-secondary hover:text-heading transition">
            Cancel
          </button>
        <% else %>
          <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
          <%= render 'shared/hold_button',
            default_text: "Hold to Confirm",
            hold_text: "Almost there...",
            success_text: "Confirmed!",
            duration: 2000,
            hold_id: "desktop",
            guard: "data.selectionCount === #{@contest.picks_required}",
            validate: "d.runHoldValidations()",
            validate_at: 750,
            on_success: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
            early_action: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
            early_action_at: 1500,
            early_action_guard: "d.contestOnchain && Alpine.store('session') && Alpine.store('session').isWeb3" %>
          </div>
          <button x-show="selectionCount > 0" @click="clearSelections()"
                  class="w-full py-2 text-sm font-semibold text-secondary hover:text-red-400 transition">
            Clear All
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Error popup -->
  <div x-show="error"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="-translate-y-full opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-full opacity-0"
       class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
    <div class="bg-red-900/90 border border-red-700 rounded-xl p-4 shadow-2xl relative overflow-hidden">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-red-200 font-semibold text-sm">Entry Failed</p>
          <p class="text-red-300 text-sm mt-1" x-text="error"></p>
        </div>
        <button @click="dismissError()" class="text-red-400 hover:text-white transition text-lg ml-4 leading-none">&times;</button>
      </div>
      <div class="absolute bottom-0 left-0 h-0.5 bg-red-500"
           x-ref="errorProgress"
           :style="error ? 'animation: progress-countdown 5s linear forwards' : ''"></div>
    </div>
  </div>

  <%# Orb-glow CSS for the in-modal pack buttons (shared with the
      standalone /tokens/buy page via tokens/_pack_button). Rendered
      outside any modal x-if so the rules are in the DOM before the
      auth wizard mounts the buttons on first open. %>
  <%= render "tokens/pack_button_styles" %>

  <%# All auth/tokens/redirect modals moved to app/views/modals/_auth.html.erb,
      rendered through shared/_modal_host as the 'auth' modal id with internal
      step state. The board's show*() methods open the wizard at the right
      step; the wizard partial dispatches window events (auth-signup-submit,
      auth-login-submit, auth-phantom-click, auth-google-click — the
      redirect step's CTA navigates through cta_redirect, no dispatch)
      that the selectionBoard root listens for (see x-data attribute above). %>

  <!-- Mobile spacer to prevent fixed cart from covering content -->
  <div x-show="selectionCount > 0" class="md:hidden" style="height:10rem"></div>

  <!-- Mobile Cart: Fixed bottom bar (hidden until first selection) -->
  <div x-show="selectionCount > 0"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden bg-surface border-t-2 border-strong rounded-t-xl px-4 py-3"
       style="position:fixed;bottom:0;left:0;right:0;z-index:9999;box-shadow:0 -6px 30px rgba(0,0,0,0.4)">
    <% if edit_entry %>
      <%# Edit mode: plain Update button (no hold) + Cancel link. DB-only
          update, no on-chain signature required. %>
      <div x-show="selectionCount === <%= @contest.picks_required %>" class="mb-3">
        <button type="button" @click="updateEntry()" :disabled="submitting"
                class="w-full px-4 py-3 rounded-xl text-base font-bold bg-primary hover:bg-primary-700 disabled:bg-surface-alt disabled:text-muted text-white transition"
                x-text="submitting ? 'Updating…' : 'Update Entry'"></button>
      </div>
    <% else %>
    <div x-show="selectionCount === <%= @contest.picks_required %>" class="mb-5">
      <%= render 'shared/hold_button',
        default_text: "Hold to Confirm",
        hold_text: "Almost there...",
        success_text: "Confirmed!",
        duration: 2000,
        hold_id: "mobile",
        guard: "data.selectionCount === #{@contest.picks_required}",
        validate: "d.runHoldValidations()",
        validate_at: 750,
        on_success: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
        early_action: "window.dispatchEvent(new CustomEvent('hold-confirm-entry'))",
        early_action_at: 1500,
        early_action_guard: "d.contestOnchain && Alpine.store('session') && Alpine.store('session').isWeb3" %>
    </div>
    <% end %>
    <p x-show="selectionCount < <%= @contest.picks_required %>" class="text-heading font-bold text-sm text-center mb-3">Your Picks</p>
    <div class="grid grid-cols-3 gap-1.5">
      <template x-for="i in <%= @contest.picks_required %>" :key="i">
        <div>
          <template x-if="selectionSlots[i-1]">
            <div class="bg-surface-alt rounded-md px-1.5 py-1 border border-primary-700 text-center relative" style="min-height:2.75rem">
              <p class="text-heading font-semibold text-xs truncate" x-text="selectionSlots[i-1].emoji + ' ' + selectionSlots[i-1].name"></p>
              <p class="text-muted text-[10px] truncate">vs <span x-text="selectionSlots[i-1].opName"></span> <span class="text-primary font-mono" x-text="'x' + selectionSlots[i-1].turfScore"></span></p>
              <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                      class="absolute -top-1 -right-1 w-4 h-4 bg-surface border border-strong rounded-full text-muted hover:text-red-400 text-[10px] leading-none flex items-center justify-center">&times;</button>
            </div>
          </template>
          <template x-if="!selectionSlots[i-1]">
            <div class="border border-dashed border-strong rounded-md px-1.5 py-1 text-center flex items-center justify-center"
                 :class="i === selectionCount + 1 ? (i === <%= @contest.picks_required %> ? (pickUrgent ? 'pick-pulse-urgent' : 'pick-pulse-shimmer') : (i === 2 ? 'pick-pulse-shimmer' : 'pick-pulse')) : ''"
                 style="min-height:2.75rem">
              <p class="text-[10px]" :class="i === selectionCount + 1 ? 'text-secondary' : 'text-muted'">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <% if edit_entry %>
      <button type="button" @click="cancelEdit()" class="w-full text-center text-xs font-semibold text-secondary hover:text-heading transition mt-2">
        Cancel
      </button>
    <% else %>
      <button @click="clearSelections()" class="w-full text-center text-xs font-semibold text-secondary hover:text-red-400 transition mt-2">
        Clear <span x-text="selectionCount"></span> / <%= @contest.picks_required %>
      </button>
    <% end %>
  </div>

  <!-- JSON Debug Block -->
  <section class="transition-all" :class="{ 'cart-pushed': cartOpen }">
    <%= render "components/json_debug", record: @contest.as_json.merge("slate_matchups" => @matchups.as_json(methods: [:locked?]), "entries" => contest_debug_entries(@entries)), label: "Contest JSON", collapsible: true %>
  </section>

</div>

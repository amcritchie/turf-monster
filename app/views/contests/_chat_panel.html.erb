<%# Contest chat panel — real-time via Turbo Streams over ActionCable.
    Composer is pinned at the top, under the heading; messages read newest-first
    below it. Reading is public; posting is limited to entrants + admins
    (Contest#chat_participant?). The .chat-admin class on the root reveals the
    per-message Hide buttons for admins — broadcast partials can't know the
    viewer, so visibility is driven by this container class. %>
<% messages = Message.recent_for(contest) %>
<% can_post = logged_in? && contest.chat_enabled? && contest.chat_participant?(current_user) %>

<%# .chat-admin*, .chat-message-in, .chat-kbd, .chat-live-ping, .chat-scroll-fade
    + their @keyframes live in application.tailwind.css (migrated 2026-05-24). %>
<div class="flex flex-col <%= 'chat-admin' if current_user&.admin? %> <%= 'chat-can-react' if can_post %>"
     style="height: 32rem;"
     x-data="contestChat(<%= messages.empty? %>)"
     data-post-url="<%= contest_messages_path(contest) %>"
     data-can-react="<%= can_post %>">
  <%= turbo_stream_from contest, :messages %>

  <%# Header %>
  <div class="flex items-center justify-between mb-4 flex-shrink-0">
    <h2 class="text-xl font-semibold text-body">Contest Chat</h2>
    <span class="flex items-center gap-1.5 text-xs text-muted">
      <span class="relative inline-flex w-2 h-2">
        <span class="chat-live-ping absolute inline-flex w-full h-full rounded-full bg-primary"></span>
        <span class="relative inline-flex w-2 h-2 rounded-full bg-primary"></span>
      </span>
      Live
    </span>
  </div>

  <%# Composer — pinned at the top, directly under the heading. %>
  <div class="flex-shrink-0 pb-3 border-b border-subtle">
    <% if !contest.chat_enabled? %>
      <p class="text-sm text-muted text-center py-1">Chat is closed for this contest.</p>
    <% elsif !logged_in? %>
      <p class="text-sm text-muted text-center py-1">
        <%= link_to "Sign in", signin_path, class: "text-primary hover:text-primary-300 font-medium" %> to join the chat.
      </p>
    <% elsif !can_post %>
      <p class="text-sm text-muted text-center py-1">Enter the contest to join the chat.</p>
    <% else %>
      <form class="flex items-center gap-2" @submit.prevent="send()">
        <textarea x-model="body" x-ref="input" rows="1" maxlength="<%= Message::BODY_MAX_LENGTH %>"
                  placeholder="Message the contest…"
                  @keydown.enter="if ($event.metaKey || $event.ctrlKey) { $event.preventDefault(); send(); }"
                  class="flex-1 h-10 resize-none rounded-lg bg-surface-alt border border-subtle px-3 py-2 text-sm text-body placeholder:text-muted focus:outline-none focus:border-primary"></textarea>
        <button type="submit" :disabled="sending || !body.trim()"
                :class="{ 'opacity-50 cursor-not-allowed': sending || !body.trim() }"
                class="btn btn-primary btn-sm flex-shrink-0 inline-flex items-center gap-2 h-10">
          <span>Send</span>
          <span class="inline-flex items-center gap-1" aria-hidden="true">
            <kbd class="chat-kbd" x-text="isMac ? '⌘' : 'Ctrl'"></kbd>
            <kbd class="chat-kbd">↵</kbd>
          </span>
        </button>
      </form>
    <% end %>
  </div>

  <%# Messages — newest first, reading top to bottom. %>
  <div class="flex-1 min-h-0 overflow-y-auto pt-3 chat-scroll-fade">
    <div id="contest_<%= contest.id %>_messages" x-ref="messageList" class="flex flex-col space-y-4">
      <% if messages.empty? %>
        <p x-show="empty" class="text-sm text-muted text-center py-8">
          No messages yet — say hi 👋
        </p>
      <% end %>
      <%= render partial: "messages/message", collection: messages %>
    </div>
  </div>

  <%# Shared "Find another reaction" picker — one per panel, position:fixed so
      the message-list overflow can't clip it. openReactionPicker() points its
      data-react-url at the hovered message before showing it. %>
  <div id="chat-reaction-picker" class="chat-reaction-picker bg-surface border border-strong rounded-xl shadow-2xl" data-react-url="" role="menu" aria-label="Pick a reaction">
    <% Reaction::PICKER.each do |e| %>
      <button type="button" onclick="pickReaction('<%= e %>')"><%= e %></button>
    <% end %>
  </div>
</div>

<script>
  // Inline (not a module): Alpine evaluates x-data before importmap modules
  // load — see CLAUDE.md "Inline JS that MUST stay inline".

  // Error toast — the studio-engine toast manager renders 'alert' as error styling.
  function chatToast(title, message) {
    window.dispatchEvent(new CustomEvent('toast', {
      detail: { type: 'alert', title: title, message: message || '', duration: 4000 }
    }));
  }

  function contestChat(isEmpty) {
    return {
      body: '',
      sending: false,
      empty: isEmpty,
      // ⌘+Enter on Mac, Ctrl+Enter elsewhere — drives the Send-button hint.
      isMac: /Mac/i.test(navigator.platform || navigator.userAgent || ''),
      init() {
        // Focus the composer on load so you can type straight away.
        // preventScroll keeps the page from jumping down to the chat; on
        // mobile the panel sits in a hidden tab, so focus() no-ops there.
        this.$nextTick(() => { this.$refs.input?.focus({ preventScroll: true }); });

        // Who am I + can I react — read once for the client-side "reacted"
        // highlight and the participant gate (the server is the real gate).
        var session = window.Alpine && Alpine.store('session');
        window.__chatMyUserId = (session && session.userId) || null;
        window.__chatCanReact = this.$root.dataset.canReact === 'true';

        var listEl = this.$refs.messageList;
        if (listEl) {
          // New messages prepend at the top — clear the empty state and play a
          // slide-in animation on each freshly added bubble. Direct children
          // only, so a nested reactions-row replace doesn't re-trigger it.
          new MutationObserver((mutations) => {
            this.empty = false;
            mutations.forEach((m) => {
              m.addedNodes.forEach((node) => {
                if (node.nodeType === 1 && node.id && node.id.startsWith('message_')) {
                  node.classList.add('chat-message-in');
                }
              });
            });
          }).observe(listEl, { childList: true });

          // Separate subtree observer for reaction highlighting: fires for both
          // freshly prepended messages AND the per-message reactions row being
          // replaced by a broadcast. Re-marks which pills are "mine".
          new MutationObserver((mutations) => {
            mutations.forEach((m) => {
              m.addedNodes.forEach((node) => {
                if (node.nodeType === 1) markMyReactions(node);
              });
            });
          }).observe(listEl, { childList: true, subtree: true });

          // Highlight reactions already present on initial load.
          this.$nextTick(() => markMyReactions(listEl));
        }

        // Desktop: keep the panel as tall as the leaderboard column so the two
        // columns line up at the bottom. Mobile keeps the fixed CSS height.
        var leaderboard = document.getElementById('leaderboard-container');
        if (leaderboard && window.ResizeObserver) {
          var panel = this.$root;
          var desktop = window.matchMedia('(min-width: 768px)');
          new ResizeObserver(function () {
            panel.style.height = desktop.matches ? leaderboard.offsetHeight + 'px' : '32rem';
          }).observe(leaderboard);
        }
      },
      async send() {
        var text = this.body.trim();
        if (!text || this.sending) return;
        this.sending = true;
        try {
          var resp = await fetch(this.$root.dataset.postUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: JSON.stringify({ message: { body: text } })
          });
          var data = await resp.json().catch(() => ({}));
          if (resp.ok && data.ok) {
            this.body = '';
          } else {
            chatToast('Message not sent', data.error || 'Please try again.');
          }
        } catch (e) {
          chatToast('Message not sent', 'Network error.');
        } finally {
          this.sending = false;
        }
      }
    };
  }

  function hideChatMessage(btn) {
    if (!window.confirm('Hide this message for everyone?')) return;
    fetch(btn.dataset.messageUrl, {
      method: 'DELETE',
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      }
    }).then(function(r) {
      if (!r.ok) {
        chatToast('Could not hide message');
      }
      // On success the bubble is removed for everyone via the Turbo Stream broadcast.
    }).catch(function() {});
  }

  // === Emoji reactions =================================================
  // The updated pill row arrives for everyone (including the actor) via the
  // Reaction broadcast, so these only fire the toggle + manage the picker —
  // no optimistic DOM writes. markMyReactions() (above, via observer) re-applies
  // the viewer's "reacted" highlight whenever a row renders.

  // Toggle which of THIS viewer's pills are highlighted, by comparing the
  // server-rendered reactor ids against my own id. Viewer-specific, so it lives
  // here and never in the broadcast partial.
  function markMyReactions(root) {
    var myId = window.__chatMyUserId;
    if (myId == null || !root.querySelectorAll) return;
    var pills = (root.matches && root.matches('[data-reactor-ids]'))
      ? [root] : root.querySelectorAll('[data-reactor-ids]');
    pills.forEach(function(p) {
      var ids = (p.dataset.reactorIds || '').split(',');
      p.classList.toggle('reacted', ids.indexOf(String(myId)) !== -1);
    });
  }

  function sendReaction(url, emoji) {
    if (!url) return;
    if (!window.__chatCanReact) {
      chatToast('Join to react', 'Enter the contest to react to messages.');
      return;
    }
    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: JSON.stringify({ emoji: emoji })
    }).then(function(r) { return r.json().catch(function() { return {}; }); })
      .then(function(data) { if (data && data.error) chatToast('Reaction failed', data.error); })
      .catch(function() { chatToast('Reaction failed', 'Network error.'); });
  }

  // Click handler for the hover quick-bar buttons AND the existing pills.
  function reactToMessage(el, emoji) {
    var root = el.closest('[data-react-url]');
    hideReactionPicker();
    if (root) sendReaction(root.dataset.reactUrl, emoji);
  }

  function openReactionPicker(btn) {
    var picker = document.getElementById('chat-reaction-picker');
    if (!picker) return;
    var root = btn.closest('[data-react-url]');
    picker.dataset.reactUrl = root ? root.dataset.reactUrl : '';
    picker.classList.add('is-open');
    // Prefer above-right of the "+"; clamp into the viewport, flip below if no room.
    var r = btn.getBoundingClientRect();
    var pw = picker.offsetWidth, ph = picker.offsetHeight;
    var left = Math.min(Math.max(8, r.right - pw), window.innerWidth - pw - 8);
    var top = r.top - ph - 6;
    if (top < 8) top = r.bottom + 6;
    picker.style.left = left + 'px';
    picker.style.top = top + 'px';
  }

  function hideReactionPicker() {
    var picker = document.getElementById('chat-reaction-picker');
    if (picker) picker.classList.remove('is-open');
  }

  function pickReaction(emoji) {
    var picker = document.getElementById('chat-reaction-picker');
    var url = picker ? picker.dataset.reactUrl : '';
    hideReactionPicker();
    sendReaction(url, emoji);
  }

  // Dismissal wiring once per page (chat may render on more than one view).
  if (!window.__chatReactionsWired) {
    window.__chatReactionsWired = true;
    document.addEventListener('click', function(e) {
      var picker = document.getElementById('chat-reaction-picker');
      if (!picker || !picker.classList.contains('is-open')) return;
      if (picker.contains(e.target)) return;
      if (e.target.closest && e.target.closest('.chat-react-add')) return; // opener manages itself
      hideReactionPicker();
    }, true);
    window.addEventListener('scroll', function() { hideReactionPicker(); }, true);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') hideReactionPicker(); });
  }
</script>

<%# locals: (left:, right:, locked:) %>
<div class="flex rounded-2xl shadow transition-all <%= locked ? 'opacity-50' : '' %>"
     :style="(selections['<%= left.id %>'] && selections['<%= right.id %>'])
       ? 'outline: 3px solid rgb(var(--color-primary-rgb)); box-shadow: 0 0 20px 4px rgb(var(--color-primary-rgb) / 0.35)'
       : ''">
  <% [left, right].each_with_index do |matchup, side| %>
    <button @click="toggleSelection('<%= matchup.id %>')"
            class="relative flex-1 min-w-0 bg-surface p-5 md:p-6 transition-all text-center border-2 <%= side == 0 ? 'rounded-l-2xl' : 'rounded-r-2xl' %>"
            :class="{
              'matchup-selected': selections['<%= matchup.id %>'] && !(selections['<%= left.id %>'] && selections['<%= right.id %>']),
              'bg-primary/5': selections['<%= matchup.id %>'] && selections['<%= left.id %>'] && selections['<%= right.id %>'],
              'border-subtle hover:bg-surface-alt/50': !selections['<%= matchup.id %>'],
              'matchup-pulse': pulseId === '<%= matchup.id %>' && selectionCount === 0
            }"
            :style="(selections['<%= left.id %>'] && selections['<%= right.id %>']) ? 'border-color: transparent' : ''"
            role="checkbox" :aria-checked="!!selections['<%= matchup.id %>']"
            aria-label="<%= matchup.team.name %><%= matchup.opponent_team ? " vs #{matchup.opponent_team.name}" : '' %>"
            <% if locked %>disabled<% end %>>
      <% if locked && side == 0 %>
        <span class="absolute top-2 left-2 text-[10px] text-yellow-500">&#128274;</span>
      <% end %>
      <%= render "contests/matchup_card_face", matchup: matchup %>
    </button>
    <% if side == 0 %>
      <div class="flex items-center self-stretch px-3 transition-all"
           :style="selections['<%= left.id %>'] && selections['<%= right.id %>']
             ? 'background: color-mix(in srgb, var(--color-surface) 85%, var(--color-cta) 15%)'
             : 'background: color-mix(in srgb, var(--color-surface) 70%, var(--color-page) 30%)'">
        <span class="text-xs font-bold text-muted uppercase">vs</span>
      </div>
    <% end %>
  <% end %>
</div>

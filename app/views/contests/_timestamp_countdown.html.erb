<%# Live countdown to an on-chain-mirrored contest timestamp (lock or
    conclusion). The chain value is authoritative; this is a visual mirror off
    the viewer's wall clock. Inline x-data (no named factory) to dodge the
    importmap-timing trap. Renders nothing when target is nil.
    Locals:
      target     (Time|nil) — the timestamp to count down to
      label      (String)   — shown while counting, e.g. "Locks in"
      done_label (String)   — shown once passed, e.g. "🔒 Entries closed"
      tone       (String)   — "yellow" (lock) | "orange" (conclusion) %>
<% if target.present? %>
  <% done_classes = tone.to_s == "orange" ? "border-orange-700 bg-orange-900/50 text-orange-400" : "border-yellow-700 bg-yellow-900/50 text-yellow-400" %>
  <div
    class="mt-2"
    x-data="{
      target: <%= target.to_i * 1000 %>,
      now: Date.now(),
      get diff() { return Math.max(this.target - this.now, 0); },
      get done() { return this.target - this.now <= 0; },
      get d() { return Math.floor(this.diff / 86400000); },
      get h() { return Math.floor((this.diff % 86400000) / 3600000); },
      get m() { return Math.floor((this.diff % 3600000) / 60000); },
      get s() { return Math.floor((this.diff % 60000) / 1000); },
      p(n) { return String(n).padStart(2, '0'); }
    }"
    x-init="if (target - now > 0) { const t = setInterval(() => { now = Date.now(); if (target - now <= 0) clearInterval(t); }, 1000); }"
  >
    <div x-show="!done" x-cloak
         class="inline-flex items-center gap-2 rounded-lg border border-subtle bg-surface-alt px-3 py-1.5">
      <span class="text-[10px] uppercase tracking-wider text-muted"><%= label %></span>
      <span class="font-mono text-sm font-bold text-heading tabular-nums">
        <span x-show="d > 0"><span x-text="d"></span>d </span><span x-text="p(h)"></span>h <span x-text="p(m)"></span>m <span x-text="p(s)"></span>s
      </span>
    </div>
    <div x-show="done" x-cloak
         class="inline-flex items-center gap-1.5 rounded-lg border <%= done_classes %> px-3 py-1.5">
      <span class="text-sm font-semibold"><%= done_label %></span>
    </div>
  </div>
<% end %>

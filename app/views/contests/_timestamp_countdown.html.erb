<%# Live countdown to an on-chain-mirrored contest timestamp (lock or
    conclusion). The chain value is authoritative; this is a visual mirror off
    the viewer's wall clock. Inline x-data (no named factory) to dodge the
    importmap-timing trap. Renders nothing when target is nil.

    The digits TICK DOWN on rolling reels — each unit is a vertical stack of
    its values translated by `translateY`, the same mechanism the entry-success
    seeds bar uses to roll UP (modals/blocks/_entry_confirmed). The value
    decreases each second, so the reel slides down. A normal -1 step animates;
    a rollover (e.g. 00s -> 59s when the minute borrows) snaps without a
    transition so the reel never whips back up through every value.

    Locals:
      target        (Time|nil) — the timestamp to count down to
      label         (String)   — shown beside the digits, e.g. "Locks in"
      done_label    (String)   — shown once passed, e.g. "🔒 Entries closed"
      tone          (String)   — "yellow" (lock) | "orange" (conclusion)
      on_done_modal (String?)  — modal id to open the instant the timer crosses
                                 zero LIVE (skipped if already done on load)
      on_done_url   (String?)  — lobbyUrl prop passed to that modal
      done_href     (String?)  — if set, the done state renders as a CTA link to
                                 this URL (e.g. the live page) instead of the badge
      wrapper_class (String?)  — outer margin class (default "mt-2"; "" for inline)
      bare          (Bool?)    — drop the bordered pill (no border/bg/padding);
                                 just the inline digits + label (default false)
      label_after   (Bool?)    — render the label AFTER the digits instead of
                                 before, e.g. "7d 14h 29m 34s Until Lock"
                                 (default false) %>
<% if target.present? %>
  <% done_classes = tone.to_s == "orange" ? "border-orange-700 bg-orange-900/50 text-orange-400" : "border-yellow-700 bg-yellow-900/50 text-yellow-400" %>
  <% on_done_modal = local_assigns[:on_done_modal] %>
  <% on_done_url   = local_assigns[:on_done_url] %>
  <% bare        = local_assigns.fetch(:bare, false) %>
  <% label_after = local_assigns.fetch(:label_after, false) %>
  <%# Days reel is sized in Ruby from the time remaining at render — days only
      ever count down from this max, so 0..dmax (plus a 1-day buffer) covers it. %>
  <% secs_left = [target.to_i - Time.current.to_i, 0].max %>
  <% dmax = (secs_left / 86400) + 1 %>
  <div
    class="<%= local_assigns.fetch(:wrapper_class, "mt-2") %>"
    x-data="{
      target: <%= target.to_i * 1000 %>,
      now: Date.now(),
      d: 0, h: 0, m: 0, s: 0,
      animD: false, animH: false, animM: false, animS: false,
      _t: null,
      get done() { return this.target - this.now <= 0; },
      get underHour() { return this.d === 0 && this.h === 0; },
      _set(animate) {
        var diff = Math.max(this.target - this.now, 0);
        var nd = Math.floor(diff / 86400000);
        var nh = Math.floor((diff % 86400000) / 3600000);
        var nm = Math.floor((diff % 3600000) / 60000);
        var ns = Math.floor((diff % 60000) / 1000);
        // Animate a unit only when it ticks DOWN by a step; snap (no transition)
        // on a rollover, where the new value is larger than the one it replaces.
        this.animD = animate && nd <= this.d;
        this.animH = animate && nh <= this.h;
        this.animM = animate && nm <= this.m;
        this.animS = animate && ns <= this.s;
        this.d = nd; this.h = nh; this.m = nm; this.s = ns;
      },
      tr(on) { return on ? 'transform .55s cubic-bezier(0.16, 1, 0.3, 1)' : 'none'; },
      destroy() { if (this._t) { clearInterval(this._t); this._t = null; } }
    }"
    x-init="now = Date.now(); _set(false);
            if (target - now > 0) {
              _t = setInterval(() => {
                now = Date.now(); _set(true);
                if (target - now <= 0) { clearInterval(_t); _t = null; <% if on_done_modal.present? %>if (window.Alpine && Alpine.store('modals')) { Alpine.store('modals').open('<%= j on_done_modal %>', { lobbyUrl: '<%= j on_done_url.to_s %>' }); }<% end %> }
              }, 1000);
            }"
  >
    <div x-show="!done" x-cloak
         class="<%= bare ? "inline-flex items-baseline gap-2" : "inline-flex items-center gap-2 rounded-lg border border-subtle bg-surface-alt px-3 py-1.5" %>">
      <% unless label_after %>
        <span class="text-[10px] uppercase tracking-wider text-muted"><%= label %></span>
      <% end %>
      <%# Each unit is one rolling reel + its letter in a baseline-aligned
          wrapper that carries the unit's font size. The two leading VISIBLE
          units take the large "N/M Entries" size (text-lg font-extrabold) and
          the trailing pair stays small: days + hours lead while shown, but once
          we drop under an hour (d == 0 && h == 0, so neither "0d" nor "0h"
          renders) minutes + seconds inherit the large size instead. Reel cells
          are em/ch-sized, so each unit's digits scale with its wrapper's size.
          One config row per unit drives a single reel template below — the
          letter is just the unit key, and anim<Var> is the per-unit snap flag. %>
      <%
        large = "text-lg font-extrabold"
        # m/s class binding (display + size): below an hour they're the large
        # leading pair, shown everywhere. Above an hour they're small and, on
        # mobile, hidden entirely — there's no room beside the big d+h, and the
        # two large units already carry the meaningful precision. `hidden
        # sm:inline-flex` keeps them on >= sm (desktop). Driven by class (not
        # x-show) so the responsive `hidden` isn't overridden by an inline style.
        ms_bind = "underHour ? 'inline-flex #{large}' : 'hidden sm:inline-flex text-sm font-bold'"
        units = [
          { v: "d", max: dmax, pad: false, w: "#{dmax.to_s.length}ch", show: "d > 0",      cls: large },
          { v: "h", max: 23,   pad: true,  w: "2ch",                   show: "!underHour",  cls: large },
          { v: "m", max: 59,   pad: true,  w: "2ch",                   bind: ms_bind },
          { v: "s", max: 59,   pad: true,  w: "2ch",                   bind: ms_bind, last: true },
        ]
      %>
      <span class="font-mono text-heading tabular-nums inline-flex items-baseline">
        <% units.each do |u| %>
          <%# Units that bind :class own their own display; the rest are inline-flex. %>
          <span class="items-baseline<%= " inline-flex" unless u[:bind] %><%= " #{u[:cls]}" if u[:cls] %><%= " mr-[0.5em]" unless u[:last] %>"
                <% if u[:show] %>x-show="<%= u[:show] %>"<% end %>
                <% if u[:bind] %>:class="<%= u[:bind] %>"<% end %>>
            <span style="display:inline-block;overflow:hidden;height:1em;line-height:1em;width:<%= u[:w] %>;text-align:right;">
              <span class="block" :style="{ transform: 'translateY(-' + <%= u[:v] %> + 'em)', transition: tr(anim<%= u[:v].upcase %>) }">
                <% (0..u[:max]).each do |n| %><span class="block" style="height:1em;line-height:1em;"><%= u[:pad] ? format("%02d", n) : n %></span><% end %>
              </span>
            </span><span><%= u[:v] %></span>
          </span>
        <% end %>
      </span>
      <% if label_after %>
        <span class="text-[10px] uppercase tracking-wider text-muted"><%= label %></span>
      <% end %>
    </div>
    <% if local_assigns[:done_href].present? %>
      <%# Done state as a CTA link (e.g. "Watch Live" the instant a contest locks). %>
      <a href="<%= done_href %>" x-show="done" x-cloak
         class="btn btn-primary btn-sm inline-flex items-center gap-2 shadow-lg shadow-primary/20">
        <span class="h-2 w-2 rounded-full bg-white animate-pulse"></span>
        <span class="font-semibold"><%= done_label %></span>
      </a>
    <% else %>
      <div x-show="done" x-cloak
           class="inline-flex items-center gap-1.5 rounded-lg border <%= done_classes %> px-3 py-1.5">
        <span class="text-sm font-semibold"><%= done_label %></span>
      </div>
    <% end %>
  </div>
<% end %>

<div class="flex-1 overflow-y-auto p-4 space-y-3">
  <template x-for="i in <%= @contest.picks_required %>" :key="i">
    <div>
      <template x-if="selectionSlots[i-1]">
        <%# Same team-color dress as the board cards: a team-hue gradient, the
            mascot in the accent color, no emoji, and foreground text that flips
            for light-forward teams (Saints, Steelers). %>
        <div class="rounded-xl p-3 border transition overflow-hidden"
             :style="{ background: selectionSlots[i-1].gradient, color: selectionSlots[i-1].fg, borderColor: selectionSlots[i-1].fgFaint }"
             :class="isShaking(selectionSlots[i-1].matchupId) ? 'shake' : ''">
          <div class="flex items-center justify-between gap-2">
            <div class="min-w-0">
              <p class="text-sm truncate">
                <%# Short name ("Chargers"), not the full "Los Angeles Chargers" —
                    a multi-week row already carries three opponents and the city
                    pushes it onto a second line. %>
                <span class="font-extrabold" :style="{ color: selectionSlots[i-1].accent }" x-text="selectionSlots[i-1].shortName || selectionSlots[i-1].name"></span>
                <template x-if="selectionSlots[i-1].opName">
                  <span class="font-normal text-xs ml-1" :style="{ color: selectionSlots[i-1].fgSoft }">vs <span x-text="selectionSlots[i-1].opName"></span></span>
                </template>
              </p>
              <p class="text-xs mt-0.5">
                <%# The multiplier is points per goal, so "Points" — matching the
                    "Points / Goal" label on the card. "Goals" mislabelled it. %>
                <span :style="{ color: selectionSlots[i-1].fgFaint }">Points</span>
                <span class="font-mono font-bold ml-1" :style="{ color: selectionSlots[i-1].fg }" x-text="'x' + selectionSlots[i-1].turfScore"></span>
              </p>
            </div>
            <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                    class="opacity-70 hover:opacity-100 transition text-lg leading-none shrink-0"
                    :style="{ color: selectionSlots[i-1].fg }">&times;</button>
          </div>
        </div>
      </template>
      <template x-if="!selectionSlots[i-1]">
        <div class="border-2 border-dashed border-strong rounded-xl p-3 text-center"
             :class="i === selectionCount + 1 ? (i === <%= @contest.picks_required %> ? (pickUrgent ? 'pick-pulse-urgent' : 'pick-pulse-shimmer') : (i === 2 ? 'pick-pulse-shimmer' : 'pick-pulse')) : ''">
          <p class="text-sm" :class="i === selectionCount + 1 ? 'text-secondary' : 'text-muted'">Pick <span x-text="i"></span></p>
        </div>
      </template>
    </div>
  </template>
</div>

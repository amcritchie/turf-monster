<%# Live countdown to the contest lock time (@contest.locks_at, an alias for
    starts_at). Rendered only when a lock is scheduled and the contest hasn't
    settled. The on-chain lock_timestamp is authoritative (enter_contest rejects
    past it); this is a visual mirror off the viewer's wall clock, so it can be
    a second or two off the chain at the boundary — fine for a countdown.
    Inline x-data (no named factory) to dodge the importmap-timing trap. %>
<% if @contest.locks_at.present? && !@contest.settled? %>
  <div
    class="mt-2"
    x-data="{
      target: <%= @contest.locks_at.to_i * 1000 %>,
      now: Date.now(),
      get diff() { return Math.max(this.target - this.now, 0); },
      get locked() { return this.target - this.now <= 0; },
      get d() { return Math.floor(this.diff / 86400000); },
      get h() { return Math.floor((this.diff % 86400000) / 3600000); },
      get m() { return Math.floor((this.diff % 3600000) / 60000); },
      get s() { return Math.floor((this.diff % 60000) / 1000); },
      p(n) { return String(n).padStart(2, '0'); }
    }"
    x-init="if (target - now > 0) { const t = setInterval(() => { now = Date.now(); if (target - now <= 0) clearInterval(t); }, 1000); }"
  >
    <div x-show="!locked" x-cloak
         class="inline-flex items-center gap-2 rounded-lg border border-subtle bg-surface-alt px-3 py-1.5">
      <span class="text-[10px] uppercase tracking-wider text-muted">Locks in</span>
      <span class="font-mono text-sm font-bold text-heading tabular-nums">
        <span x-show="d > 0"><span x-text="d"></span>d </span><span x-text="p(h)"></span>h <span x-text="p(m)"></span>m <span x-text="p(s)"></span>s
      </span>
    </div>
    <div x-show="locked" x-cloak
         class="inline-flex items-center gap-1.5 rounded-lg border border-yellow-700 bg-yellow-900/50 px-3 py-1.5">
      <span class="text-sm font-semibold text-yellow-400">🔒 Entries closed</span>
    </div>
  </div>
<% end %>

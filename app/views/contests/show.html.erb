<%
  creator_name = @creator&.display_name || "Turf Monster"
  # When the URL has ?add_entry=true, the user has an existing entry but is
  # explicitly starting another one — show the matchup board on top of the
  # leaderboard so they can pick a new lineup.
  show_board_for_existing_entry = @has_entry && params[:add_entry].present? && @contest.open?
  # When ?edit_entry=<slug> resolves to one of current_user's active entries,
  # the show template renders the selection board in edit mode instead of the
  # leaderboard (see Section 4 below).
  edit_mode = @edit_entry.present?
%>

<!-- Section 1: Hero Banner + Creator Avatar -->
<div class="-mx-4 relative mb-8">
  <% if @contest.contest_image.attached? %>
    <%= image_tag @contest.contest_image, class: "w-full h-48 md:h-64 lg:h-72 object-cover", alt: @contest.name %>
  <% else %>
    <div class="w-full h-48 md:h-64 lg:h-72" style="background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-900))"></div>
  <% end %>

  <!-- Onchain address overlay (SE corner with shaded triangle) -->
  <% if @contest.onchain? %>
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top left, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 25%, transparent 50%);"></div>
    <%# Link to the explorer's basic account view (not /anchor-account, which
        requires the program's IDL to be published on-chain via
        `anchor idl init` — currently not done; tracked in
        mcritchie-studio audit doc Tier 3 #22). The base account view
        renders raw data + lamports + owner reliably for any valid PDA. %>
    <a href="https://explorer.solana.com/address/<%= @contest.onchain_contest_id %><%= '?cluster=devnet' if Solana::Config.devnet? %>"
       target="_blank" rel="noopener"
       class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 text-xs font-mono text-white/90 hover:text-white transition">
      ...<%= @contest.onchain_contest_id.last(6) %>
      <svg class="w-3.5 h-3.5" viewBox="0 0 397.7 311.7" fill="currentColor"><path d="M64.6 237.9c2.4-2.4 5.7-3.8 9.2-3.8h317.4c5.8 0 8.7 7 4.6 11.1l-62.7 62.7c-2.4 2.4-5.7 3.8-9.2 3.8H6.5c-5.8 0-8.7-7-4.6-11.1l62.7-62.7z"/><path d="M64.6 3.8C67.1 1.4 70.4 0 73.8 0h317.4c5.8 0 8.7 7 4.6 11.1l-62.7 62.7c-2.4 2.4-5.7 3.8-9.2 3.8H6.5c-5.8 0-8.7-7-4.6-11.1L64.6 3.8z"/><path d="M333.1 120.1c-2.4-2.4-5.7-3.8-9.2-3.8H6.5c-5.8 0-8.7 7-4.6 11.1l62.7 62.7c2.4 2.4 5.7 3.8 9.2 3.8h317.4c5.8 0 8.7-7 4.6-11.1l-62.7-62.7z"/></svg>
    </a>
  <% end %>

  <!-- Creator avatar -->
  <div class="absolute -bottom-6 left-4">
    <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center text-white font-bold text-lg ring-4" style="--tw-ring-color: var(--bg-page, #1A1535)">
      <%= creator_name.first.upcase %>
    </div>
  </div>
</div>

<!-- Section 2: Contest Info -->
<%= render "contests/contest_header" %>

<!-- Section 3: Conditional cards above the board.
     Entered users: seeds + share row.
     Not-entered users: nothing here — the matchup board partial (Section 4)
     renders the lobby info cards ("Build Roster" / "Win $X") inline at its
     top, so rendering them in Section 3 too would double-display. -->
<% if @has_entry %>
  <div class="mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%# Once the user has 2+ entries on this contest, the entries-nav card
          is more useful than the "Earn a Free Entry" seed progress nudge —
          surface picks they can recognize at a glance. Seeds card returns
          for single-entry users (still in onboarding flow). %>
      <% if @my_active_entries && @my_active_entries.size >= 2 %>
        <%= render "contests/your_entries" %>
      <% elsif @seeds_data %>
        <%= render "contests/slate_progress_xp", seeds_data: @seeds_data %>
        <script>
          localStorage.setItem('seedsNavbar', JSON.stringify({
            seeds_total: <%= @seeds_data[:seeds] %>,
            level: <%= @seeds_data[:level] %>,
            toward_next: <%= @seeds_data[:toward_next] %>,
            progress: <%= @seeds_data[:progress] %>
          }));
        </script>
      <% end %>
      <%= render "contests/share_invite" %>
    </div>
  </div>
<% end %>

<!-- Section 4: Board — Turf Totals matchups, or the World Cup Survivor board -->
<%# id + scroll-margin-top let /tokens/processing iframe this page with
    `#board` and land on the matchup grid (skipping the hero/info above),
    clearing the sticky navbar height set by the studio-engine head. %>
<% if @contest.world_cup_survivor? %>
  <div id="board" class="mb-8" style="scroll-margin-top: var(--nav-h, 64px)">
    <%= render "contests/world_cup_survivor_board" %>
  </div>
<% elsif edit_mode %>
  <div id="board" class="mb-8" style="scroll-margin-top: var(--nav-h, 64px)">
    <%= render "contests/turf_totals_board", edit_entry: @edit_entry %>
  </div>
<% elsif @contest.open? && (!@has_entry || show_board_for_existing_entry) %>
  <div id="board" class="mb-8" style="scroll-margin-top: var(--nav-h, 64px)">
    <%= render "contests/turf_totals_board" %>
  </div>
<% end %>

<!-- Section 5: Leaderboard + Chat -->
<%# Leaderboard + Chat split (2026-05-19). Two columns on desktop, a
    Leaderboard / Chat tab toggle on mobile. To revert to the original
    single-column page, replace this whole block with a full-width div
    (id "leaderboard-container", class "mb-8") that renders the
    contests/turf_totals_leaderboard partial once. Hidden during edit
    mode so the user focuses on the selection board above. %>
<% unless edit_mode %>
<div x-data="{ tab: 'leaderboard' }" class="mb-8">
  <%# Tab switcher — mobile only %>
  <div class="flex gap-1 mb-4 md:hidden bg-surface-alt rounded-lg p-1">
    <button type="button" @click="tab = 'leaderboard'"
            :class="tab === 'leaderboard' ? 'bg-primary text-white' : 'text-secondary hover:text-heading'"
            class="flex-1 py-2 rounded-md text-sm font-semibold transition">
      Leaderboard
    </button>
    <button type="button" @click="tab = 'chat'"
            :class="tab === 'chat' ? 'bg-primary text-white' : 'text-secondary hover:text-heading'"
            class="flex-1 py-2 rounded-md text-sm font-semibold transition">
      Chat
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:items-start">
    <%# Left — leaderboard. compact: true renders just the ranked list (no
        contest-details / admin chrome) so both columns start at the same place.
        Keeps id="leaderboard-container" for the leaderboard_poll JS. %>
    <div id="leaderboard-container" :class="tab === 'leaderboard' ? '' : 'hidden'" class="md:block">
      <%= render (@contest.world_cup_survivor? ? "contests/world_cup_survivor_leaderboard" : "contests/turf_totals_leaderboard"), compact: true %>
    </div>
    <%# Right — contest chat panel (see contests/_chat_panel). %>
    <div x-cloak :class="tab === 'chat' ? '' : 'hidden'" class="md:block">
      <%= render "contests/chat_panel", contest: @contest %>
    </div>
  </div>
</div>
<% end %>

<!-- Section 5b: Survivor Admin -->
<% if current_user&.admin? && !@contest.settled? && @contest.world_cup_survivor? %>
  <div class="mb-8">
    <h3 class="text-sm font-semibold text-secondary mb-3">Admin</h3>
    <div class="card p-4">
      <p class="text-xs font-semibold text-muted mb-2 uppercase tracking-wide">Contest</p>
      <div class="flex flex-wrap gap-2">
        <% if @contest.open? && !@contest.locked? %>
          <button type="button" onclick="lockContestViaPhantom('<%= @contest.slug %>', 0)" class="btn btn-sm bg-yellow-600 hover:bg-yellow-500 text-white">Lock Entries</button>
          <button type="button" onclick="lockContestViaPhantom('<%= @contest.slug %>', 30)" class="btn btn-sm bg-yellow-700 hover:bg-yellow-600 text-white">Lock in 30s</button>
        <% end %>
        <% if @current_round %>
          <%= button_to "Grade #{@current_round.name}", grade_round_contest_path(@contest, round_id: @current_round.id), method: :post, class: "btn btn-primary btn-sm" %>
        <% else %>
          <%= button_to "Settle Contest", grade_contest_path(@contest), method: :post, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
      <p class="text-xs text-muted mt-2">Grade each round once its matches are final; settle the contest after the Final.</p>
    </div>
  </div>
<% end %>

<!-- Section 6: Admin Actions (Turf Totals) -->
<% if current_user&.admin? && !@contest.settled? && @contest.turf_totals? %>
  <div class="mb-8">
    <h3 class="text-sm font-semibold text-secondary mb-3">Admin</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Contest actions -->
      <div class="card p-4">
        <p class="text-xs font-semibold text-muted mb-2 uppercase tracking-wide">Contest</p>
        <div class="flex flex-wrap gap-2">
          <% if @contest.open? && !@contest.locked? %>
            <% active_count = @contest.active_entry_count %>
            <% if @contest.max_entries.nil? || active_count < (@contest.max_entries || @contest.format_config[:max_entries]) %>
              <%= button_to "Fill", fill_contest_path(@contest), method: :post, class: "btn btn-secondary btn-sm" %>
            <% end %>
            <button type="button" onclick="lockContestViaPhantom('<%= @contest.slug %>', 0)" class="btn btn-sm bg-yellow-600 hover:bg-yellow-500 text-white">Lock</button>
            <button type="button" onclick="lockContestViaPhantom('<%= @contest.slug %>', 30)" class="btn btn-sm bg-yellow-700 hover:bg-yellow-600 text-white">Lock in 30s</button>
          <% end %>
          <% if @contest.locked? %>
            <%= button_to "Grade", grade_contest_path(@contest), method: :post, class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      </div>
      <!-- Simulate actions -->
      <div class="card p-4">
        <p class="text-xs font-semibold text-muted mb-2 uppercase tracking-wide">Simulate</p>
        <div class="flex flex-wrap gap-2">
          <% next_game = @contest.matchups.pending.includes(:game).select { |m| m.game.present? }.sort_by { |m| m.game.kickoff_at || Time.current }.first %>
          <% if next_game %>
            <%= button_to "Next Game", simulate_game_contest_path(@contest), method: :post, class: "btn btn-primary btn-sm" %>
            <%= button_to "Next 5", simulate_batch_contest_path(@contest, count: 5), method: :post, class: "btn btn-outline btn-sm" %>
            <%= button_to "Next 20", simulate_batch_contest_path(@contest, count: 20), method: :post, class: "btn btn-outline btn-sm" %>
          <% end %>
          <%= button_to "All", jump_contest_path(@contest), method: :post, class: "btn btn-outline btn-sm" %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- Leaderboard polling (locked or entered contests) -->
<% if @contest.locked? || @has_entry %>
  <script>
  (function() {
    let version = <%= @contest.updated_at.to_i %>;
    const contestId = '<%= @contest.slug %>';
    const pollUrl = '/c/' + contestId + '/leaderboard_poll';

    var pollTimer = setInterval(async function() {
      try {
        const resp = await fetch(pollUrl + '?version=' + version);
        const data = await resp.json();
        if (data.changed) {
          const container = document.getElementById('leaderboard-container');
          if (container && data.html) {
            container.innerHTML = data.html;
            version = data.version;
            window.dispatchEvent(new CustomEvent('toast', {
              detail: { type: 'info', title: 'Leaderboard Updated', message: 'Scores have changed', duration: 3000 }
            }));
          }
        }
      } catch (e) { /* silently retry next interval */ }
    }, 90000);

    document.addEventListener('turbo:before-cache', function() {
      clearInterval(pollTimer);
    }, { once: true });
  })();
  </script>
<% end %>

<!-- Auto-scroll on arrival
     - ?scroll=<px> — absolute pixel scroll (landing-page CTAs).
     - ?add_entry=true / ?edit_entry=<slug> — scroll to #board so the user
       lands on the picks UI instead of re-reading the contest header. -->
<script>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var px = parseInt(params.get('scroll'), 10);
    if (px > 0) {
      setTimeout(function() { window.scrollTo({ top: px, behavior: 'smooth' }); }, 200);
    } else if (params.get('add_entry') === 'true' || params.get('edit_entry')) {
      setTimeout(function() {
        var board = document.getElementById('board');
        if (board) board.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }
  })();
</script>

<!-- Section 7: More Contests -->
<% if @other_contests&.any? %>
  <div>
    <h3 class="text-sm font-semibold text-secondary mb-3">More Contests</h3>
    <div class="space-y-2">
      <% @other_contests.each do |c| %>
        <%= link_to contest_path(c), class: "card-hover block p-3 rounded-lg border border-subtle" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-bold text-heading"><%= c.name %></p>
              <p class="text-xs text-muted"><%= c.tagline %></p>
            </div>
            <span class="text-xs font-semibold px-2 py-1 rounded-full <%= c.open? ? 'bg-primary/10 text-primary' : 'bg-surface-alt text-muted' %>">
              <%= c.status.capitalize %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

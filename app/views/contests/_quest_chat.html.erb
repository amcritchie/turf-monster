<%# Quest mission 2 — send your first contest-chat message for a one-time
    25-seed bonus. Mirrors _quest_username's two-row layout, BUT there's no
    CTA button: the action happens in the Contest Chat panel, which sits
    directly BELOW this card on the contest show page. So the right column
    is a big southwest (down-left) arrow nudging the eye toward the chat.
    The grant fires server-side on the user's first message; the chat
    panel's send() fires the seeds tick-up + dispatches quest-advance.
    No mb-* — direct grid child. %>
<div x-data="{}" class="card shadow p-5 relative h-full">
  <style>
    /* Southwest nudge — the arrow drifts toward the chat (down + left) and
       eases back, once every 2.4s, so it reads as "look down there". */
    @keyframes questArrowSW {
      0%   { transform: translate(0, 0); }
      45%  { transform: translate(-5px, 5px); }
      100% { transform: translate(0, 0); }
    }
    .quest-arrow-sw { animation: questArrowSW 2.4s ease-in-out infinite; }
    @media (prefers-reduced-motion: reduce) { .quest-arrow-sw { animation: none; } }
  </style>

  <%# Row 1 — header + quest badge %>
  <div class="flex items-center justify-between gap-3 mb-3">
    <h3 class="text-heading font-semibold text-sm">Send Your First Message</h3>
    <span class="inline-block text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">Quest 2 of 4</span>
  </div>

  <%# Row 2 — description (one-time bonus prompt) | a big southwest arrow
      pointing down-left at the Contest Chat panel below. %>
  <div class="grid grid-cols-2 gap-4 items-center">
    <p class="text-secondary text-xs leading-relaxed">
      Say hi in the <span class="text-heading font-semibold">Contest Chat</span> just below &mdash; your first message earns <span class="text-primary font-semibold">+25 seeds</span>.
    </p>
    <div class="flex items-center justify-center h-full">
      <span class="quest-arrow-sw text-primary leading-none" style="font-size: 2.75rem;" aria-hidden="true">&#x2199;</span>
    </div>
  </div>
</div>

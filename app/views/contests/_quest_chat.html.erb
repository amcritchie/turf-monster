<%# Quest mission 2 — send your first contest-chat message for a one-time
    25-seed bonus. The southwest arrow floats LEFT, nudging the eye down at the
    Contest Chat panel below; the prompt sits to its right. Clicking the arrow
    smooth-scrolls to + focuses the chat input (id contest-chat-input). The arrow
    has three states driven by the chat panel's send() over window events:
    idle (arrow) -> loading (spinner, on submit) -> success (checkmark, on the
    seeds-earning first message). No mb-* (direct grid child). x-data is
    double-quoted, so every inner quote is single. %>
<div x-data="{ st: 'idle' }"
     @quest-chat-sending.window="st = 'loading'"
     @quest-chat-success.window="st = 'success'"
     @quest-chat-reset.window="st = 'idle'"
     class="card shadow p-5 relative h-full">
  <style>
    /* Southwest nudge — the arrow drifts toward the chat (down + left) and
       eases back, once every 2.4s, so it reads as "look down there". */
    @keyframes questArrowSW {
      0%   { transform: translate(0, 0); }
      45%  { transform: translate(-5px, 5px); }
      100% { transform: translate(0, 0); }
    }
    .quest-arrow-sw { animation: questArrowSW 2.4s ease-in-out infinite; }
    /* Loading spinner — same green as the arrow via currentColor. */
    @keyframes questSpin { to { transform: rotate(360deg); } }
    .quest-arrow-spinner {
      width: 2.4rem; height: 2.4rem; border-radius: 9999px;
      border: 4px solid currentColor; border-top-color: transparent;
      animation: questSpin 0.7s linear infinite;
    }
    /* Success checkmark pop. */
    @keyframes questCheckPop {
      0%   { transform: scale(0.4); opacity: 0; }
      60%  { transform: scale(1.15); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }
    .quest-arrow-check { animation: questCheckPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @media (prefers-reduced-motion: reduce) {
      .quest-arrow-sw, .quest-arrow-spinner, .quest-arrow-check { animation: none; }
    }
  </style>

  <%# Row 1 — header + quest badge %>
  <div class="flex items-center justify-between gap-3 mb-3">
    <h3 class="text-heading font-semibold text-sm">Send Your First Message</h3>
    <span data-quest-badge class="inline-block text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">Quest 2 of 4</span>
  </div>

  <%# Row 2 — arrow (LEFT, three states) | prompt (right). %>
  <div class="flex items-center gap-4">
    <div class="flex-shrink-0 text-primary flex items-center justify-center" style="width: 2.75rem; height: 2.75rem;">
      <%# idle: clickable southwest arrow -> scroll + focus the chat input %>
      <button x-show="st === 'idle'" type="button"
              @click="var i=document.getElementById('contest-chat-input'); if(i){i.scrollIntoView({behavior:'smooth',block:'center'}); i.focus({preventScroll:true});} window.dispatchEvent(new CustomEvent('quest-chat-active'))"
              class="quest-arrow-sw leading-none cursor-pointer bg-transparent border-0 p-0 hover:opacity-75 transition-opacity"
              style="font-size: 2.75rem;"
              aria-label="Jump to Contest Chat">&#x2199;</button>
      <%# loading: spinner while the first message is in flight %>
      <span x-show="st === 'loading'" x-cloak class="quest-arrow-spinner" role="status" aria-label="Sending"></span>
      <%# success: checkmark once the message lands + earns seeds %>
      <span x-show="st === 'success'" x-cloak class="quest-arrow-check leading-none" style="font-size: 2.75rem;" aria-label="Sent">&#x2713;</span>
    </div>
    <p class="text-secondary text-xs leading-relaxed flex-1">
      Say hi in the <span class="text-heading font-semibold">Contest Chat</span> just below &mdash; your first message earns <span class="text-primary font-semibold">+25 seeds</span>.
    </p>
  </div>
</div>

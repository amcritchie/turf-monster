<% content_for :title, "Contest Generator" %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex items-baseline justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-heading">Contest Generator</h1>
      <p class="text-sm text-secondary mt-1">
        Slates × tiers. Click any cell to spin up a new on-chain contest for that combination.
        Existing counts shown per cell; click the count to see what's already there.
      </p>
    </div>
    <%= link_to "+ Custom Contest", new_contest_path, class: "btn btn-outline btn-sm" %>
  </div>

  <%# Phantom-driven provisioning of the curated contest + landing-page bundles.
      Server builds the partially-signed create_contest TX, operator's Phantom
      signs the prize-pool USDC transfer, /contests/finalize_bundle persists. %>
  <div class="mb-6 rounded-lg border border-subtle bg-surface p-4">
    <h2 class="text-sm font-bold uppercase tracking-wider text-secondary mb-1">Provision Setup</h2>
    <p class="text-xs text-muted mb-3">
      One-click create a curated contest + its landing page. Idempotent — safe to re-run.
      Your Phantom wallet funds the on-chain prize pool when you sign.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3" id="bundle-cards">
      <% ContestBundle::ALL.each do |key, spec| %>
        <% existing = LandingPage.find_by(slug: spec[:landing_page][:slug]) %>
        <%
          format = Contest::FORMATS[spec[:contest][:contest_type]] || {}
          prize_dollars = (format[:payouts]&.values&.sum.to_i / 100).to_i
        %>
        <div class="rounded-lg border border-subtle p-3">
          <div class="text-sm font-semibold text-heading mb-1"><%= spec[:label] %></div>
          <div class="text-xs text-muted mb-2 font-mono">prize pool: $<%= prize_dollars %></div>
          <button type="button" class="btn btn-primary btn-sm w-full bundle-generate-btn"
                  data-bundle-key="<%= key %>"
                  data-bundle-label="<%= spec[:label] %>"
                  data-bundle-slug="<%= spec[:landing_page][:slug] %>">
            Generate
          </button>
          <% if existing %>
            <%= link_to "✓ live — /lp/#{existing.slug}", landing_page_path(existing), target: "_blank", rel: "noopener",
                  class: "block text-xs text-mint mt-2 hover:underline" %>
          <% else %>
            <p class="text-xs text-muted mt-2">Not provisioned yet.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <script type="application/json" id="bundle-config">
    <%= {
      hasPhantom:           current_user&.phantom_wallet?,
      userWallet:           current_user&.web3_solana_address,
      csrfToken:            form_authenticity_token,
      generateBundlePath:   generate_bundle_contests_path,
      finalizeBundlePath:   finalize_bundle_contests_path,
      usdcBalance:          display_balance&.to_f # null when navbar cache cold
    }.to_json.html_safe %>
  </script>
  <script>
    (function() {
      var cfg = JSON.parse(document.getElementById('bundle-config').textContent);
      var btns = document.querySelectorAll('.bundle-generate-btn');

      function modal() { return Alpine.store('solanaModal'); }

      function showWalletRequired() {
        var m = modal();
        m.show('Phantom Wallet Required', '');
        m.error('Provisioning a bundle is a web3 transaction — log in with a Phantom wallet to provision.', 'Phantom Wallet Required');
        m.setRecovery('Sign in with Phantom', function() { window.location.href = '/signin'; }, { phantom: true });
      }

      async function generate(key, label, slug, btn) {
        var origLabel = btn.textContent.trim();
        function setBusy(t) { btn.disabled = true; btn.textContent = t; }
        function setIdle() { btn.disabled = false; btn.textContent = origLabel; }

        if (!cfg.hasPhantom || !window.walletProvider || !window.walletProvider.isAvailable()) {
          showWalletRequired();
          return;
        }

        if (!confirm('Provision "' + label + '" + /lp/' + slug + '?\n\nYour Phantom will sign a TX that funds the prize pool on-chain.')) {
          return;
        }

        setBusy('Preparing on-chain TX…');
        var m = modal();
        m.show('Preparing Transaction', 'Building the on-chain create_contest instruction…');

        try {
          var provider = window.walletProvider.detect();
          var connectResp = await provider.connect();
          var pubkeyB58 = connectResp.publicKey.toBase58();
          if (cfg.userWallet && pubkeyB58 !== cfg.userWallet) {
            throw new Error('Wrong wallet connected. Switch to ' + cfg.userWallet.substring(0, 8) + '… in Phantom and try again.');
          }

          // Step 1 — server builds partially-signed TX from bundle spec
          var prepareForm = new FormData();
          prepareForm.append('key', key);
          var prepareResp = await fetch(cfg.generateBundlePath, {
            method: 'POST',
            headers: { 'X-CSRF-Token': cfg.csrfToken, 'Accept': 'application/json' },
            body: prepareForm
          });
          var prepareData = await prepareResp.json();
          if (!prepareData.success) throw new Error(prepareData.error || 'Failed to build transaction');

          m.show('Sign Transaction', 'Approve the prize-pool USDC transfer in Phantom…');

          // Step 2 — Phantom signs, we broadcast + confirm
          var txBytes = Uint8Array.from(atob(prepareData.serialized_tx), function(c) { return c.charCodeAt(0); });
          var tx = solanaWeb3.Transaction.from(txBytes);
          var signedTx = await provider.signTransaction(tx);

          m.show('Broadcasting', 'Submitting to Solana…');
          var connection = new solanaWeb3.Connection(document.body.dataset.solanaRpcUrl, 'confirmed');
          var txSig = await connection.sendRawTransaction(signedTx.serialize(), { skipPreflight: true, maxRetries: 3 });

          m.show('Confirming', 'Waiting for Solana confirmation…');
          await connection.confirmTransaction(txSig, 'confirmed');

          // Step 3 — server persists Contest + LandingPage
          m.show('Saving', 'Creating the contest + landing page…');
          var finalizeForm = new FormData();
          finalizeForm.append('tx_signature', txSig);
          finalizeForm.append('contest_pda', prepareData.contest_pda);
          finalizeForm.append('params_token', prepareData.params_token);

          var finalResp = await fetch(cfg.finalizeBundlePath, {
            method: 'POST',
            headers: { 'X-CSRF-Token': cfg.csrfToken, 'Accept': 'application/json' },
            body: finalizeForm
          });
          var finalData = await finalResp.json();
          if (!finalData.success) throw new Error(finalData.error || 'Failed to save bundle');

          m.show('Done', 'Reloading…');
          window.location.href = finalData.redirect;
        } catch (err) {
          console.error('[bundle generate]', err);
          modal().error(err.message || String(err), 'Provision Failed');
          setIdle();
        }
      }

      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          generate(btn.dataset.bundleKey, btn.dataset.bundleLabel, btn.dataset.bundleSlug, btn);
        });
      });
    })();
  </script>

  <% if @slates.empty? %>
    <div class="rounded-lg border border-subtle bg-surface p-8 text-center text-secondary">
      No slates available. Run <code class="text-mint">bin/rails db:seed</code> to load the World Cup 2026 slates.
    </div>
  <% else %>
    <div class="overflow-x-auto rounded-lg border border-subtle bg-surface">
      <table class="w-full">
        <thead>
          <tr class="bg-surface-alt border-b border-subtle">
            <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-secondary">Slate</th>
            <% Contest.selectable_formats.each do |tier, config| %>
              <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wider text-secondary">
                <div class="text-heading text-sm normal-case font-bold mb-0.5"><%= tier.capitalize %></div>
                <div class="text-xs text-muted font-mono"><%= config[:max_entries] %> × <%= dollars(config[:entry_fee_cents] / 100.0) %></div>
                <div class="text-xs text-primary font-mono">$<%= config[:payouts].values.sum / 100 %> guar.</div>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @slates.each_with_index do |slate, slate_idx| %>
            <% matchup_count = slate.slate_matchups.count %>
            <% picks_required = Contest.picks_required_for_slate(slate) %>
            <tr class="<%= slate_idx.even? ? 'bg-page' : 'bg-surface-alt/30' %> border-b border-subtle hover:bg-surface-alt/60 transition">
              <td class="px-4 py-4 align-top">
                <div class="font-semibold text-heading"><%= slate.name %></div>
                <%# Weekly NFL slates carry no starts_at and no game kickoffs (the
                    projections feed has no times), and they are selectable here
                    now — so this MUST tolerate a nil start rather than 500 the
                    whole generator. Saying so plainly is also the useful signal:
                    #create refuses a contest whose lock time can't be resolved,
                    so the operator has to set one by hand. %>
                <% slate_start = slate.first_game_starts_at || slate.starts_at %>
                <div class="text-xs <%= slate_start ? 'text-secondary' : 'text-muted italic' %> mt-0.5">
                  <%= slate_start ? "starts #{slate_start.strftime('%b %-d, %Y · %H:%M %Z')}" : "no scheduled start — set a lock time" %>
                </div>
                <div class="text-xs text-muted mt-0.5"><%= matchup_count %> matchups available</div>
                <div class="text-xs text-muted mt-0.5"><%= picks_required %> picks required</div>
              </td>
              <% Contest.selectable_formats.each do |tier, config| %>
                <%
                  count = @contest_counts[[slate.id, tier]] || 0
                  existing = @contests_by_cell[[slate.id, tier]] || []
                %>
                <td class="px-2 py-2 text-center align-top">
                  <%= link_to new_contest_path(slate_id: slate.id, contest_type: tier),
                              class: "block rounded-lg border-2 border-dashed #{count.zero? ? 'border-subtle hover:border-primary hover:bg-primary/5' : 'border-mint/40 hover:border-mint hover:bg-mint/5'} px-3 py-4 transition",
                              title: "Create new #{tier} contest on #{slate.name}" do %>
                    <div class="text-3xl font-bold <%= count.zero? ? 'text-muted' : 'text-mint' %>">
                      <%= count %>
                    </div>
                    <div class="text-xs <%= count.zero? ? 'text-muted' : 'text-secondary' %> mt-1">
                      <%= count == 1 ? "contest" : "contests" %>
                    </div>
                    <div class="text-xs text-primary font-medium mt-2">
                      + new <%= tier %> →
                    </div>
                  <% end %>

                  <% if existing.any? %>
                    <div class="mt-2 space-y-1 text-left">
                      <% existing.first(3).each do |contest| %>
                        <%= link_to contest_path(contest), class: "block px-2 py-1 rounded text-xs hover:bg-surface-alt transition" do %>
                          <div class="flex items-center justify-between gap-1">
                            <span class="text-body truncate">
                              <span class="<%= contest.onchain? ? 'text-mint' : 'text-yellow-500' %>">●</span>
                              <%= contest.entries.where(status: [:active, :complete]).count %>/<%= contest.max_entries %>
                            </span>
                            <span class="text-muted font-mono text-[10px]"><%= contest.status %></span>
                          </div>
                        <% end %>
                      <% end %>
                      <% if existing.size > 3 %>
                        <div class="text-xs text-muted text-center pt-1">+<%= existing.size - 3 %> more</div>
                      <% end %>
                    </div>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-6 text-xs text-muted space-y-1">
      <div><span class="text-mint">●</span> on-chain contest &nbsp;|&nbsp; <span class="text-yellow-500">●</span> DB-only (on-chain creation failed or was opted out)</div>
      <div>"3/9" = 3 active or complete entries of 9 max.</div>
      <div>Contests created from this page use the Phantom-driven create flow (your wallet signs to fund the prize pool on-chain).</div>
    </div>
  <% end %>
</div>

<%# Locals/ivar shim (2026-05-29): callers (show, leaderboard_poll) render this
    in controller context with contest/entries/matchups/onchain_contest set,
    and pass only `compact:`. Contest::LiveBroadcast renders it from a model
    callback (no controller ivars) and passes all four explicitly. fetch() falls
    back to the ivar so the request path is unchanged. %>
<%
  contest         = local_assigns.fetch(:contest, @contest)
  entries         = local_assigns.fetch(:entries, @entries)
  matchups        = local_assigns.fetch(:matchups, @matchups)
  onchain_contest = local_assigns.fetch(:onchain_contest, @onchain_contest)

  # "Everyone equal" = an unsettled contest where every entry shares the same
  # score (e.g. pre-kickoff, all 0). There's no real ranking yet, so float the
  # logged-in viewer's own entries to the top to make them easy to find, and
  # suppress the (unearned) first-place crown below. The viewer is passed in by
  # the request-context callers (show / live / leaderboard_poll); the
  # Contest::LiveBroadcast path omits it (one HTML for all subscribers, no
  # per-viewer float) — same locals-shim convention as the ivars above.
  viewer = local_assigns.fetch(:viewer, nil)

  # Multi-week span, hoisted ONCE for the whole board: every pick's tooltip needs
  # the week list and that team's matchup in each week, and resolving those
  # per-pill would be an N+1 across six picks per entry.
  multi_week    = contest.multi_week?
  span_matchups = multi_week ? contest.matchups_by_team : {}
  # Weeks come off the matchups themselves, and the multiplier is the FROZEN
  # turf_score stored on them — the same value settlement multiplies by.
  span_weeks    = multi_week ? span_matchups.values.flatten.filter_map(&:week).uniq.sort : []
  span_scores   = multi_week ? span_matchups.transform_values { |ms| ms.first.turf_score } : {}
  everyone_equal = !contest.settled? && entries.size > 1 &&
                   entries.map { |e| e.score.to_i }.uniq.size <= 1
  if everyone_equal && viewer
    mine, others = entries.partition { |e| e.user_id == viewer.id }
    entries = mine + others
  end
%>
<% unless local_assigns[:compact] %>
<!-- Contest Details -->
<% explorer_base = Solana::Config.devnet? ? "?cluster=devnet" : "" %>
<section class="mb-8">
  <div class="card shadow p-6">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= contest_badge_classes(contest.status) %>">
          <%= contest.status.upcase %>
        </span>
        <% if contest.starts_at %>
          <span class="text-sm text-secondary"><%= contest.starts_at.strftime("%b %d, %Y %I:%M %p") %></span>
        <% end %>
      </div>
      <% if contest.onchain? %>
        <a href="https://explorer.solana.com/address/<%= contest.onchain_contest_id %><%= explorer_base %>"
           target="_blank" class="inline-flex items-center gap-1 text-xs text-primary hover:text-primary-300 font-medium transition" title="View on Solana Explorer">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Verified
        </a>
      <% end %>
    </div>
    <% if onchain_contest %>
      <% oc = onchain_contest %>
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Entry Fee</p>
          <p class="font-mono text-lg text-heading"><%= dollars(oc[:entry_fee_dollars]) %></p>
        </div>
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Prize Pool</p>
          <p class="font-mono text-lg text-primary"><%= dollars(oc[:prizes_dollars]) %></p>
        </div>
        <div class="bg-surface-alt rounded-lg p-3">
          <p class="label-upper">Entries</p>
          <p class="font-mono text-lg text-heading"><%= oc[:current_entries] %> / <%= oc[:max_entries] %></p>
        </div>
      </div>
      <div class="mt-3 flex items-center justify-center gap-3 text-sm">
        <span class="text-muted font-medium">Payouts:</span>
        <% oc[:payout_amounts].each_with_index do |amount, i| %>
          <span class="px-2 py-0.5 rounded bg-surface-alt text-secondary font-mono text-xs"><%= (i + 1).ordinalize %> — <%= dollars(amount) %></span>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-lg border border-red-500/30 bg-red-500/10 p-4 text-center">
        <p class="text-sm text-red-400 font-medium">Failed to load onchain data</p>
        <p class="text-xs text-muted mt-1">Contest may not be deployed or RPC is unavailable</p>
      </div>
    <% end %>
    <%# Onchain details — dev mode only %>
    <% if contest.onchain? %>
      <div x-show="$store.devMode" x-cloak class="mt-3 pt-3 border-t border-subtle space-y-1">
        <div class="flex items-center gap-2 text-xs text-muted">
          <span class="text-secondary">PDA:</span>
          <a href="https://explorer.solana.com/address/<%= contest.onchain_contest_id %><%= explorer_base %>"
             target="_blank" class="font-mono hover:text-primary transition truncate"><%= contest.onchain_contest_id %></a>
        </div>
        <% if contest.onchain_tx_signature.present? %>
          <div class="flex items-center gap-2 text-xs text-muted">
            <span class="text-secondary">TX:</span>
            <a href="https://explorer.solana.com/tx/<%= contest.onchain_tx_signature %><%= explorer_base %>"
               target="_blank" class="font-mono hover:text-primary transition truncate"><%= contest.onchain_tx_signature %></a>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Admin Actions -->
<% if current_user&.admin? && !contest.settled? %>
  <section class="mb-8">
    <div class="flex flex-wrap gap-3">
      <% if contest.open? && !contest.locked? %>
        <% active_count = contest.entries.where(status: [:active, :complete]).count %>
        <% if contest.max_entries.nil? || active_count < contest.max_entries %>
          <%= button_to "Fill Contest", fill_contest_path(contest), method: :post,
            class: "btn btn-secondary btn-lg" %>
        <% end %>
        <button type="button" onclick="lockContestViaPhantom('<%= contest.slug %>', 0)"
          class="btn btn-lg bg-yellow-600 hover:bg-yellow-500 text-white">Lock Contest</button>
        <button type="button" onclick="lockContestViaPhantom('<%= contest.slug %>', 60)"
          class="btn btn-lg bg-yellow-700 hover:bg-yellow-600 text-white">Lock in 60s</button>
      <% end %>

      <% next_game = contest.matchups.pending.includes(:game).select { |m| m.game.present? }.sort_by { |m| m.game.kickoff_at || Time.current }.first %>
      <% if next_game %>
        <%= button_to "Simulate: #{next_game.team.name} vs #{next_game.opponent_team&.name}",
          simulate_game_contest_path(contest), method: :post,
          class: "btn btn-primary btn-lg" %>
        <%= button_to "Simulate 5", simulate_batch_contest_path(contest, count: 5), method: :post,
          class: "btn btn-outline btn-lg" %>
        <%= button_to "Simulate 20", simulate_batch_contest_path(contest, count: 20), method: :post,
          class: "btn btn-outline btn-lg" %>
      <% end %>

      <%= button_to "Jump (Simulate All)", jump_contest_path(contest), method: :post,
        class: "btn btn-primary btn-lg" %>

      <%= link_to "Rank Matchups", slate_path(contest.slate),
        class: "px-6 py-2 bg-surface-alt hover:bg-surface-alt/80 text-heading font-bold rounded-xl shadow transition inline-flex items-center" %>

      <% if contest.open? && logged_in? && contest.entries.where(user: current_user, status: [:active, :complete]).exists? %>
        <%= link_to contest_path(contest, add_entry: true), class: "btn btn-outline btn-lg" do %>
          + Add Another Entry
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
<% end %>

<%# Completed Games grid removed 2026-06-01 (operator request). The live page's
    Games row already lists completed games + scorers; the contest show page no
    longer shows a Completed Games section. %>

<!-- Leaderboard -->
<% total_seats = contest.max_entries || entries.size %>
<% collapse = total_seats > 8 %>
<% if total_seats > 0 %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Leaderboard</h2>
    <div class="space-y-2"<% if collapse %> x-data="{ expanded: false }"<% end %>>
      <% lb_row = 0 %>
      <% entries.each_with_index do |entry, i| %>
        <%
          paid = contest.settled? && entry.payout_cents.to_i > 0
          display_rank = contest.settled? && entry.rank ? entry.rank : i + 1
          dimmed = contest.settled? && !paid
          # No crown while everyone is tied — nobody has won yet.
          first_place = display_rank == 1 && !everyone_equal
          is_viewer = viewer && entry.user_id == viewer.id
        %>
        <div <% if collapse && lb_row >= 8 %>x-show="expanded" x-cloak <% end %>class="card overflow-hidden <%= paid ? 'ring-1 ring-primary/40' : '' %> <%= first_place ? 'border-primary/40' : '' %> <%= everyone_equal && is_viewer ? 'ring-1 ring-secondary/40' : '' %>"
             style="<%= first_place ? 'background: linear-gradient(90deg, rgba(75,175,80,0.08) 0%, transparent 40%)' : '' %>">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 px-4 py-3">
            <%# Rank %>
            <div class="w-8 text-center font-mono font-bold text-lg <%= first_place ? 'text-primary' : (dimmed ? 'text-muted' : 'text-secondary') %>">
              <% if first_place %>
                <span title="In the money">👑</span>
              <% else %>
                <%= display_rank %>
              <% end %>
            </div>
            <%# Player %>
            <div class="flex items-center gap-2 min-w-0" style="width:14rem">
              <%= render "components/avatar", user: entry.user, size: "nav" %>
              <span class="font-semibold truncate text-sm <%= dimmed ? 'text-muted' : 'text-heading' %>"><%= entry.user.display_name %></span>
              <% if entry.onchain_tx_signature.present? %>
                <a href="https://explorer.solana.com/tx/<%= entry.onchain_tx_signature %><%= '?cluster=devnet' if Solana::Config.devnet? %>"
                   target="_blank" class="text-muted hover:text-primary transition flex-shrink-0" title="Verified onchain">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </a>
              <% end %>
            </div>
            <% rank_prize = contest.settled? ? entry.payout_cents : contest.payouts[display_rank] %>
            <% if rank_prize.to_i > 0 %>
              <span class="text-xs font-bold text-primary flex-shrink-0"><%= dollars(rank_prize / 100.0) %></span>
            <% end %>
            <%# Audit H2 (2026-05-23): per-entry admin Payout button removed.
                Payouts now flow through the on-chain settle_contest path
                exclusively (Contest#grade! -> settle_onchain! -> 2-of-3 cosign
                in /admin/pending_transactions). Winners' UserAccount.balance
                is credited on settle; they withdraw via /wallet themselves.
                The `entries.payout_tx_signature` column was dropped in the
                companion migration (RemovePayoutTxSignatureFromEntries). %>
            <%# Score — right end of the top info row %>
            <div class="text-right flex-shrink-0 ml-auto" style="min-width:3.5rem">
              <div class="font-mono font-bold text-lg <%= dimmed ? 'text-muted' : 'text-violet' %>"><%= sprintf('%.1f', entry.score) %></div>
            </div>
            <%# Selections — stacked on mobile (tap to expand 3×2), inline on desktop.
                While the contest is `open`, only the entry owner (and admins on
                /contests/:slug/admin) see the picks; everyone else gets six
                placeholder pills so network-tab readers can't preview the
                competition. Reveal flips automatically once the contest locks. %>
            <% if picks_visible_for?(entry) %>
            <%
              sorted_sels = entry.selections.sort_by { |s| s.slate_matchup.game&.kickoff_at || Time.at(0) }
              pills = sorted_sels.map do |sel|
                t = sel.slate_matchup.team
                g = sel.slate_matchup.game
                c1 = t.color_primary || "#666"
                c2 = t.color_secondary || c1
                # Multi-week: a pick is "live" as soon as ANY week of its span has
                # scored — the anchor week's game status alone would keep the pill
                # showing a multiplier for the whole rest of the contest.
                done = multi_week ? sel.points.present? : g&.status == "completed"
                if done && sel.points.present?
                  sv = sel.points; ip = sv.to_i.to_s
                  dp = sv == sv.to_i ? nil : ".#{((sv % 1) * 10).round}"
                else
                  # Matchups created without ranks (legacy seed paths) have nil
                  # turf_score — render "x?" instead of crashing. Root cause
                  # belongs in seeds/contest-create; this is defense-in-depth.
                  # Multi-week pills carry the SPAN multiplier, not the anchor
                  # week's — the anchor number would misprice a three-week pick.
                  m = multi_week ? span_scores[sel.slate_matchup.team_slug] : sel.slate_matchup.turf_score
                  ip = m ? "x#{m.to_i}" : "x?"
                  dp = (m && m != m.to_i) ? ".#{((m % 1) * 10).round}" : nil
                end
                tv = if multi_week && sel.points.present?
                       weekly_points_breakdown(sel, weeks: span_weeks, by_team: span_matchups,
                                                    multiplier: span_scores[sel.slate_matchup.team_slug])
                     elsif done && sel.points.present?
                       "#{sel.points} pts"
                     else
                       span_or_week = multi_week ? span_scores[sel.slate_matchup.team_slug] : sel.slate_matchup.turf_score
                       span_or_week ? "x#{span_or_week}" : "x?"
                     end
                { team: t, c1: c1, c2: c2, ip: ip, dp: dp, tv: tv }
              end
            %>
            <div class="w-full" x-data="{ picksOpen: false, wide: window.innerWidth >= 490, mid: window.innerWidth >= 490, dkFull: window.innerWidth >= 1080 }" @resize.window="wide = window.innerWidth >= 490; mid = window.innerWidth >= 490; dkFull = window.innerWidth >= 1080">
              <%# Stacked pills (below 1080px): compressed → 3×2 grid on tap %>
              <div x-show="!dkFull" x-cloak @click="picksOpen = !picksOpen">
                <div class="cursor-pointer" :class="picksOpen ? 'grid grid-cols-3 gap-1.5' : 'flex'">
                  <% pills.each_with_index do |p, si| %>
                    <span class="inline-flex items-center py-1 rounded-lg text-xs font-semibold text-white border border-white/15"
                          :class="{ 'px-2': picksOpen || mid, 'px-1': !picksOpen && !mid, 'justify-between': <%= si == pills.size - 1 ? '(picksOpen || wide)' : 'true' %>, 'justify-center': <%= si == pills.size - 1 ? '!(picksOpen || wide)' : 'false' %> }"
                          style="background: linear-gradient(135deg, <%= p[:c1] %>, <%= p[:c2] %>)"
                          :style="picksOpen ? {} : { width: wide ? '7rem' : (mid ? 'calc((100% - <%= (pills.size - 1) * 0.3 %>rem) / <%= pills.size %>)' : '5rem'), <% if si > 0 %>marginLeft: wide ? 'calc((100% - <%= pills.size * 7 %>rem) / <%= pills.size - 1 %>)' : (mid ? '0.3rem' : 'calc((100% - <%= pills.size * 5 %>rem) / <%= pills.size - 1 %>)'), <% end %>position: 'relative', zIndex: <%= si + 1 %> }"
                          title="<%= p[:team].name %> — <%= p[:tv] %>">
                      <span class="truncate"><%= p[:team].emoji %> <%= p[:team].short_name %></span>
                      <span x-show="picksOpen || wide" class="font-mono ml-1 flex-shrink-0" style="opacity:0.85"><%= p[:ip] %><% if p[:dp] %><span style="font-size:0.7em;opacity:0.8"><%= p[:dp] %></span><% end %></span>
                    </span>
                  <% end %>
                </div>
              </div>
              <%# Desktop (1080px+): one full-width row of 6 even pills %>
              <div x-show="dkFull" x-cloak class="grid grid-cols-6 gap-1.5">
                <% pills.each do |p| %>
                  <span class="flex items-center justify-between min-w-0 px-2 py-1 rounded-lg text-xs font-semibold text-white border border-white/15"
                        style="background: linear-gradient(135deg, <%= p[:c1] %>cc, <%= p[:c2] %>99)"
                        title="<%= p[:team].name %> — <%= p[:tv] %>">
                    <span class="truncate"><%= p[:team].emoji %> <%= p[:team].short_name %></span>
                    <span class="font-mono ml-1 flex-shrink-0" style="opacity:0.85"><%= p[:ip] %><% if p[:dp] %><span style="font-size:0.7em;opacity:0.8"><%= p[:dp] %></span><% end %></span>
                  </span>
                <% end %>
              </div>
            </div>
            <% else %>
            <div class="w-full grid grid-cols-6 gap-1.5" title="Picks hidden until contest locks">
              <% entry.selections.size.clamp(1, contest.picks_required).times do %>
                <span class="flex items-center justify-center px-2 py-1 rounded-lg text-xs font-semibold text-muted bg-surface-alt border border-subtle">
                  <span aria-hidden="true">&#x2022;&#x2022;&#x2022;</span>
                  <span class="sr-only">Hidden</span>
                </span>
              <% end %>
            </div>
            <% end %>
          </div>
        </div>
        <% lb_row += 1 %>
      <% end %>
      <%# Empty seats %>
      <% empty_seats = total_seats - entries.size %>
      <% contest_payouts = contest.payouts %>
      <% user_entry_count = current_user ? entries.count { |e| e.user_id == current_user.id } : 0 %>
      <% can_add_entry = current_user && contest.open? && user_entry_count < contest.max_entries_per_user %>
      <% first_open = true %>
      <% empty_seats.times do |j| %>
        <% seat_rank = entries.size + j + 1 %>
        <% prize_cents = contest_payouts[seat_rank] %>
        <div <% if collapse && lb_row >= 8 %>x-show="expanded" x-cloak <% end %>class="relative">
          <div class="card overflow-hidden" style="opacity: 0.5">
            <div class="flex items-center gap-3 px-4 py-3">
              <div class="w-8 text-center font-mono font-bold text-lg text-muted">
                <% if seat_rank == 1 %>
                  <span>👑</span>
                <% else %>
                  <%= seat_rank %>
                <% end %>
              </div>
              <div class="flex items-center gap-2 min-w-0" style="width:14rem">
                <div class="w-8 h-8 rounded-full bg-surface-alt border border-subtle flex-shrink-0"></div>
                <span class="text-sm text-muted">Open</span>
              </div>
            </div>
          </div>
          <% if prize_cents %>
            <span class="absolute text-xs font-bold text-primary" style="top:50%; transform:translateY(-50%); left: calc(1rem + 2rem + 0.75rem + 14rem + 0.75rem)"><%= dollars(prize_cents / 100.0) %></span>
          <% end %>
          <% if first_open && can_add_entry %>
            <%= link_to contest_path(contest, add_entry: true), class: "absolute right-4 btn btn-primary btn-sm", style: "top: 50%; transform: translateY(-50%);" do %>
              <%= user_entry_count == 0 ? "Enter Contest" : "Add #{(user_entry_count + 1).ordinalize} Entry" %>
            <% end %>
            <% first_open = false %>
          <% end %>
        </div>
        <% lb_row += 1 %>
      <% end %>
      <%# --- Gradient fade overlay + expand trigger (covers rows 7-8) --- %>
      <% if collapse %>
        <div x-show="!expanded" @click="expanded = true"
             class="relative cursor-pointer flex items-center justify-center"
             style="margin-top: -8.5rem; height: 8.5rem; background: linear-gradient(to bottom, transparent 0%, rgba(255,255,255,0.15) 50%); z-index: 1;">
          <span class="text-sm font-semibold text-heading tracking-wide" style="text-shadow: 0 1px 4px rgba(0,0,0,0.5);">Show all <%= total_seats %> seats &#9662;</span>
        </div>
        <button x-show="expanded" x-cloak @click="expanded = false" class="w-full text-center py-2 text-sm text-primary hover:text-primary-300 transition cursor-pointer">
          Show less &#9652;
        </button>
      <% end %>
    </div>
  </section>
<% end %>

<%= render "components/json_debug", record: contest.as_json.merge("slate_matchups" => matchups.as_json(methods: [:locked?]), "entries" => contest_debug_entries(entries)), label: "Contest JSON", collapsible: true %>

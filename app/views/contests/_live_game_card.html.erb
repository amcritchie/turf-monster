<%# A single game card for the live page. Locals: game (Game),
    phase (:active | :upcoming | :completed). For active/completed games we list
    scorers below the score — each goal's player (optional) + minute, in the
    order they were scored. There's no match clock in the data, so live games
    show only a LIVE badge; goal minutes are the only times surfaced. Card is a
    flex column with h-full so the carousel's row-stretch keeps every card in a
    row the same height even when scorer counts differ. %>
<% goals = phase == :upcoming ? [] : game.goals.sort_by { |g| g.minute || 0 } %>
<%# h-full makes every card in the carousel row the same height as the tallest
    (most scorers). Cards with no scorers (upcoming, or 0-0) center their content
    so that shared height reads as intentional rather than a top-stuck gap. %>
<div class="card p-3 h-full flex flex-col<%= goals.empty? ? " justify-center" : "" %>">
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-1.5 min-w-0">
      <span class="text-lg"><%= game.home_team&.emoji %></span>
      <span class="text-sm font-semibold text-heading truncate"><%= game.home_team&.short_name || game.home_team_slug %></span>
    </div>
    <% if phase == :upcoming %>
      <span class="text-xs text-muted font-mono px-1">vs</span>
    <% else %>
      <span class="text-base font-extrabold text-heading tabular-nums whitespace-nowrap">
        <%= game.home_score.to_i %><span class="text-muted mx-0.5">&ndash;</span><%= game.away_score.to_i %>
      </span>
    <% end %>
    <div class="flex items-center gap-1.5 min-w-0 justify-end">
      <span class="text-sm font-semibold text-heading truncate text-right"><%= game.away_team&.short_name || game.away_team_slug %></span>
      <span class="text-lg"><%= game.away_team&.emoji %></span>
    </div>
  </div>
  <div class="mt-2 text-center">
    <% case phase %>
    <% when :active %>
      <span class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-red-400">
        <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-pulse"></span> Live
      </span>
    <% when :upcoming %>
      <span class="text-[11px] text-muted"><%= game.kickoff_at ? game.kickoff_at.strftime("%b %-d · %-I:%M %p") : "TBD" %></span>
    <% when :completed %>
      <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Final</span>
    <% end %>
  </div>

  <%# Scorers — a single horizontal strip, chronological, that scrolls when it
      overflows the card. Each chip: team flag (the "image"), scorer last name,
      minute. Falls back to the team short name when the goal has no player. %>
  <% if goals.any? %>
    <div class="mt-2 pt-2 border-t border-subtle flex items-center gap-3 overflow-x-auto pb-1">
      <% goals.each do |goal| %>
        <% scoring_team = goal.team_slug == game.home_team_slug ? game.home_team : game.away_team %>
        <div class="flex items-center gap-1 flex-shrink-0 text-[11px] leading-none whitespace-nowrap">
          <span class="text-[10px]"><%= scoring_team&.emoji %></span>
          <span class="text-secondary font-medium"><%= goal.player&.name&.split&.last || scoring_team&.short_name || "Goal" %></span>
          <% if goal.minute %>
            <span class="text-muted font-mono tabular-nums"><%= goal.minute %>'</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%
  creator_name = @creator&.display_name || "Turf Monster"
  entry_count  = @contest.active_entry_count
  max          = @contest.max_entries || @contest.format_config[:max_entries]
  # Only `active` entries are editable — `complete` (settled-contest) entries
  # show up in @my_active_entries but can't be modified.
  editable_entries = (@my_active_entries || []).select(&:active?)
  has_edit_items   = @contest.open? && editable_entries.any?
  has_admin_item   = current_user&.admin?
  show_dropdown    = has_edit_items || has_admin_item
%>

<div class="mb-6">
  <p class="text-sm font-medium">
    <%# A multi-week contest names its span ("Weeks 1-3") rather than just the
        anchor slate, which alone would read as a single-week contest. %>
    <% if @contest.multi_week? && @contest.week_span_label %><span class="text-secondary"><%= @contest.week_span_label %></span><span class="text-muted mx-1">&middot;</span><% elsif @contest.slate %><span class="text-secondary"><%= @contest.slate.name %></span><span class="text-muted mx-1">&middot;</span><% end %><span class="text-muted"><%= creator_name.downcase %></span>
  </p>

  <div class="flex items-start justify-between gap-2">
    <h1 class="text-2xl md:text-3xl font-extrabold text-heading">
      <%= @contest.name %>
      <% if @contest.cancelled? %>
        <span class="align-middle inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-red-100 text-red-800 uppercase tracking-wide">Cancelled</span>
      <% end %>
    </h1>

    <% if show_dropdown %>
      <div x-data="{ open: false }" @click.outside="open = false" class="relative flex-shrink-0">
        <button type="button" @click="open = !open"
                class="p-2 -m-2 rounded-md text-secondary hover:text-heading hover:bg-surface-alt transition"
                :aria-expanded="open"
                aria-label="Contest actions">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M10 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm0 5.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM10 14a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/>
          </svg>
        </button>
        <div x-show="open" x-cloak
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="transition ease-in duration-100"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             class="absolute right-0 mt-1 w-48 rounded-lg bg-surface border border-subtle shadow-lg py-1 z-30 origin-top-right">
          <% if has_edit_items %>
            <% editable_entries.each_with_index do |entry, idx| %>
              <% label = editable_entries.size > 1 ? "Edit Entry #{idx + 1}" : "Edit Entry" %>
              <%= link_to label, contest_path(@contest, edit_entry: entry.slug),
                    class: "block px-4 py-2 text-sm text-body hover:bg-surface-alt transition" %>
            <% end %>
          <% end %>
          <% if has_admin_item %>
            <% if has_edit_items %>
              <div class="border-t border-subtle my-1"></div>
            <% end %>
            <%= link_to "Edit Contest", edit_contest_path(@contest),
                  class: "block px-4 py-2 text-sm text-body hover:bg-surface-alt transition" %>
            <%= link_to "Admin View", admin_contest_path(@contest),
                  class: "block px-4 py-2 text-sm text-secondary hover:text-heading hover:bg-surface-alt transition" %>
            <%= link_to "Pending Transactions", admin_pending_transactions_path,
                  class: "block px-4 py-2 text-sm text-secondary hover:text-heading hover:bg-surface-alt transition" %>
            <% if @contest.locked? && !@contest.settled? %>
              <%= button_to "Grade", grade_contest_path(@contest), method: :post,
                    form_class: "block",
                    class: "block w-full text-left px-4 py-2 text-sm text-body hover:bg-surface-alt transition" %>
            <% end %>
            <% if @contest.open? && !@contest.locked? %>
              <%# Testing aid: schedule the lock 60s out (Phantom-signed) to watch the countdown engage. %>
              <button type="button"
                      onclick="lockContestViaPhantom('<%= @contest.slug %>', 60)"
                      class="block w-full text-left px-4 py-2 text-sm text-yellow-500 hover:bg-surface-alt transition">
                Lock in 60s
              </button>
            <% end %>
            <% unless @contest.concluded? || @contest.settled? %>
              <%# Testing aid: schedule the conclusion 60s out (Phantom-signed). %>
              <button type="button"
                      onclick="concludeContestViaPhantom('<%= @contest.slug %>', 60)"
                      class="block w-full text-left px-4 py-2 text-sm text-orange-500 hover:bg-surface-alt transition">
                Conclude in 60s
              </button>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Creator moved up beside the title; the exact start date moved into a click
      tooltip on the "Starts In" countdown in the stats row below — so the old
      "creator · lock date" subtitle line is gone. %>

  <%# Start countdown moved inline into the stats row (next to Entries). Only
      the conclusion countdown lives here now. %>
  <% if @contest.concludes_at.present? && !@contest.settled? %>
    <div class="flex flex-wrap items-center gap-2">
      <%= render "contests/timestamp_countdown", target: @contest.concludes_at, label: "Concludes in", done_label: "🏁 Concluded", tone: "orange" %>
    </div>
  <% end %>

  <%# The standalone "Watch Live" button moved inline into the stats-row lock
      countdown's done-state (see the Stats row below). %>

  <!-- Stats row -->
  <div class="flex items-center gap-4 mt-3 flex-wrap">
    <div>
      <span class="text-lg font-extrabold text-primary">$<%= @contest.guaranteed_prize_dollars.to_i %></span>
      <span class="text-xs text-muted ml-1">Prizes</span>
    </div>
    <div class="w-px h-5 bg-subtle"></div>
    <div>
      <span class="text-lg font-extrabold text-heading">$<%= @contest.entry_fee_dollars.to_i %></span>
      <span class="text-xs text-muted ml-1">Entry</span>
    </div>
    <div class="w-px h-5 bg-subtle"></div>
    <div>
      <span class="text-lg font-extrabold text-heading"><%= entry_count %>/<%= max %></span>
      <span class="text-xs text-muted ml-1">Entries</span>
    </div>
    <%# Starts countdown inline next to the entries count (replaces the old
        "+ Add Nth Entry" link). Shows "Starts In X" while open; once the
        derived start passes it flips to a "Watch Live" CTA (turf_totals, which
        has a live page) or a "🔒 Entries closed" badge otherwise. Only rendered
        when a start time is set and the contest isn't settled. %>
    <% if @contest.starts_in_at.present? && !@contest.settled? %>
      <div class="w-px h-5 bg-subtle"></div>
      <%# Click the start countdown to reveal the exact start date as a tooltip. %>
      <div x-data="{ tip: false }" @click.outside="tip = false" class="relative">
        <div role="button" tabindex="0" @click="tip = !tip" @keydown.enter.prevent="tip = !tip" @keydown.space.prevent="tip = !tip"
             class="cursor-pointer" aria-label="Show start time" :aria-expanded="tip">
          <%= render "contests/timestamp_countdown", target: @contest.starts_in_at, label: "Starts In",
                done_label: (@contest.turf_totals? ? "Watch Live" : "🔒 Entries closed"),
                done_href: (@contest.turf_totals? ? live_contest_path(@contest) : nil),
                tone: "yellow", on_done_modal: "it-begins", on_done_url: contest_path(@contest),
                wrapper_class: "", bare: true, label_after: false, emphasize: true %>
        </div>
        <div x-show="tip" x-cloak
             x-transition:enter="transition ease-out duration-150"
             x-transition:enter-start="opacity-0 translate-y-1"
             x-transition:enter-end="opacity-100 translate-y-0"
             class="absolute left-0 top-full mt-1.5 z-30 whitespace-nowrap rounded-lg border border-subtle bg-surface px-3 py-1.5 text-xs font-medium text-secondary shadow-lg">
          <%= @contest.start_time_display %>
        </div>
      </div>
    <% end %>
  </div>
</div>

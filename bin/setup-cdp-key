#!/bin/zsh
# bin/setup-cdp-key — install a Coinbase CDP secret API key into turf-monster/.env
#
# Usage:
#   1. In portal.cdp.coinbase.com, create a Secret API key for the project and
#      copy the downloaded key JSON to the clipboard — the WHOLE blob, either:
#        {"name": "organizations/.../apiKeys/...", "privateKey": "-----BEGIN EC PRIVATE KEY-----..."}
#      or (newer Ed25519 keys):
#        {"id": "...", "privateKey": "base64..."}
#   2. Run:  bin/setup-cdp-key
#   3. Restart the dev stack:  bin/tm restart
#
# Why this exists:
#   Pasting multi-line PEM keys directly into a terminal reliably breaks on
#   macOS (smart quotes, line wrapping splitting the paste). pbpaste sidesteps
#   shell parsing entirely — same pattern as mcritchie-studio's
#   bin/setup-1pass-token. The key never appears in shell history or chat.
#
# Writes CDP_API_KEY_ID and CDP_API_KEY_SECRET to .env
# (PEM newlines stored as \n escapes inside double quotes — dotenv unescapes
# them at load). Re-runs replace any prior values cleanly.

set -e
cd "$(dirname "$0")/.."

if ! command -v pbpaste >/dev/null 2>&1; then
  echo "ERROR: pbpaste not found. This script is macOS-only."
  exit 1
fi

pbpaste | ruby -rjson -e '
  raw = STDIN.read
  abort "ERROR: clipboard is empty. Copy the CDP key JSON first, then re-run." if raw.strip.empty?

  begin
    key = JSON.parse(raw)
  rescue JSON::ParserError
    abort "ERROR: clipboard is not valid JSON. Copy the FULL downloaded key blob " \
          "({\"name\": ..., \"privateKey\": ...}), not just the secret, and re-run."
  end

  id     = key["name"] || key["id"]
  secret = key["privateKey"]
  abort "ERROR: JSON parsed but is missing name/id or privateKey fields." unless id && secret

  env_path = ".env"
  lines = File.exist?(env_path) ? File.read(env_path).lines : []
  lines = lines.map { |l| l.end_with?("\n") ? l : l + "\n" }
  lines = lines.reject { |l| l =~ /^CDP_API_KEY_(ID|SECRET)=/ }
  lines << "CDP_API_KEY_ID=#{id}\n"
  lines << %Q(CDP_API_KEY_SECRET="#{secret.gsub("\n", "\\n")}"\n)
  File.write(env_path, lines.join)
  File.chmod(0600, env_path)

  kind = secret.include?("BEGIN") ? "ECDSA PEM" : "Ed25519 base64"
  puts "Installed CDP key into .env"
  puts "  key id: #{id}"
  puts "  secret: #{secret.length} chars (#{kind}) — not echoed"
  puts ""
  puts "Run bin/tm restart to pick it up."
'

#!/bin/zsh
# bin/setup-cdp-key — install the Coinbase CDP secret API key into turf-monster/.env
#
# Default (recommended) — pull the key straight from 1Password (agents vault):
#   bin/setup-cdp-key
#
# Fallbacks (first-time setup before the key is in 1Password, or a different key):
#   bin/setup-cdp-key --clipboard     # full key JSON blob (portal "Download API key") in the clipboard
#   bin/setup-cdp-key <key-id-uuid>   # JUST the secret in the clipboard, key id as the arg
#
# Then restart the dev stack:  bin/tm restart
#
# 1Password item: op://agents/Coinbase Developer Platform/{API key ID, Secret}
# (op runs as the agent service account — see mcritchie-studio docs/agents/system/credentials.md.)
#
# The secret never appears in shell history or chat — it's piped via stdin to a
# Ruby validator, never echoed. Ed25519 secrets are length-checked (64 bytes);
# ECDSA keys arrive as PEM. Writes CDP_API_KEY_ID + CDP_API_KEY_SECRET to .env
# (PEM newlines stored as \n escapes inside double quotes — dotenv unescapes at
# load). Re-runs replace any prior values cleanly.

set -e
cd "$(dirname "$0")/.."

# Shared validator+writer: reads the secret on stdin, key id from $KEY_ID (or
# parses both from a JSON blob), writes .env. $SRC labels the source in output.
RUBY_INSTALL='
  raw = STDIN.read.strip
  abort "ERROR: no secret received." if raw.empty?
  id = secret = nil
  begin
    key = JSON.parse(raw)
    id     = key["name"] || key["id"]
    secret = key["privateKey"]
    abort "ERROR: JSON parsed but is missing name/id or privateKey." unless id && secret
  rescue JSON::ParserError
    id = ENV["KEY_ID"].to_s.strip
    abort "ERROR: no key id (clipboard is not the key JSON and none was provided)." if id.empty?
    secret = raw
  end
  if secret.include?("BEGIN")
    kind = "ECDSA PEM"
  else
    d = Base64.decode64(secret)
    abort "ERROR: secret base64-decodes to #{d.length} bytes; Ed25519 CDP keys must be 64. Wrong field?" unless d.length == 64
    kind = "Ed25519 base64 (64-byte check OK)"
  end
  ep = ".env"
  lines = File.exist?(ep) ? File.read(ep).lines : []
  lines = lines.map { |l| l.end_with?("\n") ? l : l + "\n" }.reject { |l| l =~ /^CDP_API_KEY_(ID|SECRET)=/ }
  lines << "CDP_API_KEY_ID=#{id}\n"
  lines << %Q(CDP_API_KEY_SECRET="#{secret.gsub("\n", "\\n")}"\n)
  File.write(ep, lines.join)
  File.chmod(0600, ep)
  puts "Installed CDP key into .env (source: #{ENV["SRC"]})"
  puts "  key id: #{id}"
  puts "  secret: #{secret.length} chars (#{kind}) — not echoed"
  puts ""
  puts "Run bin/tm restart to pick it up."
'

OP_ITEM="op://agents/Coinbase Developer Platform"

case "${1:-}" in
  --clipboard)
    command -v pbpaste >/dev/null 2>&1 || { echo "ERROR: pbpaste not found. This mode is macOS-only."; exit 1; }
    pbpaste | KEY_ID="" SRC="clipboard JSON" ruby -rjson -rbase64 -e "$RUBY_INSTALL"
    ;;
  "")
    # Default: 1Password.
    command -v op >/dev/null 2>&1 || { echo "ERROR: 1Password CLI not installed (brew install 1password-cli), or use --clipboard."; exit 1; }
    op whoami >/dev/null 2>&1 || { echo "ERROR: op is not authenticated. Run mcritchie-studio/bin/setup-1pass-token first, or use --clipboard."; exit 1; }
    KEY_ID=$(op read "$OP_ITEM/API key ID" 2>/dev/null | tr -d '[:space:]')
    [ -n "$KEY_ID" ] || { echo "ERROR: couldn't read '$OP_ITEM/API key ID' from 1Password. Item/field names correct? (or use --clipboard)"; exit 1; }
    op read "$OP_ITEM/Secret" 2>/dev/null | KEY_ID="$KEY_ID" SRC="1Password" ruby -rjson -rbase64 -e "$RUBY_INSTALL"
    ;;
  *)
    # Key id as the arg, secret in the clipboard.
    command -v pbpaste >/dev/null 2>&1 || { echo "ERROR: pbpaste not found. This mode is macOS-only."; exit 1; }
    pbpaste | KEY_ID="$1" SRC="clipboard secret" ruby -rjson -rbase64 -e "$RUBY_INSTALL"
    ;;
esac

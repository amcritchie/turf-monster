#!/usr/bin/env bash
#
# pre-push — run the fast minitest suite (~10s, ~590 tests) before every push so
# a red suite never reaches the remote or a PR. This is the test gate CLAUDE.md
# refers to; there is deliberately no pre-COMMIT hook (commits stay fast — the
# gate is per-push, not per-commit).
#
# Shared via core.hooksPath=.githooks (set by bin/setup, or once by hand:
#   git config core.hooksPath .githooks
# ). Bypass an emergency push with `git push --no-verify`, or SKIP_TESTS=1
# (matches bin/deploy's flag).
#
# git feeds pre-push "<local ref> <local sha> <remote ref> <remote sha>" lines on
# stdin. We skip when the push is only branch deletions (local sha all-zeros) —
# there's nothing new to test.

set -uo pipefail

if [ "${SKIP_TESTS:-}" = "1" ]; then
  echo "pre-push: SKIP_TESTS=1 — skipping the test gate"
  exit 0
fi

zero="0000000000000000000000000000000000000000"
has_update=false
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ -n "${local_sha:-}" ] && [ "$local_sha" != "$zero" ]; then
    has_update=true
  fi
done

if [ "$has_update" = false ]; then
  exit 0   # deletions only (or nothing to push) — no test run needed
fi

echo "pre-push: running bin/rails test before push  (bypass: git push --no-verify)"
if bin/rails test; then
  echo "✓ pre-push: tests passed — pushing"
  exit 0
else
  status=$?
  echo ""
  echo "✗ pre-push: tests failed — push aborted."
  echo "  Fix them, or bypass with: git push --no-verify"
  exit "$status"
fi

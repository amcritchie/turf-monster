# Turf Monster — environment variables
# Copy to .env and fill in. See mcritchie-studio/docs/agents/modules/credentials.md,
# mcritchie-studio/docs/agents/modules/credential-inventory.md, and docs/SOLANA.md
# for current 1Password / Heroku locations.

# ───── REQUIRED for db:seed ─────
# Seeds call User#generate_managed_wallet! which encrypts via
# Rails.application.credentials.secret_key_base — fails without this.
RAILS_MASTER_KEY=                 # heroku config:get RAILS_MASTER_KEY --app turf-monster

# ───── Google OAuth ─────
# Often the same OAuth app as mcritchie_studio; verify in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───── Solana (admin wallet for vault ops + contest settlement) ─────
# Alex Bot is the primary admin. 2-of-3 multisig requires any 2 of: Alex Bot, Alex, Mason.
SOLANA_ADMIN_KEY=                 # op item get "agent.alex.solana" --vault agents --fields "private key"
SOLANA_RPC_URL=https://api.devnet.solana.com   # paid provider if public devnet is rate-limited

# ───── AWS S3 (team images, contest banners, headshots) ─────
# Bucket: turf-monster-{dev,production}
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ───── Sidekiq queue ─────
# Local: brew services start redis (defaults to redis://localhost:6379/0).
# Heroku: REDIS_URL is set automatically by the redis addon.
# REDIS_URL=

# ───── Stripe (entry-token card checkout + USDC top-up) ─────
# Grab a test key from https://dashboard.stripe.com/test/apikeys (sk_test_…).
# Webhook secret is for /webhooks/stripe — pull from `stripe listen` or dashboard.
# Without these, /tokens/buy shows the dev-mint buttons only (admin + devnet).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ───── PayPal / Venmo (entry-token checkout — PayPal-rails onramp) ─────
# PAYMENT_PROVIDER picks the active fiat rails: "stripe" (default when unset),
# "paypal", or "none". Leave unset to keep current Stripe behavior.
# Sandbox creds: developer.paypal.com → Apps & Credentials (Sandbox tab).
# PAYPAL_WEBHOOK_ID comes from registering /webhooks/paypal on the REST app.
# PAYPAL_ENV is "sandbox" (default) or "live" — production REQUIRES "live"
# when PAYMENT_PROVIDER=paypal (boot fails otherwise). See docs/PAYPAL_VENMO.md.
# PAYMENT_PROVIDER=paypal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# ───── Passwordless email (magic links + transactional mail) ─────
# Target: AWS SES. Resend remains a rollback path while SES is being adopted.
# SES credentials: 1Password item `agent.aws.mcritchie-ses` (agents vault).
MAIL_TRANSPORT=ses                # ses | resend. Use ses once SES creds/domain are ready.
SES_REGION=us-east-2
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
SES_SMTP_HOST=                    # optional; defaults to email-smtp.${SES_REGION}.amazonaws.com
SES_SMTP_PORT=587
RESEND_API_KEY=
MAILER_FROM=noreply@turfmonster.media
MAILER_HOST=app.turfmonster.media

# ───── Managed-wallet encryption (OPSEC-015) ─────
# 256-bit key (64 hex chars) for encrypting custodial wallet private keys at
# rest. MUST be independent of RAILS_MASTER_KEY / secret_key_base so those
# can be rotated without orphaning every managed wallet. Generate with:
#   ruby -e 'require "securerandom"; puts SecureRandom.hex(32)'
# Required in production (boot fails without it). Dev/test fall back to
# secret_key_base if unset. Backed up in 1Password: item agent.managed_wallet,
# field "encryption key".
MANAGED_WALLET_ENCRYPTION_KEY=

# ───── Coinbase CDP Onramp/Offramp (USDC on Solana) ─────
# Secret API Key from portal.cdp.coinbase.com → API keys → "Secret API Key" tab
# (NOT Client API Key), algorithm Ed25519. Stored in 1Password; set on Heroku
# via the pbpaste secret-paste workflow. See docs/CDP_RAMP_INTEGRATION.md.
CDP_API_KEY_ID=                   # key UUID — used as both JWT kid header and sub claim
CDP_API_KEY_SECRET=               # base64; MUST decode to exactly 64 bytes (Ed25519 seed + pubkey)
ENABLE_CDP_RAMP=                  # feature flag — buy/cash-out hidden unless "true"; unset = kill-switch
ENABLE_AGE_ATTESTATION=           # feature flag — legal-age checkbox on signup surfaces; parked OFF for the first contest, set "true" to restore the gate
ENABLE_AGE_GATE=                  # feature flag — date-of-birth age verification at FIRST contest entry (supersedes ENABLE_AGE_ATTESTATION; run one model, not both). "true" to enable.
ENABLE_WEB2_USDC_ENTRY=true       # KILL-SWITCH (DEFAULT ON) — web2/managed users fund entries with USDC (token-first, then USDC) via server-signed enter_contest. Set "false" to revert web2 to token-only. web3 unaffected.
STRIPE_CHECKOUT_DISABLED=            # "true" hides pack buttons + blocks new checkouts; keep STRIPE_SECRET_KEY set for refunds/webhooks
DEV_GEO_STATE=                    # dev only — state for loopback requests (default CO); DEV_CLIENT_IP overrides the egress IP sent to Coinbase
# CDP_WEBHOOK_SECRET=             # phase 2 — metadata.secret returned ONCE at webhook subscription creation

# Optional: anchor operator tx flows (contest-create) on a durable nonce account
# so a slow Phantom sign cannot expire the tx (mainnet BlockhashNotFound fix).
# Authority is the admin managed wallet. Unset = default recent-blockhash.
SOLANA_DURABLE_NONCE_PUBKEY=
